g tư"]],["LI",{},["A",{"href":"#term-6"},"6",". ","Giới hạn trách nhiệm"]],["LI",{},["A",{"href":"#term-7"},"7",". ","Thay đổi điều khoản"]],["LI",{},["A",{"href":"#term-8"},"8",". ","Liên hệ hỗ trợ"]]]],["SECTION",{"class":"static-page__terms-content"},["ARTICLE",{"id":"term-1","class":"static-page__terms-item"},["DIV",{"class":"static-page__terms-heading"},["SPAN",{},"1"],["H3",{},"Chấp nhận điều khoản"]],["P",{},"Bằng việc truy cập, đăng ký tài khoản và sử dụng nền tảng E-XANH, bạn đồng ý tuân thủ các điều khoản sử dụng được công bố trên trang này."]],["ARTICLE",{"id":"term-2","class":"static-page__terms-item"},["DIV",{"class":"static-page__terms-heading"},["SPAN",{},"2"],["H3",{},"Tài khoản người dùng"]],["P",{},"Bạn cần cung cấp thông tin cơ bản chính xác khi đăng ký và có trách nhiệm bảo mật tài khoản, mật khẩu cũng như mọi hoạt động diễn ra dưới tên đăng nhập của mình."]],["ARTICLE",{"id":"term-3","class":"static-page__terms-item"},["DIV",{"class":"static-page__terms-heading"},["SPAN",{},"3"],["H3",{},"Nội dung do người dùng đăng"]],["P",{},"Bạn chịu trách nhiệm với bài viết, bình luận và nội dung mình chia sẻ. E-XANH có quyền từ chối hoặc gỡ bỏ nội dung vi phạm quy tắc cộng đồng."]],["ARTICLE",{"id":"term-4","class":"static-page__terms-item"},["DIV",{"class":"static-page__terms-heading"},["SPAN",{},"4"],["H3",{},"Quy tắc cộng đồng"]],["P",{},"Mọi thành viên cần tôn trọng nhau, không spam, không phát tán thông tin sai lệch và không sử dụng nền tảng cho mục đích quảng cáo gây hiểu nhầm."]],["ARTICLE",{"id":"term-5","class":"static-page__terms-item"},["DIV",{"class":"static-page__terms-heading"},["SPAN",{},"5"],["H3",{},"Dữ liệu và quyền riêng tư"]],["P",{},"Chúng tôi chỉ sử dụng dữ liệu cần thiết để duy trì trải nghiệm cá nhân hóa cơ bản, bao gồm bài đã lưu và lịch sử kiểm tra điện của bạn."]],["ARTICLE",{"id":"term-6","class":"static-page__terms-item"},["DIV",{"class":"static-page__terms-heading"},["SPAN",{},"6"],["H3",{},"Giới hạn trách nhiệm"]],["P",{},"E-XANH cung cấp thông tin tham khảo và công cụ hỗ trợ. Kết quả tính toán chi phí điện không thay thế hóa đơn chính thức từ nhà cung cấp điện."]],["ARTICLE",{"id":"term-7","class":"static-page__terms-item"},["DIV",{"class":"static-page__terms-heading"},["SPAN",{},"7"],["H3",{},"Thay đổi điều khoản"]],["P",{},"Các điều khoản có thể được cập nhật theo thời gian. Việc tiếp tục sử dụng nền tảng sau khi cập nhật được hiểu là bạn chấp nhận phiên bản mới."]],["ARTICLE",{"id":"term-8","class":"static-page__terms-item"},["DIV",{"class":"static-page__terms-heading"},["SPAN",{},"8"],["H3",{},"Liên hệ hỗ trợ"]],["P",{},"Nếu có câu hỏi liên quan đến điều khoản sử dụng, bạn có thể liên hệ với E-XANH qua email hỗ trợ hoặc trang Liên hệ để được giải đáp."]],["DIV",{"class":"static-page__terms-note"},"Cập nhật lần cuối: 12/06/2024"]]]]],["FOOTER",{"class":"user-footer"},["DIV",{"class":"shell shell--wide user-footer__content"},["DIV",{"class":"user-footer__brand"},["A",{"class":"brand-logo brand-logo--footer ","data-testid":"site-logo","aria-label":"E-XANH về trang chủ","href":"/"},["IMG",{"__playwright_current_src__":"","alt":"E-XANH","class":"brand-logo__image","src":"/src/assets/branding/logo.png"}]],["P",{},"Dùng điện thông minh, sống xanh bền vững."]],["NAV",{"class":"user-footer__nav","aria-label":"Liên kết chân trang"},["A",{"class":"","href":"/"},"Trang chủ"],["A",{"class":"","href":"/meo-tiet-kiem"},"Mẹo tiết kiệm"],["A",{"class":"","href":"/cong-dong"},"Cộng đồng"],["A",{"class":"","href":"/kiem-tra-tien-dien"},"Kiểm tra tiền điện"],["A",{"class":"","href":"/ve-chung-toi"},"Về chúng tôi"],["A",{"aria-current":"page","class":"active","href":"/dieu-khoan"},"Điều khoản"],["A",{"class":"","href":"/lien-he"},"Liên hệ"]],["DIV",{"class":"user-footer__copyright"},["P",{},"© 2024 E-XANH. Made by VanhKhucDev"]]]]]],"\n    ","\n  \n\n"]],"viewport":{"width":390,"height":844},"timestamp":1962473.378,"wallTime":1781156210672,"collectionTime":38.5,"resourceOverrides":[],"isMainFrame":true}