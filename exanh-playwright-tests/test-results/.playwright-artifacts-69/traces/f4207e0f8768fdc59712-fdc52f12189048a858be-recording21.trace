adius: 30px;\n  box-shadow: 0 8px 24px rgba(79, 132, 40, 0.25);\n  animation: slideUpFade 0.4s ease-out;\n}\n\n.development-report-button.development-notice-mini-btn:hover {\n  box-shadow: 0 12px 28px rgba(79, 132, 40, 0.3);\n}\n\n@keyframes slideUpFade {\n  from {\n    opacity: 0;\n    transform: translateY(20px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n@media (max-width: 768px) {\n  .development-notice-container {\n    bottom: 16px;\n    right: 5%;\n    left: 5%;\n    align-items: stretch;\n  }\n  \n  .development-notice-box {\n    width: 100%;\n    max-width: none;\n  }\n  \n  .development-notice-mini-btn {\n    align-self: flex-end;\n  }\n}\n"],["STYLE",{},".brand-logo {\n  display: block;\n  text-decoration: none;\n  flex-shrink: 0;\n}\n\n.brand-logo__image {\n  width: var(--logo-width);\n  height: auto;\n  max-height: none;\n  object-fit: contain;\n  display: block;\n  flex-shrink: 0;\n}\n\n/* small size */\n.brand-logo--small {\n  --logo-width: 110px;\n}\n\n/* medium size (Navbar) - responsive */\n.brand-logo--medium {\n  --logo-width: 110px; /* Mobile */\n}\n@media (min-width: 768px) {\n  .brand-logo--medium {\n    --logo-width: 140px; /* Desktop */\n  }\n}\n\n/* large size (Loading / 404 / About) */\n.brand-logo--large {\n  --logo-width: 220px;\n}\n\n/* auth size (Login / Register) */\n.brand-logo--auth {\n  --logo-width: 200px;\n}\n\n/* admin size (Admin sidebar) */\n.brand-logo--admin {\n  --logo-width: 160px;\n}\n\n/* footer size */\n.brand-logo--footer {\n  --logo-width: 180px; /* Mobile */\n}\n@media (min-width: 768px) {\n  .brand-logo--footer {\n    --logo-width: 280px; /* Desktop (approx 1.75x of 160px) */\n  }\n}\n\n"],["STYLE",{},".admin-shell {\n  grid-template-columns: 310px minmax(0, 1fr);\n  background:\n    radial-gradient(circle at top right, rgba(193, 217, 92, 0.24), transparent 18%),\n    linear-gradient(180deg, #f8fbef 0%, #f1f7e2 100%);\n}\n\n.admin-sidebar {\n  position: sticky;\n  top: 0;\n  min-height: 100vh;\n  padding: 30px 18px 24px;\n  background: #336a29;\n  box-shadow: inset -1px 0 0 rgba(255, 255, 255, 0.08);\n}\n\n.admin-sidebar__brand {\n  margin-bottom: 22px;\n}\n\n.admin-sidebar__nav {\n  gap: 10px;\n}\n\n.admin-sidebar__link {\n  gap: 14px;\n  min-width: 0;\n  border: 1px solid transparent;\n}\n\n.admin-sidebar__link:hover,\n.admin-sidebar__link.is-active {\n  color: #183814;\n  background: linear-gradient(135deg, #9fc45c, #84b44f);\n  box-shadow: 0 10px 22px rgba(24, 56, 20, 0.16);\n}\n\n.admin-sidebar__icon {\n  flex-shrink: 0;\n  width: 42px;\n  height: 42px;\n  min-width: 42px;\n  background: rgba(255, 255, 255, 0.12);\n}\n\n.admin-sidebar__icon svg {\n  width: 20px;\n  height: 20px;\n  stroke: currentColor;\n  fill: none;\n  stroke-width: 1.9;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n}\n\n.admin-sidebar__link.is-active .admin-sidebar__icon {\n  background: rgba(255, 255, 255, 0.42);\n}\n\n.admin-topbar {\n  position: sticky;\n  top: 0;\n  z-index: 8;\n  padding: 24px 28px;\n  background: rgba(241, 250, 220, 0.88);\n  box-shadow: 0 12px 28px rgba(79, 132, 40, 0.06);\n}\n\n.admin-topbar__summary {\n  min-width: 0;\n}\n\n.admin-topbar h1 {\n  margin: 6px 0 8px;\n  font-size: clamp(1.8rem, 2.3vw, 2.6rem);\n  line-height: 1.08;\n}\n\n.admin-topbar__summary > span {\n  display: block;\n  max-width: 620px;\n  line-height: 1.6;\n}\n\n.admin-topbar__search {\n  position: relative;\n  min-width: min(360px, 34vw);\n}\n\n.admin-topbar__search input {\n  padding: 15px 18px 15px 50px;\n  color: var(--color-text);\n  background: linear-gradient(180deg, rgba(193, 217, 92, 0.52), rgba(193, 217, 92, 0.34));\n}\n\n.admin-topbar__search input::placeholder {\n  color: rgba(23, 55, 21, 0.62);\n}\n\n.admin-topbar__search-icon {\n  position: absolute;\n  top: 50%;\n  left: 18px;\n  display: grid;\n  place-items: center;\n  width: 20px;\n  height: 20px;\n  transform: translateY(-50%);\n  color: var(--color-primary-500);\n}\n\n.admin-topbar__search-icon svg,\n.admin-topbar__icon-button svg {\n  width: 20px;\n  height: 20px;\n  stroke: currentColor;\n  fill: none;\n  stroke-width: 1.9;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n}\n\n.admin-topbar__icon-button {\n  position: relative;\n  flex-shrink: 0;\n}\n\n.admin-topbar__dot {\n  position: absolute;\n  top: 11px;\n  right: 10px;\n  width: 8px;\n  height: 8px;\n  border-radius: 50%;\n  background: #d97745;\n  box-shadow: 0 0 0 3px #fff;\n}\n\n.admin-topbar__profile {\n  padding: 8px 14px 8px 10px;\n}\n\n.admin-topbar__profile strong,\n.admin-topbar__profile small {\n  display: block;\n}\n\n.admin-topbar__profile strong {\n  margin-bottom: 2px;\n}\n\n.admin-topbar__profile small {\n  color: var(--color-text-muted);\n}\n\n.admin-main {\n  padding: 28px;\n  background: transparent;\n}\n\n.admin-dashboard {\n  gap: 24px;\n}\n\n.admin-dashboard__hero {\n  display: grid;\n  gap: 14px;\n}\n\n.admin-dashboard__hero-copy h2,\n.admin-dashboard__section-title h3 {\n  margin: 0 0 10px;\n  font-size: clamp(2rem, 3vw, 2.8rem);\n  letter-spacing: -0.04em;\n}\n\n.admin-dashboard__hero-copy p,\n.admin-dashboard__section-title p,\n.admin-panel__header p,\n.admin-quick-card p,\n.admin-comment-item p,\n.admin-metric-card__body p {\n  margin: 0;\n  color: var(--color-text-muted);\n  line-height: 1.7;\n}\n\n.admin-stats-grid {\n  display: grid;\n  grid-template-columns: repeat(5, minmax(0, 1fr));\n  gap: 18px;\n}\n\n.admin-metric-card {\n  display: grid;\n  gap: 18px;\n  padding: 22px 20px 24px;\n  border-radius: 28px;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  background: #fff;\n  box-shadow: 0 14px 30px rgba(79, 132, 40, 0.08);\n  min-width: 0;\n}\n\n.admin-metric-card__top {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 12px;\n}\n\n.admin-metric-card__icon {\n  display: inline-grid;\n  place-items: center;\n  width: 56px;\n  height: 56px;\n  border-radius: 20px;\n  color: var(--color-primary-500);\n}\n\n.admin-metric-card__icon svg,\n.admin-quick-card__icon svg {\n  width: 24px;\n  height: 24px;\n  stroke: currentColor;\n  fill: none;\n  stroke-width: 1.9;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n}\n\n.admin-metric-card__change {\n  padding: 10px 14px;\n  border-radius: 999px;\n  font-size: 0.95rem;\n  font-weight: 700;\n}\n\n.admin-metric-card__body strong {\n  display: block;\n  margin-top: 10px;\n  font-size: clamp(2.2rem, 3.4vw, 3.2rem);\n  line-height: 1;\n  letter-spacing: -0.05em;\n}\n\n.admin-metric-card--peach .admin-metric-card__icon,\n.admin-metric-card--peach .admin-metric-card__change {\n  background: rgba(247, 182, 168, 0.42);\n}\n\n.admin-metric-card--peach .admin-metric-card__change {\n  color: #a65039;\n}\n\n.admin-metric-card--green .admin-metric-card__icon {\n  background: rgba(128, 177, 85, 0.22);\n}\n\n.admin-metric-card--green .admin-metric-card__change {\n  color: #fff;\n  background: #7bab48;\n}\n\n.admin-metric-card--lime .admin-metric-card__icon {\n  background: rgba(193, 217, 92, 0.34);\n}\n\n.admin-metric-card--lime .admin-metric-card__change {\n  color: #526e17;\n  background: rgba(207, 230, 85, 0.88);\n}\n\n.admin-metric-card--olive .admin-metric-card__icon {\n  background: rgba(128, 177, 85, 0.2);\n}\n\n.admin-metric-card--olive .admin-metric-card__change {\n  color: #264918;\n  background: rgba(128, 177, 85, 0.32);\n}\n\n.admin-dashboard__insights {\n  display: grid;\n  grid-template-columns: minmax(0, 1.25fr) minmax(320px, 0.95fr);\n  gap: 22px;\n}\n\n.admin-dashboard__secondary {\n  display: grid;\n  grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);\n  gap: 22px;\n}\n\n.admin-panel {\n  display: grid;\n  gap: 20px;\n  min-width: 0;\n  padding: 26px;\n  border-radius: 28px;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  background: rgba(255, 255, 255, 0.92);\n  box-shadow: 0 16px 32px rgba(79, 132, 40, 0.08);\n}\n\n.admin-panel__header {\n  display: flex;\n  align-items: flex-start;\n  justify-content: space-between;\n  gap: 16px;\n}\n\n.admin-panel__header h3 {\n  margin: 0 0 6px;\n  font-size: 1.45rem;\n  letter-spacing: -0.03em;\n}\n\n.admin-panel__count {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  min-width: 38px;\n  height: 38px;\n  padding-inline: 12px;\n  border-radius: 999px;\n  color: #fff;\n  background: #c85f33;\n  font-weight: 700;\n}\n\n.admin-chart-legend {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 14px;\n}\n\n.admin-chart-legend span {\n  display: inline-flex;\n  align-items: center;\n  gap: 8px;\n  color: var(--color-text-muted);\n  font-size: 0.92rem;\n}\n\n.admin-chart-legend i,\n.admin-content-list__label i {\n  display: inline-block;\n  width: 12px;\n  height: 12px;\n  border-radius: 50%;\n}\n\n.admin-chart-legend .is-like {\n  background: #d2ea57;\n}\n\n.admin-chart-legend .is-comment {\n  background: #88b753;\n}\n\n.admin-chart-legend .is-save {\n  background: #4f8428;\n}\n\n.admin-weekly-chart {\n  display: grid;\n  grid-template-columns: repeat(7, minmax(0, 1fr));\n  gap: 12px;\n  align-items: end;\n  min-height: 320px;\n  padding: 20px;\n  border-radius: 24px;\n  background: linear-gradient(180deg, rgba(234, 245, 157, 0.16), rgba(247, 250, 239, 0.78));\n}\n\n.admin-weekly-chart__group {\n  display: grid;\n  justify-items: center;\n  gap: 12px;\n  min-width: 0;\n}\n\n.admin-weekly-chart__bars {\n  display: grid;\n  grid-template-columns: repeat(3, minmax(0, 1fr));\n  align-items: end;\n  gap: 6px;\n  width: 100%;\n  min-height: 240px;\n}\n\n.admin-weekly-chart__bars span {\n  display: block;\n  min-height: 16px;\n  border-radius: 16px 16px 10px 10px;\n}\n\n.admin-weekly-chart__bars .bar-like {\n  background: #d2ea57;\n}\n\n.admin-weekly-chart__bars .bar-comment {\n  background: #88b753;\n}\n\n.admin-weekly-chart__bars .bar-save {\n  background: #4f8428;\n}\n\n.admin-weekly-chart__group small {\n  color: var(--color-text-muted);\n  font-weight: 600;\n}\n\n.admin-content-share {\n  display: grid;\n  grid-template-columns: minmax(0, 220px) minmax(0, 1fr);\n  align-items: center;\n  gap: 22px;\n}\n\n.admin-donut-chart {\n  position: relative;\n  width: min(220px, 100%);\n  aspect-ratio: 1;\n  margin: 0 auto;\n  border-radius: 50%;\n}\n\n.admin-donut-chart::after {\n  content: '';\n  position: absolute;\n  inset: 24px;\n  border-radius: 50%;\n  background: #fff;\n  box-shadow: inset 0 0 0 1px rgba(79, 132, 40, 0.06);\n}\n\n.admin-donut-chart__center {\n  position: absolute;\n  inset: 0;\n  z-index: 1;\n  display: grid;\n  place-items: center;\n  text-align: center;\n}\n\n.admin-donut-chart__center strong {\n  font-size: 1.9rem;\n  letter-spacing: -0.04em;\n}\n\n.admin-content-list {\n  display: grid;\n  gap: 14px;\n  margin: 0;\n  padding: 0;\n  list-style: none;\n}\n\n.admin-content-list li {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 16px;\n}\n\n.admin-content-list__label {\n  display: inline-flex;\n  align-items: center;\n  gap: 10px;\n}\n\n.admin-comment-list {\n  display: grid;\n  gap: 18px;\n  margin: 0;\n  padding: 0;\n  list-style: none;\n}\n\n.admin-comment-item {\n  display: grid;\n  grid-template-columns: auto minmax(0, 1fr) auto;\n  gap: 14px;\n  align-items: start;\n  padding-bottom: 16px;\n  border-bottom: 1px solid rgba(79, 132, 40, 0.12);\n}\n\n.admin-comment-item:last-child {\n  padding-bottom: 0;\n  border-bottom: 0;\n}\n\n.admin-comment-item__avatar,\n.admin-quick-card__icon {\n  display: grid;\n  place-items: center;\n  width: 46px;\n  height: 46px;\n  border-radius: 18px;\n  color: var(--color-primary-500);\n  background: rgba(193, 217, 92, 0.54);\n  font-weight: 700;\n}\n\n.admin-comment-item__meta {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 8px;\n  margin-bottom: 6px;\n}\n\n.admin-comment-item__meta span {\n  color: var(--color-text-muted);\n  font-size: 0.92rem;\n}\n\n.admin-comment-item__action {\n  align-self: center;\n  padding: 10px 16px;\n  border: 1px solid rgba(79, 132, 40, 0.12);\n  border-radius: 999px;\n  color: var(--color-primary-500);\n  background: rgba(234, 245, 157, 0.2);\n  font-weight: 600;\n}\n\n.admin-timeline {\n  display: grid;\n  gap: 18px;\n  margin: 0;\n  padding: 0 0 0 10px;\n  list-style: none;\n}\n\n.admin-timeline li {\n  position: relative;\n  padding-left: 24px;\n  color: var(--color-text-muted);\n  line-height: 1.7;\n}\n\n.admin-timeline li::before {\n  content: '';\n  position: absolute;\n  top: 10px;\n  left: 0;\n  width: 11px;\n  height: 11px;\n  border-radius: 50%;\n  background: linear-gradient(135deg, var(--color-primary-200), var(--color-primary-400));\n  box-shadow: 0 0 0 6px rgba(234, 245, 157, 0.42);\n}\n\n.admin-timeline li::after {\n  content: '';\n  position: absolute;\n  top: 22px;\n  left: 5px;\n  width: 1px;\n  height: calc(100% + 8px);\n  background: rgba(79, 132, 40, 0.18);\n}\n\n.admin-timeline li:last-child::after {\n  display: none;\n}\n\n.admin-dashboard__quick {\n  display: grid;\n  gap: 18px;\n}\n\n.admin-quick-grid {\n  display: grid;\n  grid-template-columns: repeat(4, minmax(0, 1fr));\n  gap: 18px;\n}\n\n.admin-quick-card {\n  display: grid;\n  grid-template-columns: auto minmax(0, 1fr);\n  gap: 16px;\n  min-width: 0;\n  padding: 22px;\n  border-radius: 24px;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  background: #fff;\n  box-shadow: 0 14px 30px rgba(79, 132, 40, 0.08);\n  transition: transform 0.2s ease, box-shadow 0.2s ease;\n}\n\n.admin-quick-card:hover {\n  transform: translateY(-2px);\n  box-shadow: 0 18px 36px rgba(79, 132, 40, 0.12);\n}\n\n.admin-quick-card strong {\n  display: block;\n  margin-bottom: 6px;\n  font-size: 1.1rem;\n}\n\n@media (max-width: 1380px) {\n  .admin-stats-grid {\n    grid-template-columns: repeat(3, minmax(0, 1fr));\n  }\n\n  .admin-quick-grid {\n    grid-template-columns: repeat(2, minmax(0, 1fr));\n  }\n}\n\n@media (max-width: 1200px) {\n  .admin-shell {\n    grid-template-columns: 1fr;\n  }\n\n  .admin-sidebar {\n    position: static;\n    min-height: auto;\n  }\n\n  .admin-dashboard__insights,\n  .admin-dashboard__secondary,\n  .admin-content-share {\n    grid-template-columns: 1fr;\n  }\n\n  .admin-content-share {\n    justify-items: center;\n  }\n}\n\n@media (max-width: 920px) {\n  .admin-topbar__search {\n    min-width: 100%;\n  }\n\n  .admin-stats-grid,\n  .admin-quick-grid {\n    grid-template-columns: repeat(2, minmax(0, 1fr));\n  }\n}\n\n@media (max-width: 720px) {\n  .admin-main,\n  .admin-topbar {\n    padding: 18px;\n  }\n\n  .admin-sidebar {\n    padding: 20px 14px 18px;\n  }\n\n  .admin-stats-grid,\n  .admin-quick-grid {\n    grid-template-columns: 1fr;\n  }\n\n  .admin-panel,\n  .admin-metric-card,\n  .admin-quick-card {\n    padding: 20px;\n  }\n\n  .admin-comment-item {\n    grid-template-columns: auto minmax(0, 1fr);\n  }\n\n  .admin-comment-item__action {\n    grid-column: 2;\n    justify-self: start;\n  }\n\n  .admin-weekly-chart {\n    padding: 14px;\n    gap: 8px;\n  }\n}\n"],["STYLE",{},".create-post-page {\n  display: grid;\n  gap: 26px;\n  box-sizing: border-box;\n  max-width: 100%;\n  min-width: 0;\n}\n\n.create-post-page__hero {\n  display: grid;\n  grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.92fr);\n  gap: 28px;\n  align-items: center;\n}\n\n.create-post-page__hero-content {\n  display: grid;\n  gap: 18px;\n}\n\n.create-post-page__badge {\n  display: inline-flex;\n  width: fit-content;\n  padding: 10px 16px;\n  border-radius: 999px;\n  color: var(--color-primary-500);\n  background: rgba(193, 217, 92, 0.24);\n  font-size: 0.92rem;\n  font-weight: 700;\n}\n\n.create-post-page__hero-content h1 {\n  margin: 0;\n  font-size: clamp(2.8rem, 5vw, 4.4rem);\n  line-height: 1.02;\n  letter-spacing: -0.05em;\n}\n\n.create-post-page__hero-content p,\n.create-post-page__alert p,\n.create-post-sidebar__card p,\n.create-post-sidebar__card li {\n  margin: 0;\n  color: var(--color-text-muted);\n  line-height: 1.8;\n}\n\n.create-post-page__hero-visual img {\n  display: block;\n  width: 100%;\n  min-height: 240px;\n  object-fit: cover;\n  border-radius: 30px;\n  box-shadow: var(--shadow-soft);\n}\n\n.create-post-page__alert {\n  display: grid;\n  gap: 8px;\n  padding: 22px 24px;\n  border-radius: 24px;\n  background: linear-gradient(180deg, rgba(193, 217, 92, 0.28), rgba(183, 246, 157, 0.52));\n  border: 1px solid rgba(79, 132, 40, 0.14);\n  box-shadow: var(--shadow-card);\n}\n\n.create-post-page__layout {\n  display: grid;\n  grid-template-columns: minmax(0, 1.75fr) minmax(0, 0.9fr);\n  gap: 24px;\n  align-items: start;\n}\n\n.create-post-form,\n.create-post-sidebar__card {\n  border-radius: 30px;\n  background: rgba(255, 255, 255, 0.96);\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  box-shadow: var(--shadow-card);\n}\n\n.create-post-form {\n  display: grid;\n  gap: 20px;\n  padding: 28px;\n  box-sizing: border-box;\n}\n\n.post-modal-form {\n  width: 100%;\n  min-width: 0;\n}\n\n.create-post-form__messages {\n  display: grid;\n  gap: 10px;\n}\n\n.create-post-form__utility {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 12px;\n  padding: 14px 16px;\n  border-radius: 18px;\n  background: rgba(234, 245, 157, 0.22);\n  border: 1px solid rgba(79, 132, 40, 0.08);\n}\n\n.create-post-form__draft-meta {\n  color: rgba(23, 55, 21, 0.74);\n  font-size: 0.9rem;\n  line-height: 1.5;\n}\n\n.create-post-form__clear-draft {\n  border: 0;\n  color: #336a29;\n  background: transparent;\n  font: inherit;\n  font-weight: 700;\n}\n\n.create-post-form__message {\n  padding: 14px 16px;\n  border-radius: 16px;\n  font-weight: 600;\n}\n\n.create-post-form__message--error {\n  color: #8a5a0b;\n  background: rgba(246, 224, 177, 0.5);\n  border: 1px solid rgba(214, 162, 74, 0.24);\n}\n\n.create-post-form__message--success {\n  color: var(--color-primary-500);\n  background: rgba(234, 245, 157, 0.34);\n  border: 1px solid rgba(79, 132, 40, 0.16);\n}\n\n.create-post-form__message--info {\n  color: rgba(23, 55, 21, 0.82);\n  background: rgba(193, 217, 92, 0.18);\n  border: 1px solid rgba(79, 132, 40, 0.12);\n}\n\n.create-post-form__field {\n  display: grid;\n  gap: 10px;\n}\n\n.post-form-group {\n  display: grid;\n  gap: 10px;\n  width: 100%;\n  min-width: 0;\n}\n\n.post-form-group__header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 12px;\n}\n\n.create-post-form__field span,\n.create-post-sidebar__card h2 {\n  margin: 0;\n  font-weight: 700;\n}\n\n.post-form-group__counter,\n.post-form-group__hint,\n.post-form-group__help {\n  color: rgba(51, 106, 41, 0.72);\n  font-size: 0.86rem;\n  line-height: 1.5;\n}\n\n.post-form-group label {\n  display: block;\n  color: #336a29;\n  font-weight: 700;\n}\n\n.post-form-control,\n.create-post-form__field input,\n.create-post-form__field select,\n.create-post-form__field textarea {\n  display: block;\n  width: 100%;\n  min-width: 0;\n  box-sizing: border-box;\n  border: 1px solid rgba(79, 132, 40, 0.16);\n  border-radius: 14px;\n  padding: 15px 16px;\n  background: linear-gradient(180deg, rgba(234, 245, 157, 0.32), rgba(255, 255, 255, 0.98));\n  color: #173715;\n  font: inherit;\n  line-height: 1.5;\n  transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;\n  appearance: none;\n  -webkit-appearance: none;\n}\n\nselect.post-form-control,\n.create-post-form__field select {\n  background-image: url(\"data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%23336a29' stroke='%23336a29' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e\");\n  background-repeat: no-repeat;\n  background-position: right 16px center;\n  background-size: 16px;\n  padding-right: 40px;\n  cursor: pointer;\n}\n\n.post-form-control::placeholder,\n.create-post-form__field input::placeholder,\n.create-post-form__field textarea::placeholder {\n  color: rgba(51, 106, 41, 0.58);\n}\n\n.post-form-control:focus,\n.create-post-form__field input:focus,\n.create-post-form__field select:focus,\n.create-post-form__field textarea:focus {\n  outline: none;\n  border-color: #4f8428;\n  box-shadow: 0 0 0 4px rgba(128, 177, 85, 0.18);\n  background: #fff;\n}\n\n.post-form-control.is-invalid {\n  border-color: rgba(176, 59, 42, 0.45);\n  box-shadow: 0 0 0 4px rgba(176, 59, 42, 0.08);\n  background: rgba(255, 247, 246, 0.98);\n}\n\n.post-form-group__error {\n  margin: 0;\n  color: #b23b2a;\n  font-size: 0.88rem;\n  line-height: 1.55;\n}\n\n.post-form-row,\n.create-post-form__row {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: 18px;\n  width: 100%;\n  min-width: 0;\n}\n\n.create-post-form__file-input {\n  position: absolute;\n  width: 1px;\n  height: 1px;\n  opacity: 0;\n  pointer-events: none;\n}\n\n.create-post-form__upload-box {\n  display: grid;\n  justify-items: center;\n  gap: 8px;\n  padding: 36px 20px;\n  border: 2px dashed rgba(115, 121, 106, 0.32);\n  border-radius: 22px;\n  text-align: center;\n  background: linear-gradient(180deg, rgba(234, 245, 157, 0.36), rgba(255, 255, 255, 0.9));\n  cursor: pointer;\n  transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;\n}\n\n.create-post-form__upload-box:hover {\n  border-color: rgba(79, 132, 40, 0.42);\n  box-shadow: 0 12px 24px rgba(79, 132, 40, 0.08);\n}\n\n.create-post-form__upload-trigger {\n  margin-top: 6px;\n}\n\n.create-post-form__upload-box:focus-visible {\n  outline: none;\n  border-color: #4f8428;\n  box-shadow: 0 0 0 4px rgba(128, 177, 85, 0.18);\n}\n\n.create-post-form__upload-box small,\n.create-post-form__upload-box em,\n.create-post-sidebar__timeline span,\n.create-post-sidebar__preview-meta small {\n  color: var(--color-text-muted);\n}\n\n.create-post-form__upload-box em {\n  font-style: normal;\n  font-weight: 700;\n}\n\n.create-post-form__content {\n  min-height: 280px;\n  resize: vertical;\n}\n\n.post-editor {\n  display: grid;\n  gap: 12px;\n  padding: 14px;\n  border: 1px solid rgba(79, 132, 40, 0.12);\n  border-radius: 20px;\n  background: linear-gradient(180deg, rgba(250, 252, 241, 0.98), rgba(255, 255, 255, 0.98));\n}\n\n.post-editor__toolbar,\n.post-editor__tools,\n.post-editor__tabs,\n.post-editor__footer {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  flex-wrap: wrap;\n}\n\n.post-editor__toolbar {\n  justify-content: space-between;\n}\n\n.post-editor__toolbar--sticky {\n  position: sticky;\n  top: -14px;\n  z-index: 10;\n  background: rgba(250, 252, 241, 0.95);\n  backdrop-filter: blur(8px);\n  padding: 10px 0;\n  margin: -10px 0 10px 0;\n  border-bottom: 1px solid rgba(79, 132, 40, 0.08);\n}\n\n.post-editor__tool,\n.post-editor__tab {\n  border: 1px solid rgba(79, 132, 40, 0.1);\n  border-radius: 999px;\n  padding: 9px 14px;\n  color: #336a29;\n  background: rgba(234, 245, 157, 0.34);\n  font: inherit;\n  font-size: 0.88rem;\n  font-weight: 700;\n}\n\n.post-editor__tab.is-active {\n  color: #fff;\n  background: linear-gradient(135deg, #4f8428, #336a29);\n  border-color: #336a29;\n}\n\n.post-editor__textarea {\n  width: 100%;\n  min-height: 320px;\n  resize: vertical;\n  border: 0;\n  background: #fff;\n  box-shadow: none;\n  padding: 12px;\n}\n\n.post-editor__textarea:focus {\n  outline: none;\n}\n\n.post-editor__textarea.is-invalid {\n  border-radius: 16px;\n  box-shadow: inset 0 0 0 1px rgba(176, 59, 42, 0.42);\n}\n\n.post-editor__preview {\n  min-height: 320px;\n  padding: 18px;\n  border-radius: 18px;\n  background: rgba(255, 255, 255, 0.92);\n  border: 1px solid rgba(79, 132, 40, 0.08);\n}\n\n.post-editor__footer {\n  justify-content: space-between;\n  color: rgba(51, 106, 41, 0.72);\n  font-size: 0.84rem;\n}\n\n.markdown-content {\n  display: grid;\n  gap: 14px;\n  color: rgba(23, 55, 21, 0.84);\n  line-height: 1.8;\n}\n\n.markdown-content h2,\n.markdown-content h3,\n.markdown-content h4,\n.markdown-content p,\n.markdown-content ul,\n.markdown-content blockquote,\n.markdown-content figure {\n  margin: 0;\n}\n\n.markdown-content h2,\n.markdown-content h3,\n.markdown-content h4 {\n  letter-spacing: -0.03em;\n}\n\n.markdown-content ul {\n  padding-left: 20px;\n}\n\n.markdown-content blockquote {\n  padding: 14px 16px;\n  border-left: 4px solid #80b155;\n  border-radius: 0 16px 16px 0;\n  background: rgba(234, 245, 157, 0.24);\n}\n\n.markdown-content a {\n  color: #336a29;\n  text-decoration: underline;\n}\n\n.markdown-content code {\n  padding: 2px 8px;\n  border-radius: 999px;\n  background: rgba(193, 217, 92, 0.24);\n  font-size: 0.9em;\n}\n\n.markdown-content__figure {\n  display: grid;\n  gap: 10px;\n}\n\n.markdown-content__figure img {\n  width: 100%;\n  max-height: 340px;\n  object-fit: cover;\n  border-radius: 20px;\n}\n\n.markdown-content__figure figcaption,\n.markdown-content__empty {\n  color: rgba(51, 106, 41, 0.72);\n  font-size: 0.88rem;\n}\n\n.create-post-form__actions {\n  display: flex;\n  flex-wrap: nowrap;\n  align-items: center;\n  gap: 14px;\n  justify-content: space-between;\n  padding-top: 6px;\n}\n\n.create-post-form__actions .btn {\n  min-height: 48px;\n  padding: 0 18px;\n  border-radius: 999px;\n  font-weight: 700;\n  white-space: nowrap;\n}\n\n.create-post-form__actions .btn:disabled,\n.composer-modal__footer-actions .btn:disabled {\n  opacity: 0.66;\n  cursor: not-allowed;\n}\n\n.create-post-form__actions .btn--primary {\n  background: linear-gradient(135deg, #4f8428, #336a29);\n  border-color: #336a29;\n}\n\n.create-post-form__actions .btn--secondary {\n  color: #336a29;\n  background: rgba(234, 245, 157, 0.62);\n  border-color: rgba(79, 132, 40, 0.14);\n}\n\n.create-post-form__draft {\n  color: #336a29;\n  background: linear-gradient(180deg, rgba(234, 245, 157, 0.98), rgba(193, 217, 92, 0.9));\n  border: 1px solid rgba(79, 132, 40, 0.16);\n}\n\n.create-post-sidebar {\n  display: grid;\n  gap: 18px;\n}\n\n.create-post-sidebar__card {\n  display: grid;\n  gap: 16px;\n  padding: 22px;\n}\n\n.create-post-sidebar__timeline {\n  position: relative;\n  display: grid;\n  gap: 20px;\n  padding-left: 20px;\n}\n\n.create-post-sidebar__timeline::before {\n  content: '';\n  position: absolute;\n  left: 5px;\n  top: 6px;\n  bottom: 6px;\n  width: 2px;\n  background: rgba(115, 121, 106, 0.24);\n}\n\n.create-post-sidebar__timeline div {\n  position: relative;\n  display: grid;\n  gap: 4px;\n}\n\n.create-post-sidebar__timeline div::before {\n  content: '';\n  position: absolute;\n  left: -20px;\n  top: 8px;\n  width: 12px;\n  height: 12px;\n  border-radius: 50%;\n  background: rgba(115, 121, 106, 0.28);\n}\n\n.create-post-sidebar__timeline .is-active::before {\n  background: var(--color-primary-500);\n}\n\n.create-post-sidebar__preview {\n  overflow: hidden;\n  border-radius: 20px;\n  border: 1px solid rgba(79, 132, 40, 0.12);\n  background: rgba(234, 245, 157, 0.2);\n}\n\n.create-post-sidebar__card.is-highlighted {\n  box-shadow: 0 16px 36px rgba(79, 132, 40, 0.16);\n}\n\n.create-post-sidebar__preview-cover {\n  position: relative;\n  display: grid;\n  place-items: center;\n  min-height: 120px;\n  color: rgba(51, 106, 41, 0.62);\n  background: linear-gradient(180deg, rgba(193, 217, 92, 0.42), rgba(234, 245, 157, 0.28));\n}\n\n.create-post-sidebar__preview-cover em {\n  position: absolute;\n  top: 12px;\n  right: 12px;\n  padding: 8px 10px;\n  border-radius: 999px;\n  color: #7f7a00;\n  background: rgba(234, 245, 157, 0.92);\n  font-style: normal;\n  font-size: 0.74rem;\n  font-weight: 800;\n}\n\n.create-post-sidebar__preview-body {\n  display: grid;\n  gap: 10px;\n  padding: 16px;\n}\n\n.create-post-sidebar__preview-tag {\n  width: fit-content;\n  padding: 8px 10px;\n  border-radius: 999px;\n  color: var(--color-primary-500);\n  background: rgba(193, 217, 92, 0.3);\n  font-size: 0.78rem;\n  font-weight: 700;\n}\n\n.create-post-sidebar__preview-body h3 {\n  margin: 0;\n  font-size: 1.2rem;\n  line-height: 1.35;\n}\n\n.create-post-sidebar__preview-body p {\n  font-size: 0.94rem;\n}\n\n.create-post-sidebar__preview-meta {\n  display: grid;\n  gap: 4px;\n  padding-top: 12px;\n  border-top: 1px solid rgba(79, 132, 40, 0.1);\n}\n\n.create-post-sidebar__card ul {\n  display: grid;\n  gap: 10px;\n  margin: 0;\n  padding-left: 18px;\n  line-height: 1.75;\n}\n\n.create-post-sidebar__card--tips {\n  background: linear-gradient(180deg, rgba(234, 245, 157, 0.44), rgba(255, 255, 255, 0.96));\n}\n\n@media (max-width: 1180px) {\n  .create-post-page__hero,\n  .create-post-page__layout {\n    grid-template-columns: 1fr;\n  }\n}\n\n@media (max-width: 760px) {\n  .create-post-form,\n  .create-post-sidebar__card,\n  .create-post-page__alert {\n    padding: 20px;\n  }\n\n  .create-post-form__row {\n    grid-template-columns: 1fr;\n  }\n\n  .create-post-form__actions {\n    flex-direction: column;\n    align-items: stretch;\n  }\n\n  .create-post-form__actions .btn {\n    width: 100%;\n  }\n\n  .post-form-group__header {\n    flex-direction: column;\n    align-items: flex-start;\n  }\n\n  .create-post-form__utility,\n  .post-editor__toolbar,\n  .post-editor__footer {\n    flex-direction: column;\n    align-items: flex-start;\n  }\n\n  .post-editor__tools,\n  .post-editor__tabs {\n    width: 100%;\n  }\n\n  .post-editor__tool,\n  .post-editor__tab {\n    flex: 1 1 calc(50% - 10px);\n    text-align: center;\n  }\n}\n"],["STYLE",{},".home-page {\n  display: grid;\n  gap: 32px;\n}\n\n.home-section {\n  display: grid;\n  gap: 24px;\n}\n\n.home-section--last {\n  margin-bottom: 12px;\n}\n\n.home-hero {\n  position: relative;\n  overflow: hidden;\n  min-height: calc(100vh - 140px);\n  padding: 44px 28px 32px;\n  border-radius: 40px;\n  background: linear-gradient(180deg, #f7faef 0%, #ffffff 100%);\n}\n\n.home-hero__glow {\n  position: absolute;\n  border-radius: 999px;\n  filter: blur(72px);\n  opacity: 0.75;\n  pointer-events: none;\n}\n\n.home-hero__glow--left {\n  top: 8%;\n  left: -6%;\n  width: 360px;\n  height: 360px;\n  background: rgba(234, 245, 157, 0.62);\n}\n\n.home-hero__glow--right {\n  right: -4%;\n  bottom: 10%;\n  width: 460px;\n  height: 460px;\n  background: rgba(128, 177, 85, 0.24);\n}\n\n.home-hero__grid {\n  position: relative;\n  z-index: 1;\n  display: grid;\n  grid-template-columns: minmax(0, 1fr) minmax(460px, 0.98fr);\n  gap: 36px;\n  align-items: center;\n}\n\n.home-chip {\n  display: inline-flex;\n  align-items: center;\n  gap: 10px;\n  width: fit-content;\n  padding: 10px 16px;\n  border-radius: 999px;\n  color: var(--color-primary-500);\n  background: rgba(128, 177, 85, 0.12);\n  border: 1px solid rgba(128, 177, 85, 0.18);\n  font-size: 0.92rem;\n  font-weight: 700;\n}\n\n.home-chip__dot {\n  width: 10px;\n  height: 10px;\n  border-radius: 50%;\n  background: linear-gradient(180deg, var(--color-primary-300), var(--color-primary-500));\n}\n\n.home-hero__content h1 {\n  display: grid;\n  margin: 18px 0 20px;\n  font-size: clamp(2.9rem, 6vw, 5rem);\n  line-height: 0.96;\n  letter-spacing: -0.05em;\n}\n\n.home-hero__content h1 span {\n  color: var(--color-primary-500);\n}\n\n.home-hero__content p {\n  max-width: 640px;\n  margin: 0;\n  color: var(--color-text-muted);\n  font-size: 1.08rem;\n  line-height: 1.8;\n}\n\n.home-hero__actions {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 14px;\n  margin-top: 28px;\n}\n\n.home-hero__stats {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 24px;\n  margin-top: 36px;\n  padding-top: 24px;\n  border-top: 1px solid rgba(79, 132, 40, 0.12);\n}\n\n.home-hero__stat {\n  display: grid;\n  gap: 6px;\n  min-width: 112px;\n}\n\n.home-hero__stat strong {\n  font-size: 1.75rem;\n  color: var(--color-primary-500);\n}\n\n.home-hero__stat span {\n  color: var(--color-text-muted);\n  font-size: 0.95rem;\n  font-weight: 500;\n}\n\n.home-hero__visual {\n  position: relative;\n  min-height: 640px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.home-hero__image-shell {\n  position: relative;\n  width: 100%;\n  max-width: 720px;\n  padding: 12px;\n  border-radius: 36px;\n  box-shadow: 0 0 120px rgba(79, 132, 40, 0.24);\n}\n\n.home-hero__image-shell::before {\n  content: '';\n  position: absolute;\n  inset: 26px;\n  border-radius: 999px;\n  background: rgba(128, 177, 85, 0.24);\n  filter: blur(54px);\n}\n\n.home-hero__image-shell img {\n  position: relative;\n  z-index: 1;\n  display: block;\n  width: 100%;\n  border-radius: 32px;\n  border: 1px solid rgba(255, 255, 255, 0.72);\n  box-shadow: 0 24px 60px -12px rgba(79, 132, 40, 0.4);\n}\n\n.home-floating-card {\n  position: absolute;\n  z-index: 2;\n  display: grid;\n  gap: 8px;\n  padding: 18px;\n  border: 1px solid rgba(255, 255, 255, 0.68);\n  border-radius: 24px;\n  background: rgba(255, 255, 255, 0.9);\n  backdrop-filter: blur(14px);\n  box-shadow: 0 22px 44px rgba(79, 132, 40, 0.16);\n}\n\n.home-floating-card span {\n  font-size: 0.72rem;\n  font-weight: 800;\n  text-transform: uppercase;\n  letter-spacing: 0.08em;\n}\n\n.home-floating-card strong {\n  font-size: 1.2rem;\n  line-height: 1.35;\n}\n\n.home-floating-card small,\n.home-floating-card p {\n  margin: 0;\n  color: var(--color-text-muted);\n  font-size: 0.92rem;\n  line-height: 1.5;\n}\n\n.home-floating-card--savings {\n  top: 64px;\n  left: -32px;\n}\n\n.home-floating-card--savings span {\n  color: var(--color-primary-500);\n}\n\n.home-floating-card--warning {\n  right: -18px;\n  bottom: 180px;\n  max-width: 220px;\n}\n\n.home-floating-card--warning span {\n  color: #d98b00;\n}\n\n.home-floating-card--tip {\n  left: 84px;\n  bottom: -18px;\n  max-width: 270px;\n  color: #fff;\n  background: linear-gradient(135deg, var(--color-primary-400), var(--color-primary-500));\n  border-color: rgba(255, 255, 255, 0.22);\n}\n\n.home-floating-card--tip span,\n.home-floating-card--tip p {\n  color: inherit;\n}\n\n.home-feature-grid {\n  display: grid;\n  grid-template-columns: repeat(3, minmax(0, 1fr));\n  gap: 24px;\n}\n\n.home-feature-card {\n  display: grid;\n  gap: 14px;\n  padding: 30px;\n  border-radius: 32px;\n  background: #fff;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.03);\n  transition:\n    transform 0.25s ease,\n    box-shadow 0.25s ease;\n}\n\n.home-feature-card:hover {\n  transform: translateY(-4px);\n  box-shadow: 0 12px 32px rgba(51, 106, 41, 0.08);\n}\n\n.home-feature-card__icon {\n  display: grid;\n  place-items: center;\n  width: 64px;\n  height: 64px;\n  border-radius: 20px;\n  color: var(--color-primary-500);\n  font-size: 0.8rem;\n  font-weight: 800;\n}\n\n.home-feature-card__icon--yellow {\n  background: rgba(234, 245, 157, 0.4);\n}\n\n.home-feature-card__icon--green {\n  background: rgba(128, 177, 85, 0.18);\n}\n\n.home-feature-card__icon--dark {\n  background: rgba(51, 106, 41, 0.1);\n}\n\n.home-feature-card h2 {\n  margin: 0;\n  font-size: 1.62rem;\n  letter-spacing: -0.04em;\n}\n\n.home-feature-card p {\n  margin: 0;\n  color: var(--color-text-muted);\n  line-height: 1.75;\n}\n\n.home-feature-card a,\n.home-section__link {\n  color: var(--color-primary-500);\n  font-weight: 800;\n}\n\n.electricity-preview {\n  position: relative;\n  display: grid;\n  grid-template-columns: 1fr 0.95fr;\n  overflow: hidden;\n  border-radius: 40px;\n  background: linear-gradient(135deg, var(--color-primary-500), #29551f);\n  box-shadow: 0 26px 48px rgba(51, 106, 41, 0.22);\n}\n\n.electricity-preview::before {\n  content: '';\n  position: absolute;\n  inset: 0;\n  background-image: radial-gradient(circle at 2px 2px, rgba(255, 255, 255, 0.36) 1px, transparent 0);\n  background-size: 32px 32px;\n  opacity: 0.08;\n}\n\n.electricity-preview__content,\n.electricity-preview__card {\n  position: relative;\n  z-index: 1;\n}\n\n.electricity-preview__content {\n  display: grid;\n  align-content: center;\n  gap: 18px;\n  padding: 56px 52px;\n  color: #fff;\n}\n\n.electricity-preview__eyebrow {\n  color: var(--color-primary-50);\n  font-size: 0.88rem;\n  font-weight: 800;\n  text-transform: uppercase;\n  letter-spacing: 0.08em;\n}\n\n.electricity-preview__content h2 {\n  margin: 0;\n  font-size: clamp(2.2rem, 4vw, 4rem);\n  line-height: 1.06;\n  letter-spacing: -0.05em;\n}\n\n.electricity-preview__content p {\n  max-width: 500px;\n  margin: 0;\n  color: rgba(255, 255, 255, 0.82);\n  font-size: 1.05rem;\n  line-height: 1.78;\n}\n\n.electricity-preview__button {\n  width: fit-content;\n  color: var(--color-primary-500);\n  background: var(--color-primary-50);\n}\n\n.electricity-preview__card {\n  display: grid;\n  gap: 20px;\n  align-content: center;\n  padding: 42px;\n  background: linear-gradient(180deg, rgba(79, 132, 40, 0.24), rgba(51, 106, 41, 0.14));\n}\n\n.electricity-preview__card > div,\n.electricity-preview__device {\n  border-radius: 28px;\n}\n\n.electricity-preview__card-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: 12px;\n  padding: 0 2px;\n  color: #fff;\n}\n\n.electricity-preview__card-header span {\n  padding: 8px 12px;\n  border-radius: 999px;\n  color: var(--color-primary-500);\n  background: rgba(234, 245, 157, 0.84);\n  font-size: 0.78rem;\n  font-weight: 800;\n}\n\n.electricity-preview__list {\n  display: grid;\n  gap: 14px;\n  padding: 28px;\n  border-radius: 32px;\n  background: rgba(255, 255, 255, 0.94);\n  box-shadow: 0 18px 40px rgba(25, 54, 17, 0.16);\n}\n\n.electricity-preview__device {\n  display: grid;\n  grid-template-columns: auto 1fr auto;\n  gap: 16px;\n  align-items: center;\n  padding: 18px;\n  background: #f7faef;\n  border: 1px solid rgba(79, 132, 40, 0.12);\n}\n\n.electricity-preview__device-icon {\n  display: grid;\n  place-items: center;\n  width: 48px;\n  height: 48px;\n  border-radius: 16px;\n  color: var(--color-primary-500);\n  background: #fff;\n  font-size: 0.82rem;\n  font-weight: 800;\n  box-shadow: 0 4px 14px rgba(79, 132, 40, 0.08);\n}\n\n.electricity-preview__device h3,\n.electricity-preview__device p,\n.electricity-preview__summary span,\n.electricity-preview__summary small {\n  margin: 0;\n}\n\n.electricity-preview__device h3 {\n  font-size: 0.98rem;\n}\n\n.electricity-preview__device p {\n  color: var(--color-text-muted);\n}\n\n.electricity-preview__summary span,\n.electricity-preview__summary small {\n  color: #eaf7df;\n}\n\n.electricity-preview__summary {\n  display: grid;\n  gap: 12px;\n  padding-top: 4px;\n}\n\n.electricity-preview__summary strong {\n  color: #eaf7df;\n  font-size: 2rem;\n  font-weight: 800;\n  letter-spacing: -0.04em;\n}\n\n.electricity-preview__progress {\n  width: 100%;\n  height: 10px;\n  overflow: hidden;\n  border-radius: 999px;\n  background: rgba(255, 255, 255, 0.45);\n}\n\n.electricity-preview__progress span {\n  display: block;\n  height: 100%;\n  border-radius: inherit;\n  background: linear-gradient(90deg, #f29c38, #f6b456);\n}\n\n.home-section__header {\n  display: flex;\n  align-items: end;\n  justify-content: space-between;\n  gap: 20px;\n}\n\n.home-section__header--stacked {\n  align-items: start;\n}\n\n.home-section__header h2,\n.community-preview__members h3,\n.community-preview__cta h3 {\n  margin: 0 0 10px;\n  font-size: clamp(2rem, 3.2vw, 3rem);\n  letter-spacing: -0.04em;\n}\n\n.home-section__header p,\n.community-preview__cta p {\n  margin: 0;\n  color: var(--color-text-muted);\n}\n\n.home-post-grid {\n  display: grid;\n  grid-template-columns: repeat(3, minmax(0, 1fr));\n  gap: 24px;\n}\n\n.home-post-card {\n  display: flex;\n  flex-direction: column;\n  overflow: hidden;\n  border-radius: 32px;\n  background: #fff;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.03);\n}\n\n.home-post-card__media {\n  position: relative;\n  aspect-ratio: 4 / 3;\n  overflow: hidden;\n}\n\n.home-post-card__media img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  transition: transform 0.6s ease;\n}\n\n.home-post-card:hover .home-post-card__media img {\n  transform: scale(1.05);\n}\n\n.home-post-card__tag,\n.home-post-card__media button {\n  position: absolute;\n  top: 18px;\n  z-index: 1;\n  border-radius: 999px;\n  background: rgba(255, 255, 255, 0.92);\n  box-shadow: 0 10px 24px rgba(79, 132, 40, 0.1);\n}\n\n.home-post-card__tag {\n  left: 18px;\n  padding: 9px 14px;\n  color: var(--color-primary-500);\n  font-size: 0.8rem;\n  font-weight: 800;\n}\n\n.home-post-card__media button {\n  right: 18px;\n  border: 0;\n  padding: 10px 13px;\n  color: var(--color-primary-500);\n  font-weight: 700;\n}\n\n.home-post-card__body {\n  display: grid;\n  gap: 18px;\n  flex: 1;\n  padding: 24px;\n}\n\n.home-post-card__body h3 {\n  margin: 0;\n  font-size: 1.28rem;\n  line-height: 1.45;\n  letter-spacing: -0.03em;\n}\n\n.home-post-card__meta {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  margin-top: auto;\n  padding-top: 18px;\n  border-top: 1px solid rgba(79, 132, 40, 0.1);\n}\n\n.home-post-card__meta span:last-child {\n  margin-left: auto;\n  color: var(--color-text-muted);\n  font-size: 0.92rem;\n}\n\n.home-avatar {\n  display: grid;\n  place-items: center;\n  width: 36px;\n  height: 36px;\n  border-radius: 50%;\n  font-size: 0.8rem;\n  font-weight: 800;\n}\n\n.home-avatar--yellow {\n  color: var(--color-primary-500);\n  background: var(--color-primary-50);\n}\n\n.home-avatar--green {\n  color: #fff;\n  background: var(--color-primary-300);\n}\n\n.home-avatar--dark {\n  color: #fff;\n  background: var(--color-primary-500);\n}\n\n.home-avatar--lime {\n  color: var(--color-primary-500);\n  background: rgba(193, 217, 92, 0.54);\n}\n\n.community-preview {\n  position: relative;\n  overflow: hidden;\n  display: grid;\n  grid-template-columns: minmax(0, 1fr) 320px;\n  gap: 32px;\n  padding: 42px;\n  border-radius: 40px;\n  background: #e8f2d5;\n}\n\n.community-preview::before {\n  content: '';\n  position: absolute;\n  top: -80px;\n  right: -60px;\n  width: 260px;\n  height: 260px;\n  border-radius: 50%;\n  background: rgba(255, 255, 255, 0.34);\n  filter: blur(24px);\n}\n\n.community-preview__feed {\n  position: relative;\n  z-index: 1;\n  display: grid;\n  gap: 20px;\n}\n\n.community-preview__sidebar {\n  position: relative;\n  z-index: 1;\n  display: flex;\n  flex-direction: column;\n  gap: 20px;\n}\n\n.community-preview__posts {\n  display: grid;\n  gap: 16px;\n}\n\n.community-preview__post,\n.community-preview__members,\n.community-preview__cta {\n  padding: 24px;\n  border-radius: 28px;\n  background: rgba(255, 255, 255, 0.96);\n  border: 1px solid rgba(79, 132, 40, 0.08);\n}\n\n.community-preview__members {\n  flex: 1;\n  min-height: 220px;\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n}\n\n.community-preview__post-top,\n.community-preview__author,\n.community-preview__actions {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n}\n\n.community-preview__post-top {\n  justify-content: space-between;\n  gap: 16px;\n}\n\n.community-preview__author {\n  min-width: 0;\n  overflow: hidden;\n}\n\n.community-preview__author div {\n  min-width: 0;\n  overflow: hidden;\n}\n\n.community-preview__author strong,\n.community-preview__members strong,\n.community-preview__cta h3 {\n  display: block;\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n}\n\n.community-preview__author span,\n.community-preview__members span {\n  color: var(--color-text-muted);\n  font-size: 0.9rem;\n  display: block;\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n}\n\n.community-preview__pill {\n  padding: 8px 12px;\n  border-radius: 12px;\n  color: var(--color-primary-500);\n  background: rgba(234, 245, 157, 0.6);\n  font-size: 0.78rem;\n  font-weight: 700;\n}\n\n.community-preview__post p {\n  display: -webkit-box;\n  -webkit-line-clamp: 2;\n  -webkit-box-orient: vertical;\n  overflow: hidden;\n  margin: 16px 0 18px;\n  line-height: 1.72;\n  color: var(--color-text);\n  word-break: break-word;\n}\n\n.community-preview__actions {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 12px;\n  padding-top: 16px;\n  border-top: 1px solid rgba(79, 132, 40, 0.08);\n  color: var(--color-text-muted);\n  font-size: 0.85rem;\n  font-weight: 600;\n}\n\n.community-preview__button {\n  width: fit-content;\n  color: #fff;\n  background: var(--color-primary-500);\n}\n\n.community-preview__members ul {\n  display: grid;\n  gap: 18px;\n  margin: 0;\n  padding: 0;\n  list-style: none;\n}\n\n.community-preview__members li {\n  display: flex;\n  align-items: center;\n  gap: 14px;\n}\n\n.community-preview__rank {\n  display: grid;\n  place-items: center;\n  width: 48px;\n  height: 48px;\n  border-radius: 50%;\n  color: #fff;\n  font-weight: 800;\n  box-shadow: 0 8px 20px rgba(79, 132, 40, 0.16);\n}\n\n.community-preview__rank--1 {\n  background: linear-gradient(135deg, #f2c447, #e4a825);\n}\n\n.community-preview__rank--2 {\n  background: linear-gradient(135deg, #c8ccd1, #8f979f);\n}\n\n.community-preview__rank--3 {\n  background: linear-gradient(135deg, #e7a065, #d07b38);\n}\n\n.community-preview__cta {\n  color: #fff;\n  background: linear-gradient(180deg, var(--color-primary-400), var(--color-primary-500));\n  text-align: center;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  flex: 1;\n  min-height: 220px;\n}\n\n.community-preview__cta h3 {\n  font-size: 1.1rem;\n  white-space: normal;\n}\n\n.community-preview__cta p {\n  color: rgba(255, 255, 255, 0.84);\n  line-height: 1.6;\n  font-size: 0.9rem;\n  margin-bottom: 20px;\n}\n\n.home-final-cta {\n  position: relative;\n  overflow: hidden;\n  display: grid;\n  justify-items: center;\n  gap: 18px;\n  padding: 64px 24px;\n  border-radius: 48px;\n  text-align: center;\n  background: linear-gradient(135deg, rgba(234, 245, 157, 0.72), rgba(193, 217, 92, 0.36));\n  border: 1px solid rgba(255, 255, 255, 0.7);\n  box-shadow: var(--shadow-soft);\n}\n\n.home-final-cta::before,\n.home-final-cta::after {\n  content: '';\n  position: absolute;\n  border-radius: 50%;\n  opacity: 0.26;\n}\n\n.home-final-cta::before {\n  top: -80px;\n  left: -60px;\n  width: 180px;\n  height: 180px;\n  background: rgba(79, 132, 40, 0.14);\n}\n\n.home-final-cta::after {\n  right: -40px;\n  bottom: -70px;\n  width: 220px;\n  height: 220px;\n  background: rgba(128, 177, 85, 0.18);\n}\n\n.home-final-cta__icon {\n  display: grid;\n  place-items: center;\n  width: 72px;\n  height: 72px;\n  border-radius: 50%;\n  color: var(--color-primary-500);\n  background: rgba(255, 255, 255, 0.92);\n  font-size: 2rem;\n  box-shadow: 0 10px 24px rgba(79, 132, 40, 0.12);\n}\n\n.home-final-cta h2 {\n  max-width: 780px;\n  margin: 0;\n  color: var(--color-primary-500);\n  font-size: clamp(2.2rem, 4.2vw, 4rem);\n  line-height: 1.08;\n  letter-spacing: -0.05em;\n}\n\n.home-final-cta p {\n  max-width: 680px;\n  margin: 0;\n  color: var(--color-text-muted);\n  font-size: 1.08rem;\n  line-height: 1.8;\n}\n\n.home-final-cta__button {\n  margin-top: 8px;\n}\n\n@media (max-width: 1220px) {\n  .home-hero__grid,\n  .electricity-preview,\n  .community-preview,\n  .home-post-grid,\n  .home-feature-grid {\n    grid-template-columns: 1fr;\n  }\n\n  .home-hero__visual {\n    min-height: 560px;\n  }\n\n  .home-post-grid {\n    grid-template-columns: repeat(2, minmax(0, 1fr));\n  }\n\n  .community-preview__members,\n  .community-preview__cta {\n    flex: none;\n    min-height: auto;\n  }\n}\n\n@media (max-width: 920px) {\n  .home-hero {\n    padding: 32px 20px 28px;\n    border-radius: 32px;\n  }\n\n  .home-hero__visual {\n    min-height: 480px;\n  }\n\n  .home-floating-card--savings {\n    left: 8px;\n  }\n\n  .home-floating-card--warning {\n    right: 8px;\n  }\n\n  .community-preview,\n  .electricity-preview__content,\n  .electricity-preview__card {\n    padding: 28px;\n  }\n}\n\n@media (max-width: 720px) {\n  .home-hero__actions,\n  .home-section__header {\n    flex-direction: column;\n    align-items: stretch;\n  }\n\n  .home-feature-grid,\n  .home-post-grid {\n    grid-template-columns: 1fr;\n  }\n\n  .home-hero__visual {\n    min-height: 360px;\n  }\n\n  .home-floating-card {\n    position: static;\n    margin-top: 14px;\n  }\n\n  .home-hero__image-shell {\n    margin-bottom: 12px;\n  }\n\n  .community-preview {\n    padding: 24px;\n  }\n\n  .home-final-cta {\n    padding: 48px 20px;\n    border-radius: 36px;\n  }\n}\n"],["STYLE",{},".auth-page {\n  display: flex;\n  align-items: center;\n  padding: 32px 24px 56px;\n  min-height: calc(100vh - 80px);\n}\n\n.auth-layout {\n  max-width: 1180px;\n  width: 100%;\n  margin: 0 auto;\n  display: grid;\n  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);\n  gap: 36px;\n  align-items: stretch;\n}\n\n.auth-visual,\n.auth-card {\n  position: relative;\n  overflow: hidden;\n  border-radius: 32px;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  box-shadow: var(--shadow-soft);\n  height: 640px;\n  box-sizing: border-box;\n  width: 100%;\n}\n\n.auth-visual {\n  display: flex;\n  flex-direction: column;\n  justify-content: space-between;\n  gap: 16px;\n  padding: 34px 40px;\n  background:\n    radial-gradient(circle at top right, rgba(234, 245, 157, 0.52), transparent 24%),\n    radial-gradient(circle at bottom left, rgba(193, 217, 92, 0.26), transparent 26%),\n    linear-gradient(180deg, rgba(247, 250, 239, 0.96), rgba(255, 255, 255, 0.92));\n}\n\n.auth-visual__main {\n  display: flex;\n  flex-direction: column;\n  gap: 16px;\n}\n\n.auth-visual__top,\n.auth-visual__brand {\n  display: flex;\n  align-items: center;\n  gap: 14px;\n}\n\n.auth-visual__brand strong {\n  color: var(--color-primary-500);\n  font-size: 1.6rem;\n  letter-spacing: -0.04em;\n}\n\n.auth-visual__logo {\n  display: grid;\n  place-items: center;\n  width: 48px;\n  height: 48px;\n  border-radius: 16px;\n  color: #fff;\n  font-weight: 800;\n  background: linear-gradient(135deg, var(--color-primary-400), var(--color-primary-500));\n}\n\n.auth-visual__chip {\n  display: inline-flex;\n  align-items: center;\n  width: fit-content;\n  padding: 10px 16px;\n  border-radius: 999px;\n  color: var(--color-primary-500);\n  background: rgba(234, 245, 157, 0.78);\n  font-size: 0.92rem;\n  font-weight: 700;\n}\n\n.auth-visual__content {\n  max-width: 650px;\n}\n\n.auth-visual__content h1 {\n  margin: 0 0 10px;\n  font-size: clamp(28px, 2.2vw, 38px);\n  line-height: 1.06;\n  letter-spacing: -0.04em;\n}\n\n.auth-visual__content p,\n.auth-note p,\n.auth-card__header p,\n.auth-card__alternate,\n.auth-form__checkbox span {\n  margin: 0;\n  color: var(--color-text-muted);\n  line-height: 1.78;\n}\n\n.auth-visual__inline-features {\n  display: flex;\n  flex-wrap: wrap;\n  align-items: center;\n  gap: 10px;\n  margin-top: 12px;\n  font-size: 0.92rem;\n  font-weight: 600;\n  color: var(--color-primary-500);\n}\n\n.auth-visual__inline-features .dot {\n  color: rgba(79, 132, 40, 0.4);\n}\n\n.auth-carousel-placeholder {\n  width: 100%;\n  height: clamp(260px, 26vh, 300px);\n  margin-top: 16px;\n  overflow: hidden;\n  border-radius: 24px;\n  background: rgba(234, 245, 157, 0.4);\n  border: 1px solid rgba(79, 132, 40, 0.12);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: var(--color-primary-500);\n  font-weight: 600;\n  text-align: center;\n  padding: 20px;\n}\n\n.auth-carousel-placeholder img {\n  display: block;\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  border-radius: inherit;\n}\n\n.auth-card {\n  display: flex;\n  flex-direction: column;\n  justify-content: flex-start;\n  gap: 14px;\n  padding: 34px 40px;\n  background: rgba(255, 255, 255, 0.96);\n}\n\n.auth-card__header h2 {\n  margin: 0 0 8px;\n  font-size: 2.2rem;\n  letter-spacing: -0.04em;\n}\n\n.auth-card__switcher {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  padding: 6px;\n  border-radius: 18px;\n  background: rgba(234, 245, 157, 0.5);\n}\n\n.auth-card__switcher a,\n.auth-card__switcher span {\n  display: inline-flex;\n  justify-content: center;\n  align-items: center;\n  padding: 12px 14px;\n  border-radius: 14px;\n  font-weight: 700;\n  text-decoration: none;\n}\n\n.auth-card__switcher .is-active {\n  color: #fff;\n  background: var(--color-primary-500);\n  box-shadow: 0 8px 18px rgba(79, 132, 40, 0.18);\n}\n\n.auth-card__switcher a {\n  color: rgba(23, 55, 21, 0.76);\n}\n\n.auth-card__message {\n  padding: 14px 16px;\n  border-radius: 16px;\n  font-weight: 600;\n}\n\n.auth-card__message--error {\n  color: #8a5a0b;\n  background: rgba(246, 224, 177, 0.5);\n  border: 1px solid rgba(214, 162, 74, 0.24);\n}\n\n.auth-card__message--success {\n  color: var(--color-primary-500);\n  background: rgba(234, 245, 157, 0.34);\n  border: 1px solid rgba(79, 132, 40, 0.16);\n}\n\n.auth-form {\n  display: grid;\n  gap: 18px;\n}\n\n.auth-form label {\n  display: grid;\n  gap: 10px;\n}\n\n.auth-form label > span {\n  font-weight: 700;\n}\n\n.auth-form input {\n  width: 100%;\n  min-width: 0;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  border-radius: 16px;\n  padding: 14px 16px;\n  background: linear-gradient(90deg, rgba(247, 250, 239, 0.98), rgba(234, 245, 157, 0.28));\n  font: inherit;\n}\n\n.auth-form__row {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 12px;\n}\n\n.auth-form__checkbox {\n  display: flex !important;\n  align-items: center;\n  gap: 10px;\n}\n\n.auth-form__checkbox input {\n  width: 20px;\n  height: 20px;\n  padding: 0;\n  flex-shrink: 0;\n}\n\n.auth-form__terms-link {\n  color: var(--color-primary-500);\n  font-weight: 700;\n  text-decoration: underline;\n  text-underline-offset: 2px;\n}\n\n.auth-form__terms-link:hover {\n  color: var(--color-primary-400);\n}\n\n.auth-form__link-button {\n  border: 0;\n  padding: 0;\n  color: var(--color-primary-500);\n  background: transparent;\n  font-weight: 700;\n}\n\n.auth-form__submit {\n  width: 100%;\n  margin-top: 6px;\n}\n\n.auth-card__alternate {\n  text-align: center;\n}\n\n.auth-card__alternate a {\n  color: var(--color-primary-500);\n  font-weight: 800;\n}\n\n.auth-card__divider {\n  position: relative;\n  text-align: center;\n  color: var(--color-text-muted);\n}\n\n.auth-card__divider::before {\n  content: '';\n  position: absolute;\n  inset: 50% 0 auto;\n  height: 1px;\n  background: rgba(79, 132, 40, 0.12);\n}\n\n.auth-card__divider {\n  display: grid;\n  place-items: center;\n}\n\n.auth-card__divider::after {\n  content: 'hoặc';\n  position: relative;\n  z-index: 1;\n  padding: 0 14px;\n  background: rgba(255, 255, 255, 0.96);\n}\n\n.auth-card__socials {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: 14px;\n}\n\n.auth-card__socials button {\n  border: 1px solid rgba(79, 132, 40, 0.16);\n  border-radius: 16px;\n  padding: 14px 16px;\n  color: var(--color-text);\n  background: #fff;\n  font: inherit;\n  font-weight: 700;\n}\n\n.auth-note {\n  display: grid;\n  gap: 8px;\n  justify-items: center;\n  padding-top: 8px;\n  text-align: center;\n}\n\n.auth-note strong {\n  color: var(--color-primary-500);\n  font-size: 0.92rem;\n  text-transform: uppercase;\n  letter-spacing: 0.08em;\n}\n\n/* 2K+ screens (>= 1600px) */\n@media (min-width: 1600px) {\n  .auth-layout {\n    max-width: 1360px;\n    gap: 44px;\n  }\n\n  .auth-visual,\n  .auth-card {\n    height: 760px;\n    padding: 48px 52px;\n  }\n\n  .auth-visual__content h1 {\n    font-size: clamp(48px, 3.2vw, 68px);\n  }\n\n  .auth-carousel-placeholder {\n    margin-top: 24px;\n  }\n\n  .auth-visual__main {\n    gap: 24px;\n  }\n\n  .auth-card {\n    gap: 18px;\n    padding: 48px 52px;\n  }\n}\n\n/* Laptop / small desktop (900px – 1199px) */\n@media (max-width: 1199px) {\n  .auth-layout {\n    max-width: 1040px;\n    gap: 28px;\n  }\n\n  .auth-visual,\n  .auth-card {\n    height: auto;\n    min-height: 580px;\n    padding: 32px 36px;\n  }\n\n  .auth-visual__content h1 {\n    font-size: clamp(34px, 3.2vw, 48px);\n  }\n\n  .auth-carousel-placeholder {\n    height: 240px;\n    margin-top: 16px;\n  }\n}\n\n/* Tablet / mobile (< 900px) */\n@media (max-width: 900px) {\n  .auth-page {\n    min-height: 0;\n    padding: 24px 16px 48px;\n    align-items: flex-start;\n  }\n\n  .auth-layout {\n    grid-template-columns: 1fr;\n  }\n\n  .auth-visual,\n  .auth-card {\n    height: auto;\n    min-height: 0;\n    padding: 28px 24px;\n  }\n\n  .auth-visual__logo {\n    width: 42px;\n    height: 42px;\n  }\n}\n\n@media (max-width: 640px) {\n  .auth-card__socials {\n    grid-template-columns: 1fr;\n  }\n\n  .auth-form__row {\n    flex-direction: column;\n    align-items: flex-start;\n  }\n}\n"],["STYLE",{},"/* Font loaded via <link> in index.html for better performance */\n\n:root {\n  font-family: system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Arial, sans-serif;\n  color: #27500a;\n  background:\n    radial-gradient(circle at top left, rgba(234, 245, 157, 0.7), transparent 32%),\n    linear-gradient(180deg, #f9fceb 0%, #f4f8e7 100%);\n  font-synthesis: none;\n  text-rendering: optimizeLegibility;\n  -webkit-font-smoothing: antialiased;\n  -moz-osx-font-smoothing: grayscale;\n\n  --color-primary-50: #eaf59d;\n  --color-primary-100: #dced8a;\n  --color-primary-200: #c1d95c;\n  --color-primary-300: #80b155;\n  --color-primary-400: #4f8428;\n  --color-primary-500: #336a29;\n  --color-surface: #ffffff;\n  --color-surface-soft: rgba(255, 255, 255, 0.76);\n  --color-background: #f7faef;\n  --color-text: #173715;\n  --color-text-muted: rgba(23, 55, 21, 0.74);\n  --color-border: rgba(79, 132, 40, 0.16);\n  --shadow-soft: 0 18px 50px rgba(79, 132, 40, 0.12);\n  --shadow-card: 0 10px 28px rgba(79, 132, 40, 0.08);\n  --radius-lg: 24px;\n  --radius-md: 18px;\n  --radius-sm: 12px;\n  --container-width: 1280px;\n}\n\n* {\n  box-sizing: border-box;\n}\n\nhtml {\n  scroll-behavior: smooth;\n}\n\nbody {\n  margin: 0;\n  min-width: 320px;\n  min-height: 100vh;\n  color: var(--color-text);\n  background: var(--color-background);\n}\n\na {\n  color: inherit;\n  text-decoration: none;\n}\n\nbutton,\ninput {\n  font: inherit;\n}\n\nbutton {\n  cursor: pointer;\n}\n\n#root {\n  min-height: 100vh;\n}\n\n.shell {\n  width: min(calc(100% - 32px), var(--container-width));\n  margin: 0 auto;\n}\n\n.shell--wide {\n  width: min(calc(100% - 32px), 1360px);\n}\n\n.btn {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  gap: 8px;\n  border: 1px solid transparent;\n  border-radius: 999px;\n  padding: 12px 20px;\n  font-weight: 600;\n  transition:\n    transform 0.2s ease,\n    box-shadow 0.2s ease,\n    background-color 0.2s ease;\n}\n\n.btn:hover {\n  transform: translateY(-1px);\n}\n\n.btn--primary {\n  color: #fff;\n  background: linear-gradient(135deg, var(--color-primary-300), var(--color-primary-400));\n  box-shadow: 0 12px 24px rgba(79, 132, 40, 0.2);\n}\n\n.btn--secondary {\n  background: var(--color-surface);\n  border-color: var(--color-border);\n  color: var(--color-primary-500);\n  box-shadow: var(--shadow-card);\n}\n\n.btn--ghost {\n  color: var(--color-primary-500);\n  background: rgba(255, 255, 255, 0.68);\n  border-color: rgba(79, 132, 40, 0.2);\n}\n\n.btn--light {\n  width: 100%;\n  color: var(--color-primary-500);\n  background: #fff;\n}\n\n.page {\n  display: grid;\n  gap: 32px;\n}\n\n.page-badge {\n  display: inline-flex;\n  align-items: center;\n  width: fit-content;\n  padding: 8px 14px;\n  border-radius: 999px;\n  background: rgba(234, 245, 157, 0.9);\n  color: var(--color-primary-500);\n  font-size: 0.875rem;\n  font-weight: 600;\n}\n\n.page-badge--soft {\n  background: rgba(193, 217, 92, 0.18);\n}\n\n.content-grid {\n  display: grid;\n  gap: 24px;\n}\n\n.content-grid--three {\n  grid-template-columns: repeat(3, minmax(0, 1fr));\n}\n\n.content-grid--four {\n  grid-template-columns: repeat(4, minmax(0, 1fr));\n}\n\n.plain-list {\n  margin: 0;\n  padding-left: 18px;\n  color: var(--color-text-muted);\n  line-height: 1.8;\n}\n\n@media (max-width: 1100px) {\n  .content-grid--three,\n  .content-grid--four {\n    grid-template-columns: repeat(2, minmax(0, 1fr));\n  }\n}\n\n@media (max-width: 720px) {\n  .shell,\n  .shell--wide {\n    width: min(calc(100% - 24px), var(--container-width));\n  }\n\n  .content-grid--three,\n  .content-grid--four {\n    grid-template-columns: 1fr;\n  }\n}\n\nhtml,\nbody {\n  overflow-x: hidden;\n}\n\nimg,\nvideo,\niframe {\n  max-width: 100%;\n  height: auto;\n}\n\n.community-layout,\n.community-feed,\n.community-sidebar,\n.post-card,\n.community-post-card,\n.tip-card,\n.admin-layout,\n.admin-main {\n  min-width: 0;\n}\n\n.post-title,\n.post-content,\n.comment-content,\n.community-post-card__title,\n.community-post-card__excerpt,\n.tip-card__title,\n.tip-card__excerpt {\n  overflow-wrap: anywhere;\n  word-break: break-word;\n}\n\n/* ─── Image utilities — chống CLS ────────────────────────────────────────── */\n.hero-img,\n.banner-img {\n  aspect-ratio: 16 / 9;\n  object-fit: cover;\n  width: 100%;\n  height: auto;\n}\n\n.post-img,\n.community-img {\n  aspect-ratio: 4 / 3;\n  object-fit: cover;\n  width: 100%;\n  height: auto;\n}\n\n.avatar-img {\n  aspect-ratio: 1 / 1;\n  object-fit: cover;\n  border-radius: 50%;\n}\n\n/* Đảm bảo ảnh không overflow container */\nimg {\n  max-width: 100%;\n  height: auto;\n}\n\n/* ─── Accessibility: Focus styles ────────────────────────────────────────── */\n*:focus-visible {\n  outline: 2px solid #27500a;\n  outline-offset: 3px;\n}\n\nbutton:focus-visible,\na:focus-visible,\ninput:focus-visible,\ntextarea:focus-visible,\nselect:focus-visible {\n  outline: 2px solid #27500a;\n  outline-offset: 3px;\n}\n"],["STYLE",{},"\n.user-shell {\n  min-height: 100vh;\n  background:\n    radial-gradient(circle at 85% 14%, rgba(193, 217, 92, 0.26), transparent 20%),\n    linear-gradient(180deg, rgba(250, 252, 241, 0.96) 0%, #f6faea 100%);\n}\n\n.user-navbar {\n  position: sticky;\n  top: var(--announcement-offset, 0px);\n  z-index: 20;\n  backdrop-filter: blur(18px);\n  background: rgba(255, 255, 255, 0.8);\n  border-bottom: 1px solid rgba(255, 255, 255, 0.5);\n  box-shadow: 0 10px 24px rgba(79, 132, 40, 0.06);\n}\n\n.user-navbar__inner {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 16px;\n  min-height: 80px;\n  padding: 8px 0;\n}\n\n.user-navbar__mobile-toggle {\n  display: none;\n}\n\n.user-navbar__links,\n.user-navbar__actions {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n}\n\n.user-navbar__link {\n  padding: 10px 0;\n  color: var(--color-text-muted);\n  font-weight: 500;\n  border-bottom: 2px solid transparent;\n  transition: border-color 0.2s ease, color 0.2s ease;\n}\n\n.user-navbar__link:hover,\n.user-navbar__link.is-active {\n  color: var(--color-primary-500);\n  border-color: var(--color-primary-500);\n}\n\n.user-navbar__login {\n  padding-inline: 22px;\n}\n\n.user-navbar__publish {\n  padding-inline: 24px;\n}\n\n.user-navbar__user-menu {\n  position: relative;\n}\n\n.user-navbar__user-trigger {\n  display: inline-flex;\n  align-items: center;\n  gap: 12px;\n  padding: 8px 12px;\n  border: 1px solid rgba(79, 132, 40, 0.12);\n  border-radius: 999px;\n  color: var(--color-primary-500);\n  background: rgba(255, 255, 255, 0.88);\n  box-shadow: var(--shadow-card);\n}\n\n.user-navbar__avatar {\n  display: grid;\n  place-items: center;\n  width: 38px;\n  height: 38px;\n  border-radius: 50%;\n  color: #fff;\n  font-size: 0.84rem;\n  font-weight: 800;\n  background: linear-gradient(135deg, var(--color-primary-300), var(--color-primary-500));\n}\n\n.user-navbar__avatar-img {\n  width: 38px;\n  height: 38px;\n  border-radius: 50%;\n  object-fit: cover;\n  border: 2px solid #eaf59d;\n}\n\n.user-navbar__user-name {\n  max-width: 140px;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n  font-weight: 700;\n}\n\n.user-navbar__dropdown {\n  position: absolute;\n  top: calc(100% + 12px);\n  right: 0;\n  min-width: 220px;\n  display: grid;\n  gap: 4px;\n  padding: 10px;\n  border-radius: 18px;\n  background: rgba(255, 255, 255, 0.96);\n  border: 1px solid rgba(79, 132, 40, 0.1);\n  box-shadow: 0 18px 36px rgba(79, 132, 40, 0.14);\n}\n\n.user-navbar__dropdown-link {\n  display: block;\n  width: 100%;\n  padding: 12px 14px;\n  border: 0;\n  border-radius: 14px;\n  color: var(--color-text);\n  background: transparent;\n  text-align: left;\n  font: inherit;\n  font-weight: 600;\n}\n\n.user-navbar__dropdown-link:hover,\n.user-navbar__dropdown-link--logout:hover {\n  background: rgba(234, 245, 157, 0.32);\n}\n\n.user-navbar__dropdown-link--logout {\n  color: #8a5a0b;\n}\n\n.user-main {\n  width: min(calc(100% - 32px), 1360px);\n  margin: 0 auto;\n  padding: 24px 0 64px;\n}\n\n.user-footer {\n  color: #fff;\n  background: linear-gradient(180deg, var(--color-primary-500), #29551f);\n}\n\n.user-footer__content {\n  display: grid;\n  justify-items: center;\n  gap: 22px;\n  padding: 44px 0 28px;\n  text-align: center;\n}\n\n.user-footer__brand {\n  display: grid;\n  justify-items: center;\n  gap: 12px;\n}\n\n.user-footer__brand p {\n  max-width: 360px;\n  margin: 0;\n  color: rgba(234, 245, 157, 0.9);\n  font-size: 0.95rem;\n}\n\n.user-footer__nav {\n  display: flex;\n  flex-wrap: wrap;\n  justify-content: center;\n  gap: 14px 24px;\n}\n\n.user-footer__nav a {\n  color: rgba(255, 255, 255, 0.82);\n  font-size: 0.95rem;\n  font-weight: 500;\n}\n\n.user-footer__copyright {\n  width: min(100%, 760px);\n  padding-top: 18px;\n  border-top: 1px solid rgba(255, 255, 255, 0.18);\n}\n\n.user-footer__copyright p {\n  margin: 0;\n  color: rgba(255, 255, 255, 0.64);\n  font-size: 0.78rem;\n}\n\n.user-footer__badge {\n  display: inline-flex;\n  align-items: center;\n  gap: 8px;\n  padding: 4px 14px 4px 6px;\n  border-radius: 999px;\n  background: linear-gradient(135deg, #e53935, #b71c1c);\n  color: #fff;\n  font-size: 13.5px;\n  font-weight: 700;\n  box-shadow: 0 4px 12px rgba(183, 28, 28, 0.3);\n}\n\n.user-footer__badge-icon {\n  position: relative;\n  width: 24px;\n  height: 24px;\n  border-radius: 50%;\n  background-color: #da251d;\n  flex-shrink: 0;\n}\n\n.user-footer__badge-icon svg {\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n  width: 60%;\n  height: 60%;\n  display: block;\n}\n\n.hero-panel,\n.page-banner,\n.placeholder-page,\n.not-found__card {\n  position: relative;\n  overflow: hidden;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  border-radius: 32px;\n  background:\n    radial-gradient(circle at top right, rgba(193, 217, 92, 0.34), transparent 28%),\n    linear-gradient(180deg, rgba(245, 255, 226, 0.98) 0%, rgba(255, 255, 255, 0.96) 100%);\n  box-shadow: var(--shadow-soft);\n}\n\n.hero-panel {\n  display: grid;\n  grid-template-columns: 1.3fr 0.9fr;\n  gap: 28px;\n  padding: 42px;\n}\n\n.hero-panel__content h1,\n.page-banner h1,\n.placeholder-page h1,\n.not-found__card h1 {\n  margin: 16px 0;\n  font-size: clamp(2.4rem, 4vw, 4rem);\n  line-height: 1.05;\n  letter-spacing: -0.04em;\n}\n\n.hero-panel__content p,\n.page-banner p,\n.placeholder-page p,\n.post-card p,\n.feature-card p,\n.visual-card span,\n.side-card p {\n  margin: 0;\n  color: var(--color-text-muted);\n  font-size: 1rem;\n  line-height: 1.75;\n}\n\n.hero-panel__actions {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 12px;\n  margin-top: 28px;\n}\n\n.hero-panel__card,\n.feature-card,\n.post-card,\n.side-card,\n.panel-card,\n.admin-stat {\n  border-radius: var(--radius-lg);\n  background: var(--color-surface-soft);\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  box-shadow: var(--shadow-card);\n}\n\n.hero-panel__card {\n  align-self: end;\n  padding: 28px;\n  background: linear-gradient(180deg, rgba(79, 132, 40, 0.96), rgba(51, 106, 41, 0.96));\n  color: #fff;\n}\n\n.mini-stats {\n  display: grid;\n  gap: 14px;\n  margin: 18px 0 0;\n  padding: 0;\n  list-style: none;\n}\n\n.mini-stats li {\n  display: flex;\n  justify-content: space-between;\n  gap: 12px;\n  padding-bottom: 10px;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.14);\n}\n\n.feature-card {\n  padding: 24px;\n}\n\n.feature-card__icon {\n  display: inline-grid;\n  place-items: center;\n  width: 48px;\n  height: 48px;\n  border-radius: 16px;\n  margin-bottom: 18px;\n  color: var(--color-primary-500);\n  background: rgba(234, 245, 157, 0.88);\n  font-size: 0.8rem;\n  font-weight: 700;\n}\n\n.feature-card h2,\n.post-card h2,\n.side-card h3,\n.panel-card h2 {\n  margin: 0 0 10px;\n  letter-spacing: -0.03em;\n}\n\n.page-banner {\n  display: grid;\n  grid-template-columns: 1.1fr 0.9fr;\n  gap: 24px;\n  padding: 32px;\n}\n\n.page-banner__visual {\n  display: flex;\n  align-items: stretch;\n}\n\n.visual-card {\n  display: flex;\n  flex-direction: column;\n  justify-content: flex-end;\n  gap: 10px;\n  width: 100%;\n  min-height: 240px;\n  padding: 28px;\n  border-radius: 28px;\n  background:\n    linear-gradient(135deg, rgba(193, 217, 92, 0.24), rgba(79, 132, 40, 0.16)),\n    linear-gradient(180deg, rgba(255, 255, 255, 0.62), rgba(255, 255, 255, 0.92));\n}\n\n.community-layout {\n  display: grid;\n  grid-template-columns: minmax(0, 1.7fr) minmax(280px, 0.8fr);\n  gap: 24px;\n}\n\n.community-feed,\n.community-sidebar {\n  display: grid;\n  gap: 20px;\n}\n\n.post-card,\n.side-card,\n.placeholder-page {\n  padding: 28px;\n}\n\n.side-card--accent {\n  color: #fff;\n  background: linear-gradient(180deg, var(--color-primary-400), var(--color-primary-500));\n}\n\n.side-card--accent p {\n  color: rgba(255, 255, 255, 0.82);\n  margin-bottom: 20px;\n}\n\n.placeholder-page {\n  display: grid;\n  gap: 16px;\n}\n\n.placeholder-page__box {\n  display: grid;\n  gap: 8px;\n  padding: 20px;\n  border-radius: 22px;\n  background: rgba(255, 255, 255, 0.82);\n  border: 1px solid var(--color-border);\n}\n\n.admin-shell {\n  display: grid;\n  grid-template-columns: 300px minmax(0, 1fr);\n  min-height: 100vh;\n  background:\n    radial-gradient(circle at top right, rgba(193, 217, 92, 0.26), transparent 18%),\n    linear-gradient(180deg, #f5f9ea 0%, #eef5df 100%);\n}\n\n.admin-sidebar {\n  display: flex;\n  flex-direction: column;\n  gap: 24px;\n  padding: 28px 18px;\n  color: #fff;\n  background: linear-gradient(180deg, #2e7029 0%, #21521e 100%);\n}\n\n.admin-sidebar__brand {\n  margin-bottom: 8px;\n}\n\n.admin-sidebar__nav {\n  display: grid;\n  gap: 8px;\n}\n\n.admin-sidebar__link {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  padding: 14px 16px;\n  border-radius: 20px;\n  color: rgba(255, 255, 255, 0.88);\n  font-weight: 600;\n  transition: background-color 0.2s ease, color 0.2s ease;\n}\n\n.admin-sidebar__link:hover,\n.admin-sidebar__link.is-active {\n  color: var(--color-text);\n  background: linear-gradient(135deg, var(--color-primary-200), #98c660);\n}\n\n.admin-sidebar__icon {\n  display: inline-grid;\n  place-items: center;\n  min-width: 36px;\n  height: 36px;\n  border-radius: 12px;\n  background: rgba(255, 255, 255, 0.12);\n  font-size: 0.78rem;\n  letter-spacing: -0.03em;\n}\n\n.admin-sidebar__link.is-active .admin-sidebar__icon {\n  background: rgba(51, 106, 41, 0.12);\n}\n\n.admin-sidebar__logout {\n  margin-top: auto;\n  padding: 14px 16px;\n  color: #fff;\n  background: rgba(255, 255, 255, 0.08);\n  border: 1px solid rgba(255, 255, 255, 0.12);\n  border-radius: 18px;\n}\n\n.admin-shell__content {\n  display: flex;\n  flex-direction: column;\n  min-width: 0;\n}\n\n.admin-topbar {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 20px;\n  padding: 22px 28px;\n  border-bottom: 1px solid rgba(79, 132, 40, 0.08);\n  background: rgba(241, 251, 220, 0.68);\n  backdrop-filter: blur(14px);\n}\n\n.admin-topbar h1 {\n  margin: 6px 0;\n  font-size: clamp(2rem, 3vw, 3rem);\n  letter-spacing: -0.04em;\n}\n\n.admin-topbar span,\n.admin-topbar small,\n.admin-topbar__eyebrow {\n  color: var(--color-text-muted);\n}\n\n.admin-topbar__eyebrow {\n  margin: 0;\n  font-weight: 700;\n  text-transform: uppercase;\n  letter-spacing: 0.08em;\n  font-size: 0.78rem;\n}\n\n.admin-topbar__actions {\n  display: flex;\n  align-items: center;\n  gap: 14px;\n}\n\n.admin-topbar__search {\n  display: grid;\n  gap: 6px;\n  min-width: min(420px, 42vw);\n  color: var(--color-text-muted);\n  font-size: 0.84rem;\n}\n\n.admin-topbar__search input {\n  width: 100%;\n  border: 1px solid rgba(79, 132, 40, 0.12);\n  border-radius: 999px;\n  padding: 14px 18px;\n  background: rgba(193, 217, 92, 0.28);\n  outline: none;\n}\n\n.admin-topbar__icon-button {\n  display: grid;\n  place-items: center;\n  width: 44px;\n  height: 44px;\n  border: 0;\n  border-radius: 50%;\n  color: var(--color-primary-500);\n  background: #fff;\n  box-shadow: var(--shadow-card);\n}\n\n.admin-topbar__profile {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  padding: 8px 12px;\n  border-radius: 999px;\n  background: rgba(255, 255, 255, 0.8);\n  box-shadow: var(--shadow-card);\n}\n\n.admin-topbar__avatar {\n  display: grid;\n  place-items: center;\n  width: 42px;\n  height: 42px;\n  border-radius: 50%;\n  color: #fff;\n  font-weight: 700;\n  background: linear-gradient(135deg, var(--color-primary-300), var(--color-primary-500));\n}\n\n.admin-main {\n  padding: 28px;\n}\n\n.admin-stat {\n  display: grid;\n  gap: 10px;\n  padding: 24px;\n}\n\n.admin-stat span {\n  color: var(--color-text-muted);\n}\n\n.admin-stat strong {\n  font-size: clamp(2rem, 3vw, 3rem);\n  letter-spacing: -0.05em;\n}\n\n.admin-stat--warm {\n  background:\n    radial-gradient(circle at top right, rgba(255, 175, 163, 0.36), transparent 24%),\n    var(--color-surface-soft);\n}\n\n.admin-stat--green {\n  background:\n    radial-gradient(circle at top right, rgba(128, 177, 85, 0.26), transparent 24%),\n    var(--color-surface-soft);\n}\n\n.admin-stat--lime {\n  background:\n    radial-gradient(circle at top right, rgba(193, 217, 92, 0.32), transparent 24%),\n    var(--color-surface-soft);\n}\n\n.admin-panels {\n  display: grid;\n  grid-template-columns: 1.1fr 0.9fr;\n  gap: 24px;\n}\n\n.panel-card {\n  padding: 28px;\n}\n\n.bar-chart {\n  display: grid;\n  grid-template-columns: repeat(7, minmax(0, 1fr));\n  align-items: end;\n  gap: 10px;\n  height: 260px;\n  padding: 22px;\n  border-radius: 22px;\n  background: linear-gradient(180deg, rgba(79, 132, 40, 0.04), rgba(255, 255, 255, 0.7));\n}\n\n.bar-chart span {\n  display: block;\n  border-radius: 999px 999px 16px 16px;\n  background: linear-gradient(180deg, var(--color-primary-200), var(--color-primary-400));\n}\n\n.comment-list {\n  display: grid;\n  gap: 18px;\n  margin: 0;\n  padding: 0;\n  list-style: none;\n}\n\n.comment-list li {\n  display: grid;\n  gap: 8px;\n  padding-bottom: 18px;\n  border-bottom: 1px solid var(--color-border);\n}\n\n.not-found {\n  display: grid;\n  place-items: center;\n  min-height: 100vh;\n  padding: 24px;\n  background:\n    radial-gradient(circle at center, rgba(193, 217, 92, 0.24), transparent 34%),\n    linear-gradient(180deg, #f5fae8 0%, #eef5df 100%);\n}\n\n.not-found__card {\n  width: min(100%, 640px);\n  padding: 40px;\n  text-align: center;\n}\n\n.not-found__card .btn {\n  margin-top: 12px;\n}\n\n@media (max-width: 1200px) {\n  .community-layout,\n  .admin-panels,\n  .hero-panel,\n  .page-banner {\n    grid-template-columns: 1fr;\n  }\n\n  .admin-shell {\n    grid-template-columns: 1fr;\n  }\n\n  .admin-sidebar {\n    padding-bottom: 18px;\n  }\n}\n\n@media (max-width: 920px) {\n  .user-navbar__inner,\n  .admin-topbar,\n  .admin-topbar__actions {\n    flex-wrap: wrap;\n  }\n\n  .user-navbar__mobile-toggle {\n    display: block !important;\n    background: none;\n    border: none;\n    color: var(--color-primary-500);\n    padding: 8px;\n    cursor: pointer;\n    order: 2;\n  }\n\n  .user-navbar__links {\n    order: 3;\n    width: 100%;\n    flex-direction: column;\n    gap: 14px;\n    display: none;\n  }\n\n  .user-navbar__actions {\n    order: 4;\n    width: 100%;\n    flex-direction: column;\n    display: none;\n  }\n\n  .user-navbar__links.is-mobile-open,\n  .user-navbar__actions.is-mobile-open {\n    display: flex;\n  }\n\n  .user-navbar__dropdown {\n    right: auto;\n    left: 0;\n    width: 100%;\n  }\n\n  .admin-topbar__search {\n    min-width: 100%;\n  }\n}\n\n@media (max-width: 720px) {\n  .user-main,\n  .admin-main {\n    padding-left: 0;\n    padding-right: 0;\n  }\n\n  .hero-panel,\n  .page-banner,\n  .placeholder-page,\n  .panel-card,\n  .admin-stat,\n  .post-card,\n  .side-card {\n    padding: 22px;\n  }\n\n  .admin-topbar {\n    padding: 18px;\n  }\n\n  .admin-main {\n    padding: 18px;\n  }\n}\n"],["STYLE",{},".page-hero,\n.surface-card,\n.ui-modal,\n.post-image,\n.inline-comments,\n.avatar-uploader {\n  border-radius: 28px;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  box-shadow: var(--shadow-card);\n}\n\n.page-hero {\n  position: relative;\n  overflow: hidden;\n  display: grid;\n  grid-template-columns: minmax(0, 1.06fr) minmax(320px, 0.92fr);\n  gap: 28px;\n  align-items: center;\n  padding: 34px;\n  background:\n    radial-gradient(circle at top right, rgba(193, 217, 92, 0.28), transparent 26%),\n    linear-gradient(180deg, rgba(245, 255, 226, 0.98) 0%, rgba(255, 255, 255, 0.96) 100%);\n}\n\n.page-hero__copy,\n.page-hero__headline {\n  display: grid;\n  gap: 16px;\n}\n\n.page-hero__badge {\n  display: inline-flex;\n  width: fit-content;\n  padding: 10px 16px;\n  border-radius: 999px;\n  color: var(--color-primary-500);\n  background: rgba(193, 217, 92, 0.24);\n  font-size: 0.92rem;\n  font-weight: 700;\n}\n\n.page-hero__headline h1 {\n  margin: 0;\n  font-size: clamp(2.6rem, 5vw, 4.4rem);\n  line-height: 1.02;\n  letter-spacing: -0.05em;\n}\n\n.page-hero__headline p {\n  margin: 0;\n  color: var(--color-text-muted);\n  font-size: 1.04rem;\n  line-height: 1.8;\n}\n\n.page-hero__actions {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 14px;\n}\n\n.page-hero__visual {\n  min-width: 0;\n}\n\n.page-hero__visual img {\n  display: block;\n  width: 100%;\n  min-height: 280px;\n  aspect-ratio: 16 / 9;\n  object-fit: cover;\n  border-radius: 24px;\n  box-shadow: 0 18px 44px rgba(79, 132, 40, 0.16);\n}\n\n.post-image {\n  position: relative;\n  overflow: hidden;\n  background: rgba(234, 245, 157, 0.2);\n}\n\n.post-image img,\n.post-image__fallback img {\n  display: block;\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n}\n\n.post-image--card {\n  aspect-ratio: 16 / 9;\n}\n\n.post-image--detail {\n  aspect-ratio: 16 / 9;\n  max-height: 520px;\n}\n\n.post-image--detail img {\n  max-height: 520px;\n}\n\n.post-image--compact {\n  aspect-ratio: 1 / 1;\n}\n\n.post-image__fallback {\n  position: relative;\n  width: 100%;\n  height: 100%;\n}\n\n.post-image__fallback::after {\n  content: '';\n  position: absolute;\n  inset: 0;\n  background: linear-gradient(180deg, rgba(23, 55, 21, 0.04), rgba(23, 55, 21, 0.24));\n}\n\n.post-image__fallback span {\n  position: absolute;\n  left: 16px;\n  bottom: 16px;\n  z-index: 1;\n  color: #fff;\n  font-size: 0.86rem;\n  font-weight: 700;\n}\n\n.ui-modal-overlay {\n  position: fixed;\n  inset: 0;\n  display: grid;\n  place-items: center;\n  padding: 20px;\n  background: rgba(10, 24, 9, 0.58);\n  backdrop-filter: blur(14px);\n  z-index: 1200;\n}\n\n.ui-modal {\n  width: min(100%, 1180px);\n  max-height: min(92vh, 980px);\n  overflow: hidden;\n  background: rgba(255, 255, 255, 0.98);\n}\n\n.ui-modal--composer {\n  display: flex;\n  flex-direction: column;\n  width: min(100%, 1220px);\n  max-height: calc(100dvh - 48px);\n}\n\n.ui-modal--crop {\n  width: min(100%, 860px);\n}\n\n.ui-modal__header,\n.ui-modal__footer {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 16px;\n  padding: 22px 24px;\n}\n\n.ui-modal__header {\n  border-bottom: 1px solid rgba(79, 132, 40, 0.08);\n  flex-shrink: 0;\n  position: sticky;\n  top: 0;\n  z-index: 2;\n  background: rgba(255, 255, 255, 0.98);\n}\n\n.ui-modal__header h2 {\n  margin: 0 0 4px;\n}\n\n.ui-modal__header p {\n  margin: 0;\n  color: var(--color-text-muted);\n}\n\n.ui-modal__close {\n  width: 40px;\n  height: 40px;\n  border: 0;\n  border-radius: 50%;\n  color: rgba(23, 55, 21, 0.72);\n  background: rgba(234, 245, 157, 0.26);\n}\n\n.ui-modal__footer {\n  border-top: 1px solid rgba(79, 132, 40, 0.08);\n  flex-shrink: 0;\n  position: sticky;\n  bottom: 0;\n  z-index: 2;\n  background: rgba(255, 255, 255, 0.98);\n}\n\n.ui-cropper {\n  position: relative;\n  min-height: 420px;\n  background: #173715;\n}\n\n.ui-cropper__controls {\n  padding: 18px 24px 0;\n}\n\n.ui-cropper__slider {\n  display: grid;\n  gap: 10px;\n}\n\n.ui-cropper__slider span {\n  font-weight: 700;\n}\n\n.composer-modal__body {\n  display: grid;\n  grid-template-columns: minmax(0, 1.78fr) minmax(280px, 0.72fr);\n  gap: 18px;\n  padding: 24px;\n  overflow: auto;\n  min-height: 0;\n  align-items: start;\n}\n\n.composer-modal__body .create-post-form,\n.composer-modal__body .create-post-sidebar__card {\n  border-radius: 24px;\n}\n\n.create-post-form--compact {\n  padding: 24px;\n}\n\n.composer-modal__footer {\n  gap: 18px;\n  padding-block: 16px;\n}\n\n.composer-modal__footer-note {\n  min-width: 0;\n  color: var(--color-text-muted);\n  font-size: 0.92rem;\n  line-height: 1.6;\n}\n\n.composer-modal__footer-actions {\n  display: flex;\n  flex-wrap: nowrap;\n  align-items: center;\n  gap: 12px;\n}\n\n.composer-modal__footer-actions .btn {\n  min-height: 46px;\n  border-radius: 999px;\n  padding-inline: 18px;\n  white-space: nowrap;\n}\n\n.avatar-uploader {\n  display: grid;\n  grid-template-columns: auto minmax(0, 1fr);\n  gap: 18px;\n  padding: 18px;\n  background: linear-gradient(180deg, rgba(234, 245, 157, 0.24), rgba(255, 255, 255, 0.98));\n}\n\n.avatar-uploader__preview {\n  display: grid;\n  place-items: center;\n}\n\n.avatar-uploader__image,\n.avatar-uploader__fallback {\n  width: 112px;\n  height: 112px;\n  border-radius: 50%;\n}\n\n.avatar-uploader__image {\n  object-fit: cover;\n  border: 4px solid #eaf59d;\n}\n\n.avatar-uploader__fallback {\n  display: grid;\n  place-items: center;\n  color: #fff;\n  font-size: 2rem;\n  font-weight: 800;\n  background: linear-gradient(135deg, var(--color-primary-300), var(--color-primary-500));\n}\n\n.avatar-uploader__body {\n  display: grid;\n  gap: 14px;\n}\n\n.avatar-uploader__body p {\n  margin: 6px 0 0;\n  color: var(--color-text-muted);\n  line-height: 1.65;\n}\n\n.avatar-uploader__actions {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 10px;\n}\n\n.avatar-uploader__danger {\n  color: #b23b2a;\n}\n\n.inline-comments {\n  display: grid;\n  gap: 18px;\n  padding: 22px;\n  background: rgba(255, 255, 255, 0.96);\n}\n\n.inline-comments--inline {\n  margin-top: 12px;\n}\n\n.inline-comments__heading {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 12px;\n}\n\n.inline-comments__heading h2 {\n  margin: 0;\n  font-size: 1.4rem;\n}\n\n.inline-comments__heading span,\n.inline-comments__meta span,\n.inline-comments__item-meta span,\n.inline-comments__state {\n  color: var(--color-text-muted);\n}\n\n.inline-comments__composer,\n.inline-comments__item {\n  display: grid;\n  grid-template-columns: auto minmax(0, 1fr);\n  gap: 12px;\n}\n\n.inline-comments__avatar,\n.inline-comments__item-avatar {\n  width: 40px;\n  height: 40px;\n  border-radius: 50%;\n  object-fit: cover;\n}\n\n.inline-comments__avatar--fallback,\n.inline-comments__item-avatar--fallback {\n  display: grid;\n  place-items: center;\n  color: #fff;\n  font-weight: 700;\n  background: linear-gradient(135deg, var(--color-primary-300), var(--color-primary-500));\n}\n\n.inline-comments__form,\n.inline-comments__bubble,\n.inline-comments__list {\n  display: grid;\n  gap: 10px;\n}\n\n.inline-comments__form textarea {\n  width: 100%;\n  resize: vertical;\n  padding: 14px 16px;\n  border: 1px solid rgba(79, 132, 40, 0.12);\n  border-radius: 18px;\n  background: linear-gradient(180deg, rgba(234, 245, 157, 0.18), rgba(255, 255, 255, 0.96));\n  font: inherit;\n}\n\n.inline-comments__form-footer,\n.inline-comments__item-meta {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 12px;\n}\n\n.inline-comments__meta {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 10px;\n}\n\n.inline-comments__error {\n  color: #c62828;\n  font-weight: 600;\n}\n\n.inline-comments__bubble {\n  padding: 14px 16px;\n  border-radius: 18px;\n  background: linear-gradient(180deg, rgba(234, 245, 157, 0.18), rgba(255, 255, 255, 0.96));\n  border: 1px solid rgba(79, 132, 40, 0.08);\n}\n\n.inline-comments__bubble p {\n  margin: 0;\n  line-height: 1.7;\n}\n\n.ui-toast {\n  position: fixed;\n  right: 20px;\n  bottom: 20px;\n  z-index: 1300;\n  display: inline-flex;\n  align-items: center;\n  gap: 10px;\n  padding: 14px 18px;\n  border-radius: 16px;\n  color: #fff;\n  background: rgba(23, 55, 21, 0.92);\n  box-shadow: 0 12px 24px rgba(15, 28, 12, 0.28);\n}\n\n.announcement-bar {\n  position: sticky;\n  top: 0;\n  z-index: 30;\n  border-bottom: 1px solid rgba(79, 132, 40, 0.1);\n  background: linear-gradient(135deg, rgba(234, 245, 157, 0.96), rgba(255, 255, 255, 0.98));\n  backdrop-filter: blur(12px);\n}\n\n.announcement-bar--info {\n  background: linear-gradient(135deg, rgba(234, 245, 157, 0.96), rgba(255, 255, 255, 0.98));\n}\n\n.announcement-bar--success {\n  background: linear-gradient(135deg, rgba(193, 217, 92, 0.94), rgba(255, 255, 255, 0.98));\n}\n\n.announcement-bar--warning {\n  background: linear-gradient(135deg, rgba(246, 224, 177, 0.96), rgba(255, 255, 255, 0.98));\n}\n\n.announcement-bar--danger {\n  background: linear-gradient(135deg, rgba(255, 220, 213, 0.96), rgba(255, 255, 255, 0.98));\n}\n\n.announcement-bar__inner {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 16px;\n  min-height: 52px;\n  padding: 10px 0;\n}\n\n.announcement-bar__content {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  min-width: 0;\n  flex: 1;\n}\n\n.announcement-bar__title {\n  flex-shrink: 0;\n  color: #336a29;\n}\n\n.announcement-bar__message {\n  margin: 0;\n  color: rgba(23, 55, 21, 0.8);\n  line-height: 1.55;\n}\n\n.announcement-bar__marquee {\n  overflow: hidden;\n  min-width: 0;\n  flex: 1;\n}\n\n.announcement-bar__marquee-track {\n  display: inline-flex;\n  gap: 32px;\n  min-width: max-content;\n  white-space: nowrap;\n  animation: announcement-marquee 22s linear infinite;\n}\n\n.announcement-bar__actions {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  flex-shrink: 0;\n}\n\n.announcement-bar__cta,\n.announcement-bar__close {\n  border-radius: 999px;\n  font-weight: 700;\n}\n\n.announcement-bar__cta {\n  padding: 9px 14px;\n  color: #fff;\n  background: #336a29;\n}\n\n.announcement-bar__close {\n  width: 36px;\n  height: 36px;\n  border: 0;\n  color: #336a29;\n  background: rgba(255, 255, 255, 0.72);\n}\n\n@keyframes announcement-marquee {\n  from {\n    transform: translateX(0);\n  }\n  to {\n    transform: translateX(-50%);\n  }\n}\n\n@media (max-width: 1180px) {\n  .page-hero,\n  .composer-modal__body {\n    grid-template-columns: 1fr;\n  }\n\n  .composer-modal__footer {\n    flex-direction: column;\n    align-items: stretch;\n  }\n\n  .composer-modal__footer-actions {\n    width: 100%;\n    justify-content: stretch;\n  }\n\n  .composer-modal__footer-actions .btn {\n    flex: 1 1 0;\n  }\n}\n\n@media (max-width: 760px) {\n  .page-hero {\n    padding: 24px;\n  }\n\n  .page-hero__visual img {\n    min-height: 220px;\n  }\n\n  .ui-modal-overlay {\n    padding: 0;\n  }\n\n  .ui-modal {\n    width: 100%;\n    height: 100vh;\n    max-height: 100vh;\n    border-radius: 0;\n  }\n\n  .ui-modal__header,\n  .ui-modal__footer,\n  .composer-modal__body {\n    padding-inline: 18px;\n  }\n\n  .composer-modal__body {\n    padding-bottom: 20px;\n  }\n\n  .composer-modal__footer-actions {\n    flex-direction: column;\n    align-items: stretch;\n  }\n\n  .announcement-bar__inner,\n  .announcement-bar__content {\n    align-items: flex-start;\n  }\n\n  .announcement-bar__inner {\n    flex-direction: column;\n  }\n\n  .announcement-bar__actions {\n    width: 100%;\n    justify-content: space-between;\n  }\n\n  .avatar-uploader,\n  .inline-comments__composer,\n  .inline-comments