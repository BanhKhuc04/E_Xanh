-desc {\n  font-size: 0.9rem;\n  color: var(--color-text);\n  line-height: 1.6;\n  margin: 0 0 16px 0;\n}\n\n.development-notice-info {\n  display: flex;\n  flex-direction: column;\n  gap: 8px;\n  background: rgba(234, 245, 157, 0.2);\n  padding: 12px 16px;\n  border-radius: 12px;\n  margin-bottom: 20px;\n  font-size: 0.85rem;\n  color: var(--color-text-muted);\n}\n\n.development-notice-info p {\n  margin: 0;\n  display: flex;\n  justify-content: space-between;\n}\n\n.development-notice-info strong {\n  color: var(--color-primary-600);\n}\n\n.development-report-button,\n.development-report-button:link,\n.development-report-button:visited,\n.development-report-button:focus,\n.development-report-button:active,\n.development-report-button:focus-visible {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  gap: 8px;\n  background-color: #2f7d32 !important;\n  color: #ffffff !important;\n  text-decoration: none !important;\n  opacity: 1 !important;\n  border: none;\n  cursor: pointer;\n  padding: 10px 20px;\n  border-radius: 12px;\n  font-weight: 600;\n  font-size: 0.95rem;\n  transition: all 0.2s;\n  width: 100%;\n}\n\n.development-report-button:hover {\n  background-color: #256628 !important;\n  color: #ffffff !important;\n  text-decoration: none !important;\n  transform: translateY(-2px);\n  box-shadow: 0 4px 12px rgba(79, 132, 40, 0.2);\n}\n\n.development-report-button.development-notice-mini-btn {\n  width: auto;\n  gap: 6px;\n  padding: 12px 20px;\n  border-radius: 30px;\n  box-shadow: 0 8px 24px rgba(79, 132, 40, 0.25);\n  animation: slideUpFade 0.4s ease-out;\n}\n\n.development-report-button.development-notice-mini-btn:hover {\n  box-shadow: 0 12px 28px rgba(79, 132, 40, 0.3);\n}\n\n@keyframes slideUpFade {\n  from {\n    opacity: 0;\n    transform: translateY(20px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n@media (max-width: 768px) {\n  .development-notice-container {\n    bottom: 16px;\n    right: 5%;\n    left: 5%;\n    align-items: stretch;\n  }\n  \n  .development-notice-box {\n    width: 100%;\n    max-width: none;\n  }\n  \n  .development-notice-mini-btn {\n    align-self: flex-end;\n  }\n}\n"],["STYLE",{},".brand-logo {\n  display: block;\n  text-decoration: none;\n  flex-shrink: 0;\n}\n\n.brand-logo__image {\n  width: var(--logo-width);\n  height: auto;\n  max-height: none;\n  object-fit: contain;\n  display: block;\n  flex-shrink: 0;\n}\n\n/* small size */\n.brand-logo--small {\n  --logo-width: 110px;\n}\n\n/* medium size (Navbar) - responsive */\n.brand-logo--medium {\n  --logo-width: 110px; /* Mobile */\n}\n@media (min-width: 768px) {\n  .brand-logo--medium {\n    --logo-width: 140px; /* Desktop */\n  }\n}\n\n/* large size (Loading / 404 / About) */\n.brand-logo--large {\n  --logo-width: 220px;\n}\n\n/* auth size (Login / Register) */\n.brand-logo--auth {\n  --logo-width: 200px;\n}\n\n/* admin size (Admin sidebar) */\n.brand-logo--admin {\n  --logo-width: 160px;\n}\n\n/* footer size */\n.brand-logo--footer {\n  --logo-width: 160px;\n}\n"],["STYLE",{},".admin-shell {\n  grid-template-columns: 310px minmax(0, 1fr);\n  background:\n    radial-gradient(circle at top right, rgba(193, 217, 92, 0.24), transparent 18%),\n    linear-gradient(180deg, #f8fbef 0%, #f1f7e2 100%);\n}\n\n.admin-sidebar {\n  position: sticky;\n  top: 0;\n  min-height: 100vh;\n  padding: 30px 18px 24px;\n  background: #336a29;\n  box-shadow: inset -1px 0 0 rgba(255, 255, 255, 0.08);\n}\n\n.admin-sidebar__brand {\n  margin-bottom: 22px;\n}\n\n.admin-sidebar__nav {\n  gap: 10px;\n}\n\n.admin-sidebar__link {\n  gap: 14px;\n  min-width: 0;\n  border: 1px solid transparent;\n}\n\n.admin-sidebar__link:hover,\n.admin-sidebar__link.is-active {\n  color: #183814;\n  background: linear-gradient(135deg, #9fc45c, #84b44f);\n  box-shadow: 0 10px 22px rgba(24, 56, 20, 0.16);\n}\n\n.admin-sidebar__icon {\n  flex-shrink: 0;\n  width: 42px;\n  height: 42px;\n  min-width: 42px;\n  background: rgba(255, 255, 255, 0.12);\n}\n\n.admin-sidebar__icon svg {\n  width: 20px;\n  height: 20px;\n  stroke: currentColor;\n  fill: none;\n  stroke-width: 1.9;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n}\n\n.admin-sidebar__link.is-active .admin-sidebar__icon {\n  background: rgba(255, 255, 255, 0.42);\n}\n\n.admin-topbar {\n  position: sticky;\n  top: 0;\n  z-index: 8;\n  padding: 24px 28px;\n  background: rgba(241, 250, 220, 0.88);\n  box-shadow: 0 12px 28px rgba(79, 132, 40, 0.06);\n}\n\n.admin-topbar__summary {\n  min-width: 0;\n}\n\n.admin-topbar h1 {\n  margin: 6px 0 8px;\n  font-size: clamp(1.8rem, 2.3vw, 2.6rem);\n  line-height: 1.08;\n}\n\n.admin-topbar__summary > span {\n  display: block;\n  max-width: 620px;\n  line-height: 1.6;\n}\n\n.admin-topbar__search {\n  position: relative;\n  min-width: min(360px, 34vw);\n}\n\n.admin-topbar__search input {\n  padding: 15px 18px 15px 50px;\n  color: var(--color-text);\n  background: linear-gradient(180deg, rgba(193, 217, 92, 0.52), rgba(193, 217, 92, 0.34));\n}\n\n.admin-topbar__search input::placeholder {\n  color: rgba(23, 55, 21, 0.62);\n}\n\n.admin-topbar__search-icon {\n  position: absolute;\n  top: 50%;\n  left: 18px;\n  display: grid;\n  place-items: center;\n  width: 20px;\n  height: 20px;\n  transform: translateY(-50%);\n  color: var(--color-primary-500);\n}\n\n.admin-topbar__search-icon svg,\n.admin-topbar__icon-button svg {\n  width: 20px;\n  height: 20px;\n  stroke: currentColor;\n  fill: none;\n  stroke-width: 1.9;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n}\n\n.admin-topbar__icon-button {\n  position: relative;\n  flex-shrink: 0;\n}\n\n.admin-topbar__dot {\n  position: absolute;\n  top: 11px;\n  right: 10px;\n  width: 8px;\n  height: 8px;\n  border-radius: 50%;\n  background: #d97745;\n  box-shadow: 0 0 0 3px #fff;\n}\n\n.admin-topbar__profile {\n  padding: 8px 14px 8px 10px;\n}\n\n.admin-topbar__profile strong,\n.admin-topbar__profile small {\n  display: block;\n}\n\n.admin-topbar__profile strong {\n  margin-bottom: 2px;\n}\n\n.admin-topbar__profile small {\n  color: var(--color-text-muted);\n}\n\n.admin-main {\n  padding: 28px;\n  background: transparent;\n}\n\n.admin-dashboard {\n  gap: 24px;\n}\n\n.admin-dashboard__hero {\n  display: grid;\n  gap: 14px;\n}\n\n.admin-dashboard__hero-copy h2,\n.admin-dashboard__section-title h3 {\n  margin: 0 0 10px;\n  font-size: clamp(2rem, 3vw, 2.8rem);\n  letter-spacing: -0.04em;\n}\n\n.admin-dashboard__hero-copy p,\n.admin-dashboard__section-title p,\n.admin-panel__header p,\n.admin-quick-card p,\n.admin-comment-item p,\n.admin-metric-card__body p {\n  margin: 0;\n  color: var(--color-text-muted);\n  line-height: 1.7;\n}\n\n.admin-stats-grid {\n  display: grid;\n  grid-template-columns: repeat(5, minmax(0, 1fr));\n  gap: 18px;\n}\n\n.admin-metric-card {\n  display: grid;\n  gap: 18px;\n  padding: 22px 20px 24px;\n  border-radius: 28px;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  background: #fff;\n  box-shadow: 0 14px 30px rgba(79, 132, 40, 0.08);\n  min-width: 0;\n}\n\n.admin-metric-card__top {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 12px;\n}\n\n.admin-metric-card__icon {\n  display: inline-grid;\n  place-items: center;\n  width: 56px;\n  height: 56px;\n  border-radius: 20px;\n  color: var(--color-primary-500);\n}\n\n.admin-metric-card__icon svg,\n.admin-quick-card__icon svg {\n  width: 24px;\n  height: 24px;\n  stroke: currentColor;\n  fill: none;\n  stroke-width: 1.9;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n}\n\n.admin-metric-card__change {\n  padding: 10px 14px;\n  border-radius: 999px;\n  font-size: 0.95rem;\n  font-weight: 700;\n}\n\n.admin-metric-card__body strong {\n  display: block;\n  margin-top: 10px;\n  font-size: clamp(2.2rem, 3.4vw, 3.2rem);\n  line-height: 1;\n  letter-spacing: -0.05em;\n}\n\n.admin-metric-card--peach .admin-metric-card__icon,\n.admin-metric-card--peach .admin-metric-card__change {\n  background: rgba(247, 182, 168, 0.42);\n}\n\n.admin-metric-card--peach .admin-metric-card__change {\n  color: #a65039;\n}\n\n.admin-metric-card--green .admin-metric-card__icon {\n  background: rgba(128, 177, 85, 0.22);\n}\n\n.admin-metric-card--green .admin-metric-card__change {\n  color: #fff;\n  background: #7bab48;\n}\n\n.admin-metric-card--lime .admin-metric-card__icon {\n  background: rgba(193, 217, 92, 0.34);\n}\n\n.admin-metric-card--lime .admin-metric-card__change {\n  color: #526e17;\n  background: rgba(207, 230, 85, 0.88);\n}\n\n.admin-metric-card--olive .admin-metric-card__icon {\n  background: rgba(128, 177, 85, 0.2);\n}\n\n.admin-metric-card--olive .admin-metric-card__change {\n  color: #264918;\n  background: rgba(128, 177, 85, 0.32);\n}\n\n.admin-dashboard__insights {\n  display: grid;\n  grid-template-columns: minmax(0, 1.25fr) minmax(320px, 0.95fr);\n  gap: 22px;\n}\n\n.admin-dashboard__secondary {\n  display: grid;\n  grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);\n  gap: 22px;\n}\n\n.admin-panel {\n  display: grid;\n  gap: 20px;\n  min-width: 0;\n  padding: 26px;\n  border-radius: 28px;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  background: rgba(255, 255, 255, 0.92);\n  box-shadow: 0 16px 32px rgba(79, 132, 40, 0.08);\n}\n\n.admin-panel__header {\n  display: flex;\n  align-items: flex-start;\n  justify-content: space-between;\n  gap: 16px;\n}\n\n.admin-panel__header h3 {\n  margin: 0 0 6px;\n  font-size: 1.45rem;\n  letter-spacing: -0.03em;\n}\n\n.admin-panel__count {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  min-width: 38px;\n  height: 38px;\n  padding-inline: 12px;\n  border-radius: 999px;\n  color: #fff;\n  background: #c85f33;\n  font-weight: 700;\n}\n\n.admin-chart-legend {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 14px;\n}\n\n.admin-chart-legend span {\n  display: inline-flex;\n  align-items: center;\n  gap: 8px;\n  color: var(--color-text-muted);\n  font-size: 0.92rem;\n}\n\n.admin-chart-legend i,\n.admin-content-list__label i {\n  display: inline-block;\n  width: 12px;\n  height: 12px;\n  border-radius: 50%;\n}\n\n.admin-chart-legend .is-like {\n  background: #d2ea57;\n}\n\n.admin-chart-legend .is-comment {\n  background: #88b753;\n}\n\n.admin-chart-legend .is-save {\n  background: #4f8428;\n}\n\n.admin-weekly-chart {\n  display: grid;\n  grid-template-columns: repeat(7, minmax(0, 1fr));\n  gap: 12px;\n  align-items: end;\n  min-height: 320px;\n  padding: 20px;\n  border-radius: 24px;\n  background: linear-gradient(180deg, rgba(234, 245, 157, 0.16), rgba(247, 250, 239, 0.78));\n}\n\n.admin-weekly-chart__group {\n  display: grid;\n  justify-items: center;\n  gap: 12px;\n  min-width: 0;\n}\n\n.admin-weekly-chart__bars {\n  display: grid;\n  grid-template-columns: repeat(3, minmax(0, 1fr));\n  align-items: end;\n  gap: 6px;\n  width: 100%;\n  min-height: 240px;\n}\n\n.admin-weekly-chart__bars span {\n  display: block;\n  min-height: 16px;\n  border-radius: 16px 16px 10px 10px;\n}\n\n.admin-weekly-chart__bars .bar-like {\n  background: #d2ea57;\n}\n\n.admin-weekly-chart__bars .bar-comment {\n  background: #88b753;\n}\n\n.admin-weekly-chart__bars .bar-save {\n  background: #4f8428;\n}\n\n.admin-weekly-chart__group small {\n  color: var(--color-text-muted);\n  font-weight: 600;\n}\n\n.admin-content-share {\n  display: grid;\n  grid-template-columns: minmax(0, 220px) minmax(0, 1fr);\n  align-items: center;\n  gap: 22px;\n}\n\n.admin-donut-chart {\n  position: relative;\n  width: min(220px, 100%);\n  aspect-ratio: 1;\n  margin: 0 auto;\n  border-radius: 50%;\n}\n\n.admin-donut-chart::after {\n  content: '';\n  position: absolute;\n  inset: 24px;\n  border-radius: 50%;\n  background: #fff;\n  box-shadow: inset 0 0 0 1px rgba(79, 132, 40, 0.06);\n}\n\n.admin-donut-chart__center {\n  position: absolute;\n  inset: 0;\n  z-index: 1;\n  display: grid;\n  place-items: center;\n  text-align: center;\n}\n\n.admin-donut-chart__center strong {\n  font-size: 1.9rem;\n  letter-spacing: -0.04em;\n}\n\n.admin-content-list {\n  display: grid;\n  gap: 14px;\n  margin: 0;\n  padding: 0;\n  list-style: none;\n}\n\n.admin-content-list li {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 16px;\n}\n\n.admin-content-list__label {\n  display: inline-flex;\n  align-items: center;\n  gap: 10px;\n}\n\n.admin-comment-list {\n  display: grid;\n  gap: 18px;\n  margin: 0;\n  padding: 0;\n  list-style: none;\n}\n\n.admin-comment-item {\n  display: grid;\n  grid-template-columns: auto minmax(0, 1fr) auto;\n  gap: 14px;\n  align-items: start;\n  padding-bottom: 16px;\n  border-bottom: 1px solid rgba(79, 132, 40, 0.12);\n}\n\n.admin-comment-item:last-child {\n  padding-bottom: 0;\n  border-bottom: 0;\n}\n\n.admin-comment-item__avatar,\n.admin-quick-card__icon {\n  display: grid;\n  place-items: center;\n  width: 46px;\n  height: 46px;\n  border-radius: 18px;\n  color: var(--color-primary-500);\n  background: rgba(193, 217, 92, 0.54);\n  font-weight: 700;\n}\n\n.admin-comment-item__meta {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 8px;\n  margin-bottom: 6px;\n}\n\n.admin-comment-item__meta span {\n  color: var(--color-text-muted);\n  font-size: 0.92rem;\n}\n\n.admin-comment-item__action {\n  align-self: center;\n  padding: 10px 16px;\n  border: 1px solid rgba(79, 132, 40, 0.12);\n  border-radius: 999px;\n  color: var(--color-primary-500);\n  background: rgba(234, 245, 157, 0.2);\n  font-weight: 600;\n}\n\n.admin-timeline {\n  display: grid;\n  gap: 18px;\n  margin: 0;\n  padding: 0 0 0 10px;\n  list-style: none;\n}\n\n.admin-timeline li {\n  position: relative;\n  padding-left: 24px;\n  color: var(--color-text-muted);\n  line-height: 1.7;\n}\n\n.admin-timeline li::before {\n  content: '';\n  position: absolute;\n  top: 10px;\n  left: 0;\n  width: 11px;\n  height: 11px;\n  border-radius: 50%;\n  background: linear-gradient(135deg, var(--color-primary-200), var(--color-primary-400));\n  box-shadow: 0 0 0 6px rgba(234, 245, 157, 0.42);\n}\n\n.admin-timeline li::after {\n  content: '';\n  position: absolute;\n  top: 22px;\n  left: 5px;\n  width: 1px;\n  height: calc(100% + 8px);\n  background: rgba(79, 132, 40, 0.18);\n}\n\n.admin-timeline li:last-child::after {\n  display: none;\n}\n\n.admin-dashboard__quick {\n  display: grid;\n  gap: 18px;\n}\n\n.admin-quick-grid {\n  display: grid;\n  grid-template-columns: repeat(4, minmax(0, 1fr));\n  gap: 18px;\n}\n\n.admin-quick-card {\n  display: grid;\n  grid-template-columns: auto minmax(0, 1fr);\n  gap: 16px;\n  min-width: 0;\n  padding: 22px;\n  border-radius: 24px;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  background: #fff;\n  box-shadow: 0 14px 30px rgba(79, 132, 40, 0.08);\n  transition: transform 0.2s ease, box-shadow 0.2s ease;\n}\n\n.admin-quick-card:hover {\n  transform: translateY(-2px);\n  box-shadow: 0 18px 36px rgba(79, 132, 40, 0.12);\n}\n\n.admin-quick-card strong {\n  display: block;\n  margin-bottom: 6px;\n  font-size: 1.1rem;\n}\n\n@media (max-width: 1380px) {\n  .admin-stats-grid {\n    grid-template-columns: repeat(3, minmax(0, 1fr));\n  }\n\n  .admin-quick-grid {\n    grid-template-columns: repeat(2, minmax(0, 1fr));\n  }\n}\n\n@media (max-width: 1200px) {\n  .admin-shell {\n    grid-template-columns: 1fr;\n  }\n\n  .admin-sidebar {\n    position: static;\n    min-height: auto;\n  }\n\n  .admin-dashboard__insights,\n  .admin-dashboard__secondary,\n  .admin-content-share {\n    grid-template-columns: 1fr;\n  }\n\n  .admin-content-share {\n    justify-items: center;\n  }\n}\n\n@media (max-width: 920px) {\n  .admin-topbar__search {\n    min-width: 100%;\n  }\n\n  .admin-stats-grid,\n  .admin-quick-grid {\n    grid-template-columns: repeat(2, minmax(0, 1fr));\n  }\n}\n\n@media (max-width: 720px) {\n  .admin-main,\n  .admin-topbar {\n    padding: 18px;\n  }\n\n  .admin-sidebar {\n    padding: 20px 14px 18px;\n  }\n\n  .admin-stats-grid,\n  .admin-quick-grid {\n    grid-template-columns: 1fr;\n  }\n\n  .admin-panel,\n  .admin-metric-card,\n  .admin-quick-card {\n    padding: 20px;\n  }\n\n  .admin-comment-item {\n    grid-template-columns: auto minmax(0, 1fr);\n  }\n\n  .admin-comment-item__action {\n    grid-column: 2;\n    justify-self: start;\n  }\n\n  .admin-weekly-chart {\n    padding: 14px;\n    gap: 8px;\n  }\n}\n"],["STYLE",{},"/* ============================================================\n   Admin — Post Approval Page (admin-posts.css)\n   Đồng bộ palette E-XANH & admin.css\n   ============================================================ */\n\n/* ---- Hero ---- */\n.ap-page {\n  gap: 16px;\n}\n\n.ap-page__hero {\n  display: grid;\n  gap: 8px;\n}\n\n.ap-page__hero-copy h2 {\n  margin: 0 0 4px;\n  font-size: clamp(1.6rem, 2.5vw, 2.2rem);\n  letter-spacing: -0.02em;\n}\n\n.ap-page__hero-copy p {\n  margin: 0;\n  color: var(--color-text-muted);\n  line-height: 1.5;\n}\n\n/* ---- Stats Cards ---- */\n.ap-stats {\n  display: grid;\n  grid-template-columns: repeat(4, minmax(0, 1fr));\n  gap: 18px;\n}\n\n.ap-stats__card {\n  display: flex;\n  align-items: center;\n  gap: 16px;\n  padding: 22px 20px;\n  border-radius: 24px;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  background: #fff;\n  box-shadow: 0 14px 30px rgba(79, 132, 40, 0.08);\n  min-width: 0;\n  transition: transform 0.2s ease, box-shadow 0.2s ease;\n}\n\n.ap-stats__card:hover {\n  transform: translateY(-2px);\n  box-shadow: 0 18px 36px rgba(79, 132, 40, 0.12);\n}\n\n.ap-stats__icon {\n  display: inline-grid;\n  place-items: center;\n  width: 52px;\n  height: 52px;\n  border-radius: 18px;\n  flex-shrink: 0;\n}\n\n.ap-stats__icon svg {\n  width: 24px;\n  height: 24px;\n  stroke: currentColor;\n  fill: none;\n  stroke-width: 1.9;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n}\n\n.ap-stats__info p {\n  margin: 0 0 4px;\n  color: var(--color-text-muted);\n  font-size: 0.92rem;\n}\n\n.ap-stats__info strong {\n  font-size: clamp(1.6rem, 2.4vw, 2.4rem);\n  line-height: 1;\n  letter-spacing: -0.04em;\n}\n\n/* Accent variants */\n.ap-stats__card--warning .ap-stats__icon {\n  color: #8a6e1f;\n  background: rgba(234, 215, 120, 0.38);\n}\n\n.ap-stats__card--success .ap-stats__icon {\n  color: #336a29;\n  background: rgba(128, 177, 85, 0.22);\n}\n\n.ap-stats__card--muted .ap-stats__icon {\n  color: #7a6c5c;\n  background: rgba(180, 170, 155, 0.22);\n}\n\n.ap-stats__card--highlight .ap-stats__icon {\n  color: #4f8428;\n  background: rgba(193, 217, 92, 0.34);\n}\n\n/* ---- Filter ---- */\n.ap-filter {\n  display: grid;\n  gap: 14px;\n  padding: 22px 24px;\n  border-radius: 24px;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  background: rgba(255, 255, 255, 0.92);\n  box-shadow: 0 14px 30px rgba(79, 132, 40, 0.06);\n}\n\n.ap-filter__row {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 12px;\n  align-items: center;\n}\n\n.ap-filter__search {\n  position: relative;\n  flex: 1 1 260px;\n  min-width: 200px;\n}\n\n.ap-filter__search svg {\n  position: absolute;\n  top: 50%;\n  left: 14px;\n  width: 18px;\n  height: 18px;\n  transform: translateY(-50%);\n  stroke: var(--color-primary-400);\n  fill: none;\n  stroke-width: 1.9;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n  pointer-events: none;\n}\n\n.ap-filter__search input {\n  width: 100%;\n  padding: 13px 16px 13px 44px;\n  border: 1px solid var(--color-border);\n  border-radius: 14px;\n  background: rgba(234, 245, 157, 0.14);\n  color: var(--color-text);\n  font-size: 0.95rem;\n  outline: none;\n  transition: border-color 0.2s ease, box-shadow 0.2s ease;\n}\n\n.ap-filter__search input:focus {\n  border-color: var(--color-primary-200);\n  box-shadow: 0 0 0 4px rgba(193, 217, 92, 0.22);\n}\n\n.ap-filter__search input::placeholder {\n  color: rgba(23, 55, 21, 0.5);\n}\n\n.ap-filter__select {\n  flex: 0 1 auto;\n  min-width: 160px;\n  padding: 13px 16px;\n  border: 1px solid var(--color-border);\n  border-radius: 14px;\n  background: rgba(234, 245, 157, 0.14);\n  color: var(--color-text);\n  font: inherit;\n  font-size: 0.95rem;\n  cursor: pointer;\n  outline: none;\n  transition: border-color 0.2s ease, box-shadow 0.2s ease;\n  appearance: auto;\n}\n\n.ap-filter__select:focus {\n  border-color: var(--color-primary-200);\n  box-shadow: 0 0 0 4px rgba(193, 217, 92, 0.22);\n}\n\n.ap-filter__actions {\n  display: flex;\n  gap: 10px;\n}\n\n/* ---- Bulk Action ---- */\n.ap-bulk {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 16px;\n  padding: 16px 24px;\n  border-radius: 18px;\n  background: linear-gradient(135deg, rgba(193, 217, 92, 0.28), rgba(128, 177, 85, 0.14));\n  border: 1px solid rgba(79, 132, 40, 0.12);\n  animation: ap-slide-in 0.25s ease;\n}\n\n.ap-bulk__count {\n  color: var(--color-text);\n  font-size: 0.95rem;\n}\n\n.ap-bulk__count strong {\n  color: var(--color-primary-400);\n}\n\n.ap-bulk__actions {\n  display: flex;\n  gap: 10px;\n}\n\n/* ---- Workspace (list + preview) ---- */\n.ap-page__workspace {\n  display: grid;\n  grid-template-columns: minmax(0, 1.1fr) minmax(340px, 0.9fr);\n  gap: 22px;\n  min-height: 300px; /* Reduced from 500px so it doesn't leave huge white space */\n}\n\n/* ---- Post List ---- */\n.ap-list {\n  display: grid;\n  gap: 0;\n  align-content: start;\n  border-radius: 24px;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  background: rgba(255, 255, 255, 0.92);\n  box-shadow: 0 16px 32px rgba(79, 132, 40, 0.08);\n  overflow: hidden;\n  min-width: 0;\n}\n\n.ap-list__header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 12px;\n  padding: 16px 20px;\n  border-bottom: 1px solid rgba(79, 132, 40, 0.08);\n  background: rgba(234, 245, 157, 0.12);\n}\n\n.ap-list__check-all {\n  display: inline-flex;\n  align-items: center;\n  gap: 8px;\n  font-weight: 600;\n  font-size: 0.92rem;\n  cursor: pointer;\n}\n\n.ap-list__check-all input {\n  accent-color: var(--color-primary-400);\n  width: 16px;\n  height: 16px;\n  cursor: pointer;\n}\n\n.ap-list__total {\n  color: var(--color-text-muted);\n  font-size: 0.88rem;\n}\n\n.ap-list__items {\n  margin: 0;\n  padding: 0;\n  list-style: none;\n  max-height: 640px;\n  overflow-y: auto;\n}\n\n.ap-list__empty {\n  padding: 40px 20px;\n  text-align: center;\n  color: var(--color-text-muted);\n}\n\n.ap-list__item {\n  display: grid;\n  grid-template-columns: auto 68px minmax(0, 1fr) auto;\n  align-items: center;\n  gap: 14px;\n  padding: 16px 20px;\n  border-bottom: 1px solid rgba(79, 132, 40, 0.06);\n  cursor: default;\n  transition: background-color 0.15s ease;\n}\n\n.ap-list__item:last-child {\n  border-bottom: 0;\n}\n\n.ap-list__item:hover {\n  background: rgba(234, 245, 157, 0.14);\n}\n\n.ap-list__item.is-active {\n  background: rgba(193, 217, 92, 0.16);\n  box-shadow: inset 3px 0 0 var(--color-primary-300);\n}\n\n.ap-list__checkbox {\n  accent-color: var(--color-primary-400);\n  width: 16px;\n  height: 16px;\n  cursor: pointer;\n}\n\n.ap-list__thumb {\n  width: 68px;\n  height: 48px;\n  object-fit: cover;\n  border-radius: 10px;\n  flex-shrink: 0;\n}\n\n.ap-list__content {\n  min-width: 0;\n}\n\n.ap-list__title {\n  margin: 0 0 4px;\n  font-size: 0.98rem;\n  font-weight: 600;\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n}\n\n.ap-list__meta {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 4px;\n  color: var(--color-text-muted);\n  font-size: 0.84rem;\n  margin-bottom: 6px;\n}\n\n.ap-list__separator {\n  opacity: 0.5;\n}\n\n.ap-list__footer {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  flex-wrap: wrap;\n}\n\n.ap-list__engagement {\n  display: inline-flex;\n  gap: 10px;\n  color: var(--color-text-muted);\n  font-size: 0.82rem;\n}\n\n.ap-list__view-btn {\n  padding: 8px 16px;\n  border: 1px solid rgba(79, 132, 40, 0.14);\n  border-radius: 999px;\n  color: var(--color-primary-500);\n  background: rgba(234, 245, 157, 0.22);\n  font-weight: 600;\n  font-size: 0.88rem;\n  cursor: pointer;\n  white-space: nowrap;\n  transition: background-color 0.2s ease, transform 0.15s ease;\n}\n\n.ap-list__view-btn:hover {\n  background: rgba(193, 217, 92, 0.38);\n  transform: translateY(-1px);\n}\n\n/* ---- Status Badges ---- */\n.ap-badge {\n  display: inline-flex;\n  align-items: center;\n  padding: 4px 12px;\n  border-radius: 999px;\n  font-size: 0.8rem;\n  font-weight: 600;\n  white-space: nowrap;\n}\n\n.ap-badge.is-pending {\n  color: #6b5a10;\n  background: rgba(234, 215, 120, 0.42);\n}\n\n.ap-badge.is-approved {\n  color: #2a5e1f;\n  background: rgba(128, 177, 85, 0.26);\n}\n\n.ap-badge.is-rejected {\n  color: #7a5c42;\n  background: rgba(200, 170, 140, 0.28);\n}\n\n.ap-badge.is-hidden {\n  color: #5a5a5a;\n  background: rgba(160, 160, 160, 0.22);\n}\n\n/* ---- Preview Panel ---- */\n.ap-preview {\n  position: sticky;\n  top: 100px;\n  align-self: start;\n  border-radius: 24px;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  background: rgba(255, 255, 255, 0.92);\n  box-shadow: 0 16px 32px rgba(79, 132, 40, 0.08);\n  overflow: hidden;\n  min-width: 0;\n}\n\n.ap-preview__scroll {\n  max-height: calc(100vh - 140px);\n  overflow-y: auto;\n}\n\n.ap-preview--empty {\n  display: grid;\n  place-items: center;\n  min-height: 400px;\n}\n\n.ap-preview__placeholder {\n  text-align: center;\n  color: var(--color-text-muted);\n  padding: 40px 20px;\n}\n\n.ap-preview__placeholder svg {\n  width: 48px;\n  height: 48px;\n  stroke: var(--color-primary-200);\n  fill: none;\n  stroke-width: 1.5;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n  margin-bottom: 14px;\n  opacity: 0.6;\n}\n\n.ap-preview__placeholder p {\n  margin: 0 0 6px;\n  font-weight: 600;\n  font-size: 1.05rem;\n  color: var(--color-text);\n}\n\n.ap-preview__placeholder span {\n  font-size: 0.9rem;\n}\n\n.ap-preview__cover {\n  width: 100%;\n  height: 200px;\n  object-fit: cover;\n  display: block;\n}\n\n.ap-preview__body {\n  padding: 22px;\n  display: grid;\n  gap: 16px;\n}\n\n.ap-preview__category {\n  display: inline-flex;\n  align-items: center;\n  width: fit-content;\n  padding: 5px 14px;\n  border-radius: 999px;\n  background: rgba(193, 217, 92, 0.3);\n  color: var(--color-primary-500);\n  font-size: 0.82rem;\n  font-weight: 600;\n}\n\n.ap-preview__title {\n  margin: 0;\n  font-size: 1.3rem;\n  line-height: 1.3;\n  letter-spacing: -0.02em;\n}\n\n.ap-preview__meta {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 16px;\n  font-size: 0.9rem;\n  color: var(--color-text-muted);\n}\n\n.ap-preview__meta strong {\n  color: var(--color-text);\n}\n\n.ap-preview__section h4 {\n  margin: 0 0 8px;\n  font-size: 0.95rem;\n  color: var(--color-primary-500);\n}\n\n.ap-preview__section p {\n  margin: 0;\n  color: var(--color-text-muted);\n  line-height: 1.7;\n  font-size: 0.92rem;\n}\n\n.ap-preview__content-block {\n  padding: 16px;\n  border-radius: 14px;\n  background: rgba(234, 245, 157, 0.14);\n  border: 1px solid rgba(79, 132, 40, 0.06);\n  color: var(--color-text-muted);\n  line-height: 1.75;\n  font-size: 0.9rem;\n  white-space: pre-line;\n}\n\n.ap-preview__status-row {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  font-size: 0.92rem;\n}\n\n.ap-preview__note {\n  width: 100%;\n  padding: 14px;\n  border: 1px solid var(--color-border);\n  border-radius: 14px;\n  background: rgba(234, 245, 157, 0.1);\n  color: var(--color-text);\n  font: inherit;\n  font-size: 0.92rem;\n  resize: vertical;\n  outline: none;\n  transition: border-color 0.2s ease, box-shadow 0.2s ease;\n}\n\n.ap-preview__note:focus {\n  border-color: var(--color-primary-200);\n  box-shadow: 0 0 0 4px rgba(193, 217, 92, 0.22);\n}\n\n.ap-preview__actions {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 10px;\n}\n\n.ap-preview__actions .btn {\n  font-size: 0.9rem;\n  padding: 10px 18px;\n}\n\n/* ---- Toast ---- */\n.ap-toast {\n  position: fixed;\n  bottom: 32px;\n  left: 50%;\n  transform: translateX(-50%);\n  display: inline-flex;\n  align-items: center;\n  gap: 10px;\n  padding: 14px 24px;\n  border-radius: 999px;\n  background: linear-gradient(135deg, #336a29, #4f8428);\n  color: #fff;\n  font-weight: 600;\n  font-size: 0.95rem;\n  box-shadow: 0 16px 40px rgba(51, 106, 41, 0.3);\n  z-index: 100;\n  animation: ap-toast-in 0.3s ease;\n}\n\n.ap-toast svg {\n  width: 20px;\n  height: 20px;\n  stroke: currentColor;\n  fill: none;\n  stroke-width: 2;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n  flex-shrink: 0;\n}\n\n@keyframes ap-toast-in {\n  from {\n    opacity: 0;\n    transform: translateX(-50%) translateY(12px);\n  }\n  to {\n    opacity: 1;\n    transform: translateX(-50%) translateY(0);\n  }\n}\n\n@keyframes ap-slide-in {\n  from {\n    opacity: 0;\n    transform: translateY(-6px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n/* ---- Responsive ---- */\n@media (max-width: 1380px) {\n  .ap-stats {\n    grid-template-columns: repeat(2, minmax(0, 1fr));\n  }\n}\n\n@media (max-width: 1100px) {\n  .ap-page__workspace {\n    grid-template-columns: 1fr;\n  }\n\n  .ap-preview {\n    position: static;\n  }\n\n  .ap-preview__scroll {\n    max-height: none;\n  }\n}\n\n@media (max-width: 720px) {\n  .ap-stats {\n    grid-template-columns: 1fr;\n  }\n\n  .ap-filter__row {\n    flex-direction: column;\n  }\n\n  .ap-filter__search,\n  .ap-filter__select {\n    width: 100%;\n    min-width: 0;\n  }\n\n  .ap-bulk {\n    flex-direction: column;\n    text-align: center;\n  }\n\n  .ap-list__item {\n    grid-template-columns: auto minmax(0, 1fr);\n    gap: 10px;\n  }\n\n  .ap-list__thumb {\n    display: none;\n  }\n\n  .ap-list__view-btn {\n    grid-column: 1 / -1;\n    justify-self: start;\n  }\n\n  .ap-preview__actions {\n    flex-direction: column;\n  }\n\n  .ap-preview__actions .btn {\n    width: 100%;\n  }\n}\n"],["STYLE",{},"/* ============================================================\n   Admin — Comment Management Page (admin-comments.css)\n   Đồng bộ palette E-XANH & admin.css / admin-posts.css\n   ============================================================ */\n\n/* ---- Page & Hero ---- */\n.ac-page {\n  gap: 24px;\n}\n\n.ac-page__hero {\n  display: grid;\n  gap: 14px;\n}\n\n.ac-page__hero-copy h2 {\n  margin: 0 0 10px;\n  font-size: clamp(2rem, 3vw, 2.8rem);\n  letter-spacing: -0.04em;\n}\n\n.ac-page__hero-copy p {\n  margin: 0;\n  color: var(--color-text-muted);\n  line-height: 1.7;\n}\n\n/* ---- Stats Cards ---- */\n.ac-stats {\n  display: grid;\n  grid-template-columns: repeat(4, minmax(0, 1fr));\n  gap: 18px;\n}\n\n.ac-stats__card {\n  display: flex;\n  align-items: center;\n  gap: 16px;\n  padding: 22px 20px;\n  border-radius: 24px;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  background: #fff;\n  box-shadow: 0 14px 30px rgba(79, 132, 40, 0.08);\n  min-width: 0;\n  transition: transform 0.2s ease, box-shadow 0.2s ease;\n}\n\n.ac-stats__card:hover {\n  transform: translateY(-2px);\n  box-shadow: 0 18px 36px rgba(79, 132, 40, 0.12);\n}\n\n.ac-stats__icon {\n  display: inline-grid;\n  place-items: center;\n  width: 52px;\n  height: 52px;\n  border-radius: 18px;\n  flex-shrink: 0;\n}\n\n.ac-stats__icon svg {\n  width: 24px;\n  height: 24px;\n  stroke: currentColor;\n  fill: none;\n  stroke-width: 1.9;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n}\n\n.ac-stats__info p {\n  margin: 0 0 4px;\n  color: var(--color-text-muted);\n  font-size: 0.92rem;\n}\n\n.ac-stats__info strong {\n  font-size: clamp(1.6rem, 2.4vw, 2.4rem);\n  line-height: 1;\n  letter-spacing: -0.04em;\n}\n\n/* Accent variants */\n.ac-stats__card--success .ac-stats__icon {\n  color: #336a29;\n  background: rgba(128, 177, 85, 0.22);\n}\n\n.ac-stats__card--warning .ac-stats__icon {\n  color: #8a6e1f;\n  background: rgba(234, 215, 120, 0.38);\n}\n\n.ac-stats__card--muted .ac-stats__icon {\n  color: #7a6c5c;\n  background: rgba(180, 170, 155, 0.22);\n}\n\n.ac-stats__card--highlight .ac-stats__icon {\n  color: #8a5e2a;\n  background: rgba(224, 185, 130, 0.26);\n}\n\n/* ---- Filter ---- */\n.ac-filter {\n  display: grid;\n  gap: 14px;\n  padding: 22px 24px;\n  border-radius: 24px;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  background: rgba(255, 255, 255, 0.92);\n  box-shadow: 0 14px 30px rgba(79, 132, 40, 0.06);\n}\n\n.ac-filter__row {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 12px;\n  align-items: center;\n}\n\n.ac-filter__search {\n  position: relative;\n  flex: 1 1 260px;\n  min-width: 200px;\n}\n\n.ac-filter__search svg {\n  position: absolute;\n  top: 50%;\n  left: 14px;\n  width: 18px;\n  height: 18px;\n  transform: translateY(-50%);\n  stroke: var(--color-primary-400);\n  fill: none;\n  stroke-width: 1.9;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n  pointer-events: none;\n}\n\n.ac-filter__search input {\n  width: 100%;\n  padding: 13px 16px 13px 44px;\n  border: 1px solid var(--color-border);\n  border-radius: 14px;\n  background: rgba(234, 245, 157, 0.14);\n  color: var(--color-text);\n  font-size: 0.95rem;\n  outline: none;\n  transition: border-color 0.2s ease, box-shadow 0.2s ease;\n}\n\n.ac-filter__search input:focus {\n  border-color: var(--color-primary-200);\n  box-shadow: 0 0 0 4px rgba(193, 217, 92, 0.22);\n}\n\n.ac-filter__search input::placeholder {\n  color: rgba(23, 55, 21, 0.5);\n}\n\n.ac-filter__select {\n  flex: 0 1 auto;\n  min-width: 160px;\n  padding: 13px 16px;\n  border: 1px solid var(--color-border);\n  border-radius: 14px;\n  background: rgba(234, 245, 157, 0.14);\n  color: var(--color-text);\n  font: inherit;\n  font-size: 0.95rem;\n  cursor: pointer;\n  outline: none;\n  transition: border-color 0.2s ease, box-shadow 0.2s ease;\n  appearance: auto;\n}\n\n.ac-filter__select:focus {\n  border-color: var(--color-primary-200);\n  box-shadow: 0 0 0 4px rgba(193, 217, 92, 0.22);\n}\n\n.ac-filter__actions {\n  display: flex;\n  gap: 10px;\n}\n\n/* ---- Bulk Action ---- */\n.ac-bulk {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 16px;\n  padding: 16px 24px;\n  border-radius: 18px;\n  background: linear-gradient(135deg, rgba(193, 217, 92, 0.28), rgba(128, 177, 85, 0.14));\n  border: 1px solid rgba(79, 132, 40, 0.12);\n  animation: ac-slide-in 0.25s ease;\n}\n\n.ac-bulk__count {\n  color: var(--color-text);\n  font-size: 0.95rem;\n}\n\n.ac-bulk__count strong {\n  color: var(--color-primary-400);\n}\n\n.ac-bulk__actions {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 10px;\n}\n\n/* ---- Comment List ---- */\n.ac-list {\n  display: grid;\n  gap: 0;\n  align-content: start;\n  border-radius: 24px;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  background: rgba(255, 255, 255, 0.92);\n  box-shadow: 0 16px 32px rgba(79, 132, 40, 0.08);\n  overflow: hidden;\n  min-width: 0;\n}\n\n.ac-list__header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 12px;\n  padding: 16px 20px;\n  border-bottom: 1px solid rgba(79, 132, 40, 0.08);\n  background: rgba(234, 245, 157, 0.12);\n}\n\n.ac-list__check-all {\n  display: inline-flex;\n  align-items: center;\n  gap: 8px;\n  font-weight: 600;\n  font-size: 0.92rem;\n  cursor: pointer;\n}\n\n.ac-list__check-all input {\n  accent-color: var(--color-primary-400);\n  width: 16px;\n  height: 16px;\n  cursor: pointer;\n}\n\n.ac-list__total {\n  color: var(--color-text-muted);\n  font-size: 0.88rem;\n}\n\n.ac-list__items {\n  display: grid;\n  gap: 0;\n}\n\n.ac-list__empty {\n  padding: 40px 20px;\n  text-align: center;\n  color: var(--color-text-muted);\n}\n\n/* ---- Comment Card ---- */\n.ac-list__card {\n  display: grid;\n  gap: 10px;\n  padding: 18px 20px;\n  border-bottom: 1px solid rgba(79, 132, 40, 0.06);\n  transition: background-color 0.15s ease;\n}\n\n.ac-list__card:last-child {\n  border-bottom: 0;\n}\n\n.ac-list__card:hover {\n  background: rgba(234, 245, 157, 0.1);\n}\n\n.ac-list__card-top {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  flex-wrap: wrap;\n  min-width: 0;\n}\n\n.ac-list__checkbox {\n  accent-color: var(--color-primary-400);\n  width: 16px;\n  height: 16px;\n  cursor: pointer;\n  flex-shrink: 0;\n}\n\n.ac-list__avatar {\n  display: inline-grid;\n  place-items: center;\n  width: 40px;\n  height: 40px;\n  border-radius: 14px;\n  background: rgba(193, 217, 92, 0.5);\n  color: var(--color-primary-500);\n  font-weight: 700;\n  font-size: 0.95rem;\n  flex-shrink: 0;\n}\n\n.ac-list__user {\n  display: flex;\n  flex-direction: column;\n  gap: 2px;\n  min-width: 0;\n}\n\n.ac-list__user strong {\n  font-size: 0.95rem;\n}\n\n.ac-list__email {\n  color: var(--color-text-muted);\n  font-size: 0.82rem;\n}\n\n.ac-list__time {\n  margin-left: auto;\n  color: var(--color-text-muted);\n  font-size: 0.82rem;\n  white-space: nowrap;\n  flex-shrink: 0;\n}\n\n.ac-list__content {\n  margin: 0;\n  color: var(--color-text);\n  font-size: 0.92rem;\n  line-height: 1.6;\n  display: -webkit-box;\n  -webkit-line-clamp: 2;\n  -webkit-box-orient: vertical;\n  overflow: hidden;\n  padding-left: 68px;\n}\n\n.ac-list__card-bottom {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  flex-wrap: wrap;\n  padding-left: 68px;\n}\n\n.ac-list__post {\n  display: inline-flex;\n  align-items: center;\n  gap: 6px;\n  color: var(--color-text-muted);\n  font-size: 0.84rem;\n  min-width: 0;\n}\n\n.ac-list__post svg {\n  width: 14px;\n  height: 14px;\n  stroke: var(--color-primary-300);\n  fill: none;\n  stroke-width: 1.8;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n  flex-shrink: 0;\n}\n\n.ac-list__reports {\n  display: inline-flex;\n  align-items: center;\n  padding: 3px 10px;\n  border-radius: 999px;\n  background: rgba(214, 160, 90, 0.18);\n  color: #8a5e2a;\n  font-size: 0.78rem;\n  font-weight: 600;\n}\n\n.ac-list__actions {\n  display: flex;\n  gap: 8px;\n  margin-left: auto;\n  flex-shrink: 0;\n}\n\n.ac-list__action-btn {\n  padding: 6px 14px;\n  border: 1px solid rgba(79, 132, 40, 0.14);\n  border-radius: 999px;\n  color: var(--color-primary-500);\n  background: rgba(234, 245, 157, 0.22);\n  font-weight: 600;\n  font-size: 0.82rem;\n  cursor: pointer;\n  white-space: nowrap;\n  transition: background-color 0.2s ease, transform 0.15s ease;\n}\n\n.ac-list__action-btn:hover {\n  background: rgba(193, 217, 92, 0.38);\n  transform: translateY(-1px);\n}\n\n.ac-list__action-btn--subtle {\n  background: transparent;\n  border-color: rgba(79, 132, 40, 0.1);\n  color: var(--color-text-muted);\n}\n\n.ac-list__action-btn--subtle:hover {\n  background: rgba(234, 245, 157, 0.2);\n  color: var(--color-primary-500);\n}\n\n/* ---- Status Badges ---- */\n.ac-badge {\n  display: inline-flex;\n  align-items: center;\n  padding: 4px 12px;\n  border-radius: 999px;\n  font-size: 0.8rem;\n  font-weight: 600;\n  white-space: nowrap;\n  flex-shrink: 0;\n}\n\n.ac-badge.is-visible {\n  color: #2a5e1f;\n  background: rgba(128, 177, 85, 0.26);\n}\n\n.ac-badge.is-hidden {\n  color: #5a5a5a;\n  background: rgba(160, 160, 160, 0.22);\n}\n\n.ac-badge.is-reported {\n  color: #8a5e2a;\n  background: rgba(214, 160, 90, 0.24);\n}\n\n.ac-badge.is-spam {\n  color: #8a6e3a;\n  background: rgba(214, 185, 130, 0.28);\n}\n\n/* ---- Drawer ---- */\n.ac-drawer-overlay {\n  position: fixed;\n  inset: 0;\n  z-index: 50;\n  background: rgba(23, 55, 21, 0.28);\n  animation: ac-fade-in 0.25s ease;\n}\n\n.ac-drawer {\n  position: fixed;\n  top: 0;\n  right: 0;\n  z-index: 51;\n  width: min(460px, 92vw);\n  height: 100vh;\n  display: flex;\n  flex-direction: column;\n  background: #fff;\n  box-shadow: -16px 0 48px rgba(23, 55, 21, 0.14);\n  animation: ac-drawer-in 0.3s ease;\n}\n\n.ac-drawer__header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 12px;\n  padding: 22px 24px;\n  border-bottom: 1px solid rgba(79, 132, 40, 0.08);\n  flex-shrink: 0;\n}\n\n.ac-drawer__header h3 {\n  margin: 0;\n  font-size: 1.25rem;\n  letter-spacing: -0.02em;\n}\n\n.ac-drawer__close {\n  display: inline-grid;\n  place-items: center;\n  width: 36px;\n  height: 36px;\n  border: 1px solid rgba(79, 132, 40, 0.12);\n  border-radius: 12px;\n  background: rgba(234, 245, 157, 0.14);\n  color: var(--color-text);\n  cursor: pointer;\n  transition: background-color 0.15s ease;\n}\n\n.ac-drawer__close:hover {\n  background: rgba(193, 217, 92, 0.3);\n}\n\n.ac-drawer__close svg {\n  width: 18px;\n  height: 18px;\n  stroke: currentColor;\n  fill: none;\n  stroke-width: 2;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n}\n\n.ac-drawer__body {\n  flex: 1 1 auto;\n  overflow-y: auto;\n  padding: 24px;\n  display: grid;\n  gap: 18px;\n  align-content: start;\n}\n\n.ac-drawer__user {\n  display: flex;\n  align-items: center;\n  gap: 14px;\n}\n\n.ac-drawer__avatar {\n  display: inline-grid;\n  place-items: center;\n  width: 48px;\n  height: 48px;\n  border-radius: 16px;\n  background: rgba(193, 217, 92, 0.5);\n  color: var(--color-primary-500);\n  font-weight: 700;\n  font-size: 1.1rem;\n  flex-shrink: 0;\n}\n\n.ac-drawer__user strong {\n  display: block;\n  font-size: 1.05rem;\n  margin-bottom: 2px;\n}\n\n.ac-drawer__email {\n  display: block;\n  color: var(--color-text-muted);\n  font-size: 0.88rem;\n}\n\n.ac-drawer__field {\n  display: grid;\n  gap: 6px;\n}\n\n.ac-drawer__label {\n  font-weight: 600;\n  font-size: 0.88rem;\n  color: var(--color-primary-500);\n}\n\n.ac-drawer__content-block {\n  padding: 14px;\n  border-radius: 14px;\n  background: rgba(234, 245, 157, 0.14);\n  border: 1px solid rgba(79, 132, 40, 0.06);\n  color: var(--color-text);\n  line-height: 1.7;\n  font-size: 0.92rem;\n}\n\n.ac-drawer__post-link {\n  color: var(--color-primary-400);\n  font-weight: 500;\n}\n\n.ac-drawer__reports {\n  display: inline-flex;\n  align-items: center;\n  padding: 3px 10px;\n  border-radius: 999px;\n  background: rgba(214, 160, 90, 0.18);\n  color: #8a5e2a;\n  font-size: 0.85rem;\n  font-weight: 600;\n  width: fit-content;\n}\n\n.ac-drawer__note {\n  width: 100%;\n  padding: 14px;\n  border: 1px solid var(--color-border);\n  border-radius: 14px;\n  background: rgba(234, 245, 157, 0.1);\n  color: var(--color-text);\n  font: inherit;\n  font-size: 0.92rem;\n  resize: vertical;\n  outline: none;\n  transition: border-color 0.2s ease, box-shadow 0.2s ease;\n}\n\n.ac-drawer__note:focus {\n  border-color: var(--color-primary-200);\n  box-shadow: 0 0 0 4px rgba(193, 217, 92, 0.22);\n}\n\n.ac-drawer__footer {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 10px;\n  padding: 20px 24px;\n  border-top: 1px solid rgba(79, 132, 40, 0.08);\n  flex-shrink: 0;\n}\n\n.ac-drawer__footer .btn {\n  font-size: 0.88rem;\n  padding: 10px 16px;\n}\n\n.ac-drawer__delete-btn {\n  color: #8a5030;\n  border-color: rgba(180, 100, 60, 0.2);\n}\n\n.ac-drawer__delete-btn:hover {\n  background: rgba(220, 160, 120, 0.12);\n}\n\n/* ---- Toast ---- */\n.ac-toast {\n  position: fixed;\n  bottom: 32px;\n  left: 50%;\n  transform: translateX(-50%);\n  display: inline-flex;\n  align-items: center;\n  gap: 10px;\n  padding: 14px 24px;\n  border-radius: 999px;\n  background: linear-gradient(135deg, #336a29, #4f8428);\n  color: #fff;\n  font-weight: 600;\n  font-size: 0.95rem;\n  box-shadow: 0 16px 40px rgba(51, 106, 41, 0.3);\n  z-index: 100;\n  animation: ac-toast-in 0.3s ease;\n}\n\n.ac-toast svg {\n  width: 20px;\n  height: 20px;\n  stroke: currentColor;\n  fill: none;\n  stroke-width: 2;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n  flex-shrink: 0;\n}\n\n/* ---- Animations ---- */\n@keyframes ac-toast-in {\n  from {\n    opacity: 0;\n    transform: translateX(-50%) translateY(12px);\n  }\n  to {\n    opacity: 1;\n    transform: translateX(-50%) translateY(0);\n  }\n}\n\n@keyframes ac-slide-in {\n  from {\n    opacity: 0;\n    transform: translateY(-6px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n@keyframes ac-fade-in {\n  from {\n    opacity: 0;\n  }\n  to {\n    opacity: 1;\n  }\n}\n\n@keyframes ac-drawer-in {\n  from {\n    opacity: 0;\n    transform: translateX(100%);\n  }\n  to {\n    opacity: 1;\n    transform: translateX(0);\n  }\n}\n\n/* ---- Responsive ---- */\n@media (max-width: 1380px) {\n  .ac-stats {\n    grid-template-columns: repeat(2, minmax(0, 1fr));\n  }\n}\n\n@media (max-width: 720px) {\n  .ac-stats {\n    grid-template-columns: 1fr;\n  }\n\n  .ac-filter__row {\n    flex-direction: column;\n  }\n\n  .ac-filter__search,\n  .ac-filter__select {\n    width: 100%;\n    min-width: 0;\n  }\n\n  .ac-bulk {\n    flex-direction: column;\n    text-align: center;\n  }\n\n  .ac-bulk__actions {\n    justify-content: center;\n  }\n\n  .ac-list__content {\n    padding-left: 0;\n  }\n\n  .ac-list__card-bottom {\n    padding-left: 0;\n  }\n\n  .ac-list__card-top {\n    gap: 8px;\n  }\n\n  .ac-list__time {\n    margin-left: 0;\n    width: 100%;\n    order: 5;\n  }\n\n  .ac-list__actions {\n    margin-left: 0;\n    width: 100%;\n  }\n\n  .ac-drawer__footer {\n    flex-direction: column;\n  }\n\n  .ac-drawer__footer .btn {\n    width: 100%;\n  }\n}\n"],["STYLE",{},"/* ============================================================\n   Admin — User Management Page (admin-users.css)\n   Đồng bộ palette E-XANH & admin.css / admin-comments.css\n   ============================================================ */\n\n/* ---- Page & Hero ---- */\n.au-page {\n  gap: 24px;\n}\n\n.au-page__hero {\n  display: grid;\n  gap: 14px;\n}\n\n.au-page__hero-copy h2 {\n  margin: 0 0 10px;\n  font-size: clamp(2rem, 3vw, 2.8rem);\n  letter-spacing: -0.04em;\n}\n\n.au-page__hero-copy p {\n  margin: 0;\n  color: var(--color-text-muted);\n  line-height: 1.7;\n}\n\n/* ---- Stats Cards ---- */\n.au-stats {\n  display: grid;\n  grid-template-columns: repeat(4, minmax(0, 1fr));\n  gap: 18px;\n}\n\n.au-stats__card {\n  display: flex;\n  align-items: center;\n  gap: 16px;\n  padding: 22px 20px;\n  border-radius: 24px;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  background: #fff;\n  box-shadow: 0 14px 30px rgba(79, 132, 40, 0.08);\n  min-width: 0;\n  transition: transform 0.2s ease, box-shadow 0.2s ease;\n}\n\n.au-stats__card:hover {\n  transform: translateY(-2px);\n  box-shadow: 0 18px 36px rgba(79, 132, 40, 0.12);\n}\n\n.au-stats__icon {\n  display: inline-grid;\n  place-items: center;\n  width: 52px;\n  height: 52px;\n  border-radius: 18px;\n  flex-shrink: 0;\n}\n\n.au-stats__icon svg {\n  width: 24px;\n  height: 24px;\n  stroke: currentColor;\n  fill: none;\n  stroke-width: 1.9;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n}\n\n.au-stats__info p {\n  margin: 0 0 4px;\n  color: var(--color-text-muted);\n  font-size: 0.92rem;\n}\n\n.au-stats__info strong {\n  font-size: clamp(1.6rem, 2.4vw, 2.4rem);\n  line-height: 1;\n  letter-spacing: -0.04em;\n}\n\n/* Accent variants */\n.au-stats__card--success .au-stats__icon {\n  color: #336a29;\n  background: rgba(128, 177, 85, 0.22);\n}\n\n.au-stats__card--highlight .au-stats__icon {\n  color: #4f8428;\n  background: rgba(193, 217, 92, 0.34);\n}\n\n.au-stats__card--warning .au-stats__icon {\n  color: #8a5e2a;\n  background: rgba(214, 160, 90, 0.24);\n}\n\n.au-stats__card--muted .au-stats__icon {\n  color: #7a6c5c;\n  background: rgba(180, 170, 155, 0.22);\n}\n\n/* ---- Filter ---- */\n.au-filter {\n  display: grid;\n  gap: 14px;\n  padding: 22px 24px;\n  border-radius: 24px;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  background: rgba(255, 255, 255, 0.92);\n  box-shadow: 0 14px 30px rgba(79, 132, 40, 0.06);\n}\n\n.au-filter__row {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 12px;\n  align-items: center;\n}\n\n.au-filter__search {\n  position: relative;\n  flex: 1 1 260px;\n  min-width: 200px;\n}\n\n.au-filter__search svg {\n  position: absolute;\n  top: 50%;\n  left: 14px;\n  width: 18px;\n  height: 18px;\n  transform: translateY(-50%);\n  stroke: var(--color-primary-400);\n  fill: none;\n  stroke-width: 1.9;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n  pointer-events: none;\n}\n\n.au-filter__search input {\n  width: 100%;\n  padding: 13px 16px 13px 44px;\n  border: 1px solid var(--color-border);\n  border-radius: 14px;\n  background: rgba(234, 245, 157, 0.14);\n  color: var(--color-text);\n  font-size: 0.95rem;\n  outline: none;\n  transition: border-color 0.2s ease, box-shadow 0.2s ease;\n}\n\n.au-filter__search input:focus {\n  border-color: var(--color-primary-200);\n  box-shadow: 0 0 0 4px rgba(193, 217, 92, 0.22);\n}\n\n.au-filter__search input::placeholder {\n  color: rgba(23, 55, 21, 0.5);\n}\n\n.au-filter__select {\n  flex: 0 1 auto;\n  min-width: 160px;\n  padding: 13px 16px;\n  border: 1px solid var(--color-border);\n  border-radius: 14px;\n  background: rgba(234, 245, 157, 0.14);\n  color: var(--color-text);\n  font: inherit;\n  font-size: 0.95rem;\n  cursor: pointer;\n  outline: none;\n  transition: border-color 0.2s ease, box-shadow 0.2s ease;\n  appearance: auto;\n}\n\n.au-filter__select:focus {\n  border-color: var(--color-primary-200);\n  box-shadow: 0 0 0 4px rgba(193, 217, 92, 0.22);\n}\n\n.au-filter__actions {\n  display: flex;\n  gap: 10px;\n}\n\n/* ---- Bulk Action ---- */\n.au-bulk {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 16px;\n  padding: 16px 24px;\n  border-radius: 18px;\n  background: linear-gradient(135deg, rgba(193, 217, 92, 0.28), rgba(128, 177, 85, 0.14));\n  border: 1px solid rgba(79, 132, 40, 0.12);\n  animation: au-slide-in 0.25s ease;\n}\n\n.au-bulk__count {\n  color: var(--color-text);\n  font-size: 0.95rem;\n}\n\n.au-bulk__count strong {\n  color: var(--color-primary-400);\n}\n\n.au-bulk__actions {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 10px;\n}\n\n.au-bulk__lock-btn {\n  color: #8a5e2a;\n  border-color: rgba(180, 120, 60, 0.22);\n}\n\n.au-bulk__lock-btn:hover {\n  background: rgba(220, 170, 110, 0.14);\n}\n\n/* ---- User List ---- */\n.au-list {\n  display: grid;\n  gap: 0;\n  align-content: start;\n  border-radius: 24px;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  background: rgba(255, 255, 255, 0.92);\n  box-shadow: 0 16px 32px rgba(79, 132, 40, 0.08);\n  overflow: hidden;\n  min-width: 0;\n}\n\n.au-list__header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 12px;\n  padding: 16px 20px;\n  border-bottom: 1px solid rgba(79, 132, 40, 0.08);\n  background: rgba(234, 245, 157, 0.12);\n}\n\n.au-list__check-all {\n  display: inline-flex;\n  align-items: center;\n  gap: 8px;\n  font-weight: 600;\n  font-size: 0.92rem;\n  cursor: pointer;\n}\n\n.au-list__check-all input {\n  accent-color: var(--color-primary-400);\n  width: 16px;\n  height: 16px;\n  cursor: pointer;\n}\n\n.au-list__total {\n  color: var(--color-text-muted);\n  font-size: 0.88rem;\n}\n\n.au-list__items {\n  display: grid;\n  gap: 0;\n}\n\n.au-list__empty {\n  padding: 40px 20px;\n  text-align: center;\n  color: var(--color-text-muted);\n}\n\n/* ---- User Card ---- */\n.au-list__card {\n  display: grid;\n  gap: 10px;\n  padding: 18px 20px;\n  border-bottom: 1px solid rgba(79, 132, 40, 0.06);\n  transition: background-color 0.15s ease;\n}\n\n.au-list__card:last-child {\n  border-bottom: 0;\n}\n\n.au-list__card:hover {\n  background: rgba(234, 245, 157, 0.1);\n}\n\n.au-list__card-top {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  flex-wrap: wrap;\n  min-width: 0;\n}\n\n.au-list__checkbox {\n  accent-color: var(--color-primary-400);\n  width: 16px;\n  height: 16px;\n  cursor: pointer;\n  flex-shrink: 0;\n}\n\n.au-list__avatar {\n  display: inline-grid;\n  place-items: center;\n  width: 42px;\n  height: 42px;\n  border-radius: 14px;\n  background: rgba(193, 217, 92, 0.5);\n  color: var(--color-primary-500);\n  font-weight: 700;\n  font-size: 0.95rem;\n  flex-shrink: 0;\n}\n\n.au-list__user {\n  display: flex;\n  flex-direction: column;\n  gap: 2px;\n  min-width: 0;\n}\n\n.au-list__user strong {\n  font-size: 0.95rem;\n}\n\n.au-list__email {\n  color: var(--color-text-muted);\n  font-size: 0.82rem;\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n}\n\n.au-list__card-bottom {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 12px;\n  flex-wrap: wrap;\n  padding-left: 70px;\n}\n\n.au-list__metrics {\n  display: flex;\n  align-items: center;\n  gap: 16px;\n  flex-wrap: wrap;\n  color: var(--color-text-muted);\n  font-size: 0.84rem;\n}\n\n.au-list__metrics > span {\n  display: inline-flex;\n  align-items: center;\n  gap: 5px;\n}\n\n.au-list__metrics svg {\n  width: 14px;\n  height: 14px;\n  stroke: var(--color-primary-300);\n  fill: none;\n  stroke-width: 1.8;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n  flex-shrink: 0;\n}\n\n.au-list__last-active {\n  padding: 3px 10px;\n  border-radius: 999px;\n  background: rgba(234, 245, 157, 0.2);\n  font-size: 0.8rem;\n  white-space: nowrap;\n}\n\n.au-list__actions {\n  display: flex;\n  gap: 8px;\n  flex-shrink: 0;\n}\n\n.au-list__action-btn {\n  padding: 6px 14px;\n  border: 1px solid rgba(79, 132, 40, 0.14);\n  border-radius: 999px;\n  color: var(--color-primary-500);\n  background: rgba(234, 245, 157, 0.22);\n  font-weight: 600;\n  font-size: 0.82rem;\n  cursor: pointer;\n  white-space: nowrap;\n  transition: background-color 0.2s ease, transform 0.15s ease;\n}\n\n.au-list__action-btn:hover {\n  background: rgba(193, 217, 92, 0.38);\n  transform: translateY(-1px);\n}\n\n.au-list__action-btn--subtle {\n  background: transparent;\n  border-color: rgba(180, 120, 60, 0.18);\n  color: #8a5e2a;\n}\n\n.au-list__action-btn--subtle:hover {\n  background: rgba(220, 170, 110, 0.12);\n}\n\n.au-list__action-btn--unlock {\n  border-color: rgba(79, 132, 40, 0.14);\n  color: var(--color-primary-400);\n}\n\n.au-list__action-btn--unlock:hover {\n  background: rgba(193, 217, 92, 0.3);\n}\n\n/* ---- Role Badges ---- */\n.au-role-badge {\n  display: inline-flex;\n  align-items: center;\n  padding: 4px 12px;\n  border-radius: 999px;\n  font-size: 0.78rem;\n  font-weight: 600;\n  white-space: nowrap;\n  flex-shrink: 0;\n}\n\n.au-role-badge.is-user {\n  color: #2e6b3e;\n  background: rgba(128, 177, 85, 0.2);\n}\n\n.au-role-badge.is-moderator {\n  color: #5e6e17;\n  background: rgba(193, 217, 92, 0.32);\n}\n\n.au-role-badge.is-admin {\n  color: #fff;\n  background: #336a29;\n}\n\n/* ---- Status Badges ---- */\n.au-status-badge {\n  display: inline-flex;\n  align-items: center;\n  padding: 4px 12px;\n  border-radius: 999px;\n  font-size: 0.78rem;\n  font-weight: 600;\n  white-space: nowrap;\n  flex-shrink: 0;\n}\n\n.au-status-badge.is-active {\n  color: #2a5e1f;\n  background: rgba(128, 177, 85, 0.26);\n}\n\n.au-status-badge.is-locked {\n  color: #8a5e2a;\n  background: rgba(214, 160, 90, 0.24);\n}\n\n.au-status-badge.is-pending {\n  color: #6b5a10;\n  background: rgba(234, 215, 120, 0.38);\n}\n\n/* ---- Drawer ---- */\n.au-drawer-overlay {\n  position: fixed;\n  inset: 0;\n  z-index: 50;\n  background: rgba(23, 55, 21, 0.28);\n  animation: au-fade-in 0.25s ease;\n}\n\n.au-drawer {\n  position: fixed;\n  top: 0;\n  right: 0;\n  z-index: 51;\n  width: min(480px, 92vw);\n  height: 100vh;\n  display: flex;\n  flex-direction: column;\n  background: #fff;\n  box-shadow: -16px 0 48px rgba(23, 55, 21, 0.14);\n  animation: au-drawer-in 0.3s ease;\n}\n\n.au-drawer__header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 12px;\n  padding: 22px 24px;\n  border-bottom: 1px solid rgba(79, 132, 40, 0.08);\n  flex-shrink: 0;\n}\n\n.au-drawer__header h3 {\n  margin: 0;\n  font-size: 1.25rem;\n  letter-spacing: -0.02em;\n}\n\n.au-drawer__close {\n  display: inline-grid;\n  place-items: center;\n  width: 36px;\n  height: 36px;\n  border: 1px solid rgba(79, 132, 40, 0.12);\n  border-radius: 12px;\n  background: rgba(234, 245, 157, 0.14);\n  color: var(--color-text);\n  cursor: pointer;\n  transition: background-color 0.15s ease;\n}\n\n.au-drawer__close:hover {\n  background: rgba(193, 217, 92, 0.3);\n}\n\n.au-drawer__close svg {\n  width: 18px;\n  height: 18px;\n  stroke: currentColor;\n  fill: none;\n  stroke-width: 2;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n}\n\n.au-drawer__body {\n  flex: 1 1 auto;\n  overflow-y: auto;\n  padding: 24px;\n  display: grid;\n  gap: 20px;\n  align-content: start;\n}\n\n/* Profile section */\n.au-drawer__profile {\n  display: flex;\n  align-items: center;\n  gap: 16px;\n}\n\n.au-drawer__avatar {\n  display: inline-grid;\n  place-items: center;\n  width: 56px;\n  height: 56px;\n  border-radius: 18px;\n  background: rgba(193, 217, 92, 0.5);\n  color: var(--color-primary-500);\n  font-weight: 700;\n  font-size: 1.4rem;\n  flex-shrink: 0;\n}\n\n.au-drawer__profile strong {\n  display: block;\n  font-size: 1.1rem;\n  margin-bottom: 2px;\n}\n\n.au-drawer__email {\n  display: block;\n  color: var(--color-text-muted);\n  font-size: 0.88rem;\n}\n\n.au-drawer__badges {\n  display: flex;\n  gap: 8px;\n  flex-wrap: wrap;\n}\n\n/* Info grid */\n.au-drawer__grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 14px;\n}\n\n.au-drawer__field {\n  display: grid;\n  gap: 6px;\n}\n\n.au-drawer__label {\n  font-weight: 600;\n  font-size: 0.88rem;\n  color: var(--color-primary-500);\n}\n\n/* Metrics grid */\n.au-drawer__metrics-grid {\n  display: grid;\n  grid-template-columns: repeat(4, minmax(0, 1fr));\n  gap: 12px;\n}\n\n.au-drawer__metric {\n  display: grid;\n  gap: 4px;\n  padding: 14px;\n  border-radius: 16px;\n  background: rgba(234, 245, 157, 0.14);\n  border: 1px solid rgba(79, 132, 40, 0.06);\n  text-align: center;\n}\n\n.au-drawer__metric strong {\n  font-size: 1.4rem;\n  letter-spacing: -0.03em;\n}\n\n.au-drawer__metric span {\n  color: var(--color-text-muted);\n  font-size: 0.78rem;\n}\n\n/* Activity list */\n.au-drawer__activity-list {\n  margin: 0;\n  padding: 0;\n  list-style: none;\n  display: grid;\n  gap: 10px;\n}\n\n.au-drawer__activity-list li {\n  position: relative;\n  padding-left: 20px;\n  color: var(--color-text-muted);\n  font-size: 0.9rem;\n  line-height: 1.6;\n}\n\n.au-drawer__activity-list li::before {\n  content: '';\n  position: absolute;\n  top: 8px;\n  left: 0;\n  width: 8px;\n  height: 8px;\n  border-radius: 50%;\n  background: linear-gradient(135deg, var(--color-primary-200), var(--color-primary-400));\n}\n\n/* Admin note */\n.au-drawer__note {\n  width: 100%;\n  padding: 14px;\n  border: 1px solid var(--color-border);\n  border-radius: 14px;\n  background: rgba(234, 245, 157, 0.1);\n  color: var(--color-text);\n  font: inherit;\n  font-size: 0.92rem;\n  resize: vertical;\n  outline: none;\n  transition: border-color 0.2s ease, box-shadow 0.2s ease;\n}\n\n.au-drawer__note:focus {\n  border-color: var(--color-primary-200);\n  box-shadow: 0 0 0 4px rgba(193, 217, 92, 0.22);\n}\n\n/* Footer */\n.au-drawer__footer {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 10px;\n  padding: 20px 24px;\n  border-top: 1px solid rgba(79, 132, 40, 0.08);\n  flex-shrink: 0;\n}\n\n.au-drawer__footer .btn {\n  font-size: 0.88rem;\n  padding: 10px 16px;\n}\n\n.au-drawer__lock-btn {\n  color: #8a5e2a;\n  border-color: rgba(180, 120, 60, 0.22);\n}\n\n.au-drawer__lock-btn:hover {\n  background: rgba(220, 170, 110, 0.12);\n}\n\n/* ---- Toast ---- */\n.au-toast {\n  position: fixed;\n  bottom: 32px;\n  left: 50%;\n  transform: translateX(-50%);\n  display: inline-flex;\n  align-items: center;\n  gap: 10px;\n  padding: 14px 24px;\n  border-radius: 999px;\n  background: linear-gradient(135deg, #336a29, #4f8428);\n  color: #fff;\n  font-weight: 600;\n  font-size: 0.95rem;\n  box-shadow: 0 16px 40px rgba(51, 106, 41, 0.3);\n  z-index: 100;\n  animation: au-toast-in 0.3s ease;\n}\n\n.au-toast svg {\n  width: 20px;\n  height: 20px;\n  stroke: currentColor;\n  fill: none;\n  stroke-width: 2;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n  flex-shrink: 0;\n}\n\n/* ---- Animations ---- */\n@keyframes au-toast-in {\n  from {\n    opacity: 0;\n    transform: translateX(-50%) translateY(12px);\n  }\n  to {\n    opacity: 1;\n    transform: translateX(-50%) translateY(0);\n  }\n}\n\n@keyframes au-slide-in {\n  from {\n    opacity: 0;\n    transform: translateY(-6px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n@keyframes au-fade-in {\n  from {\n    opacity: 0;\n  }\n  to {\n    opacity: 1;\n  }\n}\n\n@keyframes au-drawer-in {\n  from {\n    opacity: 0;\n    transform: translateX(100%);\n  }\n  to {\n    opacity: 1;\n    transform: translateX(0);\n  }\n}\n\n/* ---- Responsive ---- */\n@media (max-width: 1380px) {\n  .au-stats {\n    grid-template-columns: repeat(2, minmax(0, 1fr));\n  }\n\n  .au-drawer__metrics-grid {\n    grid-template-columns: repeat(2, minmax(0, 1fr));\n  }\n}\n\n@media (max-width: 720px) {\n  .au-stats {\n    grid-template-columns: 1fr;\n  }\n\n  .au-filter__row {\n    flex-direction: column;\n  }\n\n  .au-filter__search,\n  .au-filter__select {\n    width: 100%;\n    min-width: 0;\n  }\n\n  .au-bulk {\n    flex-direction: column;\n    text-align: center;\n  }\n\n  .au-bulk__actions {\n    justify-content: center;\n  }\n\n  .au-list__card-bottom {\n    padding-left: 0;\n    flex-direction: column;\n    align-items: flex-start;\n  }\n\n  .au-list__card-top {\n    gap: 8px;\n  }\n\n  .au-list__actions {\n    width: 100%;\n  }\n\n  .au-drawer__grid {\n    grid-template-columns: 1fr;\n  }\n\n  .au-drawer__metrics-grid {\n    grid-template-columns: repeat(2, minmax(0, 1fr));\n  }\n\n  .au-drawer__footer {\n    flex-direction: column;\n  }\n\n  .au-drawer__footer .btn {\n    width: 100%;\n  }\n}\n"],["STYLE",{},"/* ============================================================\n   Admin — Device Management Page (admin-devices.css)\n   Đồng bộ palette E-XANH & admin.css / admin-users.css\n   ============================================================ */\n\n/* ---- Page & Hero ---- */\n.ad-page {\n  gap: 24px;\n}\n\n.ad-page__hero {\n  display: grid;\n  gap: 14px;\n}\n\n.ad-page__hero-copy h2 {\n  margin: 0 0 10px;\n  font-size: clamp(2rem, 3vw, 2.8rem);\n  letter-spacing: -0.04em;\n}\n\n.ad-page__hero-copy p {\n  margin: 0;\n  color: var(--color-text-muted);\n  line-height: 1.7;\n}\n\n/* ---- Stats Cards ---- */\n.ad-stats {\n  display: grid;\n  grid-template-columns: repeat(4, minmax(0, 1fr));\n  gap: 18px;\n}\n\n.ad-stats__card {\n  display: flex;\n  align-items: center;\n  gap: 16px;\n  padding: 22px 20px;\n  border-radius: 24px;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  background: #fff;\n  box-shadow: 0 14px 30px rgba(79, 132, 40, 0.08);\n  min-width: 0;\n  transition: transform 0.2s ease, box-shadow 0.2s ease;\n}\n\n.ad-stats__card:hover {\n  transform: translateY(-2px);\n  box-shadow: 0 18px 36px rgba(79, 132, 40, 0.12);\n}\n\n.ad-stats__icon {\n  display: inline-grid;\n  place-items: center;\n  width: 52px;\n  height: 52px;\n  border-radius: 18px;\n  flex-shrink: 0;\n}\n\n.ad-stats__icon svg {\n  width: 24px;\n  height: 24px;\n  stroke: currentColor;\n  fill: none;\n  stroke-width: 1.9;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n}\n\n.ad-stats__info p {\n  margin: 0 0 4px;\n  color: var(--color-text-muted);\n  font-size: 0.92rem;\n}\n\n.ad-stats__info strong {\n  font-size: clamp(1.6rem, 2.4vw, 2.4rem);\n  line-height: 1;\n  letter-spacing: -0.04em;\n}\n\n/* Accent variants */\n.ad-stats__card--success .ad-stats__icon {\n  color: #336a29;\n  background: rgba(128, 177, 85, 0.22);\n}\n\n.ad-stats__card--highlight .ad-stats__icon {\n  color: #4f8428;\n  background: rgba(193, 217, 92, 0.34);\n}\n\n.ad-stats__card--warning .ad-stats__icon {\n  color: #8a5e2a;\n  background: rgba(214, 160, 90, 0.24);\n}\n\n.ad-stats__card--muted .ad-stats__icon {\n  color: #7a6c5c;\n  background: rgba(180, 170, 155, 0.22);\n}\n\n/* ---- Filter ---- */\n.ad-filter {\n  display: grid;\n  gap: 14px;\n  padding: 22px 24px;\n  border-radius: 24px;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  background: rgba(255, 255, 255, 0.92);\n  box-shadow: 0 14px 30px rgba(79, 132, 40, 0.06);\n}\n\n.ad-filter__row {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 12px;\n  align-items: center;\n}\n\n.ad-filter__search {\n  position: relative;\n  flex: 1 1 240px;\n  min-width: 200px;\n}\n\n.ad-filter__search svg {\n  position: absolute;\n  top: 50%;\n  left: 14px;\n  width: 18px;\n  height: 18px;\n  transform: translateY(-50%);\n  stroke: var(--color-primary-400);\n  fill: none;\n  stroke-width: 1.9;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n  pointer-events: none;\n}\n\n.ad-filter__search input {\n  width: 100%;\n  padding: 13px 16px 13px 44px;\n  border: 1px solid var(--color-border);\n  border-radius: 14px;\n  background: rgba(234, 245, 157, 0.14);\n  color: var(--color-text);\n  font-size: 0.95rem;\n  outline: none;\n  transition: border-color 0.2s ease, box-shadow 0.2s ease;\n}\n\n.ad-filter__search input:focus {\n  border-color: var(--color-primary-200);\n  box-shadow: 0 0 0 4px rgba(193, 217, 92, 0.22);\n}\n\n.ad-filter__search input::placeholder {\n  color: rgba(23, 55, 21, 0.5);\n}\n\n.ad-filter__select {\n  flex: 0 1 auto;\n  min-width: 160px;\n  padding: 13px 16px;\n  border: 1px solid var(--color-border);\n  border-radius: 14px;\n  background: rgba(234, 245, 157, 0.14);\n  color: var(--color-text);\n  font: inherit;\n  font-size: 0.95rem;\n  cursor: pointer;\n  outline: none;\n  transition: border-color 0.2s ease, box-shadow 0.2s ease;\n  appearance: auto;\n}\n\n.ad-filter__select:focus {\n  border-color: var(--color-primary-200);\n  box-shadow: 0 0 0 4px rgba(193, 217, 92, 0.22);\n}\n\n.ad-filter__actions {\n  display: flex;\n  gap: 10px;\n}\n\n/* ---- Bulk Action ---- */\n.ad-bulk {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 16px;\n  padding: 16px 24px;\n  border-radius: 18px;\n  background: linear-gradient(135deg, rgba(193, 217, 92, 0.28), rgba(128, 177, 85, 0.14));\n  border: 1px solid rgba(79, 132, 40, 0.12);\n  animation: ad-slide-in 0.25s ease;\n}\n\n.ad-bulk__count {\n  color: var(--color-text);\n  font-size: 0.95rem;\n}\n\n.ad-bulk__count strong {\n  color: var(--color-primary-400);\n}\n\n.ad-bulk__actions {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 10px;\n}\n\n.ad-bulk__delete-btn {\n  color: #8a5e2a;\n  border-color: rgba(180, 120, 60, 0.22);\n}\n\n.ad-bulk__delete-btn:hover {\n  background: rgba(220, 170, 110, 0.14);\n}\n\n/* ---- Device List ---- */\n.ad-list {\n  display: grid;\n  gap: 0;\n  align-content: start;\n  border-radius: 24px;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  background: rgba(255, 255, 255, 0.92);\n  box-shadow: 0 16px 32px rgba(79, 132, 40, 0.08);\n  overflow: hidden;\n  min-width: 0;\n}\n\n.ad-list__header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 12px;\n  padding: 16px 20px;\n  border-bottom: 1px solid rgba(79, 132, 40, 0.08);\n  background: rgba(234, 245, 157, 0.12);\n  flex-wrap: wrap;\n}\n\n.ad-list__header-left {\n  display: flex;\n  align-items: center;\n  gap: 16px;\n}\n\n.ad-list__check-all {\n  display: inline-flex;\n  align-items: center;\n  gap: 8px;\n  font-weight: 600;\n  font-size: 0.92rem;\n  cursor: pointer;\n}\n\n.ad-list__check-all input {\n  accent-color: var(--color-primary-400);\n  width: 16px;\n  height: 16px;\n  cursor: pointer;\n}\n\n.ad-list__total {\n  color: var(--color-text-muted);\n  font-size: 0.88rem;\n}\n\n.ad-list__add-btn {\n  font-size: 0.88rem;\n  padding: 10px 20px;\n}\n\n.ad-list__items {\n  display: grid;\n  gap: 0;\n}\n\n.ad-list__empty {\n  padding: 40px 20px;\n  text-align: center;\n  color: var(--color-text-muted);\n}\n\n/* ---- Device Card ---- */\n.ad-list__card {\n  display: grid;\n  gap: 10px;\n  padding: 18px 20px;\n  border-bottom: 1px solid rgba(79, 132, 40, 0.06);\n  transition: background-color 0.15s ease;\n}\n\n.ad-list__card:last-child {\n  border-bottom: 0;\n}\n\n.ad-list__card:hover {\n  background: rgba(234, 245, 157, 0.1);\n}\n\n.ad-list__card-top {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  flex-wrap: wrap;\n  min-width: 0;\n}\n\n.ad-list__checkbox {\n  accent-color: var(--color-primary-400);\n  width: 16px;\n  height: 16px;\n  cursor: pointer;\n  flex-shrink: 0;\n}\n\n.ad-list__icon {\n  display: inline-grid;\n  place-items: center;\n  width: 42px;\n  height: 42px;\n  border-radius: 14px;\n  background: rgba(193, 217, 92, 0.4);\n  font-size: 1.2rem;\n  flex-shrink: 0;\n}\n\n.ad-list__info {\n  display: flex;\n  flex-direction: column;\n  gap: 2px;\n  min-width: 0;\n}\n\n.ad-list__info strong {\n  font-size: 0.95rem;\n}\n\n.ad-list__group {\n  color: var(--color-text-muted);\n  font-size: 0.82rem;\n}\n\n.ad-list__power {\n  padding: 4px 10px;\n  border-radius: 999px;\n  background: rgba(234, 245, 157, 0.25);\n  font-weight: 700;\n  font-size: 0.84rem;\n  color: var(--color-primary-500);\n  white-space: nowrap;\n  flex-shrink: 0;\n}\n\n.ad-list__hours {\n  color: var(--color-text-muted);\n  font-size: 0.82rem;\n  white-space: nowrap;\n  flex-shrink: 0;\n}\n\n.ad-list__card-bottom {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 12px;\n  flex-wrap: wrap;\n  padding-left: 70px;\n}\n\n.ad-list__tip {\n  margin: 0;\n  color: var(--color-text-muted);\n  font-size: 0.86rem;\n  line-height: 1.5;\n  display: -webkit-box;\n  -webkit-line-clamp: 1;\n  -webkit-box-orient: vertical;\n  overflow: hidden;\n  flex: 1 1 200px;\n  min-width: 0;\n}\n\n.ad-list__actions {\n  display: flex;\n  gap: 8px;\n  flex-shrink: 0;\n}\n\n.ad-list__action-btn {\n  padding: 6px 14px;\n  border: 1px solid rgba(79, 132, 40, 0.14);\n  border-radius: 999px;\n  color: var(--color-primary-500);\n  background: rgba(234, 245, 157, 0.22);\n  font-weight: 600;\n  font-size: 0.82rem;\n  cursor: pointer;\n  white-space: nowrap;\n  transition: background-color 0.2s ease, transform 0.15s ease;\n}\n\n.ad-list__action-btn:hover {\n  background: rgba(193, 217, 92, 0.38);\n  transform: translateY(-1px);\n}\n\n.ad-list__action-btn--subtle {\n  background: transparent;\n  border-color: rgba(180, 120, 60, 0.18);\n  color: #8a5e2a;\n}\n\n.ad-list__action-btn--subtle:hover {\n  background: rgba(220, 170, 110, 0.12);\n}\n\n.ad-list__action-btn--show {\n  border-color: rgba(79, 132, 40, 0.14);\n  color: var(--color-primary-400);\n}\n\n.ad-list__action-btn--show:hover {\n  background: rgba(193, 217, 92, 0.3);\n}\n\n/* ---- Level Badges ---- */\n.ad-level-badge {\n  display: inline-flex;\n  align-items: center;\n  padding: 4px 12px;\n  border-radius: 999px;\n  font-size: 0.78rem;\n  font-weight: 600;\n  white-space: nowrap;\n  flex-shrink: 0;\n}\n\n.ad-level-badge.is-low {\n  color: #2e6b3e;\n  background: rgba(128, 177, 85, 0.2);\n}\n\n.ad-level-badge.is-medium {\n  color: #5e6e17;\n  background: rgba(193, 217, 92, 0.32);\n}\n\n.ad-level-badge.is-high {\n  color: #8a5e2a;\n  background: rgba(214, 160, 90, 0.24);\n}\n\n/* ---- Status Badges ---- */\n.ad-status-badge {\n  display: inline-flex;\n  align-items: center;\n  padding: 4px 12px;\n  border-radius: 999px;\n  font-size: 0.78rem;\n  font-weight: 600;\n  white-space: nowrap;\n  flex-shrink: 0;\n}\n\n.ad-status-badge.is-active {\n  color: #2a5e1f;\n  background: rgba(128, 177, 85, 0.26);\n}\n\n.ad-status-badge.is-hidden {\n  color: #5a5a5a;\n  background: rgba(160, 160, 160, 0.22);\n}\n\n/* ---- Tips Card ---- */\n.ad-tips-card {\n  padding: 24px;\n  border-radius: 24px;\n  border: 1px solid rgba(79, 132, 40, 0.1);\n  background: linear-gradient(135deg, rgba(234, 245, 157, 0.22), rgba(193, 217, 92, 0.12));\n  box-shadow: 0 14px 30px rgba(79, 132, 40, 0.06);\n}\n\n.ad-tips-card__header {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  margin-bottom: 18px;\n}\n\n.ad-tips-card__header svg {\n  width: 24px;\n  height: 24px;\n  stroke: var(--color-primary-400);\n  fill: none;\n  stroke-width: 1.9;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n  flex-shrink: 0;\n}\n\n.ad-tips-card__header h3 {\n  margin: 0;\n  font-size: 1.1rem;\n  letter-spacing: -0.02em;\n}\n\n.ad-tips-card__list {\n  margin: 0;\n  padding: 0;\n  list-style: none;\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: 12px;\n}\n\n.ad-tips-card__list li {\n  position: relative;\n  padding: 12px 14px 12px 30px;\n  border-radius: 14px;\n  background: rgba(255, 255, 255, 0.7);\n  border: 1px solid rgba(79, 132, 40, 0.06);\n  color: var(--color-text);\n  font-size: 0.9rem;\n  line-height: 1.5;\n}\n\n.ad-tips-card__list li::before {\n  content: '✓';\n  position: absolute;\n  top: 12px;\n  left: 12px;\n  color: var(--color-primary-400);\n  font-weight: 700;\n  font-size: 0.85rem;\n}\n\n/* ---- Drawer ---- */\n.ad-drawer-overlay {\n  position: fixed;\n  inset: 0;\n  z-index: 50;\n  background: rgba(23, 55, 21, 0.28);\n  animation: ad-fade-in 0.25s ease;\n}\n\n.ad-drawer {\n  position: fixed;\n  top: 0;\n  right: 0;\n  z-index: 51;\n  width: min(480px, 92vw);\n  height: 100vh;\n  display: flex;\n  flex-direction: column;\n  background: #fff;\n  box-shadow: -16px 0 48px rgba(23, 55, 21, 0.14);\n  animation: ad-drawer-in 0.3s ease;\n}\n\n.ad-drawer__header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 12px;\n  padding: 22px 24px;\n  border-bottom: 1px solid rgba(79, 132, 40, 0.08);\n  flex-shrink: 0;\n}\n\n.ad-drawer__header h3 {\n  margin: 0;\n  font-size: 1.25rem;\n  letter-spacing: -0.02em;\n}\n\n.ad-drawer__close {\n  display: inline-grid;\n  place-items: center;\n  width: 36px;\n  height: 36px;\n  border: 1px solid rgba(79, 132, 40, 0.12);\n  border-radius: 12px;\n  background: rgba(234, 245, 157, 0.14);\n  color: var(--color-text);\n  cursor: pointer;\n  transition: background-color 0.15s ease;\n}\n\n.ad-drawer__close:hover {\n  background: rgba(193, 217, 92, 0.3);\n}\n\n.ad-drawer__close svg {\n  width: 18px;\n  height: 18px;\n  stroke: currentColor;\n  fill: none;\n  stroke-width: 2;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n}\n\n.ad-drawer__body {\n  flex: 1 1 auto;\n  overflow-y: auto;\n  padding: 24px;\n  display: grid;\n  gap: 18px;\n  align-content: start;\n}\n\n.ad-drawer__field {\n  display: grid;\n  gap: 6px;\n}\n\n.ad-drawer__label {\n  font-weight: 600;\n  font-size: 0.88rem;\n  color: var(--color-primary-500);\n}\n\n.ad-drawer__input {\n  width: 100%;\n  padding: 12px 14px;\n  border: 1px solid var(--color-border);\n  border-radius: 14px;\n  background: rgba(234, 245, 157, 0.1);\n  color: var(--color-text);\n  font: inherit;\n  font-size: 0.92rem;\n  outline: none;\n  transition: border-color 0.2s ease, box-shadow 0.2s ease;\n}\n\n.ad-drawer__input:focus {\n  border-color: var(--color-primary-200);\n  box-shadow: 0 0 0 4px rgba(193, 217, 92, 0.22);\n}\n\n.ad-drawer__input.is-error {\n  border-color: rgba(200, 120, 60, 0.5);\n  box-shadow: 0 0 0 4px rgba(200, 120, 60, 0.1);\n}\n\n.ad-drawer__textarea {\n  resize: vertical;\n}\n\n.ad-drawer__error {\n  color: #8a5030;\n  font-size: 0.82rem;\n  font-weight: 500;\n}\n\n.ad-drawer__row {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 14px;\n}\n\n.ad-drawer__footer {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 10px;\n  padding: 20px 24px;\n  border-top: 1px solid rgba(79, 132, 40, 0.08);\n  flex-shrink: 0;\n}\n\n.ad-drawer__footer .btn {\n  font-size: 0.88rem;\n  padding: 10px 16px;\n}\n\n/* ---- Toast ---- */\n.ad-toast {\n  position: fixed;\n  bottom: 32px;\n  left: 50%;\n  transform: translateX(-50%);\n  display: inline-flex;\n  align-items: center;\n  gap: 10px;\n  padding: 14px 24px;\n  border-radius: 999px;\n  background: linear-gradient(135deg, #336a29, #4f8428);\n  color: #fff;\n  font-weight: 600;\n  font-size: 0.95rem;\n  box-shadow: 0 16px 40px rgba(51, 106, 41, 0.3);\n  z-index: 100;\n  animation: ad-toast-in 0.3s ease;\n}\n\n.ad-toast svg {\n  width: 20px;\n  height: 20px;\n  stroke: currentColor;\n  fill: none;\n  stroke-width: 2;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n  flex-shrink: 0;\n}\n\n/* ---- Animations ---- */\n@keyframes ad-toast-in {\n  from {\n    opacity: 0;\n    transform: translateX(-50%) translateY(12px);\n  }\n  to {\n    opacity: 1;\n    transform: translateX(-50%) translateY(0);\n  }\n}\n\n@keyframes ad-slide-in {\n  from {\n    opacity: 0;\n    transform: translateY(-6px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n@keyframes ad-fade-in {\n  from {\n    opacity: 0;\n  }\n  to {\n    opacity: 1;\n  }\n}\n\n@keyframes ad-drawer-in {\n  from {\n    opacity: 0;\n    transform: translateX(100%);\n  }\n  to {\n    opacity: 1;\n    transform: translateX(0);\n  }\n}\n\n/* ---- Responsive ---- */\n@media (max-width: 1380px) {\n  .ad-stats {\n    grid-template-columns: repeat(2, minmax(0, 1fr));\n  }\n}\n\n@media (max-width: 720px) {\n  .ad-stats {\n    grid-template-columns: 1fr;\n  }\n\n  .ad-filter__row {\n    flex-direction: column;\n  }\n\n  .ad-filter__search,\n  .ad-filter__select {\n    width: 100%;\n    min-width: 0;\n  }\n\n  .ad-bulk {\n    flex-direction: column;\n    text-align: center;\n  }\n\n  .ad-bulk__actions {\n    justify-content: center;\n  }\n\n  .ad-list__card-bottom {\n    padding-left: 0;\n    flex-direction: column;\n    align-items: flex-start;\n  }\n\n  .ad-list__card-top {\n    gap: 8px;\n  }\n\n  .ad-list__actions {\n    width: 100%;\n  }\n\n  .ad-tips-card__list {\n    grid-template-columns: 1fr;\n  }\n\n  .ad-drawer__row {\n    grid-template-columns: 1fr;\n  }\n\n  .ad-drawer__footer {\n    flex-direction: column;\n  }\n\n  .ad-drawer__footer .btn {\n    width: 100%;\n  }\n}\n"],["STYLE",{},"/* ============================================================\n   Admin — Statistics Page (admin-statistics.css)\n   Đồng bộ palette E-XANH & admin.css / admin-users.css\n   ============================================================ */\n\n/* ---- Page & Hero ---- */\n.as-page {\n  gap: 24px;\n}\n\n.as-page__hero {\n  display: grid;\n  gap: 14px;\n}\n\n.as-page__hero-copy h2 {\n  margin: 0 0 10px;\n  font-size: clamp(2rem, 3vw, 2.8rem);\n  letter-spacing: -0.04em;\n}\n\n.as-page__hero-copy p {\n  margin: 0;\n  color: var(--color-text-muted);\n  line-height: 1.7;\n}\n\n/* ---- Time Filter ---- */\n.as-time-filter {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 8px;\n}\n\n.as-time-filter__btn {\n  padding: 10px 20px;\n  border: 1px solid rgba(79, 132, 40, 0.12);\n  border-radius: 999px;\n  background: rgba(255, 255, 255, 0.8);\n  color: var(--color-text);\n  font: inherit;\n  font-size: 0.9rem;\n  font-weight: 500;\n  cursor: pointer;\n  white-space: nowrap;\n  transition: all 0.2s ease;\n}\n\n.as-time-filter__btn:hover {\n  background: rgba(193, 217, 92, 0.2);\n  border-color: rgba(79, 132, 40, 0.2);\n}\n\n.as-time-filter__btn.is-active {\n  background: linear-gradient(135deg, #336a29, #4f8428);\n  color: #fff;\n  border-color: transparent;\n  box-shadow: 0 6px 18px rgba(51, 106, 41, 0.25);\n}\n\n/* ---- Overview Stats ---- */\n.as-overview {\n  display: grid;\n  grid-template-columns: repeat(4, minmax(0, 1fr));\n  gap: 18px;\n}\n\n.as-overview__card {\n  display: flex;\n  align-items: center;\n  gap: 16px;\n  padding: 22px 20px;\n  border-radius: 24px;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  background: #fff;\n  box-shadow: 0 14px 30px rgba(79, 132, 40, 0.08);\n  min-width: 0;\n  transition: transform 0.2s ease, box-shadow 0.2s ease;\n}\n\n.as-overview__card:hover {\n  transform: translateY(-2px);\n  box-shadow: 0 18px 36px rgba(79, 132, 40, 0.12);\n}\n\n.as-overview__icon {\n  display: inline-grid;\n  place-items: center;\n  width: 52px;\n  height: 52px;\n  border-radius: 18px;\n  flex-shrink: 0;\n}\n\n.as-overview__icon svg {\n  width: 24px;\n  height: 24px;\n  stroke: currentColor;\n  fill: none;\n  stroke-width: 1.9;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n}\n\n.as-overview__info {\n  display: grid;\n  gap: 2px;\n  min-width: 0;\n}\n\n.as-overview__info p {\n  margin: 0;\n  color: var(--color-text-muted);\n  font-size: 0.88rem;\n}\n\n.as-overview__info strong {\n  font-size: clamp(1.5rem, 2.2vw, 2.2rem);\n  line-height: 1;\n  letter-spacing: -0.04em;\n}\n\n.as-overview__change {\n  color: #4f8428;\n  font-size: 0.8rem;\n  font-weight: 600;\n}\n\n/* Accent variants */\n.as-overview__card--success .as-overview__icon {\n  color: #336a29;\n  background: rgba(128, 177, 85, 0.22);\n}\n\n.as-overview__card--highlight .as-overview__icon {\n  color: #4f8428;\n  background: rgba(193, 217, 92, 0.34);\n}\n\n.as-overview__card--warning .as-overview__icon {\n  color: #8a6e1f;\n  background: rgba(234, 215, 120, 0.38);\n}\n\n.as-overview__card--muted .as-overview__icon {\n  color: #7a6c5c;\n  background: rgba(180, 170, 155, 0.22);\n}\n\n/* ---- Charts Row ---- */\n.as-charts-row {\n  display: grid;\n  grid-template-columns: 1.4fr 1fr;\n  gap: 20px;\n}\n\n/* ---- Chart Card ---- */\n.as-chart-card {\n  padding: 24px;\n  border-radius: 24px;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  background: #fff;\n  box-shadow: 0 14px 30px rgba(79, 132, 40, 0.08);\n  min-width: 0;\n}\n\n.as-chart-card__header {\n  display: flex;\n  flex-wrap: wrap;\n  align-items: center;\n  justify-content: space-between;\n  gap: 12px;\n  margin-bottom: 20px;\n}\n\n.as-chart-card__header h3 {\n  margin: 0;\n  font-size: 1.05rem;\n  letter-spacing: -0.02em;\n}\n\n.as-chart-card__legend {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 12px;\n}\n\n.as-chart-card__legend-item {\n  display: inline-flex;\n  align-items: center;\n  gap: 5px;\n  font-size: 0.78rem;\n  color: var(--color-text-muted);\n}\n\n.as-chart-card__legend-dot {\n  display: inline-block;\n  width: 10px;\n  height: 10px;\n  border-radius: 3px;\n  flex-shrink: 0;\n}\n\n/* ---- Bar Chart ---- */\n.as-bar-chart {\n  display: flex;\n  align-items: flex-end;\n  gap: 8px;\n  height: 200px;\n  padding-top: 10px;\n}\n\n.as-bar-chart__col {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: 8px;\n  height: 100%;\n  min-width: 0;\n}\n\n.as-bar-chart__bars {\n  flex: 1;\n  width: 100%;\n  display: flex;\n  align-items: flex-end;\n  gap: 3px;\n  min-height: 0;\n}\n\n.as-bar-chart__bar {\n  flex: 1;\n  border-radius: 6px 6px 2px 2px;\n  min-height: 4px;\n  transition: height 0.3s ease;\n}\n\n.as-bar-chart__label {\n  font-size: 0.78rem;\n  font-weight: 600;\n  color: var(--color-text-muted);\n  flex-shrink: 0;\n}\n\n/* ---- Donut Chart ---- */\n.as-donut-wrapper {\n  display: flex;\n  align-items: center;\n  gap: 24px;\n  flex-wrap: wrap;\n  justify-content: center;\n}\n\n.as-donut {\n  position: relative;\n  width: 160px;\n  height: 160px;\n  border-radius: 50%;\n  flex-shrink: 0;\n}\n\n.as-donut__center {\n  position: absolute;\n  top: 50%;\n  left: 50%;\n  transform: translate(-50%, -50%);\n  width: 90px;\n  height: 90px;\n  border-radius: 50%;\n  background: #fff;\n  display: grid;\n  place-items: center;\n  text-align: center;\n  box-shadow: 0 4px 12px rgba(79, 132, 40, 0.06);\n}\n\n.as-donut__center strong {\n  font-size: 1.6rem;\n  letter-spacing: -0.04em;\n  line-height: 1;\n}\n\n.as-donut__center span {\n  font-size: 0.78rem;\n  color: var(--color-text-muted);\n}\n\n.as-donut__legend {\n  margin: 0;\n  padding: 0;\n  list-style: none;\n  display: grid;\n  gap: 10px;\n}\n\n.as-donut__legend li {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  font-size: 0.88rem;\n}\n\n.as-donut__legend-dot {\n  display: inline-block;\n  width: 12px;\n  height: 12px;\n  border-radius: 4px;\n  flex-shrink: 0;\n}\n\n.as-donut__legend-label {\n  flex: 1;\n  color: var(--color-text-muted);\n}\n\n.as-donut__legend strong {\n  font-size: 0.9rem;\n}\n\n/* ---- Two-Column Layout ---- */\n.as-two-col {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 20px;\n}\n\n/* ---- Section Card ---- */\n.as-section-card {\n  padding: 24px;\n  border-radius: 24px;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  background: #fff;\n  box-shadow: 0 14px 30px rgba(79, 132, 40, 0.08);\n  min-width: 0;\n}\n\n.as-section-card h3 {\n  margin: 0 0 18px;\n  font-size: 1.05rem;\n  letter-spacing: -0.02em;\n}\n\n/* ---- Ranking List ---- */\n.as-ranking {\n  display: grid;\n  gap: 14px;\n}\n\n.as-ranking__item {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n}\n\n.as-ranking__rank {\n  display: inline-grid;\n  place-items: center;\n  width: 28px;\n  height: 28px;\n  border-radius: 10px;\n  background: rgba(193, 217, 92, 0.35);\n  color: var(--color-primary-500);\n  font-weight: 700;\n  font-size: 0.82rem;\n  flex-shrink: 0;\n}\n\n.as-ranking__icon {\n  font-size: 1.2rem;\n  flex-shrink: 0;\n}\n\n.as-ranking__info {\n  flex: 1;\n  min-width: 0;\n  display: grid;\n  gap: 6px;\n}\n\n.as-ranking__top {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 8px;\n}\n\n.as-ranking__name {\n  font-weight: 600;\n  font-size: 0.92rem;\n}\n\n.as-ranking__count {\n  color: var(--color-text-muted);\n  font-size: 0.82rem;\n  white-space: nowrap;\n}\n\n.as-ranking__bar-track {\n  height: 6px;\n  border-radius: 999px;\n  background: rgba(234, 245, 157, 0.3);\n  overflow: hidden;\n}\n\n.as-ranking__bar-fill {\n  height: 100%;\n  border-radius: 999px;\n  background: linear-gradient(90deg, #80B155, #336A29);\n  transition: width 0.4s ease;\n}\n\n/* ---- Saved Posts List ---- */\n.as-saved-list {\n  display: grid;\n  gap: 14px;\n}\n\n.as-saved-list__item {\n  display: flex;\n  align-items: flex-start;\n  gap: 12px;\n}\n\n.as-saved-list__rank {\n  display: inline-grid;\n  place-items: center;\n  width: 28px;\n  height: 28px;\n  border-radius: 10px;\n  background: rgba(193, 217, 92, 0.35);\n  color: var(--color-primary-500);\n  font-weight: 700;\n  font-size: 0.82rem;\n  flex-shrink: 0;\n}\n\n.as-saved-list__info {\n  display: grid;\n  gap: 4px;\n  min-width: 0;\n}\n\n.as-saved-list__title {\n  font-weight: 600;\n  font-size: 0.92rem;\n  line-height: 1.4;\n}\n\n.as-saved-list__saves {\n  display: inline-flex;\n  align-items: center;\n  gap: 5px;\n  color: var(--color-text-muted);\n  font-size: 0.82rem;\n}\n\n.as-saved-list__saves svg {\n  width: 14px;\n  height: 14px;\n  stroke: var(--color-primary-300);\n  fill: none;\n  stroke-width: 1.8;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n  flex-shrink: 0;\n}\n\n/* ---- Active Users ---- */\n.as-active-users {\n  display: grid;\n  gap: 14px;\n}\n\n.as-active-users__item {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n}\n\n.as-active-users__rank {\n  display: inline-grid;\n  place-items: center;\n  width: 28px;\n  height: 28px;\n  border-radius: 10px;\n  background: rgba(193, 217, 92, 0.35);\n  color: var(--color-primary-500);\n  font-weight: 700;\n  font-size: 0.82rem;\n  flex-shrink: 0;\n}\n\n.as-active-users__avatar {\n  display: inline-grid;\n  place-items: center;\n  width: 38px;\n  height: 38px;\n  border-radius: 12px;\n  background: rgba(193, 217, 92, 0.5);\n  color: var(--color-primary-500);\n  font-weight: 700;\n  font-size: 0.9rem;\n  flex-shrink: 0;\n}\n\n.as-active-users__info {\n  display: grid;\n  gap: 2px;\n}\n\n.as-active-users__info strong {\n  font-size: 0.92rem;\n}\n\n.as-active-users__info span {\n  color: var(--color-text-muted);\n  font-size: 0.82rem;\n}\n\n/* ---- Community Grid ---- */\n.as-community-grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 14px;\n}\n\n.as-community-grid__card {\n  display: grid;\n  gap: 6px;\n  padding: 18px;\n  border-radius: 18px;\n  background: rgba(234, 245, 157, 0.14);\n  border: 1px solid rgba(79, 132, 40, 0.06);\n  text-align: center;\n}\n\n.as-community-grid__icon {\n  display: inline-grid;\n  place-items: center;\n  width: 36px;\n  height: 36px;\n  margin: 0 auto;\n  border-radius: 12px;\n  background: rgba(128, 177, 85, 0.22);\n  color: #336a29;\n}\n\n.as-community-grid__icon svg {\n  width: 18px;\n  height: 18px;\n  stroke: currentColor;\n  fill: none;\n  stroke-width: 1.9;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n}\n\n.as-community-grid__card strong {\n  font-size: 1.3rem;\n  letter-spacing: -0.03em;\n}\n\n.as-community-grid__card span {\n  color: var(--color-text-muted);\n  font-size: 0.8rem;\n}\n\n/* ---- Insights Card ---- */\n.as-insights-card {\n  padding: 24px;\n  border-radius: 24px;\n  border: 1px solid rgba(79, 132, 40, 0.1);\n  background: linear-gradient(135deg, rgba(234, 245, 157, 0.22), rgba(193, 217, 92, 0.12));\n  box-shadow: 0 14px 30px rgba(79, 132, 40, 0.06);\n}\n\n.as-insights-card__header {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  margin-bottom: 18px;\n}\n\n.as-insights-card__header svg {\n  width: 24px;\n  height: 24px;\n  stroke: var(--color-primary-400);\n  fill: none;\n  stroke-width: 1.9;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n  flex-shrink: 0;\n}\n\n.as-insights-card__header h3 {\n  margin: 0;\n  font-size: 1.1rem;\n  letter-spacing: -0.02em;\n}\n\n.as-insights-card__list {\n  margin: 0;\n  padding: 0;\n  list-style: none;\n  display: grid;\n  gap: 12px;\n}\n\n.as-insights-card__list li {\n  position: relative;\n  padding: 14px 16px 14px 34px;\n  border-radius: 14px;\n  background: rgba(255, 255, 255, 0.7);\n  border: 1px solid rgba(79, 132, 40, 0.06);\n  color: var(--color-text);\n  font-size: 0.9rem;\n  line-height: 1.6;\n}\n\n.as-insights-card__list li::before {\n  content: '💡';\n  position: absolute;\n  top: 14px;\n  left: 12px;\n  font-size: 0.85rem;\n}\n\n/* ---- Responsive ---- */\n@media (max-width: 1380px) {\n  .as-overview {\n    grid-template-columns: repeat(2, minmax(0, 1fr));\n  }\n}\n\n@media (max-width: 900px) {\n  .as-charts-row {\n    grid-template-columns: 1fr;\n  }\n\n  .as-two-col {\n    grid-template-columns: 1fr;\n  }\n}\n\n@media (max-width: 720px) {\n  .as-overview {\n    grid-template-columns: 1fr;\n  }\n\n  .as-donut-wrapper {\n    flex-direction: column;\n  }\n\n  .as-community-grid {\n    grid-template-columns: 1fr;\n  }\n\n  .as-bar-chart {\n    height: 160px;\n  }\n}\n"],["STYLE",{},"/* ============================================================\n   Admin — Settings Page (admin-settings.css)\n   Đồng bộ palette E-XANH & admin.css\n   ============================================================ */\n\n/* ---- Page & Hero ---- */\n.st-page {\n  gap: 24px;\n}\n\n.st-page__hero {\n  display: grid;\n  gap: 14px;\n}\n\n.st-page__hero-copy h2 {\n  margin: 0 0 10px;\n  font-size: clamp(2rem, 3vw, 2.8rem);\n  letter-spacing: -0.04em;\n}\n\n.st-page__hero-copy p {\n  margin: 0;\n  color: var(--color-text-muted);\n  line-height: 1.7;\n}\n\n/* ---- 2-Column Layout ---- */\n.st-layout {\n  display: grid;\n  grid-template-columns: 1.8fr 1fr;\n  gap: 22px;\n  align-items: start;\n}\n\n.st-layout__main {\n  display: grid;\n  gap: 22px;\n  min-width: 0;\n}\n\n.st-layout__sidebar {\n  display: grid;\n  gap: 22px;\n  min-width: 0;\n}\n\n/* ---- Card ---- */\n.st-card {\n  padding: 24px;\n  border-radius: 24px;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  background: #fff;\n  box-shadow: 0 14px 30px rgba(79, 132, 40, 0.08);\n  display: grid;\n  gap: 18px;\n  min-width: 0;\n}\n\n.st-card__title {\n  margin: 0;\n  font-size: 1.1rem;\n  letter-spacing: -0.02em;\n}\n\n.st-card__field {\n  display: grid;\n  gap: 6px;\n}\n\n.st-card__label {\n  font-weight: 600;\n  font-size: 0.88rem;\n  color: var(--color-primary-500);\n}\n\n.st-card__input {\n  width: 100%;\n  padding: 12px 14px;\n  border: 1px solid var(--color-border);\n  border-radius: 14px;\n  background: rgba(234, 245, 157, 0.1);\n  color: var(--color-text);\n  font: inherit;\n  font-size: 0.92rem;\n  outline: none;\n  transition: border-color 0.2s ease, box-shadow 0.2s ease;\n}\n\n.st-card__input:focus {\n  border-color: var(--color-primary-200);\n  box-shadow: 0 0 0 4px rgba(193, 217, 92, 0.22);\n}\n\n.st-card__textarea {\n  resize: vertical;\n}\n\n.st-card__actions {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 10px;\n}\n\n.st-card__actions .btn {\n  font-size: 0.88rem;\n  padding: 10px 18px;\n}\n\n.st-card__toggles {\n  display: grid;\n  gap: 0;\n}\n\n/* ---- Toggle ---- */\n.st-toggle {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 16px;\n  padding: 14px 0;\n  border-bottom: 1px solid rgba(79, 132, 40, 0.06);\n  cursor: pointer;\n}\n\n.st-toggle:last-child {\n  border-bottom: 0;\n}\n\n.st-toggle__text {\n  display: grid;\n  gap: 3px;\n  min-width: 0;\n}\n\n.st-toggle__label {\n  font-weight: 600;\n  font-size: 0.92rem;\n}\n\n.st-toggle__desc {\n  color: var(--color-text-muted);\n  font-size: 0.82rem;\n  line-height: 1.5;\n}\n\n.st-toggle__switch {\n  flex-shrink: 0;\n}\n\n.st-toggle__input {\n  position: absolute;\n  opacity: 0;\n  width: 0;\n  height: 0;\n}\n\n.st-toggle__track {\n  display: block;\n  position: relative;\n  width: 44px;\n  height: 24px;\n  border-radius: 999px;\n  background: rgba(160, 160, 160, 0.3);\n  transition: background-color 0.25s ease;\n}\n\n.st-toggle__thumb {\n  position: absolute;\n  top: 3px;\n  left: 3px;\n  width: 18px;\n  height: 18px;\n  border-radius: 50%;\n  background: #fff;\n  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.12);\n  transition: transform 0.25s ease;\n}\n\n.st-toggle__switch.is-on .st-toggle__track {\n  background: linear-gradient(135deg, #80B155, #336A29);\n}\n\n.st-toggle__switch.is-on .st-toggle__thumb {\n  transform: translateX(20px);\n}\n\n/* ---- Login History ---- */\n.st-login-history {\n  margin: 0;\n  padding: 0;\n  list-style: none;\n  display: grid;\n  gap: 10px;\n}\n\n.st-login-history li {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  padding: 10px 14px;\n  border-radius: 12px;\n  background: rgba(234, 245, 157, 0.12);\n  border: 1px solid rgba(79, 132, 40, 0.05);\n  font-size: 0.88rem;\n}\n\n.st-login-history__time {\n  font-weight: 600;\n  color: var(--color-primary-500);\n  white-space: nowrap;\n  flex-shrink: 0;\n}\n\n.st-login-history__action {\n  color: var(--color-text-muted);\n}\n\n/* ---- Appearance Grid ---- */\n.st-appearance-grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 14px;\n}\n\n.st-appearance-grid__item {\n  display: grid;\n  gap: 4px;\n  padding: 14px;\n  border-radius: 14px;\n  background: rgba(234, 245, 157, 0.12);\n  border: 1px solid rgba(79, 132, 40, 0.06);\n}\n\n.st-appearance-grid__label {\n  color: var(--color-text-muted);\n  font-size: 0.8rem;\n}\n\n.st-appearance-grid__value {\n  display: inline-flex;\n  align-items: center;\n  gap: 6px;\n  font-weight: 600;\n  font-size: 0.92rem;\n}\n\n.st-appearance-grid__color-dot {\n  display: inline-block;\n  width: 14px;\n  height: 14px;\n  border-radius: 6px;\n  background: linear-gradient(135deg, #80B155, #336A29);\n  flex-shrink: 0;\n}\n\n/* Appearance Preview */\n.st-appearance-preview {\n  display: grid;\n  gap: 8px;\n}\n\n.st-appearance-preview__label {\n  font-weight: 600;\n  font-size: 0.82rem;\n  color: var(--color-text-muted);\n}\n\n.st-appearance-preview__card {\n  display: flex;\n  align-items: center;\n  gap: 14px;\n  padding: 18px;\n  border-radius: 20px;\n  background: linear-gradient(135deg, rgba(234, 245, 157, 0.25), rgba(193, 217, 92, 0.15));\n  border: 1px solid rgba(79, 132, 40, 0.1);\n}\n\n.st-appearance-preview__icon {\n  display: inline-grid;\n  place-items: center;\n  width: 44px;\n  height: 44px;\n  border-radius: 14px;\n  background: rgba(193, 217, 92, 0.5);\n  font-size: 1.2rem;\n  flex-shrink: 0;\n}\n\n.st-appearance-preview__text {\n  display: grid;\n  gap: 2px;\n}\n\n.st-appearance-preview__text strong {\n  font-size: 0.95rem;\n}\n\n.st-appearance-preview__text span {\n  color: var(--color-text-muted);\n  font-size: 0.8rem;\n}\n\n/* ---- Profile Card ---- */\n.st-profile-card__top {\n  display: flex;\n  align-items: center;\n  gap: 14px;\n}\n\n.st-profile-card__avatar {\n  display: inline-grid;\n  place-items: center;\n  width: 52px;\n  height: 52px;\n  border-radius: 18px;\n  background: rgba(193, 217, 92, 0.5);\n  color: var(--color-primary-500);\n  font-weight: 700;\n  font-size: 1.3rem;\n  flex-shrink: 0;\n}\n\n.st-profile-card__info {\n  display: grid;\n  gap: 2px;\n}\n\n.st-profile-card__info strong {\n  font-size: 1.05rem;\n}\n\n.st-profile-card__role {\n  color: var(--color-text-muted);\n  font-size: 0.85rem;\n}\n\n.st-profile-card__details {\n  display: grid;\n  gap: 10px;\n}\n\n.st-profile-card__row {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 8px;\n  font-size: 0.88rem;\n}\n\n.st-profile-card__row > span:first-child {\n  color: var(--color-text-muted);\n}\n\n.st-logout-btn {\n  color: #8a5e2a;\n  border-color: rgba(180, 120, 60, 0.22);\n}\n\n.st-logout-btn:hover {\n  background: rgba(220, 170, 110, 0.12);\n}\n\n/* ---- Badge ---- */\n.st-badge {\n  display: inline-flex;\n  align-items: center;\n  padding: 3px 10px;\n  border-radius: 999px;\n  font-size: 0.78rem;\n  font-weight: 600;\n  white-space: nowrap;\n}\n\n.st-badge--active {\n  color: #2a5e1f;\n  background: rgba(128, 177, 85, 0.26);\n}\n\n.st-badge--warning {\n  color: #8a5e2a;\n  background: rgba(214, 160, 90, 0.24);\n}\n\n/* ---- System Status ---- */\n.st-status-list {\n  display: grid;\n  gap: 10px;\n}\n\n.st-status-list__item {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 8px;\n  padding: 10px 0;\n  border-bottom: 1px solid rgba(79, 132, 40, 0.05);\n  font-size: 0.88rem;\n}\n\n.st-status-list__item:last-child {\n  border-bottom: 0;\n  padding-bottom: 0;\n}\n\n.st-status-list__label {\n  color: var(--color-text);\n}\n\n/* ---- Backup Grid ---- */\n.st-backup-grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 12px;\n}\n\n.st-backup-grid__item {\n  display: grid;\n  gap: 4px;\n  padding: 12px;\n  border-radius: 14px;\n  background: rgba(234, 245, 157, 0.12);\n  border: 1px solid rgba(79, 132, 40, 0.06);\n}\n\n.st-backup-grid__item span {\n  color: var(--color-text-muted);\n  font-size: 0.8rem;\n}\n\n.st-backup-grid__item strong {\n  font-size: 0.95rem;\n}\n\n/* ---- Quick Actions ---- */\n.st-quick-actions {\n  display: grid;\n  gap: 10px;\n}\n\n.st-quick-actions__btn {\n  width: 100%;\n  padding: 12px 16px;\n  border: 1px solid rgba(79, 132, 40, 0.12);\n  border-radius: 14px;\n  background: rgba(234, 245, 157, 0.14);\n  color: var(--color-text);\n  font: inherit;\n  font-size: 0.9rem;\n  font-weight: 600;\n  cursor: pointer;\n  text-align: left;\n  transition: background-color 0.2s ease, transform 0.15s ease;\n}\n\n.st-quick-actions__btn:hover {\n  background: rgba(193, 217, 92, 0.25);\n  transform: translateY(-1px);\n}\n\n.st-quick-actions__btn--warning {\n  color: #8a5e2a;\n  border-color: rgba(180, 120, 60, 0.2);\n  background: rgba(220, 170, 110, 0.08);\n}\n\n.st-quick-actions__btn--warning:hover {\n  background: rgba(220, 170, 110, 0.16);\n}\n\n/* ---- Toast ---- */\n.st-toast {\n  position: fixed;\n  bottom: 32px;\n  left: 50%;\n  transform: translateX(-50%);\n  display: inline-flex;\n  align-items: center;\n  gap: 10px;\n  padding: 14px 24px;\n  border-radius: 999px;\n  background: linear-gradient(135deg, #336a29, #4f8428);\n  color: #fff;\n  font-weight: 600;\n  font-size: 0.95rem;\n  box-shadow: 0 16px 40px rgba(51, 106, 41, 0.3);\n  z-index: 100;\n  animation: st-toast-in 0.3s ease;\n}\n\n.st-toast svg {\n  width: 20px;\n  height: 20px;\n  stroke: currentColor;\n  fill: none;\n  stroke-width: 2;\n  stroke-linecap: round;\n  stroke-linejoin: round;\n  flex-shrink: 0;\n}\n\n/* ---- Animations ---- */\n@keyframes st-toast-in {\n  from {\n    opacity: 0;\n    transform: translateX(-50%) translateY(12px);\n  }\n  to {\n    opacity: 1;\n    transform: translateX(-50%) translateY(0);\n  }\n}\n\n/* ---- Responsive ---- */\n@media (max-width: 1100px) {\n  .st-layout {\n    grid-template-columns: 1fr;\n  }\n\n  .st-layout__sidebar {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 22px;\n  }\n}\n\n@media (max-width: 720px) {\n  .st-layout__sidebar {\n    grid-template-columns: 1fr;\n  }\n\n  .st-appearance-grid {\n    grid-template-columns: 1fr;\n  }\n\n  .st-backup-grid {\n    grid-template-columns: 1fr;\n  }\n\n  .st-login-history li {\n    flex-direction: column;\n    align-items: flex-start;\n    gap: 4px;\n  }\n\n  .st-card__actions {\n    flex-direction: column;\n  }\n\n  .st-card__actions .btn {\n    width: 100%;\n  }\n}\n"],["STYLE",{},".account-page {\n  display: grid;\n  gap: 24px;\n}\n\n.account-page__breadcrumb {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 10px;\n  color: rgba(23, 55, 21, 0.64);\n}\n\n.account-profile-header,\n.account-stats__card,\n.account-panel,\n.account-side-card,\n.account-guest-card {\n  border-radius: 28px;\n  background: rgba(255, 255, 255, 0.96);\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  box-shadow: var(--shadow-card);\n}\n\n.account-profile-header {\n  display: flex;\n  justify-content: space-between;\n  gap: 24px;\n  align-items: center;\n  padding: 28px;\n  background:\n    radial-gradient(circle at top right, rgba(234, 245, 157, 0.42), transparent 26%),\n    rgba(255, 255, 255, 0.96);\n}\n\n.account-profile-header__identity,\n.account-profile-header__meta,\n.account-profile-header__actions,\n.account-my-posts__meta,\n.account-my-posts__actions,\n.account-comments__footer {\n  display: flex;\n  align-items: center;\n}\n\n.account-profile-header__identity {\n  gap: 18px;\n}\n\n.account-profile-header__avatar {\n  display: grid;\n  place-items: center;\n  width: 84px;\n  height: 84px;\n  border-radius: 50%;\n  color: #fff;\n  font-size: 1.6rem;\n  font-weight: 800;\n  background: linear-gradient(135deg, var(--color-primary-300), var(--color-primary-500));\n}\n\n.account-profile-header__content h1 {\n  margin: 0 0 8px;\n  font-size: clamp(2rem, 4vw, 3rem);\n  letter-spacing: -0.04em;\n}\n\n.account-profile-header__content p,\n.account-my-posts__meta,\n.account-saved-posts__item p,\n.account-comments__item span,\n.account-side-card__rows span,\n.account-history-list__item span,\n.account-side-card__empty,\n.account-settings__message,\n.account-side-card--tips p,\n.account-guest-card p {\n  margin: 0;\n  color: var(--color-text-muted);\n}\n\n.account-profile-header__meta {\n  flex-wrap: wrap;\n  gap: 12px;\n  margin-top: 12px;\n}\n\n.account-profile-header__badge {\n  padding: 8px 12px;\n  border-radius: 999px;\n  color: var(--color-primary-500);\n  background: rgba(193, 217, 92, 0.28);\n  font-size: 0.86rem;\n  font-weight: 700;\n}\n\n.account-profile-header__actions {\n  flex-wrap: wrap;\n  justify-content: flex-end;\n  gap: 12px;\n}\n\n.account-profile-header__secondary {\n  color: var(--color-primary-500);\n  background: rgba(234, 245, 157, 0.8);\n}\n\n.account-profile-header__logout {\n  color: #8a5a0b;\n  background: rgba(246, 224, 177, 0.42);\n  border-color: rgba(214, 162, 74, 0.22);\n}\n\n.account-stats {\n  display: grid;\n  grid-template-columns: repeat(4, minmax(0, 1fr));\n  gap: 18px;\n}\n\n.account-stats__card {\n  display: grid;\n  gap: 8px;\n  padding: 22px;\n}\n\n.account-stats__card span {\n  color: rgba(23, 55, 21, 0.64);\n}\n\n.account-stats__card strong {\n  font-size: 2rem;\n  letter-spacing: -0.04em;\n}\n\n.account-layout {\n  display: grid;\n  grid-template-columns: minmax(0, 1.65fr) minmax(300px, 0.92fr);\n  gap: 24px;\n  align-items: start;\n}\n\n.account-layout__main,\n.account-layout__side,\n.account-my-posts,\n.account-saved-posts,\n.account-comments,\n.account-side-card__rows,\n.account-history-list,\n.account-settings {\n  display: grid;\n  gap: 16px;\n}\n\n.account-panel,\n.account-side-card {\n  padding: 22px;\n}\n\n.account-panel__header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 12px;\n  margin-bottom: 18px;\n}\n\n.account-panel__header h2,\n.account-side-card h2,\n.account-guest-card h1 {\n  margin: 0;\n  font-size: 1.6rem;\n  letter-spacing: -0.03em;\n}\n\n.account-panel__header a {\n  color: var(--color-primary-500);\n  font-weight: 700;\n}\n\n.account-my-posts__item,\n.account-saved-posts__item,\n.account-comments__item,\n.account-history-list__item {\n  padding: 16px;\n  border-radius: 18px;\n  background: linear-gradient(180deg, rgba(234, 245, 157, 0.22), rgba(255, 255, 255, 0.96));\n  border: 1px solid rgba(79, 132, 40, 0.08);\n}\n\n.account-my-posts__item {\n  display: flex;\n  justify-content: space-between;\n  gap: 16px;\n  align-items: center;\n}\n\n.account-my-posts__top {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 10px;\n  align-items: center;\n  margin-bottom: 8px;\n}\n\n.account-my-posts__top h3,\n.account-saved-posts__item h3 {\n  margin: 0;\n  font-size: 1.18rem;\n}\n\n.account-my-posts__status {\n  padding: 8px 10px;\n  border-radius: 999px;\n  font-size: 0.76rem;\n  font-weight: 700;\n}\n\n.account-my-posts__status.is-approved {\n  color: var(--color-primary-500);\n  background: rgba(193, 217, 92, 0.3);\n}\n\n.account-my-posts__status.is-pending {\n  color: #8a5a0b;\n  background: rgba(246, 224, 177, 0.46);\n}\n\n.account-my-posts__meta,\n.account-my-posts__actions {\n  gap: 16px;\n}\n\n.account-my-posts__actions button,\n.account-comments__footer button,\n.account-saved-posts__item a {\n  border: 0;\n  padding: 0;\n  color: var(--color-primary-500);\n  background: transparent;\n  font: inherit;\n  font-weight: 700;\n}\n\n.account-saved-posts__category {\n  display: inline-flex;\n  margin-bottom: 8px;\n  padding: 8px 10px;\n  border-radius: 999px;\n  color: var(--color-primary-500);\n  background: rgba(193, 217, 92, 0.24);\n  font-size: 0.78rem;\n  font-weight: 700;\n}\n\n.account-saved-posts__item,\n.account-history-list__item {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 16px;\n}\n\n.account-comments__item p {\n  margin: 0 0 10px;\n  line-height: 1.72;\n}\n\n.account-comments__footer {\n  justify-content: space-between;\n  gap: 12px;\n  margin-top: 10px;\n}\n\n.account-side-card__rows div {\n  display: flex;\n  justify-content: space-between;\n  gap: 16px;\n  align-items: center;\n  padding-bottom: 12px;\n  border-bottom: 1px solid rgba(79, 132, 40, 0.08);\n}\n\n.account-side-card__rows strong,\n.account-history-list__item strong,\n.account-history-list__item em {\n  font-style: normal;\n}\n\n.account-side-card__button {\n  width: 100%;\n  color: var(--color-primary-500);\n  background: rgba(193, 217, 92, 0.46);\n}\n\n.account-settings button {\n  display: flex;\n  justify-content: space-between;\n  gap: 16px;\n  align-items: center;\n  border: 0;\n  padding: 0;\n  color: var(--color-text);\n  background: transparent;\n  text-align: left;\n  font: inherit;\n}\n\n.account-toggle {\n  position: relative;\n  width: 48px;\n  height: 28px;\n  border-radius: 999px;\n  background: rgba(115, 121, 106, 0.35);\n  transition: background-color 0.2s ease;\n}\n\n.account-toggle::after {\n  content: '';\n  position: absolute;\n  top: 4px;\n  left: 4px;\n  width: 20px;\n  height: 20px;\n  border-radius: 50%;\n  background: #fff;\n  transition: transform 0.2s ease;\n}\n\n.account-toggle.is-on {\n  background: var(--color-primary-400);\n}\n\n.account-toggle.is-on::after {\n  transform: translateX(20px);\n}\n\n.account-settings__submit {\n  width: 100%;\n  margin-top: 4px;\n}\n\n.account-settings__message {\n  font-size: 0.92rem;\n  font-weight: 600;\n}\n\n.account-side-card--tips {\n  background:\n    radial-gradient(circle at top right, rgba(234, 245, 157, 0.42), transparent 30%),\n    linear-gradient(180deg, rgba(193, 217, 92, 0.2), rgba(255, 255, 255, 0.96));\n}\n\n.account-side-card--tips p {\n  line-height: 1.78;\n}\n\n.account-page--guest {\n  min-height: 60vh;\n  place-items: center;\n}\n\n.account-guest-card {\n  width: min(100%, 640px);\n  display: grid;\n  gap: 16px;\n  padding: 36px;\n  text-align: center;\n}\n\n.account-guest-card__actions {\n  display: flex;\n  justify-content: center;\n  gap: 14px;\n  flex-wrap: wrap;\n}\n\n@media (max-width: 1180px) {\n  .account-layout {\n    grid-template-columns: 1fr;\n  }\n\n  .account-stats {\n    grid-template-columns: repeat(2, minmax(0, 1fr));\n  }\n}\n\n@media (max-width: 760px) {\n  .account-profile-header,\n  .account-my-posts__item,\n  .account-saved-posts__item,\n  .account-history-list__item,\n  .account-panel__header,\n  .account-side-card__rows div,\n  .account-comments__footer {\n    flex-direction: column;\n    align-items: flex-start;\n  }\n\n  .account-profile-header__actions {\n    width: 100%;\n    justify-content: stretch;\n  }\n\n  .account-profile-header__actions .btn {\n    width: 100%;\n  }\n\n  .account-stats {\n    grid-template-columns: 1fr;\n  }\n\n  .account-panel,\n  .account-side-card,\n  .account-profile-header,\n  .account-guest-card {\n    padding: 20px;\n  }\n}\n"],["STYLE",{},".static-page {\n  display: grid;\n  gap: 28px;\n}\n\n.static-page__breadcrumb {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 10px;\n  color: rgba(23, 55, 21, 0.64);\n}\n\n.static-page__hero,\n.static-page__mission,\n.static-page__card,\n.static-page__value-card,\n.static-page__terms-menu,\n.static-page__terms-content,\n.static-page__contact-form-card,\n.static-page__contact-card,\n.static-page__cta {\n  border-radius: 30px;\n  background: rgba(255, 255, 255, 0.96);\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  box-shadow: var(--shadow-card);\n}\n\n.static-page__hero {\n  position: relative;\n  overflow: hidden;\n  display: grid;\n  gap: 24px;\n  padding: 34px;\n}\n\n.static-page__hero--about {\n  grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.92fr);\n  align-items: center;\n  background:\n    radial-gradient(circle at top left, rgba(234, 245, 157, 0.6), transparent 28%),\n    linear-gradient(180deg, rgba(236, 255, 221, 0.94), rgba(255, 255, 255, 0.96));\n}\n\n.static-page__hero--terms,\n.static-page__hero--contact {\n  background:\n    radial-gradient(circle at top left, rgba(234, 245, 157, 0.48), transparent 22%),\n    linear-gradient(180deg, rgba(242, 251, 226, 0.94), rgba(255, 255, 255, 0.96));\n}\n\n.static-page__hero-content h1,\n.static-page__section-header h2,\n.static-page__mission h2,\n.static-page__cta h2 {\n  margin: 0 0 16px;\n  font-size: clamp(2.6rem, 5vw, 4.4rem);\n  line-height: 1.02;\n  letter-spacing: -0.05em;\n}\n\n.static-page__section-header h2,\n.static-page__mission h2,\n.static-page__cta h2 {\n  font-size: clamp(2rem, 4vw, 3.6rem);\n  text-align: center;\n}\n\n.static-page__hero-content p,\n.static-page__mission p,\n.static-page__card p,\n.static-page__terms-item p,\n.static-page__contact-card strong,\n.static-page__message,\n.static-page__contact-actions span {\n  margin: 0;\n  color: var(--color-text-muted);\n  line-height: 1.82;\n}\n\n.static-page__hero-content--centered {\n  text-align: center;\n}\n\n.static-page__hero-visual img {\n  display: block;\n  width: 100%;\n  min-height: 280px;\n  border-radius: 26px;\n  object-fit: cover;\n  box-shadow: var(--shadow-soft);\n}\n\n.static-page__mission,\n.static-page__cta {\n  display: grid;\n  gap: 14px;\n  justify-items: center;\n  padding: 44px 30px;\n  text-align: center;\n}\n\n.static-page__section {\n  display: grid;\n  gap: 24px;\n}\n\n.static-page__grid {\n  display: grid;\n  gap: 20px;\n}\n\n.static-page__grid--four {\n  grid-template-columns: repeat(4, minmax(0, 1fr));\n}\n\n.static-page__grid--three {\n  grid-template-columns: repeat(3, minmax(0, 1fr));\n}\n\n.static-page__card,\n.static-page__value-card {\n  padding: 24px;\n}\n\n.static-page__card h3,\n.static-page__terms-menu h2,\n.static-page__terms-item h3,\n.static-page__contact-form-card h2,\n.static-page__contact-card h2 {\n  margin: 0 0 10px;\n  font-size: 1.48rem;\n  letter-spacing: -0.03em;\n}\n\n.static-page__value-card {\n  display: grid;\n  place-items: center;\n  min-height: 120px;\n  background: linear-gradient(180deg, rgba(183, 246, 157, 0.68), rgba(214, 255, 195, 0.92));\n}\n\n.static-page__value-card strong {\n  font-size: 1.5rem;\n}\n\n.static-page__cta {\n  background:\n    radial-gradient(circle at top right, rgba(234, 245, 157, 0.42), transparent 24%),\n    linear-gradient(180deg, rgba(183, 246, 157, 0.66), rgba(214, 255, 195, 0.92));\n}\n\n.static-page__cta-actions {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 14px;\n}\n\n.static-page__terms-layout,\n.static-page__contact-layout {\n  display: grid;\n  grid-template-columns: minmax(280px, 0.72fr) minmax(0, 1.28fr);\n  gap: 24px;\n  align-items: start;\n}\n\n.static-page__terms-menu,\n.static-page__terms-content,\n.static-page__contact-form-card,\n.static-page__contact-card {\n  padding: 24px;\n}\n\n.static-page__terms-menu {\n  position: sticky;\n  top: 112px;\n}\n\n.static-page__terms-menu ol {\n  display: grid;\n  gap: 12px;\n  margin: 0;\n  padding-left: 18px;\n}\n\n.static-page__terms-menu a {\n  color: var(--color-text);\n}\n\n.static-page__terms-content {\n  display: grid;\n  gap: 18px;\n}\n\n.static-page__terms-item {\n  padding-bottom: 18px;\n  border-bottom: 1px solid rgba(79, 132, 40, 0.08);\n}\n\n.static-page__terms-heading {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  margin-bottom: 10px;\n}\n\n.static-page__terms-heading span {\n  display: grid;\n  place-items: center;\n  width: 34px;\n  height: 34px;\n  border-radius: 50%;\n  color: #fff;\n  font-weight: 800;\n  background: var(--color-primary-400);\n}\n\n.static-page__terms-note {\n  justify-self: end;\n  color: rgba(23, 55, 21, 0.72);\n  font-style: italic;\n}\n\n.static-page__contact-form-card {\n  display: grid;\n  gap: 18px;\n}\n\n.static-page__contact-form,\n.static-page__contact-side,\n.static-page__contact-info,\n.static-page__faq {\n  display: grid;\n  gap: 16px;\n}\n\n.static-page__form-row {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: 16px;\n}\n\n.static-page__contact-form label {\n  display: grid;\n  gap: 10px;\n}\n\n.static-page__contact-form label span {\n  font-weight: 700;\n}\n\n.static-page__contact-form input,\n.static-page__contact-form select,\n.static-page__contact-form textarea {\n  width: 100%;\n  min-width: 0;\n  border: 1px solid rgba(79, 132, 40, 0.1);\n  border-radius: 16px;\n  padding: 14px 16px;\n  background: linear-gradient(90deg, rgba(247, 250, 239, 0.98), rgba(234, 245, 157, 0.24));\n  font: inherit;\n}\n\n.static-page__message {\n  padding: 14px 16px;\n  border-radius: 16px;\n  font-weight: 600;\n}\n\n.static-page__message--error {\n  color: #8a5a0b;\n  background: rgba(246, 224, 177, 0.5);\n  border: 1px solid rgba(214, 162, 74, 0.24);\n}\n\n.static-page__message--success {\n  color: var(--color-primary-500);\n  background: rgba(234, 245, 157, 0.34);\n  border: 1px solid rgba(79, 132, 40, 0.16);\n}\n\n.static-page__contact-actions {\n  display: flex;\n  justify-content: space-between;\n  gap: 16px;\n  align-items: center;\n  flex-wrap: wrap;\n}\n\n.static-page__contact-card {\n  display: grid;\n  gap: 16px;\n}\n\n.static-page__contact-info div {\n  display: grid;\n  gap: 4px;\n  padding-bottom: 12px;\n  border-bottom: 1px solid rgba(79, 132, 40, 0.08);\n}\n\n.static-page__contact-info span {\n  color: rgba(23, 55, 21, 0.68);\n}\n\n.static-page__faq article {\n  padding: 16px;\n  border-radius: 18px;\n  background: linear-gradient(180deg, rgba(234, 245, 157, 0.2), rgba(255, 255, 255, 0.96));\n}\n\n@media (max-width: 1180px) {\n  .static-page__hero--about,\n  .static-page__terms-layout,\n  .static-page__contact-layout {\n    grid-template-columns: 1fr;\n  }\n\n  .static-page__grid--four {\n    grid-template-columns: repeat(2, minmax(0, 1fr));\n  }\n\n  .static-page__terms-menu {\n    position: static;\n  }\n}\n\n@media (max-width: 720px) {\n  .static-page__grid--three,\n  .static-page__grid--four,\n  .static-page__form-row {\n    grid-template-columns: 1fr;\n  }\n\n  .static-page__hero,\n  .static-page__mission,\n  .static-page__terms-menu,\n  .static-page__terms-content,\n  .static-page__contact-form-card,\n  .static-page__contact-card,\n  .static-page__cta {\n    padding: 22px;\n  }\n\n  .static-page__cta-actions,\n  .static-page__contact-actions {\n    flex-direction: column;\n    align-items: stretch;\n  }\n}\n"],["STYLE",{},".community-page {\n  display: grid;\n  gap: 28px;\n}\n\n.community-page__hero {\n  position: relative;\n  overflow: hidden;\n  display: grid;\n  grid-template-columns: minmax(0, 1.05fr) minmax(360px, 0.88fr);\n  gap: 28px;\n  align-items: center;\n  padding: 36px;\n  border-radius: 34px;\n  background:\n    radial-gradient(circle at top right, rgba(234, 245, 157, 0.52), transparent 28%),\n    linear-gradient(180deg, rgba(216, 251, 191, 0.94) 0%, rgba(236, 255, 221, 0.96) 100%);\n  box-shadow: var(--shadow-soft);\n}\n\n.community-page__hero::after {\n  content: '';\n  position: absolute;\n  right: -88px;\n  top: -56px;\n  width: 260px;\n  height: 260px;\n  border-radius: 50%;\n  background: rgba(193, 217, 92, 0.2);\n  filter: blur(20px);\n}\n\n.community-page__hero-content,\n.community-page__feed {\n  display: grid;\n  gap: 20px;\n  min-width: 0;\n}\n\n.community-page__badge {\n  display: inline-flex;\n  align-items: center;\n  width: fit-content;\n  padding: 10px 16px;\n  border-radius: 999px;\n  color: var(--color-primary-500);\n  background: rgba(193, 217, 92, 0.28);\n  font-size: 0.92rem;\n  font-weight: 700;\n}\n\n.community-page__hero-content h1 {\n  margin: 0;\n  font-size: clamp(2.8rem, 5.5vw, 4.6rem);\n  line-height: 1;\n  letter-spacing: -0.05em;\n}\n\n.community-page__hero-content p {\n  max-width: 700px;\n  margin: 0;\n  color: var(--color-text-muted);\n  font-size: 1.04rem;\n  line-height: 1.85;\n}\n\n.community-page__hero-actions {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 14px;\n}\n\n.community-page__hero-visual {\n  position: relative;\n  z-index: 1;\n}\n\n.community-page__hero-visual img {\n  display: block;\n  width: 100%;\n  min-height: 280px;\n  border-radius: 26px;\n  object-fit: cover;\n  box-shadow: 0 18px 44px rgba(79, 132, 40, 0.16);\n}\n\n.community-page__layout {\n  display: grid;\n  grid-template-columns: minmax(0, 1fr) 320px;\n  gap: 24px;\n  align-items: start;\n}\n\n.community-composer,\n.community-post-card,\n.community-sidebar-panel__card,\n.community-page__empty {\n  border-radius: 28px;\n  background: rgba(255, 255, 255, 0.96);\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  box-shadow: var(--shadow-card);\n}\n\n.community-composer {\n  display: grid;\n  gap: 18px;\n  padding: 22px 24px;\n}\n\n.community-composer__top {\n  display: grid;\n  grid-template-columns: auto minmax(0, 1fr) auto;\n  gap: 14px;\n  align-items: center;\n}\n\n.community-composer__avatar {\n  width: 52px;\n  height: 52px;\n  border-radius: 50%;\n  object-fit: cover;\n}\n\n.community-composer__prompt {\n  min-height: 54px;\n  display: flex;\n  align-items: center;\n  padding: 0 18px;\n  border-radius: 16px;\n  color: rgba(51, 106, 41, 0.7);\n  background: linear-gradient(90deg, rgba(234, 245, 157, 0.42), rgba(193, 217, 92, 0.18));\n  cursor: pointer;\n  transition: opacity 0.2s;\n}\n\n.community-composer__prompt:hover {\n  opacity: 0.8;\n}\n\n.community-composer__button {\n  white-space: nowrap;\n}\n\n.community-composer__actions {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 22px;\n  padding-top: 14px;\n  border-top: 1px solid rgba(79, 132, 40, 0.1);\n  color: var(--color-text);\n  font-size: 0.95rem;\n}\n\n.community-composer__actions a {\n  cursor: pointer;\n  transition: color 0.2s;\n}\n\n.community-composer__actions a:hover {\n  color: var(--color-primary-500);\n}\n\n.community-filter-bar {\n  display: flex;\n  gap: 10px;\n  overflow-x: auto;\n  padding-bottom: 4px;\n}\n\n.community-filter-bar__chip {\n  flex: 0 0 auto;\n  padding: 12px 18px;\n  border: 1px solid rgba(79, 132, 40, 0.12);\n  border-radius: 999px;\n  color: rgba(23, 55, 21, 0.78);\n  background: rgba(255, 255, 255, 0.9);\n  font-weight: 600;\n}\n\n.community-filter-bar__chip.is-active {\n  color: #fff;\n  background: var(--color-primary-500);\n  box-shadow: 0 10px 20px rgba(79, 132, 40, 0.14);\n}\n\n.community-page__posts {\n  display: grid;\n  gap: 18px;\n}\n\n.community-sidebar-panel {\n  display: grid;\n  gap: 18px;\n  width: 100%;\n  position: sticky;\n  top: 96px;\n}\n\n.community-post-card {\n  display: grid;\n  gap: 18px;\n  padding: 24px;\n}\n\n.community-post-card__header,\n.community-post-card__author,\n.community-post-card__actions,\n.community-sidebar-panel__member {\n  display: flex;\n  align-items: center;\n}\n\n.community-post-card__header {\n  justify-content: space-between;\n  gap: 12px;\n}\n\n.community-post-card__author {\n  gap: 12px;\n}\n\n.community-post-card__author img,\n.community-post-card__comment img,\n.community-sidebar-panel__member img {\n  border-radius: 50%;\n  object-fit: cover;\n}\n\n.community-post-card__author img {\n  width: 44px;\n  height: 44px;\n}\n\n.community-post-card__author strong,\n.community-post-card__comment strong,\n.community-sidebar-panel__member strong,\n.community-sidebar-panel__popular strong {\n  display: block;\n}\n\n.community-post-card__author span,\n.community-post-card__body p,\n.community-post-card__comment p,\n.community-sidebar-panel__member span,\n.community-sidebar-panel__popular span,\n.community-sidebar-panel__card p,\n.community-sidebar-panel__card li {\n  color: var(--color-text-muted);\n}\n\n.community-post-card__menu {\n  color: rgba(23, 55, 21, 0.54);\n  font-weight: 800;\n}\n\n.community-post-card__tags {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 8px;\n}\n\n.community-post-card__tag {\n  padding: 8px 12px;\n  border-radius: 999px;\n  color: rgba(23, 55, 21, 0.72);\n  background: rgba(234, 245, 157, 0.16);\n  font-size: 0.78rem;\n  font-weight: 700;\n}\n\n.community-post-card__tag--primary {\n  color: var(--color-primary-500);\n  background: rgba(193, 217, 92, 0.3);\n}\n\n.community-post-card__body h2,\n.community-post-card__body p,\n.community-post-card__comment p {\n  overflow-wrap: anywhere;\n  word-break: break-word;\n  min-width: 0;\n}\n\n.community-post-card__body h2 {\n  margin: 0 0 10px;\n  font-size: clamp(1.6rem, 3vw, 2.3rem);\n  line-height: 1.2;\n  letter-spacing: -0.04em;\n}\n\n.community-post-card__body p {\n  margin: 0;\n  line-height: 1.78;\n}\n\n.community-post-card__media {\n  overflow: hidden;\n  border-radius: 22px;\n}\n\n.community-post-card__media img {\n  display: block;\n  width: 100%;\n  max-height: 520px;\n  object-fit: cover;\n  border-radius: 18px;\n}\n\n.community-post-card__comments {\n  display: grid;\n  gap: 12px;\n}\n\n.community-post-card__comment {\n  display: grid;\n  grid-template-columns: auto minmax(0, 1fr);\n  gap: 12px;\n  padding: 12px;\n  border-radius: 18px;\n  background: linear-gradient(180deg, rgba(234, 245, 157, 0.22), rgba(255, 255, 255, 0.96));\n}\n\n.community-post-card__comment img {\n  width: 36px;\n  height: 36px;\n}\n\n.community-post-card__comment p {\n  margin: 4px 0 0;\n  line-height: 1.65;\n}\n\n.community-post-card__actions {\n  flex-wrap: wrap;\n  gap: 12px;\n  justify-content: space-between;\n  padding-top: 16px;\n  border-top: 1px solid rgba(79, 132, 40, 0.1);\n}\n\n.community-post-card__actions button {\n  border: 0;\n  padding: 8px 12px;\n  border-radius: 8px;\n  color: rgba(23, 55, 21, 0.76);\n  background: transparent;\n  font-weight: 600;\n  cursor: pointer;\n  transition: all 0.2s ease;\n  display: flex;\n  align-items: center;\n  gap: 6px;\n}\n\n.community-post-card__actions button:hover {\n  background: rgba(193, 217, 92, 0.15);\n  color: var(--color-primary-500);\n}\n\n.community-post-card__actions button.is-active {\n  color: var(--color-primary-500);\n  background: rgba(193, 217, 92, 0.1);\n}\n\n.community-post-card__comment-input-area {\n  display: flex;\n  gap: 12px;\n  margin-top: 16px;\n  align-items: flex-start;\n}\n\n.community-post-card__comment-input-area img {\n  width: 36px;\n  height: 36px;\n  border-radius: 50%;\n  object-fit: cover;\n}\n\n.community-post-card__comment-input-area textarea {\n  flex: 1;\n  padding: 12px;\n  border: 1px solid rgba(79, 132, 40, 0.15);\n  border-radius: 12px;\n  resize: none;\n  font-family: inherit;\n  font-size: 0.95rem;\n  background: rgba(250, 250, 250, 0.9);\n}\n\n.community-post-card__comment-input-area textarea:focus {\n  outline: none;\n  border-color: var(--color-primary-500);\n  background: #fff;\n}\n\n.community-post-card__share-modal {\n  position: absolute;\n  background: #fff;\n  border: 1px solid rgba(79, 132, 40, 0.15);\n  border-radius: 12px;\n  box-shadow: 0 10px 25px rgba(0,0,0,0.1);\n  padding: 12px;\n  display: flex;\n  flex-direction: column;\n  gap: 8px;\n  z-index: 100;\n  bottom: 100%;\n  right: 0;\n  margin-bottom: 8px;\n  min-width: 200px;\n}\n\n.community-post-card__share-option {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  padding: 10px 12px;\n  border-radius: 8px;\n  cursor: pointer;\n  background: transparent;\n  border: none;\n  text-align: left;\n  font-weight: 500;\n  color: #333;\n  transition: background 0.2s;\n}\n\n.community-post-card__share-option:hover {\n  background: rgba(193, 217, 92, 0.15);\n}\n\n.community-sidebar-panel__card {\n  display: grid;\n  gap: 16px;\n  padding: 22px;\n}\n\n.community-sidebar-panel__card h2,\n.community-page__empty h2 {\n  margin: 0;\n  font-size: 1.5rem;\n  letter-spacing: -0.03em;\n}\n\n.community-sidebar-panel__members,\n.community-sidebar-panel__popular {\n  display: grid;\n  gap: 14px;\n}\n\n.community-sidebar-panel__member {\n  gap: 12px;\n}\n\n.community-sidebar-panel__member img {\n  width: 42px;\n  height: 42px;\n}\n\n.community-sidebar-panel__member em {\n  margin-left: auto;\n  padding: 8px 10px;\n  border-radius: 12px;\n  color: var(--color-primary-500);\n  background: rgba(234, 245, 157, 0.54);\n  font-size: 0.76rem;\n  font-style: normal;\n  font-weight: 800;\n}\n\n.community-sidebar-panel__topics {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 8px;\n}\n\n.community-sidebar-panel__topics span {\n  padding: 10px 14px;\n  border-radius: 999px;\n  background: rgba(193, 217, 92, 0.24);\n  color: rgba(23, 55, 21, 0.82);\n  font-size: 0.88rem;\n  font-weight: 600;\n}\n\n.community-sidebar-panel__card--rules {\n  background: linear-gradient(180deg, rgba(234, 245, 157, 0.26), rgba(255, 255, 255, 0.96));\n}\n\n.community-sidebar-panel__card--rules ul {\n  display: grid;\n  gap: 8px;\n  margin: 0;\n  padding-left: 18px;\n  line-height: 1.7;\n}\n\n.community-sidebar-panel__popular article {\n  display: grid;\n  gap: 6px;\n}\n\n.community-sidebar-panel__card--cta {\n  color: #fff;\n  background: linear-gradient(180deg, var(--color-primary-400), var(--color-primary-500));\n}\n\n.community-sidebar-panel__card--cta p {\n  color: rgba(255, 255, 255, 0.84);\n  line-height: 1.75;\n}\n\n.community-page__more {\n  display: flex;\n  justify-content: center;\n  padding-top: 8px;\n}\n\n.community-page__empty {\n  justify-items: center;\n  gap: 14px;\n  padding: 38px 24px;\n  text-align: center;\n}\n\n.community-page__empty span {\n  display: grid;\n  place-items: center;\n  width: 72px;\n  height: 72px;\n  border-radius: 50%;\n  color: var(--color-primary-500);\n  background: rgba(193, 217, 92, 0.34);\n  font-size: 0.92rem;\n  font-weight: 800;\n}\n\n@media (max-width: 1180px) {\n  .community-page__hero {\n    grid-template-columns: 1fr;\n  }\n}\n\n@media (max-width: 1024px) {\n  .community-page__layout {\n    grid-template-columns: 1fr;\n  }\n\n  .community-sidebar-panel {\n    position: static;\n  }\n}\n\n@media (max-width: 820px) {\n  .community-page__hero,\n  .community-post-card,\n  .community-composer,\n  .community-sidebar-panel__card {\n    padding: 20px;\n  }\n\n  .community-composer__top {\n    grid-template-columns: 1fr;\n  }\n\n  .community-composer__avatar {\n    width: 48px;\n    height: 48px;\n  }\n\n  .community-composer__button {\n    width: 100%;\n  }\n}\n\n@media (max-width: 640px) {\n  .community-page__hero-actions,\n  .community-post-card__header,\n  .community-post-card__actions {\n    flex-direction: column;\n    align-items: flex-start;\n  }\n\n  .community-page__hero {\n    padding: 22px;\n    border-radius: 28px;\n  }\n\n  .community-post-card__body h2 {\n    font-size: 1.45rem;\n  }\n}\n"],["STYLE",{},".create-post-page {\n  display: grid;\n  gap: 26px;\n  box-sizing: border-box;\n  max-width: 100%;\n  min-width: 0;\n}\n\n.create-post-page__hero {\n  display: grid;\n  grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.92fr);\n  gap: 28px;\n  align-items: center;\n}\n\n.create-post-page__hero-content {\n  display: grid;\n  gap: 18px;\n}\n\n.create-post-page__badge {\n  display: inline-flex;\n  width: fit-content;\n  padding: 10px 16px;\n  border-radius: 999px;\n  color: var(--color-primary-500);\n  background: rgba(193, 217, 92, 0.24);\n  font-size: 0.92rem;\n  font-weight: 700;\n}\n\n.create-post-page__hero-content h1 {\n  margin: 0;\n  font-size: clamp(2.8rem, 5vw, 4.4rem);\n  line-height: 1.02;\n  letter-spacing: -0.05em;\n}\n\n.create-post-page__hero-content p,\n.create-post-page__alert p,\n.create-post-sidebar__card p,\n.create-post-sidebar__card li {\n  margin: 0;\n  color: var(--color-text-muted);\n  line-height: 1.8;\n}\n\n.create-post-page__hero-visual img {\n  display: block;\n  width: 100%;\n  min-height: 240px;\n  object-fit: cover;\n  border-radius: 30px;\n  box-shadow: var(--shadow-soft);\n}\n\n.create-post-page__alert {\n  display: grid;\n  gap: 8px;\n  padding: 22px 24px;\n  border-radius: 24px;\n  background: linear-gradient(180deg, rgba(193, 217, 92, 0.28), rgba(183, 246, 157, 0.52));\n  border: 1px solid rgba(79, 132, 40, 0.14);\n  box-shadow: var(--shadow-card);\n}\n\n.create-post-page__layout {\n  display: grid;\n  grid-template-columns: minmax(0, 1.75fr) minmax(0, 0.9fr);\n  gap: 24px;\n  align-items: start;\n}\n\n.create-post-form,\n.create-post-sidebar__card {\n  border-radius: 30px;\n  background: rgba(255, 255, 255, 0.96);\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  box-shadow: var(--shadow-card);\n}\n\n.create-post-form {\n  display: grid;\n  gap: 20px;\n  padding: 28px;\n}\n\n.create-post-form__messages {\n  display: grid;\n  gap: 10px;\n}\n\n.create-post-form__message {\n  padding: 14px 16px;\n  border-radius: 16px;\n  font-weight: 600;\n}\n\n.create-post-form__message--error {\n  color: #8a5a0b;\n  background: rgba(246, 224, 177, 0.5);\n  border: 1px solid rgba(214, 162, 74, 0.24);\n}\n\n.create-post-form__message--success {\n  color: var(--color-primary-500);\n  background: rgba(234, 245, 157, 0.34);\n  border: 1px solid rgba(79, 132, 40, 0.16);\n}\n\n.create-post-form__message--info {\n  color: rgba(23, 55, 21, 0.82);\n  background: rgba(193, 217, 92, 0.18);\n  border: 1px solid rgba(79, 132, 40, 0.12);\n}\n\n.create-post-form__field {\n  display: grid;\n  gap: 10px;\n}\n\n.create-post-form__field span,\n.create-post-sidebar__card h2 {\n  margin: 0;\n  font-weight: 700;\n}\n\n.create-post-form__field input,\n.create-post-form__field select,\n.create-post-form__field textarea {\n  width: 100%;\n  min-width: 0;\n  border: 1px solid rgba(79, 132, 40, 0.1);\n  border-radius: 16px;\n  padding: 14px 16px;\n  background: linear-gradient(90deg, rgba(234, 245, 157, 0.36), rgba(255, 255, 255, 0.95));\n  font: inherit;\n}\n\n.create-post-form__row {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: 18px;\n}\n\n.create-post-form__file-input {\n  position: absolute;\n  width: 1px;\n  height: 1px;\n  opacity: 0;\n  pointer-events: none;\n}\n\n.create-post-form__upload-box {\n  display: grid;\n  justify-items: center;\n  gap: 8px;\n  padding: 36px 20px;\n  border: 2px dashed rgba(115, 121, 106, 0.32);\n  border-radius: 22px;\n  text-align: center;\n  background: linear-gradient(180deg, rgba(234, 245, 157, 0.36), rgba(255, 255, 255, 0.9));\n}\n\n.create-post-form__upload-box small,\n.create-post-form__upload-box em,\n.create-post-sidebar__timeline span,\n.create-post-sidebar__preview-meta small {\n  color: var(--color-text-muted);\n}\n\n.create-post-form__upload-box em {\n  font-style: normal;\n  font-weight: 700;\n}\n\n.create-post-form__content {\n  min-height: 280px;\n  resize: vertical;\n}\n\n.create-post-form__actions {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 14px;\n  justify-content: flex-end;\n  padding-top: 6px;\n}\n\n.create-post-form__draft {\n  color: var(--color-primary-500);\n  background: rgba(193, 217, 92, 0.65);\n}\n\n.create-post-sidebar {\n  display: grid;\n  gap: 18px;\n}\n\n.create-post-sidebar__card {\n  display: grid;\n  gap: 16px;\n  padding: 22px;\n}\n\n.create-post-sidebar__timeline {\n  position: relative;\n  display: grid;\n  gap: 20px;\n  padding-left: 20px;\n}\n\n.create-post-sidebar__timeline::before {\n  content: '';\n  position: absolute;\n  left: 5px;\n  top: 6px;\n  bottom: 6px;\n  width: 2px;\n  background: rgba(115, 121, 106, 0.24);\n}\n\n.create-post-sidebar__timeline div {\n  position: relative;\n  display: grid;\n  gap: 4px;\n}\n\n.create-post-sidebar__timeline div::before {\n  content: '';\n  position: absolute;\n  left: -20px;\n  top: 8px;\n  width: 12px;\n  height: 12px;\n  border-radius: 50%;\n  background: rgba(115, 121, 106, 0.28);\n}\n\n.create-post-sidebar__timeline .is-active::before {\n  background: var(--color-primary-500);\n}\n\n.create-post-sidebar__preview {\n  overflow: hidden;\n  border-radius: 20px;\n  border: 1px solid rgba(79, 132, 40, 0.12);\n  background: rgba(234, 245, 157, 0.2);\n}\n\n.create-post-sidebar__card.is-highlighted {\n  box-shadow: 0 16px 36px rgba(79, 132, 40, 0.16);\n}\n\n.create-post-sidebar__preview-cover {\n  position: relative;\n  display: grid;\n  place-items: center;\n  min-height: 120px;\n  color: rgba(51, 106, 41, 0.62);\n  background: linear-gradient(180deg, rgba(193, 217, 92, 0.42), rgba(234, 245, 157, 0.28));\n}\n\n.create-post-sidebar__preview-cover em {\n  position: absolute;\n  top: 12px;\n  right: 12px;\n  padding: 8px 10px;\n  border-radius: 999px;\n  color: #7f7a00;\n  background: rgba(234, 245, 157, 0.92);\n  font-style: normal;\n  font-size: 0.74rem;\n  font-weight: 800;\n}\n\n.create-post-sidebar__preview-body {\n  display: grid;\n  gap: 10px;\n  padding: 16px;\n}\n\n.create-post-sidebar__preview-tag {\n  width: fit-content;\n  padding: 8px 10px;\n  border-radius: 999px;\n  color: var(--color-primary-500);\n  background: rgba(193, 217, 92, 0.3);\n  font-size: 0.78rem;\n  font-weight: 700;\n}\n\n.create-post-sidebar__preview-body h3 {\n  margin: 0;\n  font-size: 1.2rem;\n  line-height: 1.35;\n}\n\n.create-post-sidebar__preview-body p {\n  font-size: 0.94rem;\n}\n\n.create-post-sidebar__preview-meta {\n  display: grid;\n  gap: 4px;\n  padding-top: 12px;\n  border-top: 1px solid rgba(79, 132, 40, 0.1);\n}\n\n.create-post-sidebar__card ul {\n  display: grid;\n  gap: 10px;\n  margin: 0;\n  padding-left: 18px;\n  line-height: 1.75;\n}\n\n.create-post-sidebar__card--tips {\n  background: linear-gradient(180deg, rgba(234, 245, 157, 0.44), rgba(255, 255, 255, 0.96));\n}\n\n@media (max-width: 1180px) {\n  .create-post-page__hero,\n  .create-post-page__layout {\n    grid-template-columns: 1fr;\n  }\n}\n\n@media (max-width: 760px) {\n  .create-post-form,\n  .create-post-sidebar__card,\n  .create-post-page__alert {\n    padding: 20px;\n  }\n\n  .create-post-form__row {\n    grid-template-columns: 1fr;\n  }\n\n  .create-post-form__actions {\n    justify-content: stretch;\n  }\n\n  .create-post-form__actions .btn {\n    width: 100%;\n  }\n}\n"],["STYLE",{},".electricity-page {\n  display: grid;\n  gap: 44px;\n}\n\n.electricity-hero {\n  display: grid;\n  grid-template-columns: minmax(0, 1fr) minmax(360px, 0.96fr);\n  gap: 40px;\n  align-items: center;\n}\n\n.electricity-hero__content {\n  display: grid;\n  gap: 22px;\n}\n\n.electricity-hero__badge {\n  display: inline-flex;\n  align-items: center;\n  width: fit-content;\n  padding: 10px 16px;\n  border-radius: 999px;\n  color: #4f8428;\n  background: rgba(128, 177, 85, 0.16);\n  font-size: 0.9rem;\n  font-weight: 700;\n}\n\n.electricity-hero__content h1 {\n  margin: 0;\n  font-size: clamp(2.6rem, 5.8vw, 4.7rem);\n  line-height: 0.98;\n  letter-spacing: -0.06em;\n}\n\n.electricity-hero__content p,\n.electricity-section__header p,\n.electricity-result-card p,\n.saving-suggestion-card p,\n.electricity-history__note,\n.electricity-formula__header p,\n.electricity-formula__example p {\n  margin: 0;\n  color: rgba(23, 55, 21, 0.72);\n  line-height: 1.8;\n}\n\n.electricity-hero__actions {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 14px;\n}\n\n.electricity-hero__secondary,\n.electricity-tool-layout__reset {\n  color: #336a29;\n  background: #eaf59d;\n}\n\n.electricity-hero__visual {\n  position: relative;\n  min-height: 380px;\n  padding: 16px;\n  border-radius: 32px;\n  background: linear-gradient(135deg, rgba(193, 217, 92, 0.48), rgba(128, 177, 85, 0.2));\n  box-shadow: 0 4px 20px rgba(79, 132, 40, 0.08);\n}\n\n.electricity-hero__visual img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  border-radius: 24px;\n}\n\n.electricity-floating {\n  position: absolute;\n  padding: 14px 16px;\n  border-radius: 18px;\n  background: rgba(255, 255, 255, 0.88);\n  box-shadow: 0 10px 24px rgba(79, 132, 40, 0.12);\n}\n\n.electricity-floating span {\n  display: block;\n  color: rgba(23, 55, 21, 0.62);\n  font-size: 0.8rem;\n}\n\n.electricity-floating strong {\n  display: block;\n  margin-top: 4px;\n  font-size: 1rem;\n}\n\n.electricity-floating--cost {\n  top: 20px;\n  right: 20px;\n}\n\n.electricity-floating--top {\n  left: 14px;\n  bottom: 72px;\n}\n\n.electricity-floating--save {\n  right: 22px;\n  bottom: 24px;\n}\n\n.electricity-tool-layout {\n  display: grid;\n  grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.86fr);\n  gap: 24px;\n  align-items: start;\n}\n\n.electricity-tool-layout__left,\n.electricity-tool-layout__right {\n  display: grid;\n  gap: 18px;\n}\n\n.electricity-form,\n.device-usage-list,\n.electricity-result-card,\n.electricity-breakdown,\n.saving-suggestion-card,\n.electricity-history,\n.electricity-formula {\n  min-width: 0;\n}\n\n.electricity-form {\n  display: grid;\n  gap: 10px;\n  padding: 28px;\n  border-radius: 24px;\n  background: rgba(255, 255, 255, 0.96);\n  box-shadow: 0 4px 20px rgba(79, 132, 40, 0.08);\n}\n\n.electricity-form h2,\n.electricity-section__header h2,\n.electricity-history h2,\n.electricity-formula__header h2 {\n  margin: 0;\n  font-size: 2rem;\n  letter-spacing: -0.04em;\n}\n\n.electricity-form p {\n  margin: 0 0 8px;\n  color: rgba(23, 55, 21, 0.68);\n}\n\n.electricity-form__grid {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: 16px;\n}\n\n.electricity-form label {\n  display: grid;\n  gap: 8px;\n}\n\n.electricity-form label span {\n  color: rgba(23, 55, 21, 0.68);\n  font-size: 0.9rem;\n  font-weight: 700;\n}\n\n.electricity-form input,\n.electricity-form select {\n  width: 100%;\n  min-width: 0;\n  border: 1px solid rgba(115, 121, 106, 0.22);\n  border-radius: 14px;\n  padding: 13px 14px;\n  background: rgba(234, 245, 157, 0.22);\n  font: inherit;\n}\n\n.electricity-form__add {\n  width: 100%;\n  margin-top: 4px;\n  padding: 14px;\n  border: 2px dashed #4f8428;\n  border-radius: 14px;\n  color: #4f8428;\n  background: transparent;\n  font: inherit;\n  font-weight: 700;\n}\n\n.device-usage-list {\n  display: grid;\n  gap: 12px;\n}\n\n.device-usage-item {\n  display: flex;\n  justify-content: space-between;\n  gap: 16px;\n  align-items: center;\n  padding: 16px 18px;\n  border-radius: 16px;\n  background: rgba(234, 245, 157, 0.28);\n  border: 1px solid rgba(128, 177, 85, 0.18);\n}\n\n.device-usage-item__meta h3,\n.saving-suggestion-card h3 {\n  margin: 0;\n  font-size: 1rem;\n}\n\n.device-usage-item__meta p {\n  margin: 4px 0 0;\n  color: rgba(23, 55, 21, 0.66);\n  font-size: 0.92rem;\n}\n\n.device-usage-item__actions {\n  display: flex;\n  align-items: center;\n  gap: 14px;\n}\n\n.device-usage-item__actions button {\n  border: 0;\n  color: rgba(23, 55, 21, 0.68);\n  background: transparent;\n  font: inherit;\n}\n\n.electricity-tool-layout__buttons {\n  display: flex;\n  gap: 14px;\n}\n\n.electricity-tool-layout__save {\n  display: flex;\n  flex-wrap: wrap;\n  align-items: center;\n  gap: 12px;\n}\n\n.electricity-tool-layout__save-button {\n  color: #336a29;\n  background: rgba(234, 245, 157, 0.9);\n}\n\n.electricity-tool-layout__save-button:disabled {\n  cursor: not-allowed;\n  opacity: 0.55;\n}\n\n.electricity-tool-layout__save-message {\n  color: #4f8428;\n  font-size: 0.92rem;\n  font-weight: 700;\n}\n\n.electricity-tool-layout__primary {\n  flex: 1;\n}\n\n.electricity-result-card {\n  display: grid;\n  gap: 16px;\n  padding: 28px;\n  border-radius: 24px;\n  background: linear-gradient(135deg, #eaf59d 0%, #caffb9 100%);\n  box-shadow: 0 4px 20px rgba(79, 132, 40, 0.08);\n}\n\n.electricity-result-card__eyebrow {\n  color: rgba(51, 106, 41, 0.72);\n  font-size: 0.84rem;\n  font-weight: 800;\n  text-transform: uppercase;\n  letter-spacing: 0.08em;\n}\n\n.electricity-result-card__price {\n  font-size: clamp(2.6rem, 4vw, 4rem);\n  line-height: 1;\n  letter-spacing: -0.05em;\n  font-weight: 800;\n}\n\n.electricity-result-card__stats {\n  display: grid;\n  gap: 12px;\n  padding: 18px;\n  border-radius: 18px;\n  background: rgba(255, 255, 255, 0.62);\n}\n\n.electricity-result-card__stats span,\n.electricity-history__head,\n.electricity-history__row span {\n  color: rgba(23, 55, 21, 0.66);\n}\n\n.electricity-result-card__stats strong {\n  display: block;\n  margin-top: 4px;\n}\n\n.electricity-breakdown {\n  display: grid;\n  gap: 16px;\n  padding: 24px;\n  border-radius: 24px;\n  background: rgba(255, 255, 255, 0.96);\n  box-shadow: 0 4px 20px rgba(79, 132, 40, 0.08);\n}\n\n.electricity-breakdown h3 {\n  margin: 0;\n  font-size: 1.2rem;\n}\n\n.electricity-breakdown__list {\n  display: grid;\n  gap: 14px;\n}\n\n.electricity-breakdown__row {\n  display: flex;\n  justify-content: space-between;\n  gap: 12px;\n  margin-bottom: 6px;\n  font-size: 0.95rem;\n}\n\n.electricity-breakdown__bar {\n  height: 10px;\n  overflow: hidden;\n  border-radius: 999px;\n  background: rgba(128, 177, 85, 0.18);\n}\n\n.electricity-breakdown__fill {\n  display: block;\n  height: 100%;\n  border-radius: inherit;\n}\n\n.electricity-breakdown__fill--0 {\n  background: #336a29;\n}\n\n.electricity-breakdown__fill--1 {\n  background: #80b155;\n}\n\n.electricity-breakdown__fill--2 {\n  background: #d6a24a;\n}\n\n.electricity-section {\n  display: grid;\n  gap: 20px;\n}\n\n.saving-suggestions {\n  display: grid;\n  grid-template-columns: repeat(4, minmax(0, 1fr));\n  gap: 20px;\n}\n\n.saving-suggestion-card {\n  display: grid;\n  gap: 14px;\n  padding: 22px;\n  border-radius: 24px;\n  background: rgba(255, 255, 255, 0.96);\n  box-shadow: 0 4px 20px rgba(79, 132, 40, 0.08);\n}\n\n.saving-suggestion-card__icon {\n  display: grid;\n  place-items: center;\n  width: 44px;\n  height: 44px;\n  border-radius: 50%;\n  color: #4f8428;\n  background: rgba(128, 177, 85, 0.14);\n  font-size: 0.82rem;\n  font-weight: 800;\n}\n\n.electricity-history,\n.electricity-formula {\n  display: grid;\n  gap: 20px;\n  padding: 28px;\n  border-radius: 24px;\n  background: rgba(255, 255, 255, 0.96);\n  box-shadow: 0 4px 20px rgba(79, 132, 40, 0.08);\n}\n\n.electricity-history__table {\n  display: grid;\n  gap: 10px;\n}\n\n.electricity-history__header {\n  display: flex;\n  justify-content: space-between;\n  gap: 14px;\n  align-items: center;\n}\n\n.electricity-history__header a {\n  color: #336a29;\n  font-weight: 700;\n}\n\n.electricity-history__head,\n.electricity-history__row {\n  display: grid;\n  grid-template-columns: repeat(4, minmax(0, 1fr));\n  gap: 16px;\n  align-items: center;\n}\n\n.electricity-history__head {\n  padding-bottom: 10px;\n  border-bottom: 1px solid rgba(79, 132, 40, 0.1);\n  font-size: 0.92rem;\n  font-weight: 700;\n}\n\n.electricity-history__row {\n  padding: 14px 0;\n  border-bottom: 1px solid rgba(79, 132, 40, 0.08);\n}\n\n.electricity-history__row strong {\n  color: #173715;\n}\n\n.electricity-formula__header {\n  text-align: center;\n}\n\n.electricity-formula__box {\n  display: grid;\n  grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);\n  gap: 18px;\n  align-items: center;\n  padding: 24px;\n  border-radius: 20px;\n  background: rgba(234, 245, 157, 0.24);\n  border: 1px solid rgba(128, 177, 85, 0.16);\n}\n\n.electricity-formula__equation {\n  display: grid;\n  gap: 10px;\n  justify-items: center;\n  padding: 22px;\n  border-radius: 16px;\n  background: rgba(255, 255, 255, 0.56);\n}\n\n.electricity-formula__equation strong {\n  font-size: 1.4rem;\n  text-align: center;\n  letter-spacing: -0.03em;\n}\n\n.electricity-formula__equation b {\n  display: block;\n  width: 100%;\n  padding-top: 10px;\n  border-top: 1px solid rgba(79, 132, 40, 0.14);\n  text-align: center;\n  font-size: 1.2rem;\n}\n\n.electricity-formula__example {\n  padding: 8px 6px;\n}\n\n@media (max-width: 1200px) {\n  .electricity-hero,\n  .electricity-tool-layout,\n  .electricity-formula__box {\n    grid-template-columns: 1fr;\n  }\n\n  .saving-suggestions {\n    grid-template-columns: repeat(2, minmax(0, 1fr));\n  }\n}\n\n@media (max-width: 760px) {\n  .electricity-form__grid,\n  .saving-suggestions,\n  .electricity-history__head,\n  .electricity-history__row {\n    grid-template-columns: 1fr;\n  }\n\n  .electricity-tool-layout__buttons,\n  .electricity-hero__actions,\n  .device-usage-item,\n  .device-usage-item__actions {\n    flex-direction: column;\n    align-items: stretch;\n  }\n\n  .electricity-tool-layout__save,\n  .electricity-history__header {\n    flex-direction: column;\n    align-items: flex-start;\n  }\n}\n"],["STYLE",{},".electricity-history-page {\n  display: grid;\n  gap: 28px;\n}\n\n.electricity-history-page__breadcrumb {\n  display: flex;\n  gap: 10px;\n  flex-wrap: wrap;\n  color: rgba(23, 55, 21, 0.62);\n}\n\n.electricity-history-hero {\n  display: grid;\n  grid-template-columns: minmax(0, 1fr) 320px;\n  gap: 24px;\n  align-items: center;\n  padding: 28px;\n  border-radius: 32px;\n  background: linear-gradient(135deg, rgba(234, 245, 157, 0.34), rgba(255, 255, 255, 0.94));\n  box-shadow: 0 4px 20px rgba(79, 132, 40, 0.08);\n}\n\n.electricity-history-hero__content {\n  display: grid;\n  gap: 18px;\n}\n\n.electricity-history-hero__content h1,\n.electricity-history-empty h2 {\n  margin: 0;\n  font-size: clamp(2.4rem, 4.5vw, 4rem);\n  line-height: 1.08;\n  letter-spacing: -0.05em;\n}\n\n.electricity-history-hero__content p,\n.electricity-history-empty p,\n.electricity-history-side__card ul,\n.electricity-history-modal__tips p {\n  margin: 0;\n  color: rgba(23, 55, 21, 0.72);\n  line-height: 1.8;\n}\n\n.electricity-history-hero__visual img {\n  display: block;\n  width: 100%;\n  border-radius: 24px;\n}\n\n.electricity-history-stats {\n  display: grid;\n  grid-template-columns: repeat(4, minmax(0, 1fr));\n  gap: 18px;\n}\n\n.electricity-history-stats__card,\n.electricity-history-side__card,\n.electricity-history-card,\n.electricity-history-empty,\n.electricity-history-filters {\n  border-radius: 24px;\n  background: rgba(255, 255, 255, 0.96);\n  box-shadow: 0 4px 20px rgba(79, 132, 40, 0.08);\n}\n\n.electricity-history-stats__card {\n  display: grid;\n  gap: 6px;\n  padding: 22px;\n}\n\n.electricity-history-stats__card span {\n  color: rgba(23, 55, 21, 0.62);\n}\n\n.electricity-history-stats__card strong {\n  font-size: 2rem;\n  letter-spacing: -0.04em;\n}\n\n.electricity-history-filters {\n  display: grid;\n  grid-template-columns: minmax(220px, 1fr) repeat(2, 180px) auto auto;\n  gap: 12px;\n  align-items: center;\n  padding: 16px;\n}\n\n.electricity-history-filters input,\n.electricity-history-filters select {\n  width: 100%;\n  min-width: 0;\n  padding: 12px 14px;\n  border: 1px solid rgba(115, 121, 106, 0.24);\n  border-radius: 14px;\n  background: rgba(234, 245, 157, 0.24);\n  font: inherit;\n}\n\n.electricity-history-filters__reset {\n  color: #336a29;\n  background: #eaf59d;\n}\n\n.electricity-history-layout {\n  display: grid;\n  grid-template-columns: minmax(0, 1.7fr) minmax(300px, 0.92fr);\n  gap: 24px;\n  align-items: start;\n}\n\n.electricity-history-list,\n.electricity-history-side {\n  display: grid;\n  gap: 18px;\n}\n\n.electricity-history-list__empty {\n  display: grid;\n  gap: 10px;\n  padding: 28px;\n  border-radius: 24px;\n  background: rgba(255, 255, 255, 0.96);\n  box-shadow: 0 4px 20px rgba(79, 132, 40, 0.08);\n}\n\n.electricity-history-list__empty h2 {\n  margin: 0;\n  font-size: 1.5rem;\n  letter-spacing: -0.03em;\n}\n\n.electricity-history-list__empty p {\n  margin: 0;\n  color: rgba(23, 55, 21, 0.68);\n  line-height: 1.7;\n}\n\n.electricity-history-card {\n  display: grid;\n  gap: 16px;\n  padding: 24px;\n}\n\n.electricity-history-card__top {\n  display: flex;\n  justify-content: space-between;\n  gap: 18px;\n  align-items: start;\n}\n\n.electricity-history-card__top h2,\n.electricity-history-side__card h2,\n.electricity-history-empty__fallback h3,\n.electricity-history-modal__header h2 {\n  margin: 0;\n  font-size: 1.9rem;\n  letter-spacing: -0.04em;\n}\n\n.electricity-history-card__top p,\n.electricity-history-card__summary span,\n.electricity-history-modal__summary span,\n.electricity-history-modal__item p {\n  color: rgba(23, 55, 21, 0.66);\n}\n\n.electricity-history-card__cost {\n  text-align: right;\n}\n\n.electricity-history-card__cost strong {\n  display: block;\n  font-size: 1.15rem;\n}\n\n.electricity-history-card__summary {\n  display: flex;\n  flex-wrap: wrap;\n  justify-content: space-between;\n  gap: 10px 20px;\n  padding: 14px 16px;\n  border-radius: 16px;\n  background: rgba(234, 245, 157, 0.28);\n}\n\n.electricity-history-card__actions {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 12px;\n}\n\n.electricity-history-card__actions button,\n.electricity-history-card__actions a,\n.electricity-history-modal__header button {\n  padding: 10px 16px;\n  border-radius: 999px;\n  border: 1px solid rgba(79, 132, 40, 0.18);\n  color: #336a29;\n  background: rgba(255, 255, 255, 0.72);\n  font: inherit;\n  font-weight: 600;\n}\n\n.electricity-history-card__delete {\n  color: #9b6b1c;\n  border-color: rgba(214, 162, 74, 0.26);\n  background: rgba(246, 225, 185, 0.32);\n}\n\n.electricity-history-list__load-more {\n  padding: 14px;\n  border: 1px solid rgba(79, 132, 40, 0.18);\n  border-radius: 16px;\n  color: rgba(23, 55, 21, 0.72);\n  background: rgba(234, 245, 157, 0.12);\n  font: inherit;\n  font-weight: 700;\n}\n\n.electricity-history-side__card {\n  display: grid;\n  gap: 16px;\n  padding: 24px;\n}\n\n.electricity-history-side__rankings {\n  display: grid;\n  gap: 14px;\n}\n\n.electricity-history-side__ranking {\n  display: grid;\n  grid-template-columns: 28px 1fr;\n  gap: 12px;\n  align-items: center;\n}\n\n.electricity-history-side__bar {\n  margin-top: 6px;\n  height: 8px;\n  border-radius: 999px;\n  background: rgba(128, 177, 85, 0.16);\n}\n\n.electricity-history-side__bar span {\n  display: block;\n  height: 100%;\n  border-radius: inherit;\n  background: #4f8428;\n}\n\n.electricity-history-side__card ul {\n  padding-left: 18px;\n}\n\n.electricity-history-side__card--tips {\n  background: linear-gradient(135deg, rgba(234, 245, 157, 0.72), rgba(193, 217, 92, 0.34));\n}\n\n.electricity-history-empty {\n  display: grid;\n  justify-items: center;\n  gap: 14px;\n  padding: 40px 24px;\n  text-align: center;\n}\n\n.electricity-history-empty__icon {\n  display: grid;\n  place-items: center;\n  width: 72px;\n  height: 72px;\n  border-radius: 50%;\n  color: #4f8428;\n  background: rgba(193, 217, 92, 0.38);\n  font-size: 2rem;\n}\n\n.electricity-history-empty__fallback {\n  width: min(100%, 560px);\n  display: grid;\n  gap: 10px;\n  margin-top: 12px;\n  padding: 20px;\n  border-radius: 18px;\n  background: rgba(234, 245, 157, 0.2);\n}\n\n.electricity-history-empty__fallback-item {\n  display: flex;\n  justify-content: space-between;\n  gap: 12px;\n}\n\n.electricity-history-modal {\n  position: fixed;\n  inset: 0;\n  z-index: 60;\n  display: grid;\n  place-items: center;\n  padding: 24px;\n}\n\n.electricity-history-modal__backdrop {\n  position: absolute;\n  inset: 0;\n  background: rgba(19, 35, 15, 0.42);\n}\n\n.electricity-history-modal__panel {\n  position: relative;\n  z-index: 1;\n  width: min(100%, 840px);\n  max-height: min(88vh, 920px);\n  overflow: auto;\n  display: grid;\n  gap: 18px;\n  padding: 24px;\n  border-radius: 24px;\n  background: #fff;\n  box-shadow: 0 20px 60px rgba(19, 35, 15, 0.2);\n}\n\n.electricity-history-modal__header {\n  display: flex;\n  justify-content: space-between;\n  gap: 16px;\n  align-items: center;\n}\n\n.electricity-history-modal__summary {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: 14px;\n  padding: 18px;\n  border-radius: 18px;\n  background: rgba(234, 245, 157, 0.22);\n}\n\n.electricity-history-modal__summary strong,\n.electricity-history-modal__item strong {\n  display: block;\n  margin-top: 4px;\n}\n\n.electricity-history-modal__items {\n  display: grid;\n  gap: 12px;\n}\n\n.electricity-history-modal__item {\n  display: grid;\n  gap: 6px;\n  padding: 16px;\n  border-radius: 16px;\n  background: rgba(255, 255, 255, 0.94);\n  border: 1px solid rgba(79, 132, 40, 0.12);\n}\n\n.electricity-history-modal__item h3,\n.electricity-history-modal__tips h3 {\n  margin: 0;\n  font-size: 1.08rem;\n}\n\n.electricity-history-modal__tips {\n  display: grid;\n  gap: 8px;\n  padding: 18px;\n  border-radius: 18px;\n  background: rgba(193, 217, 92, 0.22);\n}\n\n@media (max-width: 1160px) {\n  .electricity-history-hero,\n  .electricity-history-layout {\n    grid-template-columns: 1fr;\n  }\n\n  .electricity-history-stats {\n    grid-template-columns: repeat(2, minmax(0, 1fr));\n  }\n\n  .electricity-history-filters {\n    grid-template-columns: 1fr 1fr;\n  }\n}\n\n@media (max-width: 760px) {\n  .electricity-history-stats,\n  .electricity-history-filters,\n  .electricity-history-modal__summary {\n    grid-template-columns: 1fr;\n  }\n\n  .electricity-history-card__top,\n  .electricity-history-modal__header {\n    flex-direction: column;\n    align-items: flex-start;\n  }\n}\n"],["STYLE",{},".home-page {\n  display: grid;\n  gap: 32px;\n}\n\n.home-section {\n  display: grid;\n  gap: 24px;\n}\n\n.home-section--last {\n  margin-bottom: 12px;\n}\n\n.home-hero {\n  position: relative;\n  overflow: hidden;\n  min-height: calc(100vh - 140px);\n  padding: 44px 28px 32px;\n  border-radius: 40px;\n  background: linear-gradient(180deg, #f7faef 0%, #ffffff 100%);\n}\n\n.home-hero__glow {\n  position: absolute;\n  border-radius: 999px;\n  filter: blur(72px);\n  opacity: 0.75;\n  pointer-events: none;\n}\n\n.home-hero__glow--left {\n  top: 8%;\n  left: -6%;\n  width: 360px;\n  height: 360px;\n  background: rgba(234, 245, 157, 0.62);\n}\n\n.home-hero__glow--right {\n  right: -4%;\n  bottom: 10%;\n  width: 460px;\n  height: 460px;\n  background: rgba(128, 177, 85, 0.24);\n}\n\n.home-hero__grid {\n  position: relative;\n  z-index: 1;\n  display: grid;\n  grid-template-columns: minmax(0, 1fr) minmax(460px, 0.98fr);\n  gap: 36px;\n  align-items: center;\n}\n\n.home-chip {\n  display: inline-flex;\n  align-items: center;\n  gap: 10px;\n  width: fit-content;\n  padding: 10px 16px;\n  border-radius: 999px;\n  color: var(--color-primary-500);\n  background: rgba(128, 177, 85, 0.12);\n  border: 1px solid rgba(128, 177, 85, 0.18);\n  font-size: 0.92rem;\n  font-weight: 700;\n}\n\n.home-chip__dot {\n  width: 10px;\n  height: 10px;\n  border-radius: 50%;\n  background: linear-gradient(180deg, var(--color-primary-300), var(--color-primary-500));\n}\n\n.home-hero__content h1 {\n  display: grid;\n  margin: 18px 0 20px;\n  font-size: clamp(2.9rem, 6vw, 5rem);\n  line-height: 0.96;\n  letter-spacing: -0.05em;\n}\n\n.home-hero__content h1 span {\n  color: var(--color-primary-500);\n}\n\n.home-hero__content p {\n  max-width: 640px;\n  margin: 0;\n  color: var(--color-text-muted);\n  font-size: 1.08rem;\n  line-height: 1.8;\n}\n\n.home-hero__actions {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 14px;\n  margin-top: 28px;\n}\n\n.home-hero__stats {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 24px;\n  margin-top: 36px;\n  padding-top: 24px;\n  border-top: 1px solid rgba(79, 132, 40, 0.12);\n}\n\n.home-hero__stat {\n  display: grid;\n  gap: 6px;\n  min-width: 112px;\n}\n\n.home-hero__stat strong {\n  font-size: 1.75rem;\n  color: var(--color-primary-500);\n}\n\n.home-hero__stat span {\n  color: var(--color-text-muted);\n  font-size: 0.95rem;\n  font-weight: 500;\n}\n\n.home-hero__visual {\n  position: relative;\n  min-height: 640px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.home-hero__image-shell {\n  position: relative;\n  width: 100%;\n  max-width: 720px;\n  padding: 12px;\n  border-radius: 36px;\n  box-shadow: 0 0 120px rgba(79, 132, 40, 0.24);\n}\n\n.home-hero__image-shell::before {\n  content: '';\n  position: absolute;\n  inset: 26px;\n  border-radius: 999px;\n  background: rgba(128, 177, 85, 0.24);\n  filter: blur(54px);\n}\n\n.home-hero__image-shell img {\n  position: relative;\n  z-index: 1;\n  display: block;\n  width: 100%;\n  border-radius: 32px;\n  border: 1px solid rgba(255, 255, 255, 0.72);\n  box-shadow: 0 24px 60px -12px rgba(79, 132, 40, 0.4);\n}\n\n.home-floating-card {\n  position: absolute;\n  z-index: 2;\n  display: grid;\n  gap: 8px;\n  padding: 18px;\n  border: 1px solid rgba(255, 255, 255, 0.68);\n  border-radius: 24px;\n  background: rgba(255, 255, 255, 0.9);\n  backdrop-filter: blur(14px);\n  box-shadow: 0 22px 44px rgba(79, 132, 40, 0.16);\n}\n\n.home-floating-card span {\n  font-size: 0.72rem;\n  font-weight: 800;\n  text-transform: uppercase;\n  letter-spacing: 0.08em;\n}\n\n.home-floating-card strong {\n  font-size: 1.2rem;\n  line-height: 1.35;\n}\n\n.home-floating-card small,\n.home-floating-card p {\n  margin: 0;\n  color: var(--color-text-muted);\n  font-size: 0.92rem;\n  line-height: 1.5;\n}\n\n.home-floating-card--savings {\n  top: 64px;\n  left: -32px;\n}\n\n.home-floating-card--savings span {\n  color: var(--color-primary-500);\n}\n\n.home-floating-card--warning {\n  right: -18px;\n  bottom: 180px;\n  max-width: 220px;\n}\n\n.home-floating-card--warning span {\n  color: #d98b00;\n}\n\n.home-floating-card--tip {\n  left: 84px;\n  bottom: -18px;\n  max-width: 270px;\n  color: #fff;\n  background: linear-gradient(135deg, var(--color-primary-400), var(--color-primary-500));\n  border-color: rgba(255, 255, 255, 0.22);\n}\n\n.home-floating-card--tip span,\n.home-floating-card--tip p {\n  color: inherit;\n}\n\n.home-feature-grid {\n  display: grid;\n  grid-template-columns: repeat(3, minmax(0, 1fr));\n  gap: 24px;\n}\n\n.home-feature-card {\n  display: grid;\n  gap: 14px;\n  padding: 30px;\n  border-radius: 32px;\n  background: #fff;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.03);\n  transition:\n    transform 0.25s ease,\n    box-shadow 0.25s ease;\n}\n\n.home-feature-card:hover {\n  transform: translateY(-4px);\n  box-shadow: 0 12px 32px rgba(51, 106, 41, 0.08);\n}\n\n.home-feature-card__icon {\n  display: grid;\n  place-items: center;\n  width: 64px;\n  height: 64px;\n  border-radius: 20px;\n  color: var(--color-primary-500);\n  font-size: 0.8rem;\n  font-weight: 800;\n}\n\n.home-feature-card__icon--yellow {\n  background: rgba(234, 245, 157, 0.4);\n}\n\n.home-feature-card__icon--green {\n  background: rgba(128, 177, 85, 0.18);\n}\n\n.home-feature-card__icon--dark {\n  background: rgba(51, 106, 41, 0.1);\n}\n\n.home-feature-card h2 {\n  margin: 0;\n  font-size: 1.62rem;\n  letter-spacing: -0.04em;\n}\n\n.home-feature-card p {\n  margin: 0;\n  color: var(--color-text-muted);\n  line-height: 1.75;\n}\n\n.home-feature-card a,\n.home-section__link {\n  color: var(--color-primary-500);\n  font-weight: 800;\n}\n\n.electricity-preview {\n  position: relative;\n  display: grid;\n  grid-template-columns: 1fr 0.95fr;\n  overflow: hidden;\n  border-radius: 40px;\n  background: linear-gradient(135deg, var(--color-primary-500), #29551f);\n  box-shadow: 0 26px 48px rgba(51, 106, 41, 0.22);\n}\n\n.electricity-preview::before {\n  content: '';\n  position: absolute;\n  inset: 0;\n  background-image: radial-gradient(circle at 2px 2px, rgba(255, 255, 255, 0.36) 1px, transparent 0);\n  background-size: 32px 32px;\n  opacity: 0.08;\n}\n\n.electricity-preview__content,\n.electricity-preview__card {\n  position: relative;\n  z-index: 1;\n}\n\n.electricity-preview__content {\n  display: grid;\n  align-content: center;\n  gap: 18px;\n  padding: 56px 52px;\n  color: #fff;\n}\n\n.electricity-preview__eyebrow {\n  color: var(--color-primary-50);\n  font-size: 0.88rem;\n  font-weight: 800;\n  text-transform: uppercase;\n  letter-spacing: 0.08em;\n}\n\n.electricity-preview__content h2 {\n  margin: 0;\n  font-size: clamp(2.2rem, 4vw, 4rem);\n  line-height: 1.06;\n  letter-spacing: -0.05em;\n}\n\n.electricity-preview__content p {\n  max-width: 500px;\n  margin: 0;\n  color: rgba(255, 255, 255, 0.82);\n  font-size: 1.05rem;\n  line-height: 1.78;\n}\n\n.electricity-preview__button {\n  width: fit-content;\n  color: var(--color-primary-500);\n  background: var(--color-primary-50);\n}\n\n.electricity-preview__card {\n  display: grid;\n  gap: 20px;\n  align-content: center;\n  padding: 42px;\n  background: linear-gradient(180deg, rgba(79, 132, 40, 0.24), rgba(51, 106, 41, 0.14));\n}\n\n.electricity-preview__card > div,\n.electricity-preview__device {\n  border-radius: 28px;\n}\n\n.electricity-preview__card-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: 12px;\n  padding: 0 2px;\n  color: #fff;\n}\n\n.electricity-preview__card-header span {\n  padding: 8px 12px;\n  border-radius: 999px;\n  color: var(--color-primary-500);\n  background: rgba(234, 245, 157, 0.84);\n  font-size: 0.78rem;\n  font-weight: 800;\n}\n\n.electricity-preview__list {\n  display: grid;\n  gap: 14px;\n  padding: 28px;\n  border-radius: 32px;\n  background: rgba(255, 255, 255, 0.94);\n  box-shadow: 0 18px 40px rgba(25, 54, 17, 0.16);\n}\n\n.electricity-preview__device {\n  display: grid;\n  grid-template-columns: auto 1fr auto;\n  gap: 16px;\n  align-items: center;\n  padding: 18px;\n  background: #f7faef;\n  border: 1px solid rgba(79, 132, 40, 0.12);\n}\n\n.electricity-preview__device-icon {\n  display: grid;\n  place-items: center;\n  width: 48px;\n  height: 48px;\n  border-radius: 16px;\n  color: var(--color-primary-500);\n  background: #fff;\n  font-size: 0.82rem;\n  font-weight: 800;\n  box-shadow: 0 4px 14px rgba(79, 132, 40, 0.08);\n}\n\n.electricity-preview__device h3,\n.electricity-preview__device p,\n.electricity-preview__summary span,\n.electricity-preview__summary small {\n  margin: 0;\n}\n\n.electricity-preview__device h3 {\n  font-size: 0.98rem;\n}\n\n.electricity-preview__device p {\n  color: var(--color-text-muted);\n}\n\n.electricity-preview__summary span,\n.electricity-preview__summary small {\n  color: #eaf7df;\n}\n\n.electricity-preview__summary {\n  display: grid;\n  gap: 12px;\n  padding-top: 4px;\n}\n\n.electricity-preview__summary strong {\n  color: #eaf7df;\n  font-size: 2rem;\n  font-weight: 800;\n  letter-spacing: -0.04em;\n}\n\n.electricity-preview__progress {\n  width: 100%;\n  height: 10px;\n  overflow: hidden;\n  border-radius: 999px;\n  background: rgba(255, 255, 255, 0.45);\n}\n\n.electricity-preview__progress span {\n  display: block;\n  height: 100%;\n  border-radius: inherit;\n  background: linear-gradient(90deg, #f29c38, #f6b456);\n}\n\n.home-section__header {\n  display: flex;\n  align-items: end;\n  justify-content: space-between;\n  gap: 20px;\n}\n\n.home-section__header--stacked {\n  align-items: start;\n}\n\n.home-section__header h2,\n.community-preview__members h3,\n.community-preview__cta h3 {\n  margin: 0 0 10px;\n  font-size: clamp(2rem, 3.2vw, 3rem);\n  letter-spacing: -0.04em;\n}\n\n.home-section__header p,\n.community-preview__cta p {\n  margin: 0;\n  color: var(--color-text-muted);\n}\n\n.home-post-grid {\n  display: grid;\n  grid-template-columns: repeat(3, minmax(0, 1fr));\n  gap: 24px;\n}\n\n.home-post-card {\n  display: flex;\n  flex-direction: column;\n  overflow: hidden;\n  border-radius: 32px;\n  background: #fff;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.03);\n}\n\n.home-post-card__media {\n  position: relative;\n  height: 260px;\n  overflow: hidden;\n}\n\n.home-post-card__media img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  transition: transform 0.6s ease;\n}\n\n.home-post-card:hover .home-post-card__media img {\n  transform: scale(1.05);\n}\n\n.home-post-card__tag,\n.home-post-card__media button {\n  position: absolute;\n  top: 18px;\n  z-index: 1;\n  border-radius: 999px;\n  background: rgba(255, 255, 255, 0.92);\n  box-shadow: 0 10px 24px rgba(79, 132, 40, 0.1);\n}\n\n.home-post-card__tag {\n  left: 18px;\n  padding: 9px 14px;\n  color: var(--color-primary-500);\n  font-size: 0.8rem;\n  font-weight: 800;\n}\n\n.home-post-card__media button {\n  right: 18px;\n  border: 0;\n  padding: 10px 13px;\n  color: var(--color-primary-500);\n  font-weight: 700;\n}\n\n.home-post-card__body {\n  display: grid;\n  gap: 18px;\n  flex: 1;\n  padding: 24px;\n}\n\n.home-post-card__body h3 {\n  margin: 0;\n  font-size: 1.28rem;\n  line-height: 1.45;\n  letter-spacing: -0.03em;\n}\n\n.home-post-card__meta {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  margin-top: auto;\n  padding-top: 18px;\n  border-top: 1px solid rgba(79, 132, 40, 0.1);\n}\n\n.home-post-card__meta span:last-child {\n  margin-left: auto;\n  color: var(--color-text-muted);\n  font-size: 0.92rem;\n}\n\n.home-avatar {\n  display: grid;\n  place-items: center;\n  width: 36px;\n  height: 36px;\n  border-radius: 50%;\n  font-size: 0.8rem;\n  font-weight: 800;\n}\n\n.home-avatar--yellow {\n  color: var(--color-primary-500);\n  background: var(--color-primary-50);\n}\n\n.home-avatar--green {\n  color: #fff;\n  background: var(--color-primary-300);\n}\n\n.home-avatar--dark {\n  color: #fff;\n  background: var(--color-primary-500);\n}\n\n.home-avatar--lime {\n  color: var(--color-primary-500);\n  background: rgba(193, 217, 92, 0.54);\n}\n\n.community-preview {\n  position: relative;\n  overflow: hidden;\n  display: grid;\n  grid-template-columns: minmax(0, 1fr) 320px;\n  gap: 32px;\n  padding: 42px;\n  border-radius: 40px;\n  background: #e8f2d5;\n}\n\n.community-preview::before {\n  content: '';\n  position: absolute;\n  top: -80px;\n  right: -60px;\n  width: 260px;\n  height: 260px;\n  border-radius: 50%;\n  background: rgba(255, 255, 255, 0.34);\n  filter: blur(24px);\n}\n\n.community-preview__feed {\n  position: relative;\n  z-index: 1;\n  display: grid;\n  gap: 20px;\n}\n\n.community-preview__sidebar {\n  position: relative;\n  z-index: 1;\n  display: flex;\n  flex-direction: column;\n  gap: 20px;\n}\n\n.community-preview__posts {\n  display: grid;\n  gap: 16px;\n}\n\n.community-preview__post,\n.community-preview__members,\n.community-preview__cta {\n  padding: 24px;\n  border-radius: 28px;\n  background: rgba(255, 255, 255, 0.96);\n  border: 1px solid rgba(79, 132, 40, 0.08);\n}\n\n.community-preview__members {\n  flex: 1;\n  min-height: 220px;\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n}\n\n.community-preview__post-top,\n.community-preview__author,\n.community-preview__actions {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n}\n\n.community-preview__post-top {\n  justify-content: space-between;\n  gap: 16px;\n}\n\n.community-preview__author {\n  min-width: 0;\n  overflow: hidden;\n}\n\n.community-preview__author div {\n  min-width: 0;\n  overflow: hidden;\n}\n\n.community-preview__author strong,\n.community-preview__members strong,\n.community-preview__cta h3 {\n  display: block;\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n}\n\n.community-preview__author span,\n.community-preview__members span {\n  color: var(--color-text-muted);\n  font-size: 0.9rem;\n  display: block;\n  white-space: nowrap;\n  overflow: hidden;\n  text-overflow: ellipsis;\n}\n\n.community-preview__pill {\n  padding: 8px 12px;\n  border-radius: 12px;\n  color: var(--color-primary-500);\n  background: rgba(234, 245, 157, 0.6);\n  font-size: 0.78rem;\n  font-weight: 700;\n}\n\n.community-preview__post p {\n  display: -webkit-box;\n  -webkit-line-clamp: 2;\n  -webkit-box-orient: vertical;\n  overflow: hidden;\n  margin: 16px 0 18px;\n  line-height: 1.72;\n  color: var(--color-text);\n  word-break: break-word;\n}\n\n.community-preview__actions {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 12px;\n  padding-top: 16px;\n  border-top: 1px solid rgba(79, 132, 40, 0.08);\n  color: var(--color-text-muted);\n  font-size: 0.85rem;\n  font-weight: 600;\n}\n\n.community-preview__button {\n  width: fit-content;\n  color: #fff;\n  background: var(--color-primary-500);\n}\n\n.community-preview__members ul {\n  display: grid;\n  gap: 18px;\n  margin: 0;\n  padding: 0;\n  list-style: none;\n}\n\n.community-preview__members li {\n  display: flex;\n  align-items: center;\n  gap: 14px;\n}\n\n.community-preview__rank {\n  display: grid;\n  place-items: center;\n  width: 48px;\n  height: 48px;\n  border-radius: 50%;\n  color: #fff;\n  font-weight: 800;\n  box-shadow: 0 8px 20px rgba(79, 132, 40, 0.16);\n}\n\n.community-preview__rank--1 {\n  background: linear-gradient(135deg, #f2c447, #e4a825);\n}\n\n.community-preview__rank--2 {\n  background: linear-gradient(135deg, #c8ccd1, #8f979f);\n}\n\n.community-preview__rank--3 {\n  background: linear-gradient(135deg, #e7a065, #d07b38);\n}\n\n.community-preview__cta {\n  color: #fff;\n  background: linear-gradient(180deg, var(--color-primary-400), var(--color-primary-500));\n  text-align: center;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  flex: 1;\n  min-height: 220px;\n}\n\n.community-preview__cta h3 {\n  font-size: 1.1rem;\n  white-space: normal;\n}\n\n.community-preview__cta p {\n  color: rgba(255, 255, 255, 0.84);\n  line-height: 1.6;\n  font-size: 0.9rem;\n  margin-bottom: 20px;\n}\n\n.home-final-cta {\n  position: relative;\n  overflow: hidden;\n  display: grid;\n  justify-items: center;\n  gap: 18px;\n  padding: 64px 24px;\n  border-radius: 48px;\n  text-align: center;\n  background: linear-gradient(135deg, rgba(234, 245, 157, 0.72), rgba(193, 217, 92, 0.36));\n  border: 1px solid rgba(255, 255, 255, 0.7);\n  box-shadow: var(--shadow-soft);\n}\n\n.home-final-cta::before,\n.home-final-cta::after {\n  content: '';\n  position: absolute;\n  border-radius: 50%;\n  opacity: 0.26;\n}\n\n.home-final-cta::before {\n  top: -80px;\n  left: -60px;\n  width: 180px;\n  height: 180px;\n  background: rgba(79, 132, 40, 0.14);\n}\n\n.home-final-cta::after {\n  right: -40px;\n  bottom: -70px;\n  width: 220px;\n  height: 220px;\n  background: rgba(128, 177, 85, 0.18);\n}\n\n.home-final-cta__icon {\n  display: grid;\n  place-items: center;\n  width: 72px;\n  height: 72px;\n  border-radius: 50%;\n  color: var(--color-primary-500);\n  background: rgba(255, 255, 255, 0.92);\n  font-size: 2rem;\n  box-shadow: 0 10px 24px rgba(79, 132, 40, 0.12);\n}\n\n.home-final-cta h2 {\n  max-width: 780px;\n  margin: 0;\n  color: var(--color-primary-500);\n  font-size: clamp(2.2rem, 4.2vw, 4rem);\n  line-height: 1.08;\n  letter-spacing: -0.05em;\n}\n\n.home-final-cta p {\n  max-width: 680px;\n  margin: 0;\n  color: var(--color-text-muted);\n  font-size: 1.08rem;\n  line-height: 1.8;\n}\n\n.home-final-cta__button {\n  margin-top: 8px;\n}\n\n@media (max-width: 1220px) {\n  .home-hero__grid,\n  .electricity-preview,\n  .community-preview,\n  .home-post-grid,\n  .home-feature-grid {\n    grid-template-columns: 1fr;\n  }\n\n  .home-hero__visual {\n    min-height: 560px;\n  }\n\n  .home-post-grid {\n    grid-template-columns: repeat(2, minmax(0, 1fr));\n  }\n\n  .community-preview__members,\n  .community-preview__cta {\n    flex: none;\n    min-height: auto;\n  }\n}\n\n@media (max-width: 920px) {\n  .home-hero {\n    padding: 32px 20px 28px;\n    border-radius: 32px;\n  }\n\n  .home-hero__visual {\n    min-height: 480px;\n  }\n\n  .home-floating-card--savings {\n    left: 8px;\n  }\n\n  .home-floating-card--warning {\n    right: 8px;\n  }\n\n  .community-preview,\n  .electricity-preview__content,\n  .electricity-preview__card {\n    padding: 28px;\n  }\n}\n\n@media (max-width: 720px) {\n  .home-hero__actions,\n  .home-section__header {\n    flex-direction: column;\n    align-items: stretch;\n  }\n\n  .home-feature-grid,\n  .home-post-grid {\n    grid-template-columns: 1fr;\n  }\n\n  .home-hero__visual {\n    min-height: 360px;\n  }\n\n  .home-floating-card {\n    position: static;\n    margin-top: 14px;\n  }\n\n  .home-hero__image-shell {\n    margin-bottom: 12px;\n  }\n\n  .community-preview {\n    padding: 24px;\n  }\n\n  .home-final-cta {\n    padding: 48px 20px;\n    border-radius: 36px;\n  }\n}\n"],["STYLE",{},".auth-page {\n  display: flex;\n  align-items: center;\n  padding: 32px 24px 56px;\n  min-height: calc(100vh - 80px);\n}\n\n.auth-layout {\n  max-width: 1180px;\n  width: 100%;\n  margin: 0 auto;\n  display: grid;\n  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);\n  gap: 36px;\n  align-items: stretch;\n}\n\n.auth-visual,\n.auth-card {\n  position: relative;\n  overflow: hidden;\n  border-radius: 32px;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  box-shadow: var(--shadow-soft);\n  height: 640px;\n  box-sizing: border-box;\n  width: 100%;\n}\n\n.auth-visual {\n  display: flex;\n  flex-direction: column;\n  justify-content: space-between;\n  gap: 16px;\n  padding: 34px 40px;\n  background:\n    radial-gradient(circle at top right, rgba(234, 245, 157, 0.52), transparent 24%),\n    radial-gradient(circle at bottom left, rgba(193, 217, 92, 0.26), transparent 26%),\n    linear-gradient(180deg, rgba(247, 250, 239, 0.96), rgba(255, 255, 255, 0.92));\n}\n\n.auth-visual__main {\n  display: flex;\n  flex-direction: column;\n  gap: 16px;\n}\n\n.auth-visual__top,\n.auth-visual__brand {\n  display: flex;\n  align-items: center;\n  gap: 14px;\n}\n\n.auth-visual__brand strong {\n  color: var(--color-primary-500);\n  font-size: 1.6rem;\n  letter-spacing: -0.04em;\n}\n\n.auth-visual__logo {\n  display: grid;\n  place-items: center;\n  width: 48px;\n  height: 48px;\n  border-radius: 16px;\n  color: #fff;\n  font-weight: 800;\n  background: linear-gradient(135deg, var(--color-primary-400), var(--color-primary-500));\n}\n\n.auth-visual__chip {\n  display: inline-flex;\n  align-items: center;\n  width: fit-content;\n  padding: 10px 16px;\n  border-radius: 999px;\n  color: var(--color-primary-500);\n  background: rgba(234, 245, 157, 0.78);\n  font-size: 0.92rem;\n  font-weight: 700;\n}\n\n.auth-visual__content {\n  max-width: 650px;\n}\n\n.auth-visual__content h1 {\n  margin: 0 0 10px;\n  font-size: clamp(28px, 2.2vw, 38px);\n  line-height: 1.06;\n  letter-spacing: -0.04em;\n}\n\n.auth-visual__content p,\n.auth-note p,\n.auth-card__header p,\n.auth-card__alternate,\n.auth-form__checkbox span {\n  margin: 0;\n  color: var(--color-text-muted);\n  line-height: 1.78;\n}\n\n.auth-visual__inline-features {\n  display: flex;\n  flex-wrap: wrap;\n  align-items: center;\n  gap: 10px;\n  margin-top: 12px;\n  font-size: 0.92rem;\n  font-weight: 600;\n  color: var(--color-primary-500);\n}\n\n.auth-visual__inline-features .dot {\n  color: rgba(79, 132, 40, 0.4);\n}\n\n.auth-carousel-placeholder {\n  width: 100%;\n  height: clamp(260px, 26vh, 300px);\n  margin-top: 16px;\n  overflow: hidden;\n  border-radius: 24px;\n  background: rgba(234, 245, 157, 0.4);\n  border: 1px solid rgba(79, 132, 40, 0.12);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  color: var(--color-primary-500);\n  font-weight: 600;\n  text-align: center;\n  padding: 20px;\n}\n\n.auth-carousel-placeholder img {\n  display: block;\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  border-radius: inherit;\n}\n\n.auth-card {\n  display: flex;\n  flex-direction: column;\n  justify-content: flex-start;\n  gap: 14px;\n  padding: 34px 40px;\n  background: rgba(255, 255, 255, 0.96);\n}\n\n.auth-card__header h2 {\n  margin: 0 0 8px;\n  font-size: 2.2rem;\n  letter-spacing: -0.04em;\n}\n\n.auth-card__switcher {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  padding: 6px;\n  border-radius: 18px;\n  background: rgba(234, 245, 157, 0.5);\n}\n\n.auth-card__switcher a,\n.auth-card__switcher span {\n  display: inline-flex;\n  justify-content: center;\n  align-items: center;\n  padding: 12px 14px;\n  border-radius: 14px;\n  font-weight: 700;\n  text-decoration: none;\n}\n\n.auth-card__switcher .is-active {\n  color: #fff;\n  background: var(--color-primary-500);\n  box-shadow: 0 8px 18px rgba(79, 132, 40, 0.18);\n}\n\n.auth-card__switcher a {\n  color: rgba(23, 55, 21, 0.76);\n}\n\n.auth-card__message {\n  padding: 14px 16px;\n  border-radius: 16px;\n  font-weight: 600;\n}\n\n.auth-card__message--error {\n  color: #8a5a0b;\n  background: rgba(246, 224, 177, 0.5);\n  border: 1px solid rgba(214, 162, 74, 0.24);\n}\n\n.auth-card__message--success {\n  color: var(--color-primary-500);\n  background: rgba(234, 245, 157, 0.34);\n  border: 1px solid rgba(79, 132, 40, 0.16);\n}\n\n.auth-form {\n  display: grid;\n  gap: 18px;\n}\n\n.auth-form label {\n  display: grid;\n  gap: 10px;\n}\n\n.auth-form label > span {\n  font-weight: 700;\n}\n\n.auth-form input {\n  width: 100%;\n  min-width: 0;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  border-radius: 16px;\n  padding: 14px 16px;\n  background: linear-gradient(90deg, rgba(247, 250, 239, 0.98), rgba(234, 245, 157, 0.28));\n  font: inherit;\n}\n\n.auth-form__row {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 12px;\n}\n\n.auth-form__checkbox {\n  display: flex !important;\n  align-items: center;\n  gap: 10px;\n}\n\n.auth-form__checkbox input {\n  width: 20px;\n  height: 20px;\n  padding: 0;\n  flex-shrink: 0;\n}\n\n.auth-form__terms-link {\n  color: var(--color-primary-500);\n  font-weight: 700;\n  text-decoration: underline;\n  text-underline-offset: 2px;\n}\n\n.auth-form__terms-link:hover {\n  color: var(--color-primary-400);\n}\n\n.auth-form__link-button {\n  border: 0;\n  padding: 0;\n  color: var(--color-primary-500);\n  background: transparent;\n  font-weight: 700;\n}\n\n.auth-form__submit {\n  width: 100%;\n  margin-top: 6px;\n}\n\n.auth-card__alternate {\n  text-align: center;\n}\n\n.auth-card__alternate a {\n  color: var(--color-primary-500);\n  font-weight: 800;\n}\n\n.auth-card__divider {\n  position: relative;\n  text-align: center;\n  color: var(--color-text-muted);\n}\n\n.auth-card__divider::before {\n  content: '';\n  position: absolute;\n  inset: 50% 0 auto;\n  height: 1px;\n  background: rgba(79, 132, 40, 0.12);\n}\n\n.auth-card__divider {\n  display: grid;\n  place-items: center;\n}\n\n.auth-card__divider::after {\n  content: 'hoặc';\n  position: relative;\n  z-index: 1;\n  padding: 0 14px;\n  background: rgba(255, 255, 255, 0.96);\n}\n\n.auth-card__socials {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: 14px;\n}\n\n.auth-card__socials button {\n  border: 1px solid rgba(79, 132, 40, 0.16);\n  border-radius: 16px;\n  padding: 14px 16px;\n  color: var(--color-text);\n  background: #fff;\n  font: inherit;\n  font-weight: 700;\n}\n\n.auth-note {\n  display: grid;\n  gap: 8px;\n  justify-items: center;\n  padding-top: 8px;\n  text-align: center;\n}\n\n.auth-note strong {\n  color: var(--color-primary-500);\n  font-size: 0.92rem;\n  text-transform: uppercase;\n  letter-spacing: 0.08em;\n}\n\n/* 2K+ screens (>= 1600px) */\n@media (min-width: 1600px) {\n  .auth-layout {\n    max-width: 1360px;\n    gap: 44px;\n  }\n\n  .auth-visual,\n  .auth-card {\n    height: 760px;\n    padding: 48px 52px;\n  }\n\n  .auth-visual__content h1 {\n    font-size: clamp(48px, 3.2vw, 68px);\n  }\n\n  .auth-carousel-placeholder {\n    margin-top: 24px;\n  }\n\n  .auth-visual__main {\n    gap: 24px;\n  }\n\n  .auth-card {\n    gap: 18px;\n    padding: 48px 52px;\n  }\n}\n\n/* Laptop / small desktop (900px – 1199px) */\n@media (max-width: 1199px) {\n  .auth-layout {\n    max-width: 1040px;\n    gap: 28px;\n  }\n\n  .auth-visual,\n  .auth-card {\n    height: auto;\n    min-height: 580px;\n    padding: 32px 36px;\n  }\n\n  .auth-visual__content h1 {\n    font-size: clamp(34px, 3.2vw, 48px);\n  }\n\n  .auth-carousel-placeholder {\n    height: 240px;\n    margin-top: 16px;\n  }\n}\n\n/* Tablet / mobile (< 900px) */\n@media (max-width: 900px) {\n  .auth-page {\n    min-height: 0;\n    padding: 24px 16px 48px;\n    align-items: flex-start;\n  }\n\n  .auth-layout {\n    grid-template-columns: 1fr;\n  }\n\n  .auth-visual,\n  .auth-card {\n    height: auto;\n    min-height: 0;\n    padding: 28px 24px;\n  }\n\n  .auth-visual__logo {\n    width: 42px;\n    height: 42px;\n  }\n}\n\n@media (max-width: 640px) {\n  .auth-card__socials {\n    grid-template-columns: 1fr;\n  }\n\n  .auth-form__row {\n    flex-direction: column;\n    align-items: flex-start;\n  }\n}\n"],["STYLE",{},".post-card-ui {\n  display: flex;\n  flex-direction: column;\n  min-width: 0;\n  overflow: hidden;\n  border-radius: 24px;\n  background: rgba(255, 255, 255, 0.96);\n  border: 1px solid rgba(234, 245, 157, 0.62);\n  box-shadow: 0 4px 20px rgba(79, 132, 40, 0.08);\n  transition:\n    transform 0.25s ease,\n    box-shadow 0.25s ease;\n}\n\n.post-card-ui:hover {\n  transform: translateY(-2px);\n  box-shadow: 0 12px 32px rgba(79, 132, 40, 0.12);\n}\n\n.post-card-ui__media {\n  position: relative;\n  height: 220px;\n  overflow: hidden;\n  background: linear-gradient(180deg, rgba(234, 245, 157, 0.52), rgba(193, 217, 92, 0.18));\n}\n\n.post-card-ui__media img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  display: block;\n}\n\n.post-card-ui__category,\n.post-card-ui__save-button {\n  position: absolute;\n  top: 16px;\n  z-index: 1;\n  border-radius: 999px;\n  background: rgba(255, 255, 255, 0.92);\n  box-shadow: 0 8px 20px rgba(79, 132, 40, 0.12);\n}\n\n.post-card-ui__category {\n  left: 16px;\n  padding: 8px 12px;\n  color: #336a29;\n  font-size: 0.75rem;\n  font-weight: 800;\n}\n\n.post-card-ui__save-button {\n  right: 16px;\n  border: 0;\n  padding: 10px 12px;\n  color: #336a29;\n  font-weight: 700;\n}\n\n.post-card-ui__body {\n  display: grid;\n  gap: 16px;\n  flex: 1;\n  padding: 24px;\n}\n\n.post-card-ui__body h3 {\n  margin: 0;\n  font-size: 1.38rem;\n  line-height: 1.4;\n  letter-spacing: -0.03em;\n}\n\n.post-card-ui__body p {\n  margin: 0;\n  color: rgba(23, 55, 21, 0.74);\n  line-height: 1.72;\n}\n\n.post-card-ui__meta {\n  display: grid;\n  gap: 16px;\n  padding-top: 16px;\n  border-top: 1px solid rgba(79, 132, 40, 0.12);\n}\n\n.post-card-ui__author {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n}\n\n.post-card-ui__avatar {\n  display: grid;\n  place-items: center;\n  width: 36px;\n  height: 36px;\n  border-radius: 50%;\n  color: #336a29;\n  background: #eaf59d;\n  font-size: 0.78rem;\n  font-weight: 800;\n}\n\n.post-card-ui__author strong,\n.post-card-ui__author span,\n.post-card-ui__stats span {\n  display: block;\n}\n\n.post-card-ui__author span,\n.post-card-ui__stats {\n  color: rgba(23, 55, 21, 0.62);\n  font-size: 0.9rem;\n}\n\n.post-card-ui__stats {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 14px;\n}\n\n.post-card-ui__link {\n  width: fit-content;\n  color: #4f8428;\n  font-size: 0.95rem;\n  font-weight: 800;\n}\n\n@media (max-width: 720px) {\n  .post-card-ui__media {\n    height: 200px;\n  }\n\n  .post-card-ui__body {\n    padding: 20px;\n  }\n}\n"],["STYLE",{},".post-detail-page {\n  display: grid;\n  gap: 28px;\n}\n\n.post-breadcrumb {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 8px;\n  color: rgba(23, 55, 21, 0.62);\n  font-size: 0.95rem;\n}\n\n.post-breadcrumb a:hover {\n  color: #4f8428;\n}\n\n.post-detail-layout {\n  display: grid;\n  grid-template-columns: minmax(0, 2fr) minmax(300px, 0.9fr);\n  gap: 28px;\n  align-items: start;\n}\n\n.post-detail-main,\n.post-detail-sidebar {\n  min-width: 0;\n}\n\n.post-detail-main {\n  display: grid;\n  gap: 28px;\n}\n\n.article-header {\n  display: grid;\n  gap: 18px;\n}\n\n.article-header__tag {\n  display: inline-flex;\n  align-items: center;\n  width: fit-content;\n  padding: 10px 16px;\n  border-radius: 999px;\n  color: #4f8428;\n  background: rgba(128, 177, 85, 0.18);\n  font-size: 0.88rem;\n  font-weight: 700;\n}\n\n.article-header h1,\n.post-detail-empty h1 {\n  margin: 0;\n  font-size: clamp(2.4rem, 4.6vw, 3.8rem);\n  line-height: 1.08;\n  letter-spacing: -0.05em;\n}\n\n.article-header p,\n.post-detail-empty p {\n  margin: 0;\n  color: rgba(23, 55, 21, 0.72);\n  font-size: 1.08rem;\n  line-height: 1.78;\n}\n\n.article-header__meta {\n  display: flex;\n  flex-wrap: wrap;\n  align-items: center;\n  justify-content: space-between;\n  gap: 18px;\n  padding: 16px 0;\n  border-top: 1px solid rgba(79, 132, 40, 0.1);\n  border-bottom: 1px solid rgba(79, 132, 40, 0.1);\n}\n\n.article-header__author {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n}\n\n.article-header__avatar,\n.comment-section__avatar,\n.comment-item__avatar,\n.post-side-card__author-avatar {\n  display: grid;\n  place-items: center;\n  border-radius: 50%;\n  font-weight: 800;\n}\n\n.article-header__avatar {\n  width: 48px;\n  height: 48px;\n  color: #336a29;\n  background: #eaf59d;\n}\n\n.article-header__author strong,\n.article-header__author span,\n.article-header__stats span {\n  display: block;\n}\n\n.article-header__author span,\n.article-header__stats {\n  color: rgba(23, 55, 21, 0.62);\n  font-size: 0.92rem;\n}\n\n.article-header__stats {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 18px;\n}\n\n.article-content {\n  display: grid;\n  gap: 28px;\n}\n\n.article-content__cover {\n  margin: 0;\n  overflow: hidden;\n  border-radius: 24px;\n  box-shadow: 0 4px 20px rgba(79, 132, 40, 0.08);\n}\n\n.article-content__cover img {\n  display: block;\n  width: 100%;\n  aspect-ratio: 16 / 9;\n  object-fit: cover;\n}\n\n.article-content__body {\n  display: grid;\n  gap: 26px;\n}\n\n.article-content__section {\n  display: grid;\n  gap: 12px;\n}\n\n.article-content__section h2,\n.comment-section h2,\n.related-posts h2,\n.post-detail-suggestions h2,\n.post-side-card h2 {\n  margin: 0;\n  font-size: 1.9rem;\n  line-height: 1.22;\n  letter-spacing: -0.04em;\n}\n\n.article-content__section p,\n.comment-item__body p,\n.post-side-card p,\n.related-posts__item p {\n  margin: 0;\n  color: rgba(23, 55, 21, 0.78);\n  line-height: 1.8;\n}\n\n.article-quick-tip {\n  display: grid;\n  gap: 8px;\n  padding: 18px 20px;\n  border-radius: 18px;\n  background: rgba(193, 217, 92, 0.28);\n  border: 1px solid rgba(128, 177, 85, 0.22);\n}\n\n.article-quick-tip strong {\n  color: #4f8428;\n}\n\n.article-actions {\n  display: flex;\n  flex-wrap: wrap;\n  justify-content: space-between;\n  gap: 12px;\n  padding: 14px;\n  border-radius: 18px;\n  background: rgba(255, 255, 255, 0.96);\n  border: 1px solid rgba(79, 132, 40, 0.12);\n  box-shadow: 0 4px 20px rgba(79, 132, 40, 0.08);\n}\n\n.article-actions__button,\n.post-side-card--author button,\n.comment-item__footer button {\n  border: 0;\n  background: transparent;\n  color: rgba(23, 55, 21, 0.72);\n  font: inherit;\n}\n\n.article-actions__button {\n  padding: 10px 14px;\n  border-radius: 999px;\n}\n\n.article-actions__button.is-accent {\n  color: #4f8428;\n  background: rgba(128, 177, 85, 0.14);\n}\n\n.comment-section {\n  display: grid;\n  gap: 22px;\n}\n\n.comment-section__composer {\n  display: flex;\n  gap: 14px;\n}\n\n.comment-section__avatar {\n  width: 48px;\n  height: 48px;\n  color: #4f8428;\n  background: rgba(193, 217, 92, 0.38);\n}\n\n.comment-section__form {\n  flex: 1;\n}\n\n.comment-section__form textarea {\n  width: 100%;\n  resize: vertical;\n  border: 1px solid rgba(115, 121, 106, 0.26);\n  border-radius: 14px;\n  padding: 14px 16px;\n  font: inherit;\n  min-height: 112px;\n}\n\n.comment-section__actions {\n  display: flex;\n  justify-content: flex-end;\n  margin-top: 10px;\n}\n\n.comment-section__list {\n  display: grid;\n  gap: 18px;\n}\n\n.comment-item {\n  display: flex;\n  gap: 14px;\n}\n\n.comment-item__avatar {\n  width: 40px;\n  height: 40px;\n  flex: 0 0 auto;\n  color: #336a29;\n  background: #eaf59d;\n  font-size: 0.82rem;\n}\n\n.comment-item__body {\n  display: grid;\n  gap: 8px;\n}\n\n.comment-item__meta {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 8px;\n  align-items: baseline;\n}\n\n.comment-item__meta span,\n.comment-item__footer {\n  color: rgba(23, 55, 21, 0.62);\n  font-size: 0.9rem;\n}\n\n.comment-item__footer {\n  display: flex;\n  gap: 16px;\n  align-items: center;\n}\n\n.post-detail-sidebar {\n  display: grid;\n  gap: 20px;\n}\n\n.post-side-card,\n.related-posts {\n  display: grid;\n  gap: 16px;\n  padding: 24px;\n  border-radius: 24px;\n  background: rgba(255, 255, 255, 0.96);\n  border: 1px solid rgba(79, 132, 40, 0.12);\n  box-shadow: 0 4px 20px rgba(79, 132, 40, 0.08);\n}\n\n.post-side-card--author {\n  justify-items: center;\n  text-align: center;\n}\n\n.post-side-card__author-avatar {\n  width: 72px;\n  height: 72px;\n  color: #336a29;\n  background: linear-gradient(135deg, #eaf59d, #c1d95c);\n  font-size: 1.1rem;\n}\n\n.post-side-card--author button {\n  width: 100%;\n  border: 2px solid #4f8428;\n  border-radius: 999px;\n  padding: 12px 16px;\n  color: #4f8428;\n  font-weight: 700;\n}\n\n.related-posts__list {\n  display: grid;\n  gap: 14px;\n}\n\n.related-posts__item {\n  display: grid;\n  grid-template-columns: 88px 1fr;\n  gap: 12px;\n  align-items: start;\n}\n\n.related-posts__item img {\n  width: 88px;\n  height: 88px;\n  object-fit: cover;\n  border-radius: 14px;\n}\n\n.related-posts__item h3 {\n  margin: 0;\n  font-size: 1rem;\n  line-height: 1.45;\n}\n\n.related-posts__item span {\n  color: rgba(23, 55, 21, 0.62);\n  font-size: 0.86rem;\n}\n\n.post-side-card__topics {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 10px;\n}\n\n.post-side-card__topics span {\n  padding: 10px 14px;\n  border-radius: 999px;\n  color: rgba(23, 55, 21, 0.76);\n  background: rgba(193, 217, 92, 0.24);\n  font-size: 0.9rem;\n  font-weight: 600;\n}\n\n.post-side-card--cta {\n  color: #fff;\n  background: linear-gradient(180deg, #4f8428 0%, #336a29 100%);\n}\n\n.post-side-card--cta h2,\n.post-side-card--cta p {\n  color: inherit;\n}\n\n.post-detail-suggestions {\n  display: grid;\n  gap: 20px;\n}\n\n.post-detail-suggestions__grid {\n  display: grid;\n  grid-template-columns: repeat(3, minmax(0, 1fr));\n  gap: 24px;\n}\n\n.post-detail-empty {\n  display: grid;\n  gap: 16px;\n  justify-items: start;\n  padding: 32px 28px;\n  border-radius: 28px;\n  background: rgba(255, 255, 255, 0.9);\n  border: 1px solid rgba(79, 132, 40, 0.12);\n}\n\n@media (max-width: 1120px) {\n  .post-detail-layout,\n  .post-detail-suggestions__grid {\n    grid-template-columns: 1fr;\n  }\n}\n\n@media (max-width: 720px) {\n  .article-actions,\n  .comment-section__composer {\n    flex-direction: column;\n  }\n\n  .article-header__meta {\n    align-items: flex-start;\n  }\n\n  .post-side-card,\n  .related-posts {\n    padding: 20px;\n  }\n}\n"],["STYLE",{},".saved-posts-page {\n  display: grid;\n  gap: 28px;\n}\n\n.saved-posts-page__breadcrumb {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 8px;\n  color: rgba(23, 55, 21, 0.62);\n  font-size: 0.95rem;\n}\n\n.saved-posts-page__breadcrumb a:hover {\n  color: #4f8428;\n}\n\n.saved-posts-hero {\n  display: grid;\n  grid-template-columns: minmax(0, 1fr) minmax(280px, 0.74fr);\n  gap: 28px;\n  align-items: center;\n  padding: 30px 24px;\n  border-radius: 32px;\n  background: rgba(255, 255, 255, 0.94);\n  box-shadow: 0 4px 20px rgba(79, 132, 40, 0.08);\n}\n\n.saved-posts-hero__content {\n  display: grid;\n  gap: 18px;\n}\n\n.saved-posts-hero__badge {\n  display: inline-flex;\n  align-items: center;\n  width: fit-content;\n  padding: 10px 16px;\n  border-radius: 999px;\n  color: #4f8428;\n  background: rgba(128, 177, 85, 0.12);\n  font-size: 0.9rem;\n  font-weight: 700;\n}\n\n.saved-posts-hero__content h1,\n.saved-posts-empty h2 {\n  margin: 0;\n  font-size: clamp(2.4rem, 4.8vw, 3.8rem);\n  line-height: 1.08;\n  letter-spacing: -0.05em;\n}\n\n.saved-posts-hero__content p,\n.saved-posts-empty p {\n  margin: 0;\n  max-width: 640px;\n  color: rgba(23, 55, 21, 0.74);\n  font-size: 1.08rem;\n  line-height: 1.78;\n}\n\n.saved-posts-hero__visual img {\n  display: block;\n  width: 100%;\n  max-height: 320px;\n  object-fit: contain;\n}\n\n.saved-posts-stats {\n  display: grid;\n  grid-template-columns: repeat(3, minmax(0, 1fr));\n  gap: 18px;\n}\n\n.saved-posts-stats__card {\n  display: grid;\n  gap: 6px;\n  padding: 22px 24px;\n  border-radius: 24px;\n  background: rgba(255, 255, 255, 0.96);\n  box-shadow: 0 4px 20px rgba(79, 132, 40, 0.08);\n}\n\n.saved-posts-stats__card strong {\n  font-size: 2rem;\n  letter-spacing: -0.04em;\n}\n\n.saved-posts-stats__card span {\n  color: rgba(23, 55, 21, 0.66);\n}\n\n.saved-posts-filter {\n  display: grid;\n  grid-template-columns: minmax(240px, 320px) 1fr minmax(190px, 220px);\n  gap: 14px;\n  align-items: center;\n  padding: 14px;\n  border-radius: 18px;\n  background: rgba(255, 255, 255, 0.96);\n  border: 1px solid rgba(79, 132, 40, 0.1);\n}\n\n.saved-posts-filter__search,\n.saved-posts-filter__sort {\n  display: grid;\n  gap: 8px;\n}\n\n.saved-posts-filter__search span,\n.saved-posts-filter__sort span {\n  color: rgba(23, 55, 21, 0.66);\n  font-size: 0.84rem;\n  font-weight: 700;\n}\n\n.saved-posts-filter__search input,\n.saved-posts-filter__sort select {\n  width: 100%;\n  min-width: 0;\n  padding: 12px 14px;\n  border: 1px solid rgba(115, 121, 106, 0.24);\n  border-radius: 12px;\n  background: rgba(234, 245, 157, 0.22);\n  font: inherit;\n}\n\n.saved-posts-filter__chips {\n  display: flex;\n  gap: 10px;\n  overflow-x: auto;\n}\n\n.saved-posts-filter__chip {\n  flex: 0 0 auto;\n  padding: 10px 14px;\n  border: 1px solid rgba(128, 177, 85, 0.22);\n  border-radius: 999px;\n  color: #336a29;\n  background: rgba(193, 217, 92, 0.18);\n  font-size: 0.9rem;\n  font-weight: 700;\n}\n\n.saved-posts-filter__chip.is-active {\n  color: #fff;\n  background: #4f8428;\n}\n\n.saved-posts-layout {\n  display: grid;\n  grid-template-columns: minmax(0, 2fr) minmax(280px, 0.9fr);\n  gap: 24px;\n  align-items: start;\n}\n\n.saved-posts-layout__content {\n  min-width: 0;\n}\n\n.saved-posts-grid {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: 22px;\n}\n\n.saved-post-card {\n  display: flex;\n  flex-direction: column;\n  overflow: hidden;\n  border-radius: 24px;\n  background: rgba(255, 255, 255, 0.96);\n  box-shadow: 0 4px 20px rgba(79, 132, 40, 0.08);\n}\n\n.saved-post-card__media {\n  position: relative;\n  height: 220px;\n  overflow: hidden;\n}\n\n.saved-post-card__media img {\n  display: block;\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n}\n\n.saved-post-card__tag,\n.saved-post-card__bookmark {\n  position: absolute;\n  top: 14px;\n  z-index: 1;\n  border-radius: 999px;\n  background: rgba(255, 255, 255, 0.9);\n}\n\n.saved-post-card__tag {\n  left: 14px;\n  padding: 8px 12px;\n  color: #4f8428;\n  font-size: 0.78rem;\n  font-weight: 700;\n}\n\n.saved-post-card__bookmark {\n  right: 14px;\n  border: 0;\n  padding: 10px 12px;\n  color: #4f8428;\n  font-weight: 700;\n}\n\n.saved-post-card__body {\n  display: grid;\n  gap: 16px;\n  padding: 22px;\n}\n\n.saved-post-card__body h3 {\n  margin: 0;\n  font-size: 1.5rem;\n  line-height: 1.24;\n  letter-spacing: -0.04em;\n}\n\n.saved-post-card__meta {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 8px;\n  align-items: center;\n  color: rgba(23, 55, 21, 0.62);\n  font-size: 0.92rem;\n}\n\n.saved-post-card__author-badge {\n  display: grid;\n  place-items: center;\n  width: 24px;\n  height: 24px;\n  border-radius: 50%;\n  color: #336a29;\n  background: #c1d95c;\n  font-size: 0.74rem;\n  font-weight: 800;\n}\n\n.saved-post-card__actions {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 12px;\n  padding-top: 14px;\n  border-top: 1px solid rgba(79, 132, 40, 0.12);\n}\n\n.saved-post-card__remove {\n  border: 0;\n  color: rgba(23, 55, 21, 0.66);\n  background: transparent;\n  font: inherit;\n}\n\n.saved-post-card__read {\n  padding: 10px 16px;\n  border-radius: 10px;\n  color: #fff;\n  background: linear-gradient(135deg, #80b155, #4f8428);\n  font-size: 0.92rem;\n  font-weight: 700;\n}\n\n.saved-sidebar {\n  display: grid;\n  gap: 18px;\n}\n\n.saved-sidebar__card {\n  display: grid;\n  gap: 16px;\n  padding: 22px;\n  border-radius: 24px;\n  background: rgba(255, 255, 255, 0.96);\n  box-shadow: 0 4px 20px rgba(79, 132, 40, 0.08);\n}\n\n.saved-sidebar__card h2 {\n  margin: 0;\n  font-size: 1.5rem;\n  letter-spacing: -0.04em;\n}\n\n.saved-sidebar__folders,\n.saved-sidebar__recent-list {\n  display: grid;\n  gap: 10px;\n}\n\n.saved-sidebar__folder {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: 12px;\n  padding: 12px 14px;\n  border: 0;\n  border-radius: 14px;\n  color: rgba(23, 55, 21, 0.76);\n  background: transparent;\n  font: inherit;\n  text-align: left;\n}\n\n.saved-sidebar__folder.is-active {\n  color: #4f8428;\n  background: rgba(128, 177, 85, 0.12);\n}\n\n.saved-sidebar__folder strong {\n  min-width: 28px;\n  padding: 3px 8px;\n  border-radius: 999px;\n  color: #4f8428;\n  background: rgba(193, 217, 92, 0.38);\n  font-size: 0.8rem;\n  text-align: center;\n}\n\n.saved-sidebar__recent-item {\n  display: grid;\n  grid-template-columns: 80px 1fr;\n  gap: 12px;\n  align-items: center;\n}\n\n.saved-sidebar__recent-item img {\n  width: 80px;\n  height: 80px;\n  object-fit: cover;\n  border-radius: 14px;\n}\n\n.saved-sidebar__recent-item h3 {\n  margin: 0;\n  font-size: 1rem;\n  line-height: 1.4;\n}\n\n.saved-sidebar__recent-item p,\n.saved-sidebar__card--cta p {\n  margin: 0;\n  color: rgba(23, 55, 21, 0.7);\n  line-height: 1.68;\n}\n\n.saved-sidebar__card--cta {\n  color: #fff;\n  background: linear-gradient(135deg, #80b155, #4f8428);\n}\n\n.saved-sidebar__card--cta h2,\n.saved-sidebar__card--cta p {\n  color: inherit;\n}\n\n.saved-posts-empty {\n  display: grid;\n  justify-items: center;\n  gap: 14px;\n  padding: 40px 24px;\n  border-radius: 24px;\n  text-align: center;\n  background: rgba(255, 255, 255, 0.94);\n  box-shadow: 0 4px 20px rgba(79, 132, 40, 0.08);\n}\n\n.saved-posts-empty__icon {\n  display: grid;\n  place-items: center;\n  width: 72px;\n  height: 72px;\n  border-radius: 50%;\n  color: #4f8428;\n  background: rgba(234, 245, 157, 0.6);\n  font-size: 2rem;\n}\n\n@media (max-width: 1180px) {\n  .saved-posts-hero,\n  .saved-posts-layout,\n  .saved-posts-filter {\n    grid-template-columns: 1fr;\n  }\n}\n\n@media (max-width: 900px) {\n  .saved-posts-stats,\n  .saved-posts-grid {\n    grid-template-columns: 1fr;\n  }\n}\n"],["STYLE",{},".tips-page {\n  display: grid;\n  gap: 28px;\n}\n\n.tips-hero {\n  display: grid;\n  grid-template-columns: minmax(0, 1fr) minmax(320px, 0.9fr);\n  gap: 28px;\n  align-items: center;\n  overflow: hidden;\n  padding: 32px 28px;\n  border-radius: 32px;\n  background: linear-gradient(90deg, rgba(234, 245, 157, 0.58), rgba(247, 250, 239, 0.98));\n  border: 1px solid rgba(234, 245, 157, 0.48);\n  box-shadow: 0 4px 20px rgba(79, 132, 40, 0.08);\n}\n\n.tips-hero__content {\n  display: grid;\n  gap: 18px;\n}\n\n.tips-hero__badge {\n  display: inline-flex;\n  align-items: center;\n  width: fit-content;\n  padding: 10px 16px;\n  border-radius: 999px;\n  color: #336a29;\n  background: rgba(255, 255, 255, 0.68);\n  border: 1px solid rgba(128, 177, 85, 0.22);\n  font-size: 0.9rem;\n  font-weight: 700;\n}\n\n.tips-hero__content h1 {\n  margin: 0;\n  font-size: clamp(2.4rem, 4vw, 4rem);\n  line-height: 1.06;\n  letter-spacing: -0.05em;\n}\n\n.tips-hero__content p {\n  max-width: 560px;\n  margin: 0;\n  color: rgba(23, 55, 21, 0.72);\n  font-size: 1.08rem;\n  line-height: 1.78;\n}\n\n.tips-hero__visual {\n  min-width: 0;\n  height: 100%;\n}\n\n.tips-hero__visual img {\n  display: block;\n  width: 100%;\n  max-height: 320px;\n  object-fit: contain;\n  object-position: right center;\n}\n\n.tips-filter-bar {\n  position: sticky;\n  top: 92px;\n  z-index: 12;\n  display: grid;\n  grid-template-columns: minmax(260px, 360px) 1fr minmax(180px, 220px);\n  gap: 16px;\n  align-items: center;\n  padding: 14px;\n  border-radius: 24px;\n  background: rgba(255, 255, 255, 0.9);\n  backdrop-filter: blur(16px);\n  border: 1px solid rgba(255, 255, 255, 0.56);\n  box-shadow: 0 4px 20px rgba(79, 132, 40, 0.08);\n}\n\n.tips-filter-bar__search,\n.tips-filter-bar__sort {\n  display: grid;\n  gap: 8px;\n}\n\n.tips-filter-bar__search span,\n.tips-filter-bar__sort span {\n  color: rgba(23, 55, 21, 0.72);\n  font-size: 0.85rem;\n  font-weight: 700;\n}\n\n.tips-filter-bar__search input,\n.tips-filter-bar__sort select {\n  width: 100%;\n  min-width: 0;\n  border: 1px solid rgba(115, 121, 106, 0.28);\n  border-radius: 14px;\n  padding: 13px 16px;\n  color: #173715;\n  background: #fff;\n  outline: none;\n}\n\n.tips-filter-bar__search input:focus,\n.tips-filter-bar__sort select:focus {\n  border-color: #4f8428;\n  box-shadow: 0 0 0 3px rgba(128, 177, 85, 0.18);\n}\n\n.tips-filter-bar__chips {\n  display: flex;\n  gap: 10px;\n  align-items: center;\n  overflow-x: auto;\n  padding-bottom: 2px;\n}\n\n.tips-filter-chip,\n.tips-topic-chip {\n  flex: 0 0 auto;\n  border: 1px solid rgba(115, 121, 106, 0.28);\n  border-radius: 999px;\n  padding: 11px 16px;\n  color: rgba(23, 55, 21, 0.74);\n  background: #fff;\n  font-size: 0.92rem;\n  font-weight: 600;\n}\n\n.tips-filter-chip.is-active {\n  color: #fff;\n  background: #4f8428;\n  border-color: #4f8428;\n}\n\n.tips-layout {\n  display: grid;\n  grid-template-columns: minmax(0, 2fr) minmax(280px, 0.92fr);\n  gap: 28px;\n  align-items: start;\n}\n\n.tips-layout__content {\n  min-width: 0;\n}\n\n.tips-post-grid {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: 24px;\n}\n\n.tips-empty-state {\n  display: grid;\n  gap: 8px;\n  margin-top: 22px;\n  padding: 24px;\n  border-radius: 22px;\n  background: rgba(255, 255, 255, 0.88);\n  border: 1px solid rgba(234, 245, 157, 0.56);\n}\n\n.tips-empty-state p,\n.tips-side-card p {\n  margin: 0;\n  color: rgba(23, 55, 21, 0.72);\n  line-height: 1.72;\n}\n\n.tips-layout__sidebar {\n  display: grid;\n  gap: 20px;\n}\n\n.tips-side-card {\n  display: grid;\n  gap: 16px;\n  padding: 24px;\n  border-radius: 24px;\n  background: rgba(255, 255, 255, 0.96);\n  border: 1px solid rgba(234, 245, 157, 0.44);\n  box-shadow: 0 4px 20px rgba(79, 132, 40, 0.08);\n}\n\n.tips-side-card h2,\n.tips-side-card h3 {\n  margin: 0;\n  font-size: 1.26rem;\n  line-height: 1.45;\n  letter-spacing: -0.03em;\n}\n\n.tips-side-card--suggestion {\n  position: relative;\n  overflow: hidden;\n  background: linear-gradient(135deg, rgba(234, 245, 157, 0.84), rgba(234, 245, 157, 0.44));\n}\n\n.tips-side-card--suggestion::after {\n  content: '';\n  position: absolute;\n  right: -26px;\n  top: -18px;\n  width: 100px;\n  height: 100px;\n  border-radius: 50%;\n  background: rgba(79, 132, 40, 0.08);\n}\n\n.tips-topic-list {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 10px;\n}\n\n.tips-saved-list {\n  display: grid;\n  gap: 14px;\n}\n\n.tips-saved-item {\n  display: grid;\n  grid-template-columns: auto 1fr;\n  gap: 12px;\n  align-items: center;\n}\n\n.tips-saved-item__icon {\n  display: grid;\n  place-items: center;\n  width: 48px;\n  height: 48px;\n  border-radius: 12px;\n  color: #4f8428;\n  background: rgba(193, 217, 92, 0.36);\n  font-size: 0.85rem;\n  font-weight: 800;\n}\n\n.tips-saved-item h3 {\n  font-size: 0.98rem;\n}\n\n.tips-saved-item p {\n  font-size: 0.9rem;\n}\n\n.tips-side-card--cta {\n  justify-items: center;\n  text-align: center;\n  color: #fff;\n  background: linear-gradient(180deg, #4f8428 0%, #336a29 100%);\n}\n\n.tips-side-card--cta h2,\n.tips-side-card--cta p {\n  color: inherit;\n}\n\n.tips-side-card__cta-icon {\n  display: grid;\n  place-items: center;\n  width: 64px;\n  height: 64px;\n  border-radius: 50%;\n  background: rgba(255, 255, 255, 0.18);\n  font-size: 1.8rem;\n}\n\n@media (max-width: 1180px) {\n  .tips-filter-bar {\n    grid-template-columns: 1fr;\n  }\n\n  .tips-layout,\n  .tips-hero {\n    grid-template-columns: 1fr;\n  }\n\n  .tips-post-grid {\n    grid-template-columns: 1fr;\n  }\n}\n\n@media (max-width: 720px) {\n  .tips-hero {\n    padding: 24px 20px;\n    border-radius: 28px;\n  }\n\n  .tips-filter-bar {\n    top: 84px;\n    padding: 12px;\n    border-radius: 20px;\n  }\n\n  .tips-layout {\n    gap: 20px;\n  }\n\n  .tips-side-card {\n    padding: 20px;\n  }\n}\n"],["STYLE",{},"@import url('https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap');\n\n:root {\n  font-family: 'Be Vietnam Pro', sans-serif;\n  color: #336a29;\n  background:\n    radial-gradient(circle at top left, rgba(234, 245, 157, 0.7), transparent 32%),\n    linear-gradient(180deg, #f9fceb 0%, #f4f8e7 100%);\n  font-synthesis: none;\n  text-rendering: optimizeLegibility;\n  -webkit-font-smoothing: antialiased;\n  -moz-osx-font-smoothing: grayscale;\n\n  --color-primary-50: #eaf59d;\n  --color-primary-100: #dced8a;\n  --color-primary-200: #c1d95c;\n  --color-primary-300: #80b155;\n  --color-primary-400: #4f8428;\n  --color-primary-500: #336a29;\n  --color-surface: #ffffff;\n  --color-surface-soft: rgba(255, 255, 255, 0.76);\n  --color-background: #f7faef;\n  --color-text: #173715;\n  --color-text-muted: rgba(23, 55, 21, 0.74);\n  --color-border: rgba(79, 132, 40, 0.16);\n  --shadow-soft: 0 18px 50px rgba(79, 132, 40, 0.12);\n  --shadow-card: 0 10px 28px rgba(79, 132, 40, 0.08);\n  --radius-lg: 24px;\n  --radius-md: 18px;\n  --radius-sm: 12px;\n  --container-width: 1280px;\n}\n\n* {\n  box-sizing: border-box;\n}\n\nhtml {\n  scroll-behavior: smooth;\n}\n\nbody {\n  margin: 0;\n  min-width: 320px;\n  min-height: 100vh;\n  color: var(--color-text);\n  background: var(--color-background);\n}\n\na {\n  color: inherit;\n  text-decoration: none;\n}\n\nbutton,\ninput {\n  font: inherit;\n}\n\nbutton {\n  cursor: pointer;\n}\n\n#root {\n  min-height: 100vh;\n}\n\n.shell {\n  width: min(calc(100% - 32px), var(--container-width));\n  margin: 0 auto;\n}\n\n.shell--wide {\n  width: min(calc(100% - 32px), 1360px);\n}\n\n.btn {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  gap: 8px;\n  border: 1px solid transparent;\n  border-radius: 999px;\n  padding: 12px 20px;\n  font-weight: 600;\n  transition:\n    transform 0.2s ease,\n    box-shadow 0.2s ease,\n    background-color 0.2s ease;\n}\n\n.btn:hover {\n  transform: translateY(-1px);\n}\n\n.btn--primary {\n  color: #fff;\n  background: linear-gradient(135deg, var(--color-primary-300), var(--color-primary-400));\n  box-shadow: 0 12px 24px rgba(79, 132, 40, 0.2);\n}\n\n.btn--secondary {\n  background: var(--color-surface);\n  border-color: var(--color-border);\n  color: var(--color-primary-500);\n  box-shadow: var(--shadow-card);\n}\n\n.btn--ghost {\n  color: var(--color-primary-500);\n  background: rgba(255, 255, 255, 0.68);\n  border-color: rgba(79, 132, 40, 0.2);\n}\n\n.btn--light {\n  width: 100%;\n  color: var(--color-primary-500);\n  background: #fff;\n}\n\n.page {\n  display: grid;\n  gap: 32px;\n}\n\n.page-badge {\n  display: inline-flex;\n  align-items: center;\n  width: fit-content;\n  padding: 8px 14px;\n  border-radius: 999px;\n  background: rgba(234, 245, 157, 0.9);\n  color: var(--color-primary-500);\n  font-size: 0.875rem;\n  font-weight: 600;\n}\n\n.page-badge--soft {\n  background: rgba(193, 217, 92, 0.18);\n}\n\n.content-grid {\n  display: grid;\n  gap: 24px;\n}\n\n.content-grid--three {\n  grid-template-columns: repeat(3, minmax(0, 1fr));\n}\n\n.content-grid--four {\n  grid-template-columns: repeat(4, minmax(0, 1fr));\n}\n\n.plain-list {\n  margin: 0;\n  padding-left: 18px;\n  color: var(--color-text-muted);\n  line-height: 1.8;\n}\n\n@media (max-width: 1100px) {\n  .content-grid--three,\n  .content-grid--four {\n    grid-template-columns: repeat(2, minmax(0, 1fr));\n  }\n}\n\n@media (max-width: 720px) {\n  .shell,\n  .shell--wide {\n    width: min(calc(100% - 24px), var(--container-width));\n  }\n\n  .content-grid--three,\n  .content-grid--four {\n    grid-template-columns: 1fr;\n  }\n}\n\nhtml,\nbody {\n  overflow-x: hidden;\n}\n\nimg,\nvideo,\niframe {\n  max-width: 100%;\n  height: auto;\n}\n\n.community-layout,\n.community-feed,\n.community-sidebar,\n.post-card,\n.community-post-card,\n.tip-card,\n.admin-layout,\n.admin-main {\n  min-width: 0;\n}\n\n.post-title,\n.post-content,\n.comment-content,\n.community-post-card__title,\n.community-post-card__excerpt,\n.tip-card__title,\n.tip-card__excerpt {\n  overflow-wrap: anywhere;\n  word-break: break-word;\n}\n"],["STYLE",{},"\n.user-shell {\n  min-height: 100vh;\n  background:\n    radial-gradient(circle at 85% 14%, rgba(193, 217, 92, 0.26), transparent 20%),\n    linear-gradient(180deg, rgba(250, 252, 241, 0.96) 0%, #f6faea 100%);\n}\n\n.user-navbar {\n  position: sticky;\n  top: 0;\n  z-index: 20;\n  backdrop-filter: blur(18px);\n  background: rgba(255, 255, 255, 0.8);\n  border-bottom: 1px solid rgba(255, 255, 255, 0.5);\n  box-shadow: 0 10px 24px rgba(79, 132, 40, 0.06);\n}\n\n.user-navbar__inner {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 16px;\n  min-height: 80px;\n  padding: 8px 0;\n}\n\n.user-navbar__links,\n.user-navbar__actions {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n}\n\n.user-navbar__link {\n  padding: 10px 0;\n  color: var(--color-text-muted);\n  font-weight: 500;\n  border-bottom: 2px solid transparent;\n  transition: border-color 0.2s ease, color 0.2s ease;\n}\n\n.user-navbar__link:hover,\n.user-navbar__link.is-active {\n  color: var(--color-primary-500);\n  border-color: var(--color-primary-500);\n}\n\n.user-navbar__login {\n  padding-inline: 22px;\n}\n\n.user-navbar__publish {\n  padding-inline: 24px;\n}\n\n.user-navbar__user-menu {\n  position: relative;\n}\n\n.user-navbar__user-trigger {\n  display: inline-flex;\n  align-items: center;\n  gap: 12px;\n  padding: 8px 12px;\n  border: 1px solid rgba(79, 132, 40, 0.12);\n  border-radius: 999px;\n  color: var(--color-primary-500);\n  background: rgba(255, 255, 255, 0.88);\n  box-shadow: var(--shadow-card);\n}\n\n.user-navbar__avatar {\n  display: grid;\n  place-items: center;\n  width: 38px;\n  height: 38px;\n  border-radius: 50%;\n  color: #fff;\n  font-size: 0.84rem;\n  font-weight: 800;\n  background: linear-gradient(135deg, var(--color-primary-300), var(--color-primary-500));\n}\n\n.user-navbar__user-name {\n  max-width: 140px;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n  font-weight: 700;\n}\n\n.user-navbar__dropdown {\n  position: absolute;\n  top: calc(100% + 12px);\n  right: 0;\n  min-width: 220px;\n  display: grid;\n  gap: 4px;\n  padding: 10px;\n  border-radius: 18px;\n  background: rgba(255, 255, 255, 0.96);\n  border: 1px solid rgba(79, 132, 40, 0.1);\n  box-shadow: 0 18px 36px rgba(79, 132, 40, 0.14);\n}\n\n.user-navbar__dropdown-link {\n  display: block;\n  width: 100%;\n  padding: 12px 14px;\n  border: 0;\n  border-radius: 14px;\n  color: var(--color-text);\n  background: transparent;\n  text-align: left;\n  font: inherit;\n  font-weight: 600;\n}\n\n.user-navbar__dropdown-link:hover,\n.user-navbar__dropdown-link--logout:hover {\n  background: rgba(234, 245, 157, 0.32);\n}\n\n.user-navbar__dropdown-link--logout {\n  color: #8a5a0b;\n}\n\n.user-main {\n  width: min(calc(100% - 32px), 1360px);\n  margin: 0 auto;\n  padding: 24px 0 64px;\n}\n\n.user-footer {\n  color: #fff;\n  background: linear-gradient(180deg, var(--color-primary-500), #29551f);\n}\n\n.user-footer__content {\n  display: grid;\n  justify-items: center;\n  gap: 22px;\n  padding: 44px 0 28px;\n  text-align: center;\n}\n\n.user-footer__brand {\n  display: grid;\n  justify-items: center;\n  gap: 12px;\n}\n\n.user-footer__brand p {\n  max-width: 360px;\n  margin: 0;\n  color: rgba(234, 245, 157, 0.9);\n  font-size: 0.95rem;\n}\n\n.user-footer__nav {\n  display: flex;\n  flex-wrap: wrap;\n  justify-content: center;\n  gap: 14px 24px;\n}\n\n.user-footer__nav a {\n  color: rgba(255, 255, 255, 0.82);\n  font-size: 0.95rem;\n  font-weight: 500;\n}\n\n.user-footer__copyright {\n  width: min(100%, 760px);\n  padding-top: 18px;\n  border-top: 1px solid rgba(255, 255, 255, 0.18);\n}\n\n.user-footer__copyright p {\n  margin: 0;\n  color: rgba(255, 255, 255, 0.64);\n  font-size: 0.78rem;\n}\n\n.hero-panel,\n.page-banner,\n.placeholder-page,\n.not-found__card {\n  position: relative;\n  overflow: hidden;\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  border-radius: 32px;\n  background:\n    radial-gradient(circle at top right, rgba(193, 217, 92, 0.34), transparent 28%),\n    linear-gradient(180deg, rgba(245, 255, 226, 0.98) 0%, rgba(255, 255, 255, 0.96) 100%);\n  box-shadow: var(--shadow-soft);\n}\n\n.hero-panel {\n  display: grid;\n  grid-template-columns: 1.3fr 0.9fr;\n  gap: 28px;\n  padding: 42px;\n}\n\n.hero-panel__content h1,\n.page-banner h1,\n.placeholder-page h1,\n.not-found__card h1 {\n  margin: 16px 0;\n  font-size: clamp(2.4rem, 4vw, 4rem);\n  line-height: 1.05;\n  letter-spacing: -0.04em;\n}\n\n.hero-panel__content p,\n.page-banner p,\n.placeholder-page p,\n.post-card p,\n.feature-card p,\n.visual-card span,\n.side-card p {\n  margin: 0;\n  color: var(--color-text-muted);\n  font-size: 1rem;\n  line-height: 1.75;\n}\n\n.hero-panel__actions {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 12px;\n  margin-top: 28px;\n}\n\n.hero-panel__card,\n.feature-card,\n.post-card,\n.side-card,\n.panel-card,\n.admin-stat {\n  border-radius: var(--radius-lg);\n  background: var(--color-surface-soft);\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  box-shadow: var(--shadow-card);\n}\n\n.hero-panel__card {\n  align-self: end;\n  padding: 28px;\n  background: linear-gradient(180deg, rgba(79, 132, 40, 0.96), rgba(51, 106, 41, 0.96));\n  color: #fff;\n}\n\n.mini-stats {\n  display: grid;\n  gap: 14px;\n  margin: 18px 0 0;\n  padding: 0;\n  list-style: none;\n}\n\n.mini-stats li {\n  display: flex;\n  justify-content: space-between;\n  gap: 12px;\n  padding-bottom: 10px;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.14);\n}\n\n.feature-card {\n  padding: 24px;\n}\n\n.feature-card__icon {\n  display: inline-grid;\n  place-items: center;\n  width: 48px;\n  height: 48px;\n  border-radius: 16px;\n  margin-bottom: 18px;\n  color: var(--color-primary-500);\n  background: rgba(234, 245, 157, 0.88);\n  font-size: 0.8rem;\n  font-weight: 700;\n}\n\n.feature-card h2,\n.post-card h2,\n.side-card h3,\n.panel-card h2 {\n  margin: 0 0 10px;\n  letter-spacing: -0.03em;\n}\n\n.page-banner {\n  display: grid;\n  grid-template-columns: 1.1fr 0.9fr;\n  gap: 24px;\n  padding: 32px;\n}\n\n.page-banner__visual {\n  display: flex;\n  align-items: stretch;\n}\n\n.visual-card {\n  display: flex;\n  flex-direction: column;\n  justify-content: flex-end;\n  gap: 10px;\n  width: 100%;\n  min-height: 240px;\n  padding: 28px;\n  border-radius: 28px;\n  background:\n    linear-gradient(135deg, rgba(193, 217, 92, 0.24), rgba(79, 132, 40, 0.16)),\n    linear-gradient(180deg, rgba(255, 255, 255, 0.62), rgba(255, 255, 255, 0.92));\n}\n\n.community-layout {\n  display: grid;\n  grid-template-columns: minmax(0, 1.7fr) minmax(280px, 0.8fr);\n  gap: 24px;\n}\n\n.community-feed,\n.community-sidebar {\n  display: grid;\n  gap: 20px;\n}\n\n.post-card,\n.side-card,\n.placeholder-page {\n  padding: 28px;\n}\n\n.side-card--accent {\n  color: #fff;\n  background: linear-gradient(180deg, var(--color-primary-400), var(--color-primary-500));\n}\n\n.side-card--accent p {\n  color: rgba(255, 255, 255, 0.82);\n  margin-bottom: 20px;\n}\n\n.placeholder-page {\n  display: grid;\n  gap: 16px;\n}\n\n.placeholder-page__box {\n  display: grid;\n  gap: 8px;\n  padding: 20px;\n  border-radius: 22px;\n  background: rgba(255, 255, 255, 0.82);\n  border: 1px solid var(--color-border);\n}\n\n.admin-shell {\n  display: grid;\n  grid-template-columns: 300px minmax(0, 1fr);\n  min-height: 100vh;\n  background:\n    radial-gradient(circle at top right, rgba(193, 217, 92, 0.26), transparent 18%),\n    linear-gradient(180deg, #f5f9ea 0%, #eef5df 100%);\n}\n\n.admin-sidebar {\n  display: flex;\n  flex-direction: column;\n  gap: 24px;\n  padding: 28px 18px;\n  color: #fff;\n  background: linear-gradient(180deg, #2e7029 0%, #21521e 100%);\n}\n\n.admin-sidebar__brand {\n  margin-bottom: 8px;\n}\n\n.admin-sidebar__nav {\n  display: grid;\n  gap: 8px;\n}\n\n.admin-sidebar__link {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  padding: 14px 16px;\n  border-radius: 20px;\n  color: rgba(255, 255, 255, 0.88);\n  font-weight: 600;\n  transition: background-color 0.2s ease, color 0.2s ease;\n}\n\n.admin-sidebar__link:hover,\n.admin-sidebar__link.is-active {\n  color: var(--color-text);\n  background: linear-gradient(135deg, var(--color-primary-200), #98c660);\n}\n\n.admin-sidebar__icon {\n  display: inline-grid;\n  place-items: center;\n  min-width: 36px;\n  height: 36px;\n  border-radius: 12px;\n  background: rgba(255, 255, 255, 0.12);\n  font-size: 0.78rem;\n  letter-spacing: -0.03em;\n}\n\n.admin-sidebar__link.is-active .admin-sidebar__icon {\n  background: rgba(51, 106, 41, 0.12);\n}\n\n.admin-sidebar__logout {\n  margin-top: auto;\n  padding: 14px 16px;\n  color: #fff;\n  background: rgba(255, 255, 255, 0.08);\n  border: 1px solid rgba(255, 255, 255, 0.12);\n  border-radius: 18px;\n}\n\n.admin-shell__content {\n  display: flex;\n  flex-direction: column;\n  min-width: 0;\n}\n\n.admin-topbar {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: 20px;\n  padding: 22px 28px;\n  border-bottom: 1px solid rgba(79, 132, 40, 0.08);\n  background: rgba(241, 251, 220, 0.68);\n  backdrop-filter: blur(14px);\n}\n\n.admin-topbar h1 {\n  margin: 6px 0;\n  font-size: clamp(2rem, 3vw, 3rem);\n  letter-spacing: -0.04em;\n}\n\n.admin-topbar span,\n.admin-topbar small,\n.admin-topbar__eyebrow {\n  color: var(--color-text-muted);\n}\n\n.admin-topbar__eyebrow {\n  margin: 0;\n  font-weight: 700;\n  text-transform: uppercase;\n  letter-spacing: 0.08em;\n  font-size: 0.78rem;\n}\n\n.admin-topbar__actions {\n  display: flex;\n  align-items: center;\n  gap: 14px;\n}\n\n.admin-topbar__search {\n  display: grid;\n  gap: 6px;\n  min-width: min(420px, 42vw);\n  color: var(--color-text-muted);\n  font-size: 0.84rem;\n}\n\n.admin-topbar__search input {\n  width: 100%;\n  border: 1px solid rgba(79, 132, 40, 0.12);\n  border-radius: 999px;\n  padding: 14px 18px;\n  background: rgba(193, 217, 92, 0.28);\n  outline: none;\n}\n\n.admin-topbar__icon-button {\n  display: grid;\n  place-items: center;\n  width: 44px;\n  height: 44px;\n  border: 0;\n  border-radius: 50%;\n  color: var(--color-primary-500);\n  background: #fff;\n  box-shadow: var(--shadow-card);\n}\n\n.admin-topbar__profile {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  padding: 8px 12px;\n  border-radius: 999px;\n  background: rgba(255, 255, 255, 0.8);\n  box-shadow: var(--shadow-card);\n}\n\n.admin-topbar__avatar {\n  display: grid;\n  place-items: center;\n  width: 42px;\n  height: 42px;\n  border-radius: 50%;\n  color: #fff;\n  font-weight: 700;\n  background: linear-gradient(135deg, var(--color-primary-300), var(--color-primary-500));\n}\n\n.admin-main {\n  padding: 28px;\n}\n\n.admin-stat {\n  display: grid;\n  gap: 10px;\n  padding: 24px;\n}\n\n.admin-stat span {\n  color: var(--color-text-muted);\n}\n\n.admin-stat strong {\n  font-size: clamp(2rem, 3vw, 3rem);\n  letter-spacing: -0.05em;\n}\n\n.admin-stat--warm {\n  background:\n    radial-gradient(circle at top right, rgba(255, 175, 163, 0.36), transparent 24%),\n    var(--color-surface-soft);\n}\n\n.admin-stat--green {\n  background:\n    radial-gradient(circle at top right, rgba(128, 177, 85, 0.26), transparent 24%),\n    var(--color-surface-soft);\n}\n\n.admin-stat--lime {\n  background:\n    radial-gradient(circle at top right, rgba(193, 217, 92, 0.32), transparent 24%),\n    var(--color-surface-soft);\n}\n\n.admin-panels {\n  display: grid;\n  grid-template-columns: 1.1fr 0.9fr;\n  gap: 24px;\n}\n\n.panel-card {\n  padding: 28px;\n}\n\n.bar-chart {\n  display: grid;\n  grid-template-columns: repeat(7, minmax(0, 1fr));\n  align-items: end;\n  gap: 10px;\n  height: 260px;\n  padding: 22px;\n  border-radius: 22px;\n  background: linear-gradient(180deg, rgba(79, 132, 40, 0.04), rgba(255, 255, 255, 0.7));\n}\n\n.bar-chart span {\n  display: block;\n  border-radius: 999px 999px 16px 16px;\n  background: linear-gradient(180deg, var(--color-primary-200), var(--color-primary-400));\n}\n\n.comment-list {\n  display: grid;\n  gap: 18px;\n  margin: 0;\n  padding: 0;\n  list-style: none;\n}\n\n.comment-list li {\n  display: grid;\n  gap: 8px;\n  padding-bottom: 18px;\n  border-bottom: 1px solid var(--color-border);\n}\n\n.not-found {\n  display: grid;\n  place-items: center;\n  min-height: 100vh;\n  padding: 24px;\n  background:\n    radial-gradient(circle at center, rgba(193, 217, 92, 0.24), transparent 34%),\n    linear-gradient(180deg, #f5fae8 0%, #eef5df 100%);\n}\n\n.not-found__card {\n  width: min(100%, 640px);\n  padding: 40px;\n  text-align: center;\n}\n\n.not-found__card .btn {\n  margin-top: 12px;\n}\n\n@media (max-width: 1200px) {\n  .community-layout,\n  .admin-panels,\n  .hero-panel,\n  .page-banner {\n    grid-template-columns: 1fr;\n  }\n\n  .admin-shell {\n    grid-template-columns: 1fr;\n  }\n\n  .admin-sidebar {\n    padding-bottom: 18px;\n  }\n}\n\n@media (max-width: 920px) {\n  .user-navbar__inner,\n  .admin-topbar,\n  .admin-topbar__actions {\n    flex-wrap: wrap;\n  }\n\n  .user-navbar__mobile-toggle {\n    display: block !important;\n    background: none;\n    border: none;\n    color: var(--color-primary-500);\n    padding: 8px;\n    cursor: pointer;\n    order: 2;\n  }\n\n  .user-navbar__links {\n    order: 3;\n    width: 100%;\n    flex-direction: column;\n    gap: 14px;\n    display: none;\n  }\n\n  .user-navbar__actions {\n    order: 4;\n    width: 100%;\n    flex-direction: column;\n    display: none;\n  }\n\n  .user-navbar__links.is-mobile-open,\n  .user-navbar__actions.is-mobile-open {\n    display: flex;\n  }\n\n  .user-navbar__dropdown {\n    right: auto;\n    left: 0;\n    width: 100%;\n  }\n\n  .admin-topbar__search {\n    min-width: 100%;\n  }\n}\n\n@media (max-width: 720px) {\n  .user-main,\n  .admin-main {\n    padding-left: 0;\n    padding-right: 0;\n  }\n\n  .hero-panel,\n  .page-banner,\n  .placeholder-page,\n  .panel-card,\n  .admin-stat,\n  .post-card,\n  .side-card {\n    padding: 22px;\n  }\n\n  .admin-topbar {\n    padding: 18px;\n  }\n\n  .admin-main {\n    padding: 18px;\n  }\n}\n"]],"\n  ",["BODY",{},"\n    ",["DIV",{"id":"root"},["DIV",{"class":"development-notice-container"},["DIV",{"class":"development-notice-box"},["BUTTON",{"class":"development-notice-close","aria-label":"Đóng thông báo"},"×"],["H4",{"class":"development-notice-title"},"E-XANH đang trong quá trình phát triển"],["P",{"class":"development-notice-desc"},"Website có thể phát sinh vấn đề, mong bạn phản hồi để nhóm phát triển cải thiện."],["DIV",{"class":"development-notice-info"},["P",{},"Phiên bản hiện tại: ",["STRONG",{},"Beta v1.1"]],["P",{},"Cập nhật gần nhất: ",["STRONG",{},"11/06/2026"]],["P",{},"Dự kiến cập nhật tiếp theo: ",["STRONG",{},"Sắp cập nhật"]]],["BUTTON",{"class":"development-report-button"},["svg",{"width":"18","height":"18","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2","stroke-linecap":"round","stroke-linejoin":"round"},["path",{"d":"M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"}],["line",{"x1":"12","y1":"9","x2":"12","y2":"13"}],["line",{"x1":"12","y1":"17","x2":"12.01","y2":"17"}]],"Báo cáo lỗi"]]],["DIV",{"class":"user-shell"},["HEADER",{"class":"user-navbar"},["DIV",{"class":"shell shell--wide user-navbar__inner"},["A",{"class":"brand-logo brand-logo--medium ","data-testid":"site-logo","aria-lab