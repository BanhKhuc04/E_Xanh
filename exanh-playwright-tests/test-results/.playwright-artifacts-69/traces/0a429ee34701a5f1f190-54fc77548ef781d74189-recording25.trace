{"type":"frame-snapshot","snapshot":{"callId":"call@651","snapshotName":"after@call@651","pageId":"page@c1ae97cc8e4524924ea5352c0b8b981a","frameId":"frame@f627ca570d044566a63c8ff4db7c3cbe","frameUrl":"http://localhost:5173/cong-dong","doctype":"html","html":["HTML",{"lang":"vi","style":"--announcement-offset: 0px;"},["HEAD",{},[[2,0]],[[2,1]],[[2,2]],[[2,3]],[[2,4]],[[2,5]],[[2,6]],[[2,7]],["TITLE",{},"Cộng đồng — E-XANH"],[[2,9]],[[2,10]],[[2,11]],[[2,12]],[[2,13]],[[2,14]],[[2,15]],[[2,16]],[[2,17]],[[2,18]],[[2,19]],[[2,20]],[[2,21]],[[2,22]],[[2,24]],[[2,26]],[[2,28]],[[2,30]],[[2,32]],[[2,34]],[[2,36]],[[2,38]],[[2,40]],["STYLE",{},".community-page {\n  display: grid;\n  gap: 28px;\n}\n\n.community-page__hero {\n  position: relative;\n  overflow: hidden;\n  display: grid;\n  grid-template-columns: minmax(0, 1.05fr) minmax(360px, 0.88fr);\n  gap: 28px;\n  align-items: center;\n  padding: 36px;\n  border-radius: 34px;\n  background:\n    radial-gradient(circle at top right, rgba(234, 245, 157, 0.52), transparent 28%),\n    linear-gradient(180deg, rgba(216, 251, 191, 0.94) 0%, rgba(236, 255, 221, 0.96) 100%);\n  box-shadow: var(--shadow-soft);\n}\n\n.community-page__hero::after {\n  content: '';\n  position: absolute;\n  right: -88px;\n  top: -56px;\n  width: 260px;\n  height: 260px;\n  border-radius: 50%;\n  background: rgba(193, 217, 92, 0.2);\n  filter: blur(20px);\n}\n\n.community-page__hero-content,\n.community-page__feed {\n  display: grid;\n  gap: 20px;\n  min-width: 0;\n}\n\n.community-page__badge {\n  display: inline-flex;\n  align-items: center;\n  width: fit-content;\n  padding: 10px 16px;\n  border-radius: 999px;\n  color: var(--color-primary-500);\n  background: rgba(193, 217, 92, 0.28);\n  font-size: 0.92rem;\n  font-weight: 700;\n}\n\n.community-page__hero-content h1 {\n  margin: 0;\n  font-size: clamp(2.8rem, 5.5vw, 4.6rem);\n  line-height: 1;\n  letter-spacing: -0.05em;\n}\n\n.community-page__hero-content p {\n  max-width: 700px;\n  margin: 0;\n  color: var(--color-text-muted);\n  font-size: 1.04rem;\n  line-height: 1.85;\n}\n\n.community-page__hero-actions {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 14px;\n}\n\n.community-page__hero-visual {\n  position: relative;\n  z-index: 1;\n}\n\n.community-page__hero-visual img {\n  display: block;\n  width: 100%;\n  aspect-ratio: 16 / 9;\n  min-height: 280px;\n  border-radius: 26px;\n  object-fit: cover;\n  box-shadow: 0 18px 44px rgba(79, 132, 40, 0.16);\n}\n\n.community-page__layout {\n  display: grid;\n  grid-template-columns: minmax(0, 1fr) 320px;\n  gap: 24px;\n  align-items: start;\n}\n\n.community-composer,\n.community-post-card,\n.community-sidebar-panel__card,\n.community-page__empty {\n  border-radius: 28px;\n  background: rgba(255, 255, 255, 0.96);\n  border: 1px solid rgba(79, 132, 40, 0.08);\n  box-shadow: var(--shadow-card);\n}\n\n.community-composer {\n  display: grid;\n  gap: 18px;\n  padding: 22px 24px;\n}\n\n.community-composer__top {\n  display: grid;\n  grid-template-columns: auto minmax(0, 1fr) auto;\n  gap: 14px;\n  align-items: center;\n}\n\n.community-composer__avatar {\n  width: 52px;\n  height: 52px;\n  border-radius: 50%;\n  object-fit: cover;\n}\n\n.community-composer__avatar--fallback {\n  display: grid;\n  place-items: center;\n  color: #fff;\n  font-weight: 800;\n  background: linear-gradient(135deg, var(--color-primary-300), var(--color-primary-500));\n}\n\n.community-composer__prompt {\n  min-height: 54px;\n  display: flex;\n  align-items: center;\n  width: 100%;\n  border: 0;\n  padding: 0 18px;\n  border-radius: 16px;\n  color: rgba(51, 106, 41, 0.7);\n  background: linear-gradient(90deg, rgba(234, 245, 157, 0.42), rgba(193, 217, 92, 0.18));\n  cursor: pointer;\n  transition: opacity 0.2s;\n}\n\n.community-composer__prompt:hover {\n  opacity: 0.8;\n}\n\n.community-composer__button {\n  white-space: nowrap;\n}\n\n.community-composer__actions {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 22px;\n  padding-top: 14px;\n  border-top: 1px solid rgba(79, 132, 40, 0.1);\n  color: var(--color-text);\n  font-size: 0.95rem;\n}\n\n.community-composer__actions a,\n.community-composer__actions button {\n  display: inline-flex;\n  align-items: center;\n  gap: 8px;\n  border: 0;\n  padding: 0;\n  color: inherit;\n  background: transparent;\n  cursor: pointer;\n  transition: color 0.2s;\n}\n\n.community-composer__actions a:hover,\n.community-composer__actions button:hover {\n  color: var(--color-primary-500);\n}\n\n.community-filter-bar {\n  display: flex;\n  gap: 10px;\n  overflow-x: auto;\n  padding-bottom: 4px;\n}\n\n.community-filter-bar__chip {\n  flex: 0 0 auto;\n  padding: 12px 18px;\n  border: 1px solid rgba(79, 132, 40, 0.12);\n  border-radius: 999px;\n  color: rgba(23, 55, 21, 0.78);\n  background: rgba(255, 255, 255, 0.9);\n  font-weight: 600;\n}\n\n.community-filter-bar__chip.is-active {\n  color: #fff;\n  background: var(--color-primary-500);\n  box-shadow: 0 10px 20px rgba(79, 132, 40, 0.14);\n}\n\n.community-page__posts {\n  display: grid;\n  gap: 18px;\n}\n\n.community-sidebar-panel {\n  display: grid;\n  gap: 18px;\n  width: 100%;\n  position: sticky;\n  top: 96px;\n}\n\n.community-post-card {\n  display: grid;\n  gap: 18px;\n  padding: 24px;\n}\n\n.community-post-card__header,\n.community-post-card__author,\n.community-post-card__actions,\n.community-sidebar-panel__member {\n  display: flex;\n  align-items: center;\n}\n\n.community-post-card__header {\n  justify-content: space-between;\n  gap: 12px;\n}\n\n.community-post-card__author {\n  gap: 12px;\n}\n\n.community-post-card__author img,\n.community-post-card__comment img,\n.community-sidebar-panel__member img {\n  border-radius: 50%;\n  object-fit: cover;\n}\n\n.community-post-card__author img {\n  width: 44px;\n  height: 44px;\n}\n\n.community-post-card__author strong,\n.community-post-card__comment strong,\n.community-sidebar-panel__member strong,\n.community-sidebar-panel__popular strong {\n  display: block;\n}\n\n.community-post-card__author span,\n.community-post-card__body p,\n.community-post-card__comment p,\n.community-sidebar-panel__member span,\n.community-sidebar-panel__popular span,\n.community-sidebar-panel__card p,\n.community-sidebar-panel__card li {\n  color: var(--color-text-muted);\n}\n\n.community-post-card__menu {\n  color: rgba(23, 55, 21, 0.54);\n  font-weight: 800;\n}\n\n.community-post-card__tags {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 8px;\n}\n\n.community-post-card__tag {\n  padding: 8px 12px;\n  border-radius: 999px;\n  color: rgba(23, 55, 21, 0.72);\n  background: rgba(234, 245, 157, 0.16);\n  font-size: 0.78rem;\n  font-weight: 700;\n}\n\n.community-post-card__tag--primary {\n  color: var(--color-primary-500);\n  background: rgba(193, 217, 92, 0.3);\n}\n\n.community-post-card__body h2,\n.community-post-card__body p,\n.community-post-card__comment p {\n  overflow-wrap: anywhere;\n  word-break: break-word;\n  min-width: 0;\n}\n\n.community-post-card__body h2 {\n  margin: 0 0 10px;\n  font-size: clamp(1.6rem, 3vw, 2.3rem);\n  line-height: 1.2;\n  letter-spacing: -0.04em;\n}\n\n.community-post-card__body p {\n  margin: 0;\n  line-height: 1.78;\n}\n\n.community-post-card__media {\n  overflow: hidden;\n  border-radius: 22px;\n  aspect-ratio: 16 / 9;\n}\n\n.community-post-card__media img {\n  display: block;\n  width: 100%;\n  height: 100%;\n  max-height: 520px;\n  object-fit: cover;\n  border-radius: 18px;\n}\n\n.community-post-card__comments {\n  display: grid;\n  gap: 12px;\n}\n\n.community-post-card__comment {\n  display: grid;\n  grid-template-columns: auto minmax(0, 1fr);\n  gap: 12px;\n  padding: 12px;\n  border-radius: 18px;\n  background: linear-gradient(180deg, rgba(234, 245, 157, 0.22), rgba(255, 255, 255, 0.96));\n}\n\n.community-post-card__comment img {\n  width: 36px;\n  height: 36px;\n}\n\n.community-post-card__comment p {\n  margin: 4px 0 0;\n  line-height: 1.65;\n}\n\n.community-post-card__actions {\n  flex-wrap: wrap;\n  gap: 12px;\n  justify-content: space-between;\n  padding-top: 16px;\n  border-top: 1px solid rgba(79, 132, 40, 0.1);\n}\n\n.community-post-card__actions button {\n  border: 0;\n  padding: 8px 12px;\n  border-radius: 8px;\n  color: rgba(23, 55, 21, 0.76);\n  background: transparent;\n  font-weight: 600;\n  cursor: pointer;\n  transition: all 0.2s ease;\n  display: flex;\n  align-items: center;\n  gap: 6px;\n}\n\n.community-post-card__actions button:hover {\n  background: rgba(193, 217, 92, 0.15);\n  color: var(--color-primary-500);\n}\n\n.community-post-card__actions button.is-active {\n  color: var(--color-primary-500);\n  background: rgba(193, 217, 92, 0.1);\n}\n\n.community-post-card__comment-input-area {\n  display: flex;\n  gap: 12px;\n  margin-top: 16px;\n  align-items: flex-start;\n}\n\n.community-post-card__comment-input-area img {\n  width: 36px;\n  height: 36px;\n  border-radius: 50%;\n  object-fit: cover;\n}\n\n.community-post-card__comment-input-area textarea {\n  flex: 1;\n  padding: 12px;\n  border: 1px solid rgba(79, 132, 40, 0.15);\n  border-radius: 12px;\n  resize: none;\n  font-family: inherit;\n  font-size: 0.95rem;\n  background: rgba(250, 250, 250, 0.9);\n}\n\n.community-post-card__comment-input-area textarea:focus {\n  outline: none;\n  border-color: var(--color-primary-500);\n  background: #fff;\n}\n\n.community-post-card__share-modal {\n  position: absolute;\n  background: #fff;\n  border: 1px solid rgba(79, 132, 40, 0.15);\n  border-radius: 12px;\n  box-shadow: 0 10px 25px rgba(0,0,0,0.1);\n  padding: 12px;\n  display: flex;\n  flex-direction: column;\n  gap: 8px;\n  z-index: 100;\n  bottom: 100%;\n  right: 0;\n  margin-bottom: 8px;\n  min-width: 200px;\n}\n\n.community-post-card__share-option {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  padding: 10px 12px;\n  border-radius: 8px;\n  cursor: pointer;\n  background: transparent;\n  border: none;\n  text-align: left;\n  font-weight: 500;\n  color: #333;\n  transition: background 0.2s;\n}\n\n.community-post-card__share-option:hover {\n  background: rgba(193, 217, 92, 0.15);\n}\n\n.community-sidebar-panel__card {\n  display: grid;\n  gap: 16px;\n  padding: 22px;\n}\n\n.community-sidebar-panel__card h2,\n.community-page__empty h2 {\n  margin: 0;\n  font-size: 1.5rem;\n  letter-spacing: -0.03em;\n}\n\n.community-sidebar-panel__members,\n.community-sidebar-panel__popular {\n  display: grid;\n  gap: 14px;\n}\n\n.community-sidebar-panel__member {\n  gap: 12px;\n}\n\n.community-sidebar-panel__member img {\n  width: 42px;\n  height: 42px;\n}\n\n.community-sidebar-panel__member em {\n  margin-left: auto;\n  padding: 8px 10px;\n  border-radius: 12px;\n  color: var(--color-primary-500);\n  background: rgba(234, 245, 157, 0.54);\n  font-size: 0.76rem;\n  font-style: normal;\n  font-weight: 800;\n}\n\n.community-sidebar-panel__topics {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 8px;\n}\n\n.community-sidebar-panel__topics span {\n  padding: 10px 14px;\n  border-radius: 999px;\n  background: rgba(193, 217, 92, 0.24);\n  color: rgba(23, 55, 21, 0.82);\n  font-size: 0.88rem;\n  font-weight: 600;\n}\n\n.community-sidebar-panel__card--rules {\n  background: linear-gradient(180deg, rgba(234, 245, 157, 0.26), rgba(255, 255, 255, 0.96));\n}\n\n.community-sidebar-panel__card--rules ul {\n  display: grid;\n  gap: 8px;\n  margin: 0;\n  padding-left: 18px;\n  line-height: 1.7;\n}\n\n.community-sidebar-panel__popular article {\n  display: grid;\n  gap: 6px;\n}\n\n.community-sidebar-panel__card--cta {\n  color: #fff;\n  background: linear-gradient(180deg, var(--color-primary-400), var(--color-primary-500));\n}\n\n.community-sidebar-panel__card--cta p {\n  color: rgba(255, 255, 255, 0.84);\n  line-height: 1.75;\n}\n\n.community-page__more {\n  display: flex;\n  justify-content: center;\n  padding-top: 8px;\n}\n\n.community-page__empty {\n  justify-items: center;\n  gap: 14px;\n  padding: 38px 24px;\n  text-align: center;\n}\n\n.community-page__empty span {\n  display: grid;\n  place-items: center;\n  width: 72px;\n  height: 72px;\n  border-radius: 50%;\n  color: var(--color-primary-500);\n  background: rgba(193, 217, 92, 0.34);\n  font-size: 0.92rem;\n  font-weight: 800;\n}\n\n@media (max-width: 1180px) {\n  .community-page__hero {\n    grid-template-columns: 1fr;\n  }\n}\n\n@media (max-width: 1024px) {\n  .community-page__layout {\n    grid-template-columns: 1fr;\n  }\n\n  .community-sidebar-panel {\n    position: static;\n  }\n}\n\n@media (max-width: 820px) {\n  .community-page__hero,\n  .community-post-card,\n  .community-composer,\n  .community-sidebar-panel__card {\n    padding: 20px;\n  }\n\n  .community-composer__top {\n    grid-template-columns: 1fr;\n  }\n\n  .community-composer__avatar {\n    width: 48px;\n    height: 48px;\n  }\n\n  .community-composer__button {\n    width: 100%;\n  }\n}\n\n@media (max-width: 640px) {\n  .community-page__hero-actions,\n  .community-post-card__header,\n  .community-post-card__actions {\n    flex-direction: column;\n    align-items: flex-start;\n  }\n\n  .community-page__hero {\n    padding: 22px;\n    border-radius: 28px;\n  }\n\n  .community-post-card__body h2 {\n    font-size: 1.45rem;\n  }\n}\n"],["META",{"name":"description","content":"Tham gia cộng đồng E-XANH, nơi sinh viên và người trẻ chia sẻ kinh nghiệm sống xanh, mẹo tiết kiệm điện và lối sống bền vững."}],["META",{"property":"og:title","content":"Cộng đồng E-XANH — Chia sẻ kinh nghiệm sống xanh"}],["META",{"property":"og:description","content":"Cộng đồng nơi sinh viên chia sẻ mẹo tiết kiệm điện, kinh nghiệm sống xanh và các bí quyết giảm chi phí điện."}],["META",{"property":"og:type","content":"website"}],["META",{"property":"og:url","content":"https://e-xanh.vercel.app/cong-dong"}],["META",{"property":"og:image","content":"https://e-xanh.vercel.app/og-image-v2.png"}],["META",{"property":"og:image:width","content":"1200"}],["META",{"property":"og:image:height","content":"630"}],["META",{"name":"twitter:card","content":"summary_large_image"}],["LINK",{