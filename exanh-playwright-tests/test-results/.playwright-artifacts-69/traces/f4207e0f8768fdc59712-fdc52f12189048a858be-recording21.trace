dy h3 {\n  margin: 0;\n  font-size: 1.38rem;\n  line-height: 1.4;\n  letter-spacing: -0.03em;\n}\n\n.post-card-ui__body p {\n  margin: 0;\n  color: rgba(23, 55, 21, 0.74);\n  line-height: 1.72;\n}\n\n.post-card-ui__meta {\n  display: grid;\n  gap: 16px;\n  padding-top: 16px;\n  border-top: 1px solid rgba(79, 132, 40, 0.12);\n}\n\n.post-card-ui__author {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n}\n\n.post-card-ui__avatar {\n  display: grid;\n  place-items: center;\n  width: 36px;\n  height: 36px;\n  border-radius: 50%;\n  color: #336a29;\n  background: #eaf59d;\n  font-size: 0.78rem;\n  font-weight: 800;\n}\n\n.post-card-ui__author strong,\n.post-card-ui__author span,\n.post-card-ui__stats span {\n  display: block;\n}\n\n.post-card-ui__author span,\n.post-card-ui__stats {\n  color: rgba(23, 55, 21, 0.62);\n  font-size: 0.9rem;\n}\n\n.post-card-ui__stats {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 14px;\n}\n\n.post-card-ui__link {\n  width: fit-content;\n  color: #4f8428;\n  font-size: 0.95rem;\n  font-weight: 800;\n}\n\n@media (max-width: 720px) {\n  .post-card-ui__media {\n    height: 200px;\n  }\n\n  .post-card-ui__body {\n    padding: 20px;\n  }\n}\n"],["STYLE",{},".tips-page {\n  display: grid;\n  gap: 28px;\n}\n\n.tips-hero {\n  display: grid;\n  grid-template-columns: minmax(0, 1fr) minmax(320px, 0.9fr);\n  gap: 28px;\n  align-items: center;\n  overflow: hidden;\n  padding: 32px 28px;\n  border-radius: 32px;\n  background: linear-gradient(90deg, rgba(234, 245, 157, 0.58), rgba(247, 250, 239, 0.98));\n  border: 1px solid rgba(234, 245, 157, 0.48);\n  box-shadow: 0 4px 20px rgba(79, 132, 40, 0.08);\n}\n\n.tips-hero__content {\n  display: grid;\n  gap: 18px;\n}\n\n.tips-hero__badge {\n  display: inline-flex;\n  align-items: center;\n  width: fit-content;\n  padding: 10px 16px;\n  border-radius: 999px;\n  color: #336a29;\n  background: rgba(255, 255, 255, 0.68);\n  border: 1px solid rgba(128, 177, 85, 0.22);\n  font-size: 0.9rem;\n  font-weight: 700;\n}\n\n.tips-hero__content h1 {\n  margin: 0;\n  font-size: clamp(2.4rem, 4vw, 4rem);\n  line-height: 1.06;\n  letter-spacing: -0.05em;\n}\n\n.tips-hero__content p {\n  max-width: 560px;\n  margin: 0;\n  color: rgba(23, 55, 21, 0.72);\n  font-size: 1.08rem;\n  line-height: 1.78;\n}\n\n.tips-hero__visual {\n  min-width: 0;\n  height: 100%;\n}\n\n.tips-hero__visual img {\n  display: block;\n  width: 100%;\n  max-height: 320px;\n  object-fit: contain;\n  object-position: right center;\n}\n\n.tips-filter-bar {\n  position: sticky;\n  top: 92px;\n  z-index: 12;\n  display: grid;\n  grid-template-columns: minmax(260px, 360px) 1fr minmax(180px, 220px);\n  gap: 16px;\n  align-items: center;\n  padding: 14px;\n  border-radius: 24px;\n  background: rgba(255, 255, 255, 0.9);\n  backdrop-filter: blur(16px);\n  border: 1px solid rgba(255, 255, 255, 0.56);\n  box-shadow: 0 4px 20px rgba(79, 132, 40, 0.08);\n}\n\n.tips-filter-bar__search,\n.tips-filter-bar__sort {\n  display: grid;\n  gap: 8px;\n}\n\n.tips-filter-bar__search span,\n.tips-filter-bar__sort span {\n  color: rgba(23, 55, 21, 0.72);\n  font-size: 0.85rem;\n  font-weight: 700;\n}\n\n.tips-filter-bar__search input,\n.tips-filter-bar__sort select {\n  width: 100%;\n  min-width: 0;\n  border: 1px solid rgba(115, 121, 106, 0.28);\n  border-radius: 14px;\n  padding: 13px 16px;\n  color: #173715;\n  background: #fff;\n  outline: none;\n}\n\n.tips-filter-bar__search input:focus,\n.tips-filter-bar__sort select:focus {\n  border-color: #4f8428;\n  box-shadow: 0 0 0 3px rgba(128, 177, 85, 0.18);\n}\n\n.tips-filter-bar__chips {\n  display: flex;\n  gap: 10px;\n  align-items: center;\n  overflow-x: auto;\n  padding-bottom: 2px;\n}\n\n.tips-filter-chip,\n.tips-topic-chip {\n  flex: 0 0 auto;\n  border: 1px solid rgba(115, 121, 106, 0.28);\n  border-radius: 999px;\n  padding: 11px 16px;\n  color: rgba(23, 55, 21, 0.74);\n  background: #fff;\n  font-size: 0.92rem;\n  font-weight: 600;\n}\n\n.tips-filter-chip.is-active {\n  color: #fff;\n  background: #4f8428;\n  border-color: #4f8428;\n}\n\n.tips-layout {\n  display: grid;\n  grid-template-columns: minmax(0, 2fr) minmax(280px, 0.92fr);\n  gap: 28px;\n  align-items: start;\n}\n\n.tips-layout__content {\n  min-width: 0;\n}\n\n.tips-post-grid {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: 24px;\n}\n\n.tips-empty-state {\n  display: grid;\n  gap: 8px;\n  margin-top: 22px;\n  padding: 24px;\n  border-radius: 22px;\n  background: rgba(255, 255, 255, 0.88);\n  border: 1px solid rgba(234, 245, 157, 0.56);\n}\n\n.tips-empty-state p,\n.tips-side-card p {\n  margin: 0;\n  color: rgba(23, 55, 21, 0.72);\n  line-height: 1.72;\n}\n\n.tips-layout__sidebar {\n  display: grid;\n  gap: 20px;\n}\n\n.tips-side-card {\n  display: grid;\n  gap: 16px;\n  padding: 24px;\n  border-radius: 24px;\n  background: rgba(255, 255, 255, 0.96);\n  border: 1px solid rgba(234, 245, 157, 0.44);\n  box-shadow: 0 4px 20px rgba(79, 132, 40, 0.08);\n}\n\n.tips-side-card h2,\n.tips-side-card h3 {\n  margin: 0;\n  font-size: 1.26rem;\n  line-height: 1.45;\n  letter-spacing: -0.03em;\n}\n\n.tips-side-card--suggestion {\n  position: relative;\n  overflow: hidden;\n  background: linear-gradient(135deg, rgba(234, 245, 157, 0.84), rgba(234, 245, 157, 0.44));\n}\n\n.tips-side-card--suggestion::after {\n  content: '';\n  position: absolute;\n  right: -26px;\n  top: -18px;\n  width: 100px;\n  height: 100px;\n  border-radius: 50%;\n  background: rgba(79, 132, 40, 0.08);\n}\n\n.tips-topic-list {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 10px;\n}\n\n.tips-saved-list {\n  display: grid;\n  gap: 14px;\n}\n\n.tips-saved-item {\n  display: grid;\n  grid-template-columns: auto 1fr;\n  gap: 12px;\n  align-items: center;\n}\n\n.tips-saved-item__icon {\n  display: grid;\n  place-items: center;\n  width: 48px;\n  height: 48px;\n  border-radius: 12px;\n  color: #4f8428;\n  background: rgba(193, 217, 92, 0.36);\n  font-size: 0.85rem;\n  font-weight: 800;\n}\n\n.tips-saved-item h3 {\n  font-size: 0.98rem;\n}\n\n.tips-saved-item p {\n  font-size: 0.9rem;\n}\n\n.tips-side-card--cta {\n  justify-items: center;\n  text-align: center;\n  color: #fff;\n  background: linear-gradient(180deg, #4f8428 0%, #336a29 100%);\n}\n\n.tips-side-card--cta h2,\n.tips-side-card--cta p {\n  color: inherit;\n}\n\n.tips-side-card__cta-icon {\n  display: grid;\n  place-items: center;\n  width: 64px;\n  height: 64px;\n  border-radius: 50%;\n  background: rgba(255, 255, 255, 0.18);\n  font-size: 1.8rem;\n}\n\n@media (max-width: 1180px) {\n  .tips-filter-bar {\n    grid-template-columns: 1fr;\n  }\n\n  .tips-layout,\n  .tips-hero {\n    grid-template-columns: 1fr;\n  }\n\n  .tips-post-grid {\n    grid-template-columns: 1fr;\n  }\n}\n\n@media (max-width: 720px) {\n  .tips-hero {\n    padding: 24px 20px;\n    border-radius: 28px;\n  }\n\n  .tips-filter-bar {\n    top: 84px;\n    padding: 12px;\n    border-radius: 20px;\n  }\n\n  .tips-layout {\n    gap: 20px;\n  }\n\n  .tips-side-card {\n    padding: 20px;\n  }\n}\n"],["META",{"name":"description","content":"Tổng hợp mẹo tiết kiệm điện dễ áp dụng cho sinh viên, phòng trọ và ký túc xá."}],["META",{"property":"og:title","content":"Mẹo tiết kiệm điện - E-XANH"}],["META",{"property":"og:description","content":"Khám phá các mẹo dùng điện thông minh, tiết kiệm chi phí và sống xanh hơn mỗi ngày."}],["META",{"property":"og:type","content":"website"}],["META",{"property":"og:url","content":"https://e-xanh.vercel.app/meo-tiet-kiem"}],["META",{"property":"og:image","content":"https://e-xanh.vercel.app/og-image-v2.png"}],["META",{"property":"og:image:width","content":"1200"}],["META",{"property":"og:image:height","content":"630"}],["META",{"name":"twitter:card","content":"summary_large_image"}],["META",{"name":"twitter:image","content":"https://e-xanh.vercel.app/og-image-v2.png"}],["LINK",{"rel":"canonical","href":"https://e-xanh.vercel.app/meo-tiet-kiem"}]],[[2,42]],["BODY",{},[[2,43]],["DIV",{"id":"root"},[[2,70]],["D