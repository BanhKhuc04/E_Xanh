# Copy file này thành .env.qa.local nếu cần lưu tài khoản test ở máy bạn.
# Không commit file chứa password thật.

QA_BASE_URL=https://exanh.online

# Tài khoản test thường - chỉ dùng cho luồng user đăng nhập.
QA_USER_EMAIL=user01@exanh.test
QA_USER_PASSWORD=Test@123456

# Tài khoản admin/moderator test - chỉ dùng cho luồng admin an toàn.
QA_ADMIN_EMAIL=admin-test@exanh.test
QA_ADMIN_PASSWORD=Test@123456

# Bật nếu muốn chạy visual screenshot baseline/update bằng Playwright.
QA_ENABLE_VISUAL=0

# Khi test local, nên build app với VITE_DISABLE_CAPTCHA=true để automation login được.
# Production nếu còn Turnstile thật thì test đăng nhập UI có thể bị chặn.
